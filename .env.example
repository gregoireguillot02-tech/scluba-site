# Public — used by both the marketing site (CTAForm) and the /ops dashboard.
PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...

# Server-only — used by /ops to bypass RLS. NEVER ship this to the browser.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# Comma-separated allowlist of emails authorized on /ops/*.
OPS_ALLOWED_EMAILS=gregoire.guillot02@gmail.com,team@scluba.com

# Optional — public demo URL referenced by the QR code.
PUBLIC_DEMO_URL=https://scluba.com/demo

# Optional — Sentry error monitoring. Leave empty to disable (no requests sent).
# Set both to the same DSN to capture client + server errors. PII is never sent
# (sendDefaultPii=false, replays disabled). Add a privacy-policy mention if you
# enable this in production.
PUBLIC_SENTRY_DSN=
SENTRY_DSN=

# Optional — Sentry environment tag. Auto-derived in astro.config.mjs from
# CF_PAGES_BRANCH (main → "production", other branches → branch name), defaults
# to "development". Override only if you need a custom tag (e.g. "staging").
SENTRY_ENVIRONMENT=
