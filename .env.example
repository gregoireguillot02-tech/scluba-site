# Public — used by both the marketing site (CTAForm) and the /ops dashboard.
PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...

# Server-only — used by /ops to bypass RLS. NEVER ship this to the browser.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# Comma-separated allowlist of emails authorized on /ops/*.
OPS_ALLOWED_EMAILS=admin1@example.com,admin2@example.com

# Optional — public demo URL referenced by the QR code.
PUBLIC_DEMO_URL=https://klubba.golf/demo
