---
import { useT, altLocaleHref, type Locale } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useT(locale);
const altHref = altLocaleHref(locale);
const altLabel = locale === 'fr' ? 'EN' : 'FR';
---

<nav class="nav">
  <div class="container nav-inner">
    <a href={locale === 'fr' ? '/' : '/en/'} class="brand" aria-label="Klubba">
      <span class="brand-mark">Klubba<span class="brand-dot">.</span></span>
    </a>

    <ul class="nav-links">
      <li><a href="#pricing">{t.nav.pricing}</a></li>
      <li><a href="#how">{t.nav.how}</a></li>
    </ul>

    <div class="nav-actions">
      <a href={altHref} class="lang-switch" aria-label={`Switch to ${altLabel}`}>{altLabel}</a>
      <a href="#cta" class="btn btn-primary nav-cta">{t.nav.demo}</a>
    </div>
  </div>
</nav>

<style>
  .nav {
    position: fixed;
    top: 40px; left: 0; right: 0;
    z-index: 100;
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: saturate(180%) blur(14px);
    -webkit-backdrop-filter: saturate(180%) blur(14px);
    border-bottom: 1px solid var(--line);
  }
  @media (max-width: 640px) {
    .nav { top: 56px; }
  }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
    gap: var(--space-5);
  }
  .brand {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--primary);
    letter-spacing: -0.02em;
    line-height: 1;
  }
  .brand-dot { color: var(--accent); }

  .nav-links {
    display: none;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: var(--space-6);
  }
  .nav-links a {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--ink);
    transition: color 0.2s var(--ease-out);
  }
  .nav-links a:hover { color: var(--primary); }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .lang-switch {
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--muted);
    padding: 6px 10px;
    border: 1px solid var(--line);
    border-radius: var(--radius-full);
    transition: all 0.2s var(--ease-out);
  }
  .lang-switch:hover {
    color: var(--primary);
    border-color: var(--primary);
  }

  .nav-cta {
    padding: 8px 16px;
    font-size: var(--text-sm);
  }

  @media (min-width: 900px) {
    .nav-links { display: flex; }
  }
</style>
