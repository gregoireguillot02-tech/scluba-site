---
import { useT, altLocaleHref, type Locale } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useT(locale);
const altHref = altLocaleHref(locale);
const altLabel = locale === 'fr' ? 'EN' : 'FR';
---

<nav class="nav">
  <div class="container nav-inner">
    <a href={locale === 'fr' ? '/' : '/en/'} class="brand" aria-label="Scluba">
      <span class="brand-mark">Scluba<span class="brand-ball" aria-hidden="true">
        <svg viewBox="0 0 32 32">
          <defs>
            <radialGradient id="navBallBody" cx="32%" cy="28%" r="78%">
              <stop offset="0%" stop-color="#FFFFFF"/>
              <stop offset="55%" stop-color="#F2F0E8"/>
              <stop offset="100%" stop-color="#A8A296"/>
            </radialGradient>
            <clipPath id="navBallClip">
              <circle cx="16" cy="16" r="13.6"/>
            </clipPath>
          </defs>
          <circle cx="16" cy="16" r="13.8" fill="url(#navBallBody)"/>
          <g clip-path="url(#navBallClip)" fill="#000" opacity="0.13">
            <circle cx="11" cy="10" r="0.8"/><circle cx="16" cy="10" r="0.8"/><circle cx="21" cy="10" r="0.8"/>
            <circle cx="11" cy="16" r="0.8"/><circle cx="16" cy="16" r="0.8"/><circle cx="21" cy="16" r="0.8"/>
            <circle cx="11" cy="22" r="0.8"/><circle cx="16" cy="22" r="0.8"/><circle cx="21" cy="22" r="0.8"/>
          </g>
          <ellipse cx="11.5" cy="9" rx="3.6" ry="2.2" fill="#FFFFFF" opacity="0.6"/>
          <circle cx="16" cy="16" r="13.8" fill="none" stroke="#7A7468" stroke-width="0.5" opacity="0.45"/>
        </svg>
      </span></span>
    </a>

    <ul class="nav-links">
      <li><a href="#pricing">{t.nav.pricing}</a></li>
      <li><a href="#how">{t.nav.how}</a></li>
    </ul>

    <div class="nav-actions">
      <a href={altHref} class="lang-switch" aria-label={`Switch to ${altLabel}`}>{altLabel}</a>
      <a href="#cta" class="btn btn-primary nav-cta">{t.nav.demo}</a>
    </div>
  </div>
</nav>

<style>
  .nav {
    position: fixed;
    top: 40px; left: 0; right: 0;
    z-index: 100;
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: saturate(180%) blur(14px);
    -webkit-backdrop-filter: saturate(180%) blur(14px);
    border-bottom: 1px solid var(--line);
  }
  @media (max-width: 640px) {
    .nav { top: 56px; }
  }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
    gap: var(--space-5);
  }
  .brand {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--primary);
    letter-spacing: -0.02em;
    line-height: 1;
  }
  .brand-mark {
    display: inline-flex;
    align-items: baseline;
  }
  .brand-ball {
    display: inline-block;
    width: 0.42em;
    height: 0.42em;
    margin-left: 0.06em;
    filter: drop-shadow(1px 2px 3px rgba(27, 67, 50, 0.25));
  }
  .brand-ball svg { width: 100%; height: 100%; display: block; }

  .nav-links {
    display: none;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: var(--space-6);
  }
  .nav-links a {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--ink);
    transition: color 0.2s var(--ease-out);
  }
  .nav-links a:hover { color: var(--primary); }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .lang-switch {
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--muted);
    padding: 6px 10px;
    border: 1px solid var(--line);
    border-radius: var(--radius-full);
    transition: all 0.2s var(--ease-out);
  }
  .lang-switch:hover {
    color: var(--primary);
    border-color: var(--primary);
  }

  .nav-cta {
    padding: 8px 16px;
    font-size: var(--text-sm);
  }

  @media (min-width: 900px) {
    .nav-links { display: flex; }
  }
</style>
