---
import { useT, type Locale } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useT(locale);
---

<section class="steps">
  <div class="container">
    <div class="section-header" data-anim="section-header">
      <span class="section-eyebrow">{t.steps.eyebrow}</span>
      <h2 class="section-title">{t.steps.title}</h2>
      <p class="section-lead">{t.steps.lead}</p>
    </div>

    <div class="step-grid">
      {t.steps.items.map((item) => (
        <article class="step-card" data-anim="step-card">
          <span class="step-num">{item.num}</span>
          <h3 class="step-title">{item.title}</h3>
          <p class="step-body">{item.body}</p>
          <div class="step-icon" aria-hidden="true">
            {item.num === '01' && (
              <svg viewBox="0 0 80 80" fill="none">
                <rect x="20" y="14" width="40" height="44" rx="4" stroke="currentColor" stroke-width="1.5" />
                <rect x="28" y="22" width="24" height="24" fill="currentColor" opacity="0.2" />
                <rect x="32" y="26" width="6" height="6" fill="currentColor" />
                <rect x="42" y="26" width="6" height="6" fill="currentColor" />
                <rect x="32" y="36" width="6" height="6" fill="currentColor" />
                <rect x="42" y="36" width="2" height="6" fill="currentColor" />
                <rect x="46" y="36" width="2" height="6" fill="currentColor" />
                <line x1="14" y1="62" x2="66" y2="62" stroke="currentColor" stroke-width="1.5" />
              </svg>
            )}
            {item.num === '02' && (
              <svg viewBox="0 0 80 80" fill="none">
                <rect x="26" y="10" width="28" height="56" rx="4" stroke="currentColor" stroke-width="1.5" />
                <rect x="29" y="14" width="22" height="44" fill="currentColor" opacity="0.08" />
                <circle cx="40" cy="62" r="2" fill="currentColor" />
                <path d="M34 32 L40 38 L48 28" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none" />
              </svg>
            )}
            {item.num === '03' && (
              <svg viewBox="0 0 80 80" fill="none">
                <rect x="14" y="20" width="36" height="48" rx="3" fill="currentColor" opacity="0.08" stroke="currentColor" stroke-width="1.5" />
                <rect x="14" y="20" width="36" height="14" fill="currentColor" opacity="0.5" />
                <circle cx="55" cy="14" r="6" stroke="currentColor" stroke-width="1.5" fill="none" />
                <circle cx="68" cy="40" r="6" stroke="currentColor" stroke-width="1.5" fill="none" />
                <circle cx="55" cy="64" r="6" stroke="currentColor" stroke-width="1.5" fill="none" />
                <line x1="50" y1="20" x2="50" y2="14" stroke="currentColor" stroke-width="1.2" />
                <line x1="50" y1="40" x2="62" y2="40" stroke="currentColor" stroke-width="1.2" />
                <line x1="50" y1="60" x2="50" y2="64" stroke="currentColor" stroke-width="1.2" />
              </svg>
            )}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .steps {
    background: var(--bg);
  }
  .section-header {
    text-align: center;
    max-width: 720px;
    margin: 0 auto var(--space-8);
  }
  .section-header .section-eyebrow,
  .section-header .section-title,
  .section-header .section-lead {
    margin-left: auto;
    margin-right: auto;
  }
  .section-header .section-lead {
    margin-top: var(--space-3);
  }

  .step-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
  }

  @media (min-width: 768px) {
    .step-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-5);
    }
  }

  .step-card {
    position: relative;
    background: var(--bg);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    padding: var(--space-7) var(--space-5) var(--space-5);
    transition: transform 0.4s var(--ease-out), box-shadow 0.4s var(--ease-out), border-color 0.4s var(--ease-out);
    overflow: hidden;
  }
  .step-card::before {
    content: "";
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--primary), var(--accent));
    opacity: 0;
    transition: opacity 0.3s var(--ease-out);
  }
  .step-card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-lg);
    border-color: var(--accent);
  }
  .step-card:hover::before { opacity: 1; }

  .step-num {
    font-family: var(--font-serif);
    font-size: var(--text-2xl);
    font-weight: 800;
    color: var(--accent);
    line-height: 1;
    letter-spacing: -0.02em;
  }
  .step-title {
    font-size: var(--text-xl);
    margin: var(--space-3) 0 var(--space-3);
    color: var(--primary);
  }
  .step-body {
    font-size: var(--text-base);
    color: var(--muted);
    line-height: 1.5;
    max-width: 32ch;
  }
  .step-icon {
    position: absolute;
    right: var(--space-4);
    top: var(--space-4);
    width: 64px;
    height: 64px;
    color: var(--primary);
    opacity: 0.4;
    transition: opacity 0.4s var(--ease-out);
  }
  .step-card:hover .step-icon { opacity: 1; }
</style>
