---
// scluba-site/src/components/ShareCardModal.astro
// Modal de partage. Le parent (recap.astro) sérialise les données round/club/scores
// dans des data-* attributes et appelle window.openShareCardModal() au click "Partager".
export interface Props {
  initialPhotoUrl: string | null;
  shareTitle: string;
  fallbackUrl: string;
  roundId: string;
  payload: string; // JSON-stringified payload (player, club, holes, scores, totals, startedAt)
}
const { initialPhotoUrl, shareTitle, fallbackUrl, roundId, payload } = Astro.props;
---
<div
  id="share-card-modal"
  class="scm-overlay"
  hidden
  data-initial-photo={initialPhotoUrl ?? ''}
  data-share-title={shareTitle}
  data-fallback-url={fallbackUrl}
  data-round-id={roundId}
  data-payload={payload}
>
  <div class="scm-sheet" role="dialog" aria-modal="true" aria-labelledby="scm-title">
    <header class="scm-header">
      <h2 id="scm-title">Partager ta carte</h2>
      <button type="button" class="scm-close" aria-label="Fermer" data-action="close">×</button>
    </header>

    <div class="scm-body">
      <div class="scm-preview" data-role="preview" hidden>
        <img alt="" data-role="preview-img" />
      </div>
      <div class="scm-empty" data-role="empty">
        <div class="scm-empty-icon">📷</div>
        <p>Ajoute une photo pour personnaliser ta carte</p>
      </div>
      <div class="scm-png-preview" data-role="png-preview" hidden>
        <img alt="Aperçu de la carte avant partage" data-role="png-preview-img" />
        <p class="scm-png-caption">Voici ta carte. Vérifie avant de partager.</p>
      </div>
      <p class="scm-error" data-role="error" hidden></p>
    </div>

    <div class="scm-actions">
      <input type="file" accept="image/*" data-role="file-input" hidden />

      <button type="button" class="scm-btn scm-btn-secondary" data-action="pick-photo">
        Ajouter une photo
      </button>
      <button type="button" class="scm-btn scm-btn-secondary" data-action="replace-photo" hidden>
        Remplacer la photo
      </button>
      <button type="button" class="scm-btn scm-btn-secondary" data-action="back-to-photo" hidden>
        Modifier la photo
      </button>
      <button type="button" class="scm-btn scm-btn-primary" data-action="share">
        Partager
      </button>
    </div>
  </div>
</div>

<style>
  .scm-overlay {
    position: fixed; inset: 0;
    background: rgba(0,0,0,0.55);
    display: flex; align-items: flex-end; justify-content: center;
    z-index: 1000;
  }
  @media (min-width: 640px) {
    .scm-overlay { align-items: center; }
  }
  .scm-sheet {
    background: #FAF7EE;
    width: 100%; max-width: 460px;
    border-radius: 16px 16px 0 0;
    padding: 20px;
    max-height: 90vh; overflow-y: auto;
  }
  @media (min-width: 640px) {
    .scm-sheet { border-radius: 16px; }
  }
  .scm-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; }
  .scm-header h2 { margin: 0; font-size: 18px; }
  .scm-close { background: none; border: none; font-size: 28px; line-height: 1; cursor: pointer; color: #666; }
  .scm-body { margin-bottom: 20px; }
  .scm-preview { aspect-ratio: 4/5; background: #ddd; border-radius: 12px; overflow: hidden; }
  .scm-preview img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .scm-png-preview { display: flex; flex-direction: column; gap: 8px; }
  .scm-png-preview img { width: 100%; height: auto; max-height: 60vh; object-fit: contain; border-radius: 12px; background: #FAF7EE; display: block; }
  .scm-png-caption { margin: 0; font-size: 13px; color: #666; text-align: center; }
  .scm-empty { aspect-ratio: 4/5; border: 2px dashed #ccc; border-radius: 12px; display: flex; flex-direction: column; align-items: center; justify-content: center; color: #888; padding: 24px; text-align: center; }
  .scm-empty-icon { font-size: 36px; margin-bottom: 8px; }
  .scm-empty p { margin: 0; font-size: 14px; }
  .scm-error { color: #b00020; font-size: 14px; margin-top: 12px; }
  .scm-actions { display: flex; flex-direction: column; gap: 8px; }
  .scm-btn { padding: 14px; border-radius: 10px; font-size: 15px; font-weight: 600; border: none; cursor: pointer; }
  .scm-btn-primary { background: #1B4332; color: white; }
  .scm-btn-primary:disabled { opacity: 0.6; cursor: not-allowed; }
  .scm-btn-secondary { background: white; color: #1B4332; border: 1.5px solid #1B4332; }
  [hidden] { display: none !important; }
</style>

<script>
  import { compressPhoto, uploadSharePhoto, composeShareImage, sharePngFile, type ComposeInput } from '../lib/share-card';

  type State = 'idle' | 'previewing' | 'generating' | 'png-review' | 'error';

  function init() {
    const root = document.getElementById('share-card-modal');
    if (!root) return;

    const previewBox = root.querySelector<HTMLDivElement>('[data-role="preview"]')!;
    const previewImg = root.querySelector<HTMLImageElement>('[data-role="preview-img"]')!;
    const emptyBox = root.querySelector<HTMLDivElement>('[data-role="empty"]')!;
    const pngPreviewBox = root.querySelector<HTMLDivElement>('[data-role="png-preview"]')!;
    const pngPreviewImg = root.querySelector<HTMLImageElement>('[data-role="png-preview-img"]')!;
    const errorBox = root.querySelector<HTMLParagraphElement>('[data-role="error"]')!;
    const fileInput = root.querySelector<HTMLInputElement>('[data-role="file-input"]')!;
    const btnPick = root.querySelector<HTMLButtonElement>('[data-action="pick-photo"]')!;
    const btnReplace = root.querySelector<HTMLButtonElement>('[data-action="replace-photo"]')!;
    const btnBack = root.querySelector<HTMLButtonElement>('[data-action="back-to-photo"]')!;
    const btnShare = root.querySelector<HTMLButtonElement>('[data-action="share"]')!;
    const btnClose = root.querySelector<HTMLButtonElement>('[data-action="close"]')!;

    const initialPhoto = root.dataset.initialPhoto ?? '';
    const shareTitle = root.dataset.shareTitle ?? '';
    const fallbackUrl = root.dataset.fallbackUrl ?? '';
    const roundId = root.dataset.roundId ?? '';
    // Le payload est re-parsé à chaque génération de PNG (cf. readComposeBase
    // ci-dessous) plutôt que figé à l'init — sinon une mise à jour du
    // dataset.payload après init (ex. saisie de commentaire sur recap.astro)
    // n'apparaît jamais dans le PNG généré.
    function readComposeBase(): Omit<ComposeInput, 'photoUrl'> {
      return JSON.parse(root!.dataset.payload ?? '{}') as Omit<ComposeInput, 'photoUrl'>;
    }

    let state: State = initialPhoto ? 'previewing' : 'idle';
    let currentPhotoUrl: string | null = initialPhoto || null;
    let pendingBlob: Blob | null = null; // photo prise mais pas encore uploadée
    let pngBlob: Blob | null = null;
    let pngObjectUrl: string | null = null;

    function clearPngPreview() {
      if (pngObjectUrl) {
        URL.revokeObjectURL(pngObjectUrl);
        pngObjectUrl = null;
      }
      pngBlob = null;
    }

    function render() {
      errorBox.hidden = state !== 'error';
      const isPhotoState = state === 'previewing' || state === 'generating';
      const isPngState = state === 'png-review';
      previewBox.hidden = !isPhotoState;
      emptyBox.hidden = isPhotoState || isPngState;
      pngPreviewBox.hidden = !isPngState;
      btnPick.hidden = isPhotoState || isPngState;
      btnReplace.hidden = !isPhotoState;
      btnBack.hidden = !isPngState;
      btnShare.disabled = state === 'generating';
      btnShare.textContent = state === 'generating'
        ? 'Génération…'
        : state === 'png-review'
          ? 'Partager maintenant'
          : 'Partager';
    }

    function showError(msg: string) {
      errorBox.textContent = msg;
      state = 'error';
      render();
    }

    btnClose.addEventListener('click', () => {
      clearPngPreview();
      root.hidden = true;
    });

    btnPick.addEventListener('click', () => fileInput.click());
    btnReplace.addEventListener('click', () => fileInput.click());

    btnBack.addEventListener('click', () => {
      clearPngPreview();
      state = currentPhotoUrl ? 'previewing' : 'idle';
      render();
    });

    fileInput.addEventListener('change', async () => {
      const file = fileInput.files?.[0];
      if (!file) return;
      try {
        const compressed = await compressPhoto(file);
        pendingBlob = compressed;
        const objectUrl = URL.createObjectURL(compressed);
        previewImg.src = objectUrl;
        currentPhotoUrl = objectUrl; // local preview — sera remplacé par l'URL Supabase au partage
        state = 'previewing';
        render();
      } catch (err) {
        console.error(err);
        showError('Impossible de lire cette photo. Réessaye avec une autre.');
      } finally {
        fileInput.value = '';
      }
    });

    btnShare.addEventListener('click', async () => {
      // 2e click : on a déjà l'aperçu PNG, on déclenche le vrai partage
      if (state === 'png-review' && pngBlob) {
        try {
          const result = await sharePngFile(pngBlob, {
            title: shareTitle,
            fallbackUrl,
            filename: `carte-${roundId.slice(0, 8)}.png`,
          });
          if (result === 'shared' || result === 'downloaded' || result === 'url-shared') {
            clearPngPreview();
            root.hidden = true;
          }
        } catch (err) {
          if ((err as DOMException)?.name === 'AbortError') {
            // L'utilisateur a annulé le partage natif — on reste sur l'aperçu
            return;
          }
          console.error(err);
          showError('Le partage a échoué. Réessaye.');
        }
        return;
      }

      // 1er click : on génère le PNG et on affiche l'aperçu
      state = 'generating';
      render();
      try {
        let photoUrl: string | null = currentPhotoUrl;

        // Upload si on a une nouvelle photo (pendingBlob non null = pas encore en Storage)
        if (pendingBlob) {
          try {
            photoUrl = await uploadSharePhoto(roundId, pendingBlob);
            pendingBlob = null;
            currentPhotoUrl = photoUrl;
            previewImg.src = photoUrl;
          } catch (err) {
            console.error('upload failed, on continue avec object URL local', err);
            // On continue avec l'object URL pour le partage immédiat
          }
        }

        const blob = await composeShareImage({ ...readComposeBase(), photoUrl });
        clearPngPreview();
        pngBlob = blob;
        pngObjectUrl = URL.createObjectURL(blob);
        pngPreviewImg.src = pngObjectUrl;
        state = 'png-review';
        render();
      } catch (err) {
        console.error(err);
        showError('La génération de la carte a échoué. Réessaye.');
      }
    });

    // expose l'ouverture pour le parent
    (window as unknown as { openShareCardModal: () => void }).openShareCardModal = () => {
      clearPngPreview();
      state = currentPhotoUrl ? 'previewing' : 'idle';
      if (currentPhotoUrl) previewImg.src = currentPhotoUrl;
      errorBox.hidden = true;
      root.hidden = false;
      render();
    };

    render();
  }

  if (document.readyState !== 'loading') init();
  else document.addEventListener('DOMContentLoaded', init);
</script>
