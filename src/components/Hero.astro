---
import { useT, type Locale } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useT(locale);
---

<section class="hero">
  <div class="hero-bg" aria-hidden="true">
    <div class="bg-gradient"></div>
    <div class="bg-glow bg-glow-1"></div>
    <div class="bg-glow bg-glow-2"></div>
  </div>

  <div class="container hero-content">
    <div class="hero-text">
      <span class="hero-eyebrow eyebrow-mono" data-anim="hero-eyebrow">{t.hero.eyebrow}</span>
      <h1 class="hero-logo text-mega"><span class="hero-logo-text" data-anim="hero-logo">Scluba</span></h1>
      <p class="hero-tagline" data-anim="hero-tagline">{t.hero.tagline}</p>
      <p class="hero-sub" data-anim="hero-sub">{t.hero.subtagline}</p>
      <a href="#cta" class="btn btn-accent hero-cta" data-anim="hero-cta">
        {t.hero.cta}
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14"/>
          <path d="m12 5 7 7-7 7"/>
        </svg>
      </a>
    </div>

    <div class="hero-visual glow-accent" data-anim="hero-phone" aria-hidden="true">
      <div class="hero-phone-stage">
        <div class="hero-phone">
          <!-- Boutons latéraux -->
          <span class="hero-phone-btn hero-phone-btn-action"></span>
          <span class="hero-phone-btn hero-phone-btn-volup"></span>
          <span class="hero-phone-btn hero-phone-btn-voldown"></span>
          <span class="hero-phone-btn hero-phone-btn-side"></span>

          <div class="hero-phone-screen">
            <!-- Dynamic Island -->
            <div class="hero-phone-island">
              <span class="hero-phone-camera"></span>
            </div>

            <!-- Carte récap brandée (statique, version condensée du magic moment) -->
            <div class="hero-card">
              <!-- Photo -->
              <div class="hero-card-photo">
                <img src="/photos/golf-du-soleil.jpg" alt="" width="280" height="110" loading="eager" decoding="async" fetchpriority="high" />
                <div class="hero-card-photo-fade"></div>
              </div>

              <!-- Logo + nom -->
              <div class="hero-card-brand">
                <img src="/logos/golf-du-soleil.svg" alt="" class="hero-card-logo" width="50" height="50" loading="eager" decoding="async" />
                <div class="hero-card-meta">
                  <small>Carte récap</small>
                  <strong>Golf du Soleil</strong>
                </div>
              </div>

              <!-- Body -->
              <div class="hero-card-body">
                <div class="hero-card-divider">
                  <span></span><em>SCORE · 18 TROUS</em><span></span>
                </div>
                <div class="hero-card-score">87</div>
                <div class="hero-card-score-meta">+15 · Par 72</div>

                <div class="hero-card-grid">
                  {Array.from({ length: 18 }, (_, i) => (
                    <span class={`hero-card-cell ${i % 5 === 0 ? 'is-birdie' : i % 3 === 0 ? 'is-bogey' : ''}`}>{(i % 4) + 3}</span>
                  ))}
                </div>

                <button class="hero-share-cta" type="button" tabindex="-1" aria-hidden="true">
                  <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/>
                    <polyline points="16 6 12 2 8 6"/>
                    <line x1="12" y1="2" x2="12" y2="15"/>
                  </svg>
                  <span>{t.share.ctaButton}</span>
                </button>

                <div class="hero-card-footer">
                  <span>FAIT À</span><strong>Scluba<em>.</em></strong>
                </div>
              </div>

              {/* V4.1 : iOS Share Sheet supprimée — Grégoire a explicitement
                  demandé la refonte. Le néon vert PhoneShowcase prend la relève
                  comme magic moment. */}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <a href="#problem" class="hero-scroll" aria-label={t.hero.scroll}>
    <span>{t.hero.scroll}</span>
    <svg width="14" height="20" viewBox="0 0 14 20" fill="none" aria-hidden="true">
      <path d="M7 1v18m0 0L1 13m6 6 6-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </a>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding: 160px 0 80px;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }
  .bg-gradient {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 80% 20%, rgba(212, 165, 116, 0.18), transparent 60%),
      radial-gradient(ellipse at 20% 80%, rgba(45, 106, 79, 0.10), transparent 55%),
      linear-gradient(180deg, var(--primary-bg) 0%, var(--bg) 100%);
  }
  .bg-glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
    opacity: 0.45;
  }
  .bg-glow-1 {
    width: 500px; height: 500px;
    background: var(--accent);
    top: -10%; right: -10%;
  }
  .bg-glow-2 {
    width: 400px; height: 400px;
    background: var(--primary-soft);
    bottom: -20%; left: -10%;
    opacity: 0.25;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-7);
    align-items: center;
  }

  @media (min-width: 1024px) {
    .hero-content {
      grid-template-columns: 1.1fr 1fr;
      gap: var(--space-8);
    }
  }

  /* Eyebrow mono au-dessus du logo — pattern jeskojets/drinksom */
  .hero-eyebrow {
    display: block;
    margin-bottom: var(--space-4);
    color: var(--accent);
  }

  /* Hero logo SCLUBA caps Big Shoulders Display — cohérent avec le wordmark
     Nav/Footer (Modern Mono direction validée 2026-05-19 PR #95). La balle
     SVG inline historique est supprimée — la balle 3D Three.js (fixed
     inset:0) joue ce rôle visuel maintenant à plus grande échelle. */
  .hero-logo {
    line-height: 0.82;
    margin-bottom: var(--space-5);
    color: var(--primary);
    overflow: hidden;
  }
  .hero-logo .hero-logo-text {
    font-family: var(--font-display);
    font-weight: 900;
    letter-spacing: -0.05em;
    color: var(--cream, var(--primary));
    display: inline-block;
  }

  .hero-logo :global(.char) {
    display: inline-block;
    will-change: transform;
  }

  .hero-tagline {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    line-height: 1.15;
    color: var(--cream, var(--ink));
    margin-bottom: var(--space-4);
    max-width: 22ch;
    letter-spacing: -0.025em;
  }

  .hero-sub {
    font-size: var(--text-md);
    color: var(--muted);
    margin-bottom: var(--space-6);
    max-width: 32ch;
    line-height: 1.5;
  }

  .hero-cta {
    padding: 14px 28px;
    font-size: var(--text-base);
  }

  /* Phone preview hero — virage.one : panneau pastel + phone vertical face-on */
  .hero-visual {
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .hero-phone-stage {
    position: relative;
  }

  /* === Progressive enhancement : scroll-driven CSS natif ===
     Chrome 115+ / Edge 115+ / Safari 18+. Sur les autres browsers, les
     keyframes ne s'exécutent pas → rendu standard inchangé (aucune régression). */
  @media (prefers-reduced-motion: no-preference) {
    @supports (animation-timeline: view()) {
      .hero-tagline,
      .hero-sub {
        animation: heroFadeOut linear both;
        animation-timeline: view();
        animation-range: cover 40% cover 90%;
      }
      @keyframes heroFadeOut {
        to { opacity: 0.35; transform: translateY(-24px); }
      }

      .hero-phone-stage {
        animation: heroPhoneRise linear both;
        animation-timeline: view();
        animation-range: entry 0% cover 30%;
      }
      @keyframes heroPhoneRise {
        from { transform: translateY(28px); }
        to   { transform: translateY(0); }
      }
    }
  }

  /* Balle de golf — point du wordmark "Scluba." */
  .hero-ball {
    display: inline-block;
    width: 0.42em;
    height: 0.42em;
    vertical-align: -0.02em;
    margin-left: 0.05em;
    filter: drop-shadow(1.5px 3px 4px rgba(27, 67, 50, 0.28));
    will-change: transform, opacity;
  }
  .hero-ball svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  /* V4.2 — iPhone 17 Pro titanium frame plus large + couches CSS détaillées.
     Height 75vh (était 64vh, +17% présence). Bevel intérieur + gloss
     reflection + speaker grille top pour pousser le réalisme. */
  .hero-phone {
    position: relative;
    height: min(75vh, 680px);
    aspect-ratio: 9 / 19.5;
    width: auto;
    background:
      linear-gradient(135deg,
        #6E6E72 0%,
        #48484A 22%,
        #2C2C2E 50%,
        #48484A 78%,
        #6E6E72 100%);
    border-radius: 56px;
    padding: 12px;
    box-shadow:
      0 24px 48px rgba(0, 0, 0, 0.40),
      0 48px 96px rgba(0, 0, 0, 0.30),
      inset 0 1px 0 rgba(255, 255, 255, 0.22),
      0 0 0 1.5px rgba(0, 0, 0, 0.70);
    will-change: transform;
    z-index: 1;
  }
  /* Bevel intérieur — micro-trait clair à la jonction frame/screen */
  .hero-phone::before {
    content: "";
    position: absolute;
    inset: 8px;
    border-radius: 50px;
    pointer-events: none;
    box-shadow:
      inset 0 0 0 1px rgba(255, 255, 255, 0.08),
      inset 0 1px 0 rgba(255, 255, 255, 0.10);
    z-index: 2;
  }
  /* Reflet diagonal gloss subtil sur le verre */
  .hero-phone::after {
    content: "";
    position: absolute;
    inset: 12px;
    border-radius: 44px;
    pointer-events: none;
    background: linear-gradient(
      138deg,
      rgba(255, 255, 255, 0.10) 0%,
      rgba(255, 255, 255, 0) 35%,
      rgba(255, 255, 255, 0) 75%,
      rgba(255, 255, 255, 0.04) 100%
    );
    z-index: 4;
    mix-blend-mode: screen;
  }

  /* Boutons latéraux titanium (gradient cohérent avec le frame) */
  .hero-phone-btn {
    position: absolute;
    background: linear-gradient(180deg, #5C5C5E 0%, #2C2C2E 50%, #5C5C5E 100%);
    border-radius: 1.5px;
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.14);
  }
  /* Action button gold/champagne — signature iPhone Pro */
  .hero-phone-btn-action {
    left: -2px; top: 84px; width: 4px; height: 26px;
    background: linear-gradient(180deg, #C9A96A 0%, #8B7344 50%, #C9A96A 100%);
  }
  .hero-phone-btn-volup { left: -2px; top: 122px; width: 4px; height: 48px; }
  .hero-phone-btn-voldown { left: -2px; top: 180px; width: 4px; height: 48px; }
  .hero-phone-btn-side { right: -2px; top: 122px; width: 4px; height: 76px; }

  .hero-phone-screen {
    position: relative;
    width: 100%;
    height: 100%;
    background: linear-gradient(180deg, #FAF7EE 0%, #F4F8F5 100%);
    border-radius: 44px;
    overflow: hidden;
  }
  /* Speaker grille top — barre fine subtile (au-dessus du Dynamic Island) */
  .hero-phone-screen::before {
    content: "";
    position: absolute;
    top: 6px;
    left: 50%;
    transform: translateX(-50%);
    width: 12%;
    max-width: 50px;
    height: 2px;
    border-radius: 1px;
    background: rgba(0, 0, 0, 0.18);
    z-index: 4;
  }
  .hero-phone-island {
    /* Dynamic Island iPhone 17 Pro — légèrement plus large + plus bas */
    position: absolute;
    top: 11px;
    left: 50%;
    transform: translateX(-50%);
    width: 32%;
    max-width: 124px;
    min-width: 96px;
    height: 30px;
    background: #000;
    border-radius: 18px;
    z-index: 5;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding-right: 8px;
  }
  .hero-phone-camera {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: radial-gradient(circle at 30% 30%, #2a3a40, #050a0c);
    box-shadow: inset 0 0 0 1px rgba(255,255,255,0.08);
  }

  /* Hero card — version condensée carte récap */
  .hero-card {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
  }
  .hero-card-photo {
    position: relative;
    height: 110px;
    overflow: hidden;
    flex-shrink: 0;
  }
  .hero-card-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 60%;
  }
  .hero-card-photo-fade {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 36px;
    background: linear-gradient(180deg, transparent, #FAF7EE);
  }

  .hero-card-brand {
    margin-top: -38px;
    text-align: center;
    z-index: 2;
    padding: 0 12px;
  }
  .hero-card-logo {
    width: 50px;
    height: 50px;
    margin: 0 auto;
    display: block;
    filter: drop-shadow(0 2px 8px rgba(0, 0, 0, 0.15));
  }
  .hero-card-meta { margin-top: 4px; }
  .hero-card-meta small {
    display: block;
    font-size: 6.5px;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-weight: 600;
  }
  .hero-card-meta strong {
    display: block;
    font-family: var(--font-serif);
    font-size: 12px;
    color: var(--primary);
    font-weight: 700;
    margin-top: 1px;
  }

  .hero-card-body {
    padding: 8px 12px 10px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    flex: 1;
  }
  .hero-card-divider {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-top: 4px;
  }
  .hero-card-divider span {
    flex: 1;
    height: 1px;
    background: var(--accent);
    opacity: 0.5;
  }
  .hero-card-divider em {
    font-style: normal;
    font-size: 6.5px;
    color: var(--accent);
    letter-spacing: 0.16em;
    font-weight: 600;
  }
  .hero-card-score {
    text-align: center;
    font-family: var(--font-serif);
    font-size: 44px;
    font-weight: 800;
    color: var(--primary);
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }
  .hero-card-score-meta {
    text-align: center;
    font-size: 8px;
    color: var(--muted);
    letter-spacing: 0.04em;
  }
  .hero-card-grid {
    display: grid;
    grid-template-columns: repeat(9, 1fr);
    gap: 2px;
    margin-top: 2px;
  }
  .hero-card-cell {
    aspect-ratio: 1;
    background: var(--bg);
    border: 1px solid var(--line);
    border-radius: 2px;
    text-align: center;
    font-size: 7.5px;
    font-weight: 700;
    color: var(--ink);
    display: flex;
    align-items: center;
    justify-content: center;
    font-variant-numeric: tabular-nums;
  }
  .hero-card-cell.is-birdie { color: #C0392B; background: var(--accent-soft); border-color: var(--accent); }
  .hero-card-cell.is-bogey { color: var(--muted); }
  .hero-card-footer {
    text-align: center;
    font-size: 6.5px;
    color: var(--muted);
    letter-spacing: 0.16em;
    margin-top: auto;
    padding-top: 4px;
  }
  .hero-card-footer strong {
    font-family: var(--font-serif);
    color: var(--primary);
    font-size: 8px;
    margin-left: 3px;
  }
  .hero-card-footer em {
    font-style: normal;
    color: var(--accent);
  }

  /* CTA Partager dans la carte */
  .hero-share-cta {
    margin-top: 4px;
    width: 100%;
    background: var(--primary);
    color: var(--bg);
    border-radius: 6px;
    padding: 6px;
    font-size: 8.5px;
    font-weight: 600;
    letter-spacing: 0.04em;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 4px;
    cursor: pointer;
    transition: background 0.2s, transform 0.2s;
  }
  .hero-share-cta:hover {
    background: var(--primary-soft);
    transform: scale(1.02);
  }
  .hero-share-cta:active { transform: scale(0.98); }

  /* iOS Share Sheet CSS supprimée (V4.1) — voir HTML drop ci-dessus */

  .hero-scroll {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    bottom: 32px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--muted);
    z-index: 1;
    opacity: 0.65;
    animation: scrollHint 2.4s ease-in-out infinite;
  }
  @keyframes scrollHint {
    0%, 100% { transform: translate(-50%, 0); }
    50% { transform: translate(-50%, 8px); }
  }
</style>

{/* V4.1 : inline script iOS Share Sheet supprimé — Grégoire a demandé
    explicitement la refonte du Hero phone (drop iOS Share Sheet magic moment). */}
