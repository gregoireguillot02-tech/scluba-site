---
/**
 * Hero éditorial "The Golfer's Journal" — banner-first cinematic.
 *
 * Composition magazine cover :
 *   1. Banner photo full-bleed (wordmark-fairway.jpg, 1904×544 ratio 3.5:1)
 *      avec vignette dégradée bas pour la lisibilité du text en dessous.
 *   2. Content : eyebrow mono "— PRÉFACE", titre Fraunces italic XL,
 *      sub Newsreader, CTA brass-plate.
 *   3. Scroll hint discret.
 *
 * Animations : intro stagger fade-up (eyebrow → titre → sub → CTA) + parallax
 * subtil sur la banner image (translateY tied au scroll). Toutes guards
 * prefers-reduced-motion via @media query CSS + check JS au runtime.
 *
 * Out of scope : pas de phone mockup (re-créé en Chapter02 PR #3) ni de
 * iOS Share Sheet (déplacé en Chapter04 PR #3).
 */
import { useT, type Locale } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useT(locale);
---

<section class="hero hero-editorial">
  <!-- Banner photo full-bleed — lettres bois sur fairway au lever du soleil. -->
  <div class="hero-banner" data-anim="hero-banner">
    <picture>
      <img
        src="/brand/wordmark-fairway.jpg"
        alt=""
        width="1904"
        height="544"
        fetchpriority="high"
        decoding="sync"
        class="hero-banner-img"
      />
    </picture>
    <div class="hero-banner-vignette" aria-hidden="true"></div>
    <div class="hero-banner-grain" aria-hidden="true"></div>
  </div>

  <div class="container hero-content">
    <p class="hero-eyebrow" data-anim="hero-eyebrow">
      <span class="hero-eyebrow-rule" aria-hidden="true"></span>
      <span class="hero-eyebrow-text">{t.hero.eyebrow}</span>
    </p>

    <h1 class="hero-title" data-anim="hero-title">
      {t.hero.tagline}
    </h1>

    <p class="hero-sub" data-anim="hero-sub">{t.hero.subtagline}</p>

    <div class="hero-cta-row" data-anim="hero-cta">
      <a href="#cta" class="btn-brass hero-cta">
        <span>{t.hero.cta}</span>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14" />
          <path d="m12 5 7 7-7 7" />
        </svg>
      </a>
      <span class="hero-cta-meta">{t.hero.scroll}</span>
    </div>
  </div>

  <a href="#chapter-1" class="hero-scroll" aria-label={t.hero.scroll}>
    <span class="hero-scroll-rule" aria-hidden="true"></span>
  </a>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    background: var(--paper);
    overflow: hidden;
  }

  /* === Banner image — full-bleed top ============================== */
  .hero-banner {
    position: relative;
    width: 100%;
    /* Hauteur fluide : ~38vh sur mobile, ~52vh desktop. Garde un ratio
       proche du source (3.5:1) sans crop dramatique. */
    height: clamp(280px, 48vh, 520px);
    overflow: hidden;
    background: var(--paper-deep);
    will-change: transform;
  }
  .hero-banner-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 52%;
    display: block;
  }
  /* Vignette bas — fond papier qui remonte progressivement pour lier la
     bannière au content cream en dessous. Pas un dark vignette dramatique
     hollywoodien, juste un fade naturel. */
  .hero-banner-vignette {
    position: absolute;
    inset: auto 0 0 0;
    height: 50%;
    background: linear-gradient(180deg, transparent 0%, var(--paper) 100%);
    pointer-events: none;
  }
  /* Grain papier discret over la bannière pour cohérence avec le cream. */
  .hero-banner-grain {
    position: absolute;
    inset: 0;
    background-image: var(--noise-svg);
    background-size: 240px 240px;
    opacity: 0.18;
    mix-blend-mode: multiply;
    pointer-events: none;
  }

  /* === Content ===================================================== */
  .hero-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    gap: var(--space-5);
    padding-top: var(--space-7);
    padding-bottom: var(--space-7);
    max-width: 880px;
  }

  .hero-eyebrow {
    display: flex;
    align-items: center;
    gap: 0.8em;
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--brass);
  }
  .hero-eyebrow-rule {
    display: inline-block;
    width: 32px;
    height: 1px;
    background: var(--brass);
  }

  .hero-title {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 800;
    font-style: italic;
    font-size: clamp(2.5rem, 7vw, 5.25rem);
    line-height: 1.02;
    letter-spacing: -0.03em;
    color: var(--wood);
    text-wrap: balance;
    max-width: 22ch;
    font-variation-settings: 'opsz' 144, 'SOFT' 30, 'WONK' 0;
  }

  .hero-sub {
    margin: 0;
    font-family: var(--font-body-serif);
    font-size: clamp(1.125rem, 1.6vw, 1.375rem);
    line-height: 1.5;
    color: var(--wood-soft);
    max-width: 42ch;
    font-style: italic;
    font-weight: 400;
  }

  /* CTA brass-plate — bouton "plaque gravée" du club. Pas un CTA SaaS plat. */
  .hero-cta-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-5);
    margin-top: var(--space-3);
  }
  .btn-brass {
    display: inline-flex;
    align-items: center;
    gap: 0.6em;
    padding: 14px 28px;
    background: var(--brass);
    color: var(--ink-editorial);
    font-family: var(--font-mono);
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    border: 1px solid var(--brass-deep);
    border-radius: 2px;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.28),
      inset 0 -1px 0 rgba(0, 0, 0, 0.12),
      0 8px 18px rgba(61, 41, 20, 0.18);
    transition: transform var(--motion-fast) var(--ease-out), background var(--motion-fast) var(--ease-out), box-shadow var(--motion-fast) var(--ease-out);
  }
  .btn-brass:hover {
    background: var(--brass-deep);
    transform: translateY(-1px);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.32),
      inset 0 -1px 0 rgba(0, 0, 0, 0.18),
      0 12px 24px rgba(61, 41, 20, 0.24);
  }
  .btn-brass:active { transform: translateY(0); }
  .btn-brass:focus-visible {
    outline: 2px solid var(--sage-deep);
    outline-offset: 3px;
  }

  .hero-cta-meta {
    font-family: var(--font-body-serif);
    font-style: italic;
    font-size: 0.95rem;
    color: var(--graphite);
  }

  /* === Scroll hint — minimaliste, rail brass vertical ============== */
  .hero-scroll {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    bottom: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1px;
    height: 56px;
    overflow: hidden;
  }
  .hero-scroll-rule {
    display: block;
    width: 1px;
    height: 100%;
    background: linear-gradient(180deg, transparent 0%, var(--brass) 50%, transparent 100%);
    animation: scrollRule 2.6s ease-in-out infinite;
  }
  @keyframes scrollRule {
    0%, 100% { transform: translateY(-30%); opacity: 0; }
    35%, 65% { opacity: 1; }
    100% { transform: translateY(30%); }
  }

  /* === Reduced motion ============================================== */
  @media (prefers-reduced-motion: reduce) {
    .hero-scroll-rule { animation: none; opacity: 0.6; }
    .hero-banner { will-change: auto; }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  function initHeroEditorial() {
    if (prefersReduced) return;

    // === Intro stagger : eyebrow → titre → sub → CTA ===
    const items = [
      '[data-anim="hero-eyebrow"]',
      '[data-anim="hero-title"]',
      '[data-anim="hero-sub"]',
      '[data-anim="hero-cta"]',
    ];

    gsap.set(items, { opacity: 0, y: 24 });
    gsap.to(items, {
      opacity: 1,
      y: 0,
      duration: 0.9,
      ease: 'power3.out',
      stagger: 0.12,
      delay: 0.25,
    });

    // === Parallax subtil sur la banner image ===
    const banner = document.querySelector<HTMLElement>('[data-anim="hero-banner"]');
    if (banner) {
      gsap.fromTo(
        banner.querySelector('.hero-banner-img'),
        { y: 0 },
        {
          y: -36,
          ease: 'none',
          scrollTrigger: {
            trigger: banner,
            start: 'top top',
            end: 'bottom top',
            scrub: 0.6,
          },
        }
      );
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHeroEditorial);
  } else {
    initHeroEditorial();
  }
</script>
