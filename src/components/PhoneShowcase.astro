---
// Démo scroll-pinned : iPhone qui traverse 3 phases du flow Scluba.
// Mirror le vrai produit (cf docs/specs/2026-05-11-carte-perso-photo-design.md
// + src/pages/r/[shortCode]/recap.astro) — pas un mockup générique.
//
// Phase 1 — Rejoindre la partie (code + multi-joueurs sur 1 QR)
// Phase 2 — Vraie carte de score brandée (Aller/Retour + cells colorées)
// Phase 3 — Photo perso + image PNG prête à partager (sheet natif)
//
// Anim cablée dans src/scripts/animations.ts initPhoneShowcase().

import { useT, type Locale } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useT(locale);

// Front 9 / Back 9 du mockup recap — couleurs cells reflètent le vrai produit
const front9 = [
  { n: 1, score: 5, type: 'bogey' },
  { n: 2, score: 5, type: 'par' },
  { n: 3, score: 2, type: 'birdie' },
  { n: 4, score: 4, type: 'par' },
  { n: 5, score: 5, type: 'bogey' },
  { n: 6, score: 6, type: 'bogey' },
  { n: 7, score: 3, type: 'par' },
  { n: 8, score: 5, type: 'bogey' },
  { n: 9, score: 5, type: 'bogey' },
];
const back9 = [
  { n: 10, score: 4, type: 'par' },
  { n: 11, score: 3, type: 'par' },
  { n: 12, score: 6, type: 'bogey' },
  { n: 13, score: 5, type: 'bogey' },
  { n: 14, score: 4, type: 'par' },
  { n: 15, score: 4, type: 'par' },
  { n: 16, score: 6, type: 'bogey' },
  { n: 17, score: 4, type: 'par' },
  { n: 18, score: 5, type: 'bogey' },
];
---

<section class="showcase-section" data-anim="showcase-wrap">
  <div class="showcase-pin">
    <div class="container showcase-grid">

      <!-- Narrative gauche -->
      <div class="showcase-narrative">
        <span class="section-eyebrow">{t.flow.eyebrow}</span>

        <div class="narrative-stack">
          <article class="narrative-block" data-flow-phase="1">
            <span class="phase-chip phase-chip-1">{t.flow.phase1Tag}</span>
            <h2 class="section-title">{t.flow.phase1Title}</h2>
            <p class="section-lead">{t.flow.phase1Lead}</p>
          </article>
          <article class="narrative-block" data-flow-phase="2">
            <span class="phase-chip phase-chip-2">{t.flow.phase2Tag}</span>
            <h2 class="section-title">{t.flow.phase2Title}</h2>
            <p class="section-lead">{t.flow.phase2Lead}</p>
          </article>
          <article class="narrative-block" data-flow-phase="3">
            <span class="phase-chip phase-chip-3">{t.flow.phase3Tag}</span>
            <h2 class="section-title">{t.flow.phase3Title}</h2>
            <p class="section-lead">{t.flow.phase3Lead}</p>
          </article>
        </div>

        <!-- Progress dots -->
        <div class="phase-progress" aria-hidden="true">
          <span class="phase-dot" data-progress-dot="1"></span>
          <span class="phase-bar"><span class="phase-bar-fill" data-progress-bar></span></span>
          <span class="phase-dot" data-progress-dot="2"></span>
          <span class="phase-bar"><span class="phase-bar-fill" data-progress-bar></span></span>
          <span class="phase-dot" data-progress-dot="3"></span>
        </div>
      </div>

      <!-- Phone droite -->
      <div class="showcase-stage" aria-hidden="true">
        <div class="showcase-phone" data-flow-phone>
          <div class="phone-frame">
            <span class="phone-btn phone-btn-side-l-1"></span>
            <span class="phone-btn phone-btn-side-l-2"></span>
            <span class="phone-btn phone-btn-side-l-3"></span>
            <span class="phone-btn phone-btn-side-r"></span>
            <span class="phone-rim"></span>

            <div class="phone-screen">
              <!-- Dynamic Island -->
              <div class="phone-island">
                <span class="phone-island-cam"></span>
              </div>

              <!-- Status bar -->
              <div class="phone-status">
                <span class="status-time">14:30</span>
                <div class="status-icons">
                  <span class="status-signal"></span>
                  <span class="status-wifi"></span>
                  <span class="status-battery"></span>
                </div>
              </div>

              <!-- ====== ÉCRAN 1 — JOIN MULTI-JOUEURS ====== -->
              <div class="screen screen-join" data-flow-screen="1">
                <div class="join-header">
                  <div class="join-club">
                    <img src="/logos/golf-du-soleil.svg" alt="" width="28" height="28" loading="lazy" />
                    <div>
                      <strong>Golf du Soleil</strong>
                      <small>{t.flow.joinClubMeta}</small>
                    </div>
                  </div>
                </div>

                <div class="join-eyebrow">{t.flow.joinEyebrow}</div>
                <div class="join-code">BIRDIE-A7</div>
                <div class="join-helper">{t.flow.joinHelper}</div>

                <div class="join-players">
                  <div class="join-players-label">{t.flow.joinAlreadyIn}</div>
                  <div class="join-chips">
                    <span class="join-chip"><em class="join-avatar" style="--ava:#1B4332">A</em>Antoine ✓</span>
                    <span class="join-chip"><em class="join-avatar" style="--ava:#D4A574">S</em>Sophie ✓</span>
                    <span class="join-chip"><em class="join-avatar" style="--ava:#3B6B8E">P</em>Paul ✓</span>
                    <span class="join-chip join-chip-empty" data-join-self><em class="join-avatar" style="--ava:#C46444">L</em>{t.flow.joinSelfPlaceholder}</span>
                  </div>
                </div>

                <div class="join-input">
                  <label>{t.flow.joinInputLabel}</label>
                  <div class="join-input-field" data-join-input>Léa<span class="join-caret"></span></div>
                </div>

                <button class="join-cta">{t.flow.joinCta}</button>
              </div>

              <!-- ====== ÉCRAN 2 — VRAIE CARTE DE SCORE ====== -->
              <div class="screen screen-card" data-flow-screen="2">
                <!-- Photo placeholder (club fallback) -->
                <div class="card-photo" data-card-photo>
                  <img src="/photos/golf-du-soleil.jpg" alt="" width="280" height="170" loading="lazy" decoding="async" />
                  <span class="card-photo-fade"></span>
                </div>

                <!-- Logo frame -->
                <div class="card-logo-frame">
                  <img src="/logos/golf-du-soleil.svg" alt="" width="56" height="56" loading="lazy" />
                </div>

                <p class="card-eyebrow">{t.flow.cardEyebrow}</p>
                <div class="card-rail" aria-hidden="true"></div>
                <h3 class="card-title">Golf du Soleil</h3>
                <div class="card-rail" aria-hidden="true"></div>

                <!-- Meta strip -->
                <ul class="card-meta">
                  <li><span class="meta-l">{t.flow.metaDate}</span><span class="meta-v">Sam. 11 mai</span></li>
                  <li><span class="meta-l">{t.flow.metaTee}</span><span class="meta-v">14:30</span></li>
                  <li><span class="meta-l">{t.flow.metaRef}</span><span class="meta-v">BIRDIE-A7</span></li>
                </ul>

                <!-- Score block -->
                <div class="card-score-block">
                  <p class="card-score-eyebrow">{t.flow.scoreEyebrow}</p>
                  <div class="card-score-value" data-flow-score>87</div>
                  <p class="card-score-meta"><span class="score-diff over">+15</span> · Par 72</p>
                </div>

                <!-- Grid Aller/Retour -->
                <div class="card-grid">
                  <div class="card-grid-row">
                    <span class="card-grid-label">{t.flow.gridFront}</span>
                    {front9.map((h, i) => (
                      <span class={`card-grid-cell card-cell-${h.type}`} data-flow-cell={i}>{h.score}</span>
                    ))}
                  </div>
                  <div class="card-grid-row">
                    <span class="card-grid-label">{t.flow.gridBack}</span>
                    {back9.map((h, i) => (
                      <span class={`card-grid-cell card-cell-${h.type}`} data-flow-cell={i + 9}>{h.score}</span>
                    ))}
                  </div>
                </div>

                <!-- Footer brand -->
                <div class="card-footer">
                  <span class="card-footer-l">SCLUBA</span>
                </div>
              </div>

              <!-- ====== ÉCRAN 3 — PARTAGE NATIF (overlay sur écran 2) ====== -->
              <div class="screen screen-share" data-flow-screen="3">
                <!-- Card en arrière-plan (réduite) -->
                <div class="share-card-bg">
                  <div class="share-card-photo">
                    <img src="/photos/golf-du-soleil.jpg" alt="" width="280" height="160" loading="lazy" decoding="async" />
                  </div>
                  <div class="share-card-score">87 <em>+15 · Par 72</em></div>
                  <div class="share-card-grid">
                    {Array.from({length: 18}, (_, i) => (
                      <span class={`mini-cell mini-${[...front9, ...back9][i].type}`}></span>
                    ))}
                  </div>
                </div>

                <!-- iOS share sheet -->
                <div class="share-sheet" data-share-sheet>
                  <div class="share-sheet-handle"></div>
                  <div class="share-sheet-preview">
                    <div class="share-preview-thumb">
                      <span class="thumb-fmt">PNG · 1080×1350</span>
                    </div>
                    <div class="share-preview-meta">
                      <strong>{t.flow.sharePreviewTitle}</strong>
                      <small>scluba.com/r/BIRDIE-A7</small>
                    </div>
                  </div>

                  <div class="share-apps">
                    {[
                      { name: 'Instagram', cls: 'app-ig' },
                      { name: 'WhatsApp', cls: 'app-wa' },
                      { name: 'Stories', cls: 'app-st' },
                      { name: 'Mail', cls: 'app-ma' },
                    ].map((app, i) => (
                      <button class={`share-app ${app.cls}`} type="button" data-share-app={i}>
                        <span class="share-app-icon"></span>
                        <span class="share-app-label">{app.name}</span>
                      </button>
                    ))}
                  </div>

                  <div class="share-actions">
                    <button class="share-action" type="button"><span>{t.flow.shareCopyLink}</span></button>
                    <button class="share-action" type="button"><span>{t.flow.shareSavePhoto}</span></button>
                  </div>
                </div>

                <!-- Toast confirmation -->
                <div class="share-toast" data-share-toast>{t.flow.shareToast}</div>
              </div>

            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  /* ===== Section + grid ===== */
  .showcase-section {
    position: relative;
    background:
      radial-gradient(ellipse 60% 35% at 18% 8%, rgba(212, 165, 116, 0.06), transparent 55%),
      radial-gradient(ellipse 60% 35% at 82% 90%, rgba(45, 106, 79, 0.06), transparent 55%),
      var(--bg);
  }
  .showcase-pin {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: var(--space-7) 0;
  }
  .showcase-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-7);
    align-items: center;
  }
  @media (min-width: 1024px) {
    .showcase-grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-8);
    }
  }

  /* ===== Narrative ===== */
  .showcase-narrative { max-width: 520px; }
  .narrative-stack {
    position: relative;
    margin: var(--space-3) 0 var(--space-6);
    min-height: 340px;
  }
  @media (min-width: 1024px) {
    .narrative-stack { min-height: 300px; }
  }
  .narrative-block {
    position: absolute;
    top: 0; left: 0; right: 0;
    will-change: opacity, transform;
  }
  .narrative-block[data-flow-phase="2"],
  .narrative-block[data-flow-phase="3"] {
    opacity: 0;
    transform: translateY(20px);
  }
  .narrative-block .section-title { margin-bottom: var(--space-3); }

  .phase-chip {
    display: inline-block;
    padding: 4px 12px;
    border-radius: var(--radius-full);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    margin-bottom: var(--space-3);
  }
  .phase-chip-1 { background: var(--primary); color: var(--bg); }
  .phase-chip-2 { background: var(--accent); color: var(--primary-deep); }
  .phase-chip-3 { background: var(--primary-deep); color: var(--accent); }

  /* Progress 3 dots */
  .phase-progress {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }
  .phase-dot {
    width: 10px; height: 10px;
    border-radius: 50%;
    background: var(--line);
    transition: background 0.3s var(--ease-out);
  }
  .phase-dot[data-progress-dot="1"] { background: var(--primary); }
  .phase-bar {
    flex: 1;
    height: 2px;
    max-width: 80px;
    background: var(--line);
    border-radius: var(--radius-full);
    overflow: hidden;
  }
  .phase-bar-fill {
    display: block;
    height: 100%;
    width: 0;
    background: linear-gradient(90deg, var(--primary), var(--accent));
    transform-origin: left;
  }

  /* ===== Phone stage ===== */
  .showcase-stage {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: var(--space-5) 0;
  }
  .showcase-phone {
    position: relative;
    height: min(72vh, 640px);
    aspect-ratio: 9 / 19.5;
    will-change: transform;
  }
  .phone-frame {
    position: relative;
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #5a5a5d 0%, #2a2a2c 18%, #1a1a1c 40%, #2a2a2c 60%, #4a4a4d 78%, #2a2a2c 100%);
    border-radius: 52px;
    padding: 12px;
    box-shadow:
      0 16px 32px rgba(27, 67, 50, 0.18),
      0 32px 64px rgba(27, 67, 50, 0.22),
      0 8px 16px rgba(0, 0, 0, 0.15),
      inset 0 1px 0 rgba(255, 255, 255, 0.16),
      0 0 0 1.5px rgba(0, 0, 0, 0.55);
  }
  .phone-rim {
    position: absolute; inset: 4px;
    border-radius: 48px;
    pointer-events: none;
    background: linear-gradient(135deg, rgba(255,255,255,0.14) 0%, transparent 30%, transparent 70%, rgba(255,255,255,0.05) 100%);
  }
  .phone-btn {
    position: absolute;
    background: linear-gradient(180deg, #3a3a3c 0%, #1a1a1c 50%, #3a3a3c 100%);
    border-radius: 1.5px;
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.12), inset 0 -1px 0 rgba(0,0,0,0.4);
  }
  .phone-btn-side-l-1 { left: -2px; top: 90px; width: 4px; height: 28px; }
  .phone-btn-side-l-2 { left: -2px; top: 130px; width: 4px; height: 50px; }
  .phone-btn-side-l-3 { left: -2px; top: 188px; width: 4px; height: 50px; }
  .phone-btn-side-r { right: -2px; top: 130px; width: 4px; height: 80px; }

  .phone-screen {
    position: relative;
    width: 100%; height: 100%;
    background: #FAF7EE;
    border-radius: 40px;
    overflow: hidden;
  }

  /* Dynamic Island */
  .phone-island {
    position: absolute;
    top: 10px;
    left: 50%;
    transform: translateX(-50%);
    width: 30%;
    max-width: 100px;
    min-width: 76px;
    height: 26px;
    background: #000;
    border-radius: 18px;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding-right: 7px;
  }
  .phone-island-cam {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: radial-gradient(circle at 30% 30%, #2a3a40, #050a0c);
    box-shadow: inset 0 0 0 1px rgba(255,255,255,0.1);
  }

  /* Status bar */
  .phone-status {
    position: absolute;
    top: 13px; left: 0; right: 0;
    z-index: 9;
    padding: 0 16px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: #1A1A1A;
    font-size: 11px;
    font-weight: 600;
    pointer-events: none;
  }
  .status-icons { display: flex; align-items: center; gap: 4px; }
  .status-signal {
    width: 13px; height: 8px;
    background:
      linear-gradient(to right,
        currentColor 0 2.5px, transparent 2.5px 3.5px,
        currentColor 3.5px 6px, transparent 6px 7px,
        currentColor 7px 9.5px, transparent 9.5px 10.5px,
        currentColor 10.5px 13px);
  }
  .status-wifi {
    width: 11px; height: 8px;
    background: currentColor;
    -webkit-mask: radial-gradient(circle at 50% 100%, #000 35%, transparent 36%) center/100% 100% no-repeat;
            mask: radial-gradient(circle at 50% 100%, #000 35%, transparent 36%) center/100% 100% no-repeat;
  }
  .status-battery {
    width: 20px; height: 9px;
    border: 1px solid currentColor;
    border-radius: 2.5px;
    position: relative;
    padding: 1px;
  }
  .status-battery::before {
    content: ""; display: block;
    width: 80%; height: 100%;
    background: currentColor;
    border-radius: 1px;
  }
  .status-battery::after {
    content: ""; position: absolute;
    right: -3px; top: 2px;
    width: 2px; height: 5px;
    background: currentColor;
    border-radius: 0 2px 2px 0;
  }

  /* ===== Screens (3 layers stacked) ===== */
  .screen {
    position: absolute;
    inset: 0;
    padding: 50px 18px 18px;
    display: flex;
    flex-direction: column;
    will-change: opacity, transform;
    overflow: hidden;
  }
  .screen-card { padding: 50px 16px 14px; opacity: 0; transform: scale(1.02); }
  .screen-share { padding: 0; opacity: 0; transform: scale(1.02); }

  /* ====== SCREEN 1 — JOIN ====== */
  .join-header { display: flex; align-items: center; }
  .join-club {
    display: flex; align-items: center; gap: 8px;
    padding: 4px 0;
  }
  .join-club img {
    width: 28px; height: 28px;
    border-radius: 50%;
    background: var(--primary-bg);
    padding: 2px;
    border: 1px solid var(--accent);
  }
  .join-club strong {
    font-family: var(--font-serif);
    font-size: 13px;
    color: var(--primary);
    display: block;
    line-height: 1.1;
  }
  .join-club small {
    font-size: 9px;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .join-eyebrow {
    margin-top: 18px;
    font-size: 9px;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-weight: 700;
    text-align: center;
  }
  .join-code {
    font-family: var(--font-serif);
    font-size: 32px;
    font-weight: 800;
    color: var(--primary);
    text-align: center;
    letter-spacing: 0.05em;
    margin: 6px 0 2px;
    font-variant-numeric: tabular-nums;
  }
  .join-helper {
    font-size: 9px;
    color: var(--muted);
    text-align: center;
    margin-bottom: 16px;
  }

  .join-players {
    background: var(--primary-bg);
    border-radius: 10px;
    padding: 10px;
    margin-bottom: 14px;
  }
  .join-players-label {
    font-size: 9px;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 6px;
  }
  .join-chips { display: flex; flex-direction: column; gap: 5px; }
  .join-chip {
    display: flex; align-items: center; gap: 6px;
    background: var(--bg);
    border: 1px solid var(--line);
    border-radius: var(--radius-full);
    padding: 4px 10px 4px 4px;
    font-size: 10.5px;
    color: var(--ink);
    font-weight: 600;
  }
  .join-chip-empty {
    border: 1px dashed var(--accent);
    background: rgba(212, 165, 116, 0.08);
    color: var(--accent);
  }
  .join-avatar {
    width: 18px; height: 18px;
    border-radius: 50%;
    background: var(--ava);
    color: #fff;
    font-style: normal;
    font-size: 9px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .join-input { margin-bottom: 14px; }
  .join-input label {
    display: block;
    font-size: 9px;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 4px;
  }
  .join-input-field {
    background: var(--bg);
    border: 1.5px solid var(--primary);
    border-radius: 8px;
    padding: 9px 12px;
    font-size: 13px;
    font-weight: 600;
    color: var(--ink);
    display: flex;
    align-items: center;
  }
  .join-caret {
    display: inline-block;
    width: 1.5px;
    height: 14px;
    margin-left: 2px;
    background: var(--primary);
    animation: joinBlink 1s infinite;
  }
  @keyframes joinBlink { 0%, 50% { opacity: 1; } 51%, 100% { opacity: 0; } }

  .join-cta {
    margin-top: auto;
    width: 100%;
    padding: 11px;
    background: var(--primary);
    color: var(--bg);
    border-radius: 10px;
    font-size: 13px;
    font-weight: 700;
    border: none;
  }

  /* ====== SCREEN 2 — CARD ====== */
  .card-photo {
    position: relative;
    height: 130px;
    border-radius: 8px;
    overflow: hidden;
    margin-bottom: 10px;
    flex-shrink: 0;
  }
  .card-photo img {
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: center 55%;
    display: block;
  }
  .card-photo-fade {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 50px;
    background: linear-gradient(180deg, transparent, #FAF7EE);
  }

  .card-logo-frame {
    position: relative;
    width: 56px; height: 56px;
    margin: -40px auto 6px;
    background: var(--bg);
    border-radius: 50%;
    padding: 4px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.12);
    z-index: 2;
  }
  .card-logo-frame img { width: 100%; height: 100%; }

  .card-eyebrow {
    font-size: 8px;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-weight: 700;
    text-align: center;
    margin: 0 0 4px;
  }
  .card-rail {
    width: 36px;
    height: 1px;
    background: var(--accent);
    opacity: 0.5;
    margin: 0 auto 4px;
  }
  .card-title {
    font-family: var(--font-serif);
    font-size: 16px;
    font-weight: 800;
    color: var(--primary);
    text-align: center;
    margin: 2px 0;
  }

  .card-meta {
    display: flex;
    justify-content: space-around;
