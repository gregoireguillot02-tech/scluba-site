---
// V4.4 — Refonte PhoneShowcase (Grégoire spec images 2 + 3) :
// drop l'ancienne 3-screens morph (join / card / share).
// Replace par 2 screens qui matchent la vraie webapp Scluba :
//   Screen 1 — Trou 1/9 scoring (image 2)
//   Screen 2 — Partager ta carte avec iOS native share menu (image 3)
//
// Anim cablée dans src/scripts/animations.ts initPhoneShowcase().
// Frame iPhone 17 Pro titanium + néon sweep conic-gradient préservés.

import { useT, type Locale } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useT(locale);
---

<section class="showcase-section" data-anim="showcase-wrap">
  <div class="showcase-pin">
    <div class="container showcase-grid">

      <!-- Narrative gauche -->
      <div class="showcase-narrative">
        <span class="section-eyebrow">{t.flow.eyebrow}</span>

        <div class="narrative-stack">
          <article class="narrative-block" data-flow-phase="1">
            <span class="phase-chip phase-chip-1">{t.flow.phase2Tag}</span>
            <h2 class="section-title">{t.flow.phase2Title}</h2>
            <p class="section-lead">{t.flow.phase2Lead}</p>
          </article>
          <article class="narrative-block" data-flow-phase="2">
            <span class="phase-chip phase-chip-2">{t.flow.phase3Tag}</span>
            <h2 class="section-title">{t.flow.phase3Title}</h2>
            <p class="section-lead">{t.flow.phase3Lead}</p>
          </article>
        </div>

        <!-- Progress 2 dots -->
        <div class="phase-progress" aria-hidden="true">
          <span class="phase-dot" data-progress-dot="1"></span>
          <span class="phase-bar"><span class="phase-bar-fill" data-progress-bar></span></span>
          <span class="phase-dot" data-progress-dot="2"></span>
        </div>
      </div>

      <!-- Phone droite -->
      <div class="showcase-stage" aria-hidden="true">
        <!-- V4.2 Néon sweep conic-gradient continu — .showcase-phone::before -->
        <div class="showcase-phone" data-flow-phone>
          <div class="phone-frame">
            <span class="phone-btn phone-btn-side-l-1"></span>
            <span class="phone-btn phone-btn-side-l-2"></span>
            <span class="phone-btn phone-btn-side-l-3"></span>
            <span class="phone-btn phone-btn-side-r"></span>
            <span class="phone-rim"></span>

            <div class="phone-screen">
              <!-- Dynamic Island -->
              <div class="phone-island">
                <span class="phone-island-cam"></span>
              </div>

              <!-- Status bar -->
              <div class="phone-status">
                <span class="status-time">14:30</span>
                <div class="status-icons">
                  <span class="status-signal"></span>
                  <span class="status-wifi"></span>
                  <span class="status-battery"></span>
                </div>
              </div>

              <!-- ====== SCREEN 1 — TROU 1/9 SCORING (image 2) ====== -->
              <div class="screen screen-score" data-flow-screen="1">
                <div class="score-player-bar">
                  <span class="score-player-ava">G</span>
                  <div class="score-player-meta">
                    <strong>greg <em>(vous)</em></strong>
                    <small>EN ATTENTE</small>
                  </div>
                  <span class="score-hole-pill">TROU <strong>1/9</strong></span>
                </div>

                <div class="score-par-block">
                  <span class="score-par-lbl">PAR</span>
                  <div class="score-par-num">3</div>
                </div>

                <div class="score-hint">← tap un trou ou swipe →</div>

                <div class="score-pills">
                  {Array.from({ length: 9 }, (_, i) => (
                    <span class={`pill ${i === 0 ? 'pill-active' : ''}`}>{i + 1}</span>
                  ))}
                </div>

                <div class="score-cards">
                  <span class="s-card"><em>ACE</em><strong>1</strong></span>
                  <span class="s-card"><em>BIRDIE</em><strong>2</strong></span>
                  <span class="s-card is-active"><em>PAR</em><strong>3</strong></span>
                  <span class="s-card"><em>BOGEY</em><strong>4</strong></span>
                  <span class="s-card"><em>DOUBLE</em><strong>5</strong></span>
                </div>

                <div class="score-carte">
                  <span class="carte-lbl">CARTE</span>
                  <div class="carte-row">
                    <span class="carte-boucle">BOUCLE 1</span>
                    {Array.from({ length: 9 }, () => <span class="carte-cell">—</span>)}
                  </div>
                </div>

                <button class="score-cta" tabindex="-1">Terminer maintenant</button>
              </div>

              <!-- ====== SCREEN 2 — PARTAGER TA CARTE (image 3) ====== -->
              <div class="screen screen-share" data-flow-screen="2">
                <div class="share-modal-header">
                  <span class="share-modal-title">Partager ta carte</span>
                  <span class="share-modal-close" aria-hidden="true">×</span>
                </div>

                <div class="share-photo">
                  <img src="/photos/golf-du-soleil.jpg" alt="" width="280" height="100" loading="lazy" decoding="async" />
                  <div class="share-photo-logo">
                    <img src="/logos/golf-du-soleil.svg" alt="" width="32" height="32" loading="lazy" />
                  </div>
                </div>

                <!-- iOS native share menu mocked compact -->
                <div class="ios-menu">
                  <div class="ios-file">
                    <span class="ios-file-icon">PNG</span>
                    <div class="ios-file-meta">
                      <strong>carte-golf-du-soleil</strong>
                      <small>Image PNG · 858 ko</small>
                    </div>
                  </div>

                  <div class="ios-contacts">
                    <span class="ios-contact"><em class="ios-ava" style="--ava:#1B4332">A</em>Antoine</span>
                    <span class="ios-contact"><em class="ios-ava" style="--ava:#D4A574">S</em>Sophie</span>
                    <span class="ios-contact"><em class="ios-ava" style="--ava:#3B6B8E">P</em>Paul</span>
                    <span class="ios-contact"><em class="ios-ava" style="--ava:#C46444">L</em>Léa</span>
                  </div>

                  <ul class="ios-apps">
                    <li>AirDrop</li>
                    <li>Mail</li>
                    <li>Messages</li>
                    <li>Notes</li>
                  </ul>
                </div>

                <button class="share-cta" tabindex="-1">Partager maintenant</button>
              </div>

            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  /* ===== Section + grid ===== */
  .showcase-section {
    position: relative;
    background: var(--bg);
  }
  .showcase-pin {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: var(--space-7) 0;
  }
  .showcase-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-7);
    align-items: center;
  }
  @media (min-width: 1024px) {
    .showcase-grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-8);
    }
  }

  /* ===== Narrative ===== */
  .showcase-narrative { max-width: 520px; }
  .narrative-stack {
    position: relative;
    margin: var(--space-3) 0 var(--space-6);
    min-height: 320px;
  }
  @media (min-width: 1024px) {
    .narrative-stack { min-height: 280px; }
  }
  .narrative-block {
    position: absolute;
    top: 0; left: 0; right: 0;
    will-change: opacity, transform;
  }
  .narrative-block[data-flow-phase="2"] {
    opacity: 0;
    transform: translateY(20px);
  }
  .narrative-block .section-title { margin-bottom: var(--space-3); }

  .phase-chip {
    display: inline-block;
    padding: 4px 12px;
    border-radius: var(--radius-full);
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    margin-bottom: var(--space-3);
  }
  .phase-chip-1 { background: var(--accent); color: var(--ink); }
  .phase-chip-2 { background: var(--accent-soft); color: var(--accent); }

  /* Progress 2 dots */
  .phase-progress {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }
  .phase-dot {
    width: 10px; height: 10px;
    border-radius: 50%;
    background: var(--line);
    transition: background 0.3s var(--ease-out);
  }
  .phase-dot[data-progress-dot="1"] { background: var(--accent); }
  .phase-bar {
    flex: 1;
    height: 2px;
    max-width: 80px;
    background: var(--line);
    border-radius: var(--radius-full);
    overflow: hidden;
  }
  .phase-bar-fill {
    display: block;
    height: 100%;
    width: 0;
    background: var(--accent);
    transform-origin: left;
  }

  /* ===== Phone stage ===== */
  .showcase-stage {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: var(--space-5) 0;
  }
  .showcase-phone {
    position: relative;
    height: min(82vh, 740px);
    aspect-ratio: 9 / 19.5;
    will-change: transform;
  }

  /* V4.2 Néon conic-gradient sweep continu */
  @property --neon-angle {
    syntax: '<angle>';
    initial-value: 0deg;
    inherits: false;
  }
  .showcase-phone::before {
    content: "";
    position: absolute;
    inset: -4px;
    border-radius: 60px;
    padding: 4px;
    background: conic-gradient(
      from var(--neon-angle),
      transparent 0deg,
      transparent 265deg,
      rgba(0, 220, 130, 0.35) 295deg,
      rgba(0, 220, 130, 0.85) 340deg,
      #00FF9A 357deg,
      rgba(0, 220, 130, 0.85) 360deg
    );
    -webkit-mask:
      linear-gradient(#000 0 0) content-box,
      linear-gradient(#000 0 0);
            mask:
      linear-gradient(#000 0 0) content-box,
      linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
            mask-composite: exclude;
    pointer-events: none;
    z-index: 1;
    filter:
      drop-shadow(0 0 6px var(--accent))
      drop-shadow(0 0 18px rgba(0, 220, 130, 0.55));
    animation: neonSweep 4s linear infinite;
  }
  @keyframes neonSweep {
    to { --neon-angle: 360deg; }
  }
  @media (prefers-reduced-motion: reduce) {
    .showcase-phone::before {
      animation: none;
      background: var(--accent);
      opacity: 0.55;
    }
  }
  @supports not (background: paint(angle-painter)) {
    .showcase-phone::before {
      background: var(--accent);
      animation: neonPulse 3s ease-in-out infinite;
    }
    @keyframes neonPulse {
      0%, 100% { opacity: 0.45; }
      50% { opacity: 0.90; }
    }
  }

  /* iPhone 17 Pro titanium frame (cohérent avec Hero) */
  .phone-frame {
    position: relative;
    width: 100%;
    height: 100%;
    background:
      linear-gradient(135deg, #6E6E72 0%, #48484A 22%, #2C2C2E 50%, #48484A 78%, #6E6E72 100%);
    border-radius: 56px;
    padding: 12px;
    box-shadow:
      0 24px 48px rgba(0, 0, 0, 0.40),
      0 48px 96px rgba(0, 0, 0, 0.30),
      inset 0 1px 0 rgba(255, 255, 255, 0.22),
      0 0 0 1.5px rgba(0, 0, 0, 0.70);
  }
  .phone-frame::before {
    content: "";
    position: absolute;
    inset: 8px;
    border-radius: 50px;
    pointer-events: none;
    box-shadow:
      inset 0 0 0 1px rgba(255, 255, 255, 0.08),
      inset 0 1px 0 rgba(255, 255, 255, 0.10);
    z-index: 2;
  }
  .phone-frame::after {
    content: "";
    position: absolute;
    inset: 12px;
    border-radius: 44px;
    pointer-events: none;
    background: linear-gradient(
      138deg,
      rgba(255, 255, 255, 0.10) 0%,
      rgba(255, 255, 255, 0) 35%,
      rgba(255, 255, 255, 0) 75%,
      rgba(255, 255, 255, 0.04) 100%
    );
    z-index: 4;
    mix-blend-mode: screen;
  }
  .phone-rim {
    position: absolute; inset: 4px;
    border-radius: 52px;
    pointer-events: none;
    background: linear-gradient(135deg, rgba(255,255,255,0.16) 0%, transparent 30%, transparent 70%, rgba(255,255,255,0.06) 100%);
  }
  .phone-btn {
    position: absolute;
    background: linear-gradient(180deg, #5C5C5E 0%, #2C2C2E 50%, #5C5C5E 100%);
    border-radius: 1.5px;
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.14);
  }
  .phone-btn-side-l-1 {
    left: -2px; top: 90px; width: 4px; height: 28px;
    background: linear-gradient(180deg, #C9A96A 0%, #8B7344 50%, #C9A96A 100%);
  }
  .phone-btn-side-l-2 { left: -2px; top: 130px; width: 4px; height: 50px; }
  .phone-btn-side-l-3 { left: -2px; top: 188px; width: 4px; height: 50px; }
  .phone-btn-side-r { right: -2px; top: 130px; width: 4px; height: 80px; }

  .phone-screen {
    /* V4.3 sub-context palette */
    --primary: #1F1F1F;
    --primary-soft: #3A3A3A;
    --primary-deep: #0A0A0A;
    --primary-bg: rgba(0, 220, 130, 0.08);
    --accent: #00DC82;
    --accent-soft: rgba(0, 220, 130, 0.12);
    --accent-bright: #1AE89A;
    --ink: #1F1F1F;
    --ink-soft: #3A3A3A;
    --bg: #E8E1D0;
    --muted: #7A7A7A;
    --line: rgba(31, 31, 31, 0.12);

    position: relative;
    width: 100%; height: 100%;
    background: linear-gradient(180deg, #E8E1D0 0%, #DDD5C0 100%);
    border-radius: 44px;
    overflow: hidden;
  }
  .phone-screen::before {
    content: "";
    position: absolute;
    top: 6px;
    left: 50%;
    transform: translateX(-50%);
    width: 12%;
    max-width: 50px;
    height: 2px;
    border-radius: 1px;
    background: rgba(0, 0, 0, 0.18);
    z-index: 4;
  }

  /* Dynamic Island */
  .phone-island {
    position: absolute;
    top: 11px;
    left: 50%;
    transform: translateX(-50%);
    width: 32%;
    max-width: 124px;
    min-width: 96px;
    height: 30px;
    background: #000;
    border-radius: 18px;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding-right: 8px;
  }
  .phone-island-cam {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: radial-gradient(circle at 30% 30%, #2a3a40, #050a0c);
    box-shadow: inset 0 0 0 1px rgba(255,255,255,0.08);
  }

  /* Status bar */
  .phone-status {
    position: absolute;
    top: 13px; left: 0; right: 0;
    z-index: 9;
    padding: 0 16px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: var(--ink);
    font-size: 11px;
    font-weight: 600;
    pointer-events: none;
  }
  .status-icons { display: flex; align-items: center; gap: 4px; }
  .status-signal {
    width: 13px; height: 8px;
    background:
      linear-gradient(to right,
        currentColor 0 2.5px, transparent 2.5px 3.5px,
        currentColor 3.5px 6px, transparent 6px 7px,
        currentColor 7px 9.5px, transparent 9.5px 10.5px,
        currentColor 10.5px 13px);
  }
  .status-wifi {
    width: 11px; height: 8px;
    background: currentColor;
    -webkit-mask: radial-gradient(circle at 50% 100%, #000 35%, transparent 36%) center/100% 100% no-repeat;
            mask: radial-gradient(circle at 50% 100%, #000 35%, transparent 36%) center/100% 100% no-repeat;
  }
  .status-battery {
    width: 20px; height: 9px;
    border: 1px solid currentColor;
    border-radius: 2.5px;
    position: relative;
    padding: 1px;
  }
  .status-battery::before {
    content: ""; display: block;
    width: 80%; height: 100%;
    background: currentColor;
    border-radius: 1px;
  }
  .status-battery::after {
    content: ""; position: absolute;
    right: -3px; top: 2px;
    width: 2px; height: 5px;
    background: currentColor;
    border-radius: 0 2px 2px 0;
  }

  /* ===== Screens (2 layers stacked) ===== */
  .screen {
    position: absolute;
    inset: 0;
    padding: 50px 14px 14px;
    display: flex;
    flex-direction: column;
    will-change: opacity, transform;
    overflow: hidden;
  }
  .screen-share { opacity: 0; transform: scale(1.02); }

  /* ====== SCREEN 1 — TROU 1/9 SCORING ====== */
  .score-player-bar {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 6px 8px;
    background: rgba(0, 220, 130, 0.10);
    border: 1px solid var(--accent);
    border-radius: 12px;
    margin-bottom: 14px;
  }
  .score-player-ava {
    width: 30px; height: 30px;
    border-radius: 50%;
    background: #7C3AED;
    color: #fff;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 13px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .score-player-meta {
    flex: 1;
    min-width: 0;
  }
  .score-player-meta strong {
    display: block;
    font-family: var(--font-display);
    font-size: 11px;
    color: var(--primary);
    font-weight: 700;
    line-height: 1.1;
  }
  .score-player-meta strong em {
    font-style: normal;
    color: var(--muted);
    font-weight: 500;
  }
  .score-player-meta small {
    display: block;
    font-family: var(--font-mono);
    font-size: 7.5px;
    color: var(--muted);
    letter-spacing: 0.18em;
    margin-top: 1px;
  }
  .score-hole-pill {
    font-family: var(--font-mono);
    font-size: 8.5px;
    color: var(--accent);
    letter-spacing: 0.18em;
    font-weight: 500;
    flex-shrink: 0;
  }
  .score-hole-pill strong {
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 700;
    color: var(--accent);
    margin-left: 4px;
  }

  .score-par-block {
    text-align: center;
    margin-bottom: 8px;
  }
  .score-par-lbl {
    font-family: var(--font-mono);
    font-size: 8.5px;
    letter-spacing: 0.18em;
    color: var(--muted);
    font-weight: 500;
  }
  .score-par-num {
    font-family: var(--font-display);
    font-size: 42px;
    font-weight: 900;
    color: var(--accent);
    line-height: 0.9;
    letter-spacing: -0.04em;
  }

  .score-hint {
    text-align: center;
    font-family: var(--font-mono);
    font-size: 7px;
    color: var(--muted);
    letter-spacing: 0.10em;
    margin: 4px 0 10px;
  }

  .score-pills {
    display: flex;
    justify-content: center;
    gap: 4px;
    margin-bottom: 10px;
  }
  .pill {
    width: 18px; height: 18px;
    border-radius: 50%;
    background: var(--bg);
    border: 1px solid var(--line);
    color: var(--muted);
    font-family: var(--font-display);
    font-size: 9px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .pill-active {
    background: var(--primary);
    color: var(--bg);
    border-color: var(--primary);
  }

  .score-cards {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 3px;
    margin-bottom: 10px;
  }
  .s-card {
    background: var(--bg);
    border: 1px solid var(--line);
    border-radius: 5px;
    padding: 4px 2px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1px;
  }
  .s-card em {
    font-family: var(--font-mono);
    font-style: normal;
    font-size: 6.5px;
    letter-spacing: 0.10em;
    color: var(--muted);
    font-weight: 500;
  }
  .s-card strong {
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 700;
    color: var(--primary);
  }
  .s-card.is-active {
    background: rgba(201, 169, 106, 0.18);
    border-color: var(--accent);
  }
  .s-card.is-active em { color: var(--accent); }
  .s-card.is-active strong { color: var(--accent); }

  .score-carte {
    background: rgba(255, 255, 255, 0.45);
    border-radius: 6px;
    padding: 6px 6px 6px 8px;
    margin-bottom: 8px;
  }
  .carte-lbl {
    display: block;
    font-family: var(--font-mono);
    font-size: 7px;
    letter-spacing: 0.20em;
    color: var(--accent);
    font-weight: 500;
    margin-bottom: 3px;
  }
  .carte-row {
    display: flex;
    align-items: center;
    gap: 2px;
  }
  .carte-boucle {
    flex-shrink: 0;
    padding: 3px 5px;
    background: var(--primary);
    color: var(--bg);
    font-family: var(--font-mono);
    font-size: 7px;
    font-weight: 600;
    letter-spacing: 0.06em;
    border-radius: 3px;
  }
  .carte-cell {
    flex: 1;
    background: var(--bg);
    border: 1px solid var(--line);
    border-radius: 2px;
    text-align: center;
    padding: 3px 0;
    font-size: 8px;
    color: var(--muted);
    font-weight: 600;
  }

  .score-cta {
    margin-top: auto;
    width: 100%;
    padding: 10px;
    background: var(--accent);
    color: var(--bg);
    border: none;
    border-radius: 8px;
    font-family: var(--font-display);
    font-size: 11px;
    font-weight: 700;
    cursor: default;
    letter-spacing: -0.005em;
  }

  /* ====== SCREEN 2 — PARTAGER TA CARTE ====== */
  .share-modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 4px 4px 10px;
    margin-bottom: 4px;
  }
  .share-modal-title {
    font-family: var(--font-display);
    font-size: 12px;
    font-weight: 700;
    color: var(--accent);
  }
  .share-modal-close {
    font-size: 16px;
    color: var(--muted);
    line-height: 1;
  }

  .share-photo {
    position: relative;
    height: 96px;
    border-radius: 6px;
