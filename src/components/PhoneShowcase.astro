---
// V5 (2026-05-23) — Refonte PhoneShowcase 4 phases avec screenshots app réels.
// Drop l'ancien mockup CSS iPhone (frame titanium + 2 screens HTML/CSS inline)
// Replace par : pattern HeroPhone (mask + frame.png par-dessus) avec 4 écrans
// PNG empilés qui morph au scroll.
//
// Les 4 phases tell le post-round flow (chronologique) :
//   01 Scoring     — saisie trou par trou + classement live
//   02 Carte       — récap brandée club (photo, score, météo)
//   03 Bilan       — classement final + commentaire + CTA Partager
//   04 Partage     — iOS native share sheet iMessage
//
// Animation : src/scripts/animations.ts initPhoneShowcase() refactorée en
// boucle dynamique N phases (extensible si on rajoute une phase 05).

import { useT, type Locale } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useT(locale);

const phases = [
  { num: 1, tag: t.flow.phase1Tag, title: t.flow.phase1Title, lead: t.flow.phase1Lead, img: '/photos/phone-screen-scoring.png' },
  { num: 2, tag: t.flow.phase2Tag, title: t.flow.phase2Title, lead: t.flow.phase2Lead, img: '/photos/phone-screen-card.png' },
  { num: 3, tag: t.flow.phase3Tag, title: t.flow.phase3Title, lead: t.flow.phase3Lead, img: '/photos/phone-screen-leaderboard.png' },
  { num: 4, tag: t.flow.phase4Tag, title: t.flow.phase4Title, lead: t.flow.phase4Lead, img: '/photos/phone-screen-share.png' },
];
---

<section class="showcase-section" data-anim="showcase-wrap">
  <div class="showcase-pin">
    <div class="container showcase-grid">

      <!-- Narrative gauche : 4 blocs superposés -->
      <div class="showcase-narrative">
        <span class="section-eyebrow">{t.flow.eyebrow}</span>

        <div class="narrative-stack">
          {phases.map((p) => (
            <article class="narrative-block" data-flow-phase={p.num}>
              <span class={`phase-chip phase-chip-${p.num}`}>{p.tag}</span>
              <h2 class="section-title">{p.title}</h2>
              <p class="section-lead">{p.lead}</p>
            </article>
          ))}
        </div>

        <!-- Progress 4 dots + 3 segments -->
        <div class="phase-progress" aria-hidden="true">
          {phases.map((p, i) => (
            <>
              <span class="phase-dot" data-progress-dot={p.num}></span>
              {i < phases.length - 1 && (
                <span class="phase-bar"><span class="phase-bar-fill" data-progress-bar={i + 1}></span></span>
              )}
            </>
          ))}
        </div>
      </div>

      <!-- Phone droite : pattern HeroPhone (mask + frame img) avec 4 screens stackés -->
      <div class="showcase-stage" aria-hidden="true">
        <div class="showcase-phone-stage" data-flow-phone>
          <div class="showcase-phone-img">
            <div class="showcase-phone-screen-mask">
              {phases.map((p) => (
                <img class="showcase-phone-screen-img"
                     data-flow-screen={p.num}
                     src={p.img}
                     alt=""
                     loading="eager" decoding="async" fetchpriority={p.num === 1 ? 'high' : 'auto'} />
              ))}
            </div>
            <img class="showcase-phone-frame-img"
                 src="/photos/phone-frame.png"
                 alt=""
                 width="420" height="861"
                 loading="eager" decoding="async" />
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  /* ===== Section + grid ===== */
  .showcase-section {
    position: relative;
    background: var(--bg);
  }
  .showcase-pin {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: var(--space-7) 0;
  }
  .showcase-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-7);
    align-items: center;
  }
  @media (min-width: 1024px) {
    .showcase-grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-8);
    }
  }

  /* ===== Narrative ===== */
  .showcase-narrative { max-width: 520px; }
  .narrative-stack {
    position: relative;
    margin: var(--space-3) 0 var(--space-6);
    min-height: 320px;
  }
  @media (min-width: 1024px) {
    .narrative-stack { min-height: 280px; }
  }
  .narrative-block {
    position: absolute;
    top: 0; left: 0; right: 0;
    will-change: opacity, transform;
  }
  /* Phases 2/3/4 cachées à l'init — phase 1 visible par défaut */
  .narrative-block[data-flow-phase="2"],
  .narrative-block[data-flow-phase="3"],
  .narrative-block[data-flow-phase="4"] {
    opacity: 0;
    transform: translateY(20px);
  }
  .narrative-block .section-title { margin-bottom: var(--space-3); }

  /* Phase chips : couleur progressive (accent plein actif, soft inactif).
     JS gère .is-active mais on garde un look neutre par défaut. */
  .phase-chip {
    display: inline-block;
    padding: 4px 12px;
    border-radius: var(--radius-full);
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    margin-bottom: var(--space-3);
    background: var(--accent-soft);
    color: var(--accent);
  }
  .phase-chip-1 { background: var(--accent); color: var(--ink); }

  /* Progress 4 dots + 3 segments */
  .phase-progress {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }
  .phase-dot {
    width: 10px; height: 10px;
    border-radius: 50%;
    background: var(--line);
    transition: background 0.3s var(--ease-out);
    flex-shrink: 0;
  }
  .phase-dot[data-progress-dot="1"] { background: var(--accent); }
  .phase-bar {
    flex: 1;
    height: 2px;
    max-width: 60px;
    background: var(--line);
    border-radius: var(--radius-full);
    overflow: hidden;
  }
  .phase-bar-fill {
    display: block;
    height: 100%;
    width: 0;
    background: var(--accent);
    transform-origin: left;
  }

  /* ===== Phone stage ===== */
  .showcase-stage {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: var(--space-5) 0;
  }
  .showcase-phone-stage {
    position: relative;
    display: inline-block;
    line-height: 0;
    will-change: transform;
    filter:
      drop-shadow(0 22px 44px rgba(70, 50, 30, 0.30))
      drop-shadow(0 44px 96px rgba(70, 50, 30, 0.20));
  }

  /* Container = aspect ratio frame. Phone large pour bien voir le contenu
     app (retour Grégoire 2026-05-23 : "voir le tel en grand"). */
  .showcase-phone-img {
    position: relative;
    width: clamp(340px, 46vw, 560px);
    aspect-ratio: 420 / 861;
  }

  /* Screen mask : pattern HeroPhone — inset 1.6%/1.4% + border-radius adaptée */
  .showcase-phone-screen-mask {
    position: absolute;
    inset: 1.6% 1.4%;
    border-radius: 11.5% / 5.6%;
    overflow: hidden;
    z-index: 1;
    background: #F4EEDD;
  }

  /* 4 screens empilés à la même position. Init : screen 1 visible (opacity 1),
     2/3/4 invisibles (opacity 0, scale 1.02). Anim GSAP les fait apparaître
     séquentiellement au scroll. */
  .showcase-phone-screen-img {
    position: absolute;
    height: 100%;
    width: auto;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    display: block;
    will-change: opacity, transform;
  }
  .showcase-phone-screen-img[data-flow-screen="2"],
  .showcase-phone-screen-img[data-flow-screen="3"],
  .showcase-phone-screen-img[data-flow-screen="4"] {
    opacity: 0;
    transform: translateX(-50%) scale(1.02);
  }

  /* Frame iPhone Pro orange par-dessus */
  .showcase-phone-frame-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    pointer-events: none;
    z-index: 2;
    display: block;
  }

  /* ===== Mobile : stack vertical, pas de pin, 1 seul screen visible ===== */
  @media (max-width: 1023px) {
    .showcase-pin {
      min-height: 0;
      padding: var(--space-6) 0;
    }
    .narrative-stack {
      min-height: 0;
      display: flex;
      flex-direction: column;
      gap: var(--space-5);
    }
    .narrative-block,
    .narrative-block[data-flow-phase="2"],
    .narrative-block[data-flow-phase="3"],
    .narrative-block[data-flow-phase="4"] {
      position: static;
      opacity: 1;
      transform: none;
    }
    .phase-progress { display: none; }

    .showcase-stage { padding: var(--space-4) 0 0; }
    .showcase-phone-img {
      width: min(82vw, 360px);
    }
    /* En mobile on garde seulement le screen 1 (scoring) visible — les autres
       sont expliqués par les narrative blocks empilés en texte. Évite de
       cloner 4 phones. */
    .showcase-phone-screen-img[data-flow-screen="2"],
    .showcase-phone-screen-img[data-flow-screen="3"],
    .showcase-phone-screen-img[data-flow-screen="4"] {
      display: none;
    }
  }

  /* Reduce motion : pas d'anim, montre screen 1 + narrative 1 */
  @media (prefers-reduced-motion: reduce) {
    .showcase-phone-screen-img,
    .narrative-block {
      transition: none !important;
    }
  }
</style>
