---
import { useT, type Locale } from '../i18n';
import PhoneAtmosphere from './PhoneAtmosphere.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useT(locale);

// Score / par par trou (mockup réaliste)
const front9 = [
  { par: 4, score: 5, type: 'bogey' },
  { par: 5, score: 5, type: 'par' },
  { par: 3, score: 2, type: 'birdie' },
  { par: 4, score: 4, type: 'par' },
  { par: 4, score: 5, type: 'bogey' },
  { par: 5, score: 6, type: 'bogey' },
  { par: 3, score: 3, type: 'par' },
  { par: 4, score: 5, type: 'bogey' },
  { par: 4, score: 5, type: 'bogey' },
];
const back9 = [
  { par: 4, score: 4, type: 'par' },
  { par: 3, score: 3, type: 'par' },
  { par: 5, score: 6, type: 'bogey' },
  { par: 4, score: 5, type: 'bogey' },
  { par: 4, score: 4, type: 'par' },
  { par: 3, score: 4, type: 'bogey' },
  { par: 5, score: 6, type: 'bogey' },
  { par: 4, score: 4, type: 'par' },
  { par: 4, score: 5, type: 'bogey' },
];
---

<section class="phone-section" data-anim="phone-wrap">
  <div class="phone-pin">
    <div class="container phone-grid">

      <div class="phone-narrative">
        <span class="section-eyebrow">{t.phone.eyebrow}</span>

        <div class="narrative-stack">
          <div class="narrative-block" data-narrative-phase="1">
            <span class="phase-tag phase-tag-79">{t.phone.phase1Tag}</span>
            <h2 class="section-title">{t.phone.phase1Title}</h2>
            <p class="section-lead">{t.phone.phase1Lead}</p>
          </div>

          <div class="narrative-block" data-narrative-phase="2">
            <span class="phase-tag phase-tag-49">{t.phone.phase2Tag}</span>
            <h2 class="section-title">{t.phone.phase2Title}</h2>
            <p class="section-lead">{t.phone.phase2Lead}</p>
          </div>
        </div>

        <div class="phase-progress" aria-hidden="true">
          <div class="phase-step" data-phase-step="1">
            <span class="phase-dot"></span>
            <span>App live</span>
          </div>
          <div class="phase-line"><div class="phase-line-fill" data-phase-line></div></div>
          <div class="phase-step" data-phase-step="2">
            <span class="phase-dot"></span>
            <span>Carte récap</span>
          </div>
        </div>
      </div>

      <div class="phone-stage" aria-hidden="true">
        <div class="phone-shadow"></div>

        <!-- Atmosphère golden hour cinématique (remplace le panneau pastel) -->
        <div class="phone-green" aria-hidden="true">
          <PhoneAtmosphere variant="full" id="mockup" />
        </div>

        <div class="phone-device" data-phone>
          <!-- Cadre titanium -->
          <div class="phone-frame">
            <!-- Boutons latéraux -->
            <span class="phone-btn phone-btn-action"></span>
            <span class="phone-btn phone-btn-volup"></span>
            <span class="phone-btn phone-btn-voldown"></span>
            <span class="phone-btn phone-btn-side"></span>

            <!-- Reflet bord -->
            <span class="phone-rim"></span>

            <!-- Écran -->
            <div class="phone-screen">
              <!-- Dynamic Island -->
              <div class="phone-island">
                <span class="phone-island-camera"></span>
              </div>

              <!-- Status bar (heure + signal) -->
              <div class="phone-status">
                <span class="status-time">14:30</span>
                <div class="status-icons">
                  <span class="status-signal"></span>
                  <span class="status-wifi"></span>
                  <span class="status-battery"></span>
                </div>
              </div>

              <!-- ÉCRAN 1 : App live (Phase 1) -->
              <div class="screen screen-live" data-screen-live>
                <div class="live-header">
                  <div class="live-club">
                    <img src="/logos/golf-du-soleil.svg" alt="Golf du Soleil" class="live-club-logo" width="20" height="20" loading="lazy" decoding="async" />
                    <div>
                      <div class="live-club-name">{t.phone.club}</div>
                      <div class="live-club-meta">{t.phone.live.playing}</div>
                    </div>
                  </div>
                  <div class="live-pill">LIVE</div>
                </div>

                <div class="live-current">
                  <div class="live-current-label">{t.phone.live.tracking}</div>
                  <div class="live-current-num" data-live-hole>{t.phone.live.currentHole}</div>
                  <div class="live-current-par">{t.phone.live.currentPar}</div>
                </div>

                <div class="live-stats">
                  <div class="live-stat">
                    <span class="live-stat-v" data-live-distance>3,2 km</span>
                    <span class="live-stat-l">Distance</span>
                  </div>
                  <div class="live-stat">
                    <span class="live-stat-v" data-live-time>1h47</span>
                    <span class="live-stat-l">Temps</span>
                  </div>
                  <div class="live-stat">
                    <span class="live-stat-v" data-live-score>+6</span>
                    <span class="live-stat-l">{t.phone.live.currentScore}</span>
                  </div>
                </div>

                <!-- Mini map live -->
                <div class="live-map">
                  <svg viewBox="0 0 200 100" preserveAspectRatio="none" width="100%" height="100%">
                    <rect width="200" height="100" fill="#E8F0E9" rx="4"/>
                    <!-- Tracé GPS partiel -->
                    <path
                      d="M 8 80 C 18 50, 32 40, 45 55 S 62 80, 78 65 S 105 35, 122 50"
                      stroke="#1B4332"
                      stroke-width="2"
                      fill="none"
                      stroke-linecap="round"
                    />
                    <!-- Suite en pointillé (à venir) -->
                    <path
                      d="M 122 50 S 148 75, 168 58 S 185 42, 192 48"
                      stroke="#1B4332"
                      stroke-width="2"
                      fill="none"
                      stroke-linecap="round"
                      stroke-dasharray="3 4"
                      opacity="0.35"
                    />
                    <!-- Joueur actuel (8e trou) -->
                    <circle cx="122" cy="50" r="4" fill="#D4A574" stroke="#1B4332" stroke-width="1.5">
                      <animate attributeName="r" values="4;6;4" dur="1.5s" repeatCount="indefinite"/>
                    </circle>
                    <circle cx="8" cy="80" r="3" fill="#1B4332"/>
                  </svg>
                  <span class="live-map-label">Trou 8 · 320 m du green</span>
                </div>

                <!-- Front 9 mini grid (en cours) -->
                <div class="live-grid">
                  <div class="live-grid-label">F9</div>
                  {front9.slice(0, 8).map((h, i) => (
                    <div class={`live-cell live-cell-${h.type}`}>{h.score}</div>
                  ))}
                  <div class="live-cell live-cell-current">·</div>
                </div>
              </div>

              <!-- ÉCRAN 2 : Carte récap finale brandée (Phase 2) -->
              <div class="screen screen-card" data-screen-card>
                <!-- Photo paysage -->
                <div class="card-photo">
                  <img src="/photos/golf-du-soleil.jpg" alt="" width="320" height="120" loading="lazy" decoding="async" />
                  <div class="card-photo-fade"></div>
                </div>

                <!-- Logo + club name overlay sur photo -->
                <div class="card-brand" data-card-brand>
                  <img src="/logos/golf-du-soleil.svg" alt="" class="card-brand-logo" data-club-logo width="60" height="60" loading="lazy" decoding="async" />
                  <div class="card-brand-meta">
                    <small>{t.phone.cardLabel}</small>
                    <strong>{t.phone.club}</strong>
                  </div>
                </div>

                <!-- Score + meta -->
                <div class="card-body">
                  <div class="card-divider">
                    <span class="card-divider-line"></span>
                    <span class="card-divider-label">SCORE · 18 TROUS</span>
                    <span class="card-divider-line"></span>
                  </div>

                  <div class="card-score-wrap">
                    <div class="card-score-num" data-score>{t.phone.score}</div>
                    <div class="card-score-meta">{t.phone.scoreOver} · {t.phone.par}</div>
                  </div>

                  <!-- Stats -->
                  <div class="card-stats">
                    <div class="card-stat" data-stat>
                      <div class="stat-v">{t.phone.stats.distance.v}</div>
                      <div class="stat-l">{t.phone.stats.distance.l}</div>
                    </div>
                    <div class="card-stat" data-stat>
                      <div class="stat-v">{t.phone.stats.steps.v}</div>
                      <div class="stat-l">{t.phone.stats.steps.l}</div>
                    </div>
                    <div class="card-stat" data-stat>
                      <div class="stat-v">{t.phone.stats.duration.v}</div>
                      <div class="stat-l">{t.phone.stats.duration.l}</div>
                    </div>
                  </div>

                  <!-- Grille trous -->
                  <div class="card-grid">
                    <div class="grid-row">
                      <div class="grid-label">F9</div>
                      {front9.map((h, i) => (
                        <div class={`grid-cell grid-cell-${h.type}`} data-hole={i + 1}>{h.score}</div>
                      ))}
                    </div>
                    <div class="grid-row">
                      <div class="grid-label">B9</div>
                      {back9.map((h, i) => (
                        <div class={`grid-cell grid-cell-${h.type}`} data-hole={i + 10}>{h.score}</div>
                      ))}
                    </div>
                    <!-- Balle qui joue les 18 trous (animée par initPhone) -->
                    <span class="grid-ball" data-grid-ball aria-hidden="true">
                      <svg viewBox="0 0 32 32">
                        <defs>
                          <radialGradient id="phoneBallBody" cx="32%" cy="28%" r="78%">
                            <stop offset="0%" stop-color="#FFFFFF"/>
                            <stop offset="55%" stop-color="#F2F0E8"/>
                            <stop offset="100%" stop-color="#A8A296"/>
                          </radialGradient>
                          <clipPath id="phoneBallClip">
                            <circle cx="16" cy="16" r="13.6"/>
                          </clipPath>
                        </defs>
                        <circle cx="16" cy="16" r="13.8" fill="url(#phoneBallBody)"/>
                        <g clip-path="url(#phoneBallClip)" fill="#000" opacity="0.13">
                          <circle cx="10" cy="9" r="0.7"/><circle cx="13.2" cy="9" r="0.7"/><circle cx="16.4" cy="9" r="0.7"/><circle cx="19.6" cy="9" r="0.7"/><circle cx="22.8" cy="9" r="0.7"/>
                          <circle cx="8.4" cy="11.8" r="0.7"/><circle cx="11.6" cy="11.8" r="0.7"/><circle cx="14.8" cy="11.8" r="0.7"/><circle cx="18" cy="11.8" r="0.7"/><circle cx="21.2" cy="11.8" r="0.7"/><circle cx="24.4" cy="11.8" r="0.7"/>
                          <circle cx="10" cy="14.6" r="0.7"/><circle cx="13.2" cy="14.6" r="0.7"/><circle cx="16.4" cy="14.6" r="0.7"/><circle cx="19.6" cy="14.6" r="0.7"/><circle cx="22.8" cy="14.6" r="0.7"/>
                          <circle cx="8.4" cy="17.4" r="0.7"/><circle cx="11.6" cy="17.4" r="0.7"/><circle cx="14.8" cy="17.4" r="0.7"/><circle cx="18" cy="17.4" r="0.7"/><circle cx="21.2" cy="17.4" r="0.7"/><circle cx="24.4" cy="17.4" r="0.7"/>
                          <circle cx="10" cy="20.2" r="0.7"/><circle cx="13.2" cy="20.2" r="0.7"/><circle cx="16.4" cy="20.2" r="0.7"/><circle cx="19.6" cy="20.2" r="0.7"/><circle cx="22.8" cy="20.2" r="0.7"/>
                        </g>
                        <ellipse cx="11.5" cy="9" rx="3.8" ry="2.4" fill="#FFFFFF" opacity="0.6"/>
                        <circle cx="16" cy="16" r="13.8" fill="none" stroke="#7A7468" stroke-width="0.5" opacity="0.45"/>
                      </svg>
                    </span>
                  </div>

                  <!-- Joueur + date -->
                  <div class="card-meta-row">
                    <div class="card-meta-cell">
                      <div class="meta-label">JOUEUR</div>
                      <div class="meta-value">{t.phone.playerName}</div>
                    </div>
                    <div class="card-meta-cell card-meta-right">
                      <div class="meta-label">DATE</div>
                      <div class="meta-value">{t.phone.date}</div>
                    </div>
                  </div>

                  <!-- Footer brand -->
                  <div class="card-footer-brand">
                    <span>FAIT À</span>
                    <strong>Scluba<span class="brand-dot">.</span></strong>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .phone-section {
    position: relative;
    background:
      radial-gradient(ellipse at 70% 30%, rgba(212, 165, 116, 0.06), transparent 50%),
      linear-gradient(180deg, var(--bg) 0%, var(--primary-bg) 30%, var(--primary-bg) 70%, var(--bg) 100%);
  }
  .phone-pin {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: var(--space-7) 0;
  }
  .phone-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-7);
    align-items: center;
  }
  @media (min-width: 1024px) {
    .phone-grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-8);
    }
  }

  /* Narrative */
  .phone-narrative { max-width: 480px; }
  .narrative-stack {
    position: relative;
    margin: var(--space-3) 0 var(--space-6);
    min-height: 220px;
  }
  .narrative-block {
    position: absolute;
    top: 0; left: 0; right: 0;
    will-change: opacity, transform;
  }
  .narrative-block[data-narrative-phase="2"] {
    opacity: 0;
    transform: translateY(20px);
  }
  .phase-tag {
    display: inline-block;
    padding: 4px 12px;
    border-radius: var(--radius-full);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: var(--space-3);
  }
  .phase-tag-79 {
    background: var(--primary);
    color: var(--bg);
  }
  .phase-tag-49 {
    background: var(--accent);
    color: var(--primary-deep);
  }
  .narrative-block .section-title { margin-bottom: var(--space-3); }

  /* Phase progress indicator */
  .phase-progress {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    color: var(--muted);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.16em;
  }
  .phase-step {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }
  .phase-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--line);
    transition: background 0.4s var(--ease-out);
  }
  .phase-step[data-phase-step="1"] .phase-dot { background: var(--primary); }
  .phase-line {
    flex: 1;
    height: 2px;
    background: var(--line);
    border-radius: var(--radius-full);
    overflow: hidden;
    max-width: 120px;
  }
  .phase-line-fill {
    height: 100%;
    width: 0;
    background: linear-gradient(90deg, var(--primary), var(--accent));
    transform-origin: left;
  }

  /* Phone stage */
  .phone-stage {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: var(--space-6) 0;
  }
  .phone-shadow {
    position: absolute;
    bottom: 8%;
    width: 50%;
    height: 50px;
    background: radial-gradient(ellipse, rgba(27, 67, 50, 0.45), transparent 70%);
    filter: blur(24px);
    z-index: 0;
  }

  /* iPhone Pro photoréaliste — face-on, hauteur calibrée pour tenir dans le viewport */
  .phone-device {
    position: relative;
    height: min(70vh, 620px);
    aspect-ratio: 9 / 19.5;
    width: auto;
    will-change: transform;
    z-index: 2;
  }

  /* === Panneau atmosphère golden hour : container snug autour du phone === */
  .phone-green {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: calc(min(70vh, 620px) * 9 / 19.5 + 70px);
    max-width: 92%;
    height: calc(min(70vh, 620px) + 70px);
    border-radius: 32px;
    overflow: hidden;
    box-shadow:
      0 24px 56px rgba(15, 42, 30, 0.18),
      0 8px 16px rgba(15, 42, 30, 0.10),
      inset 0 1px 0 rgba(255, 228, 181, 0.35);
    pointer-events: none;
    z-index: 1;
  }

  .phone-frame {
    position: relative;
    width: 100%;
    height: 100%;
    background:
      /* Reflet titanium */
      linear-gradient(135deg,
        #5a5a5d 0%,
        #2a2a2c 18%,
        #1a1a1c 40%,
        #2a2a2c 60%,
        #4a4a4d 78%,
        #2a2a2c 100%);
    border-radius: 56px;
    padding: 12px;
    box-shadow:
      /* Ombre verticale propre (phone face-on) */
      0 16px 32px rgba(27, 67, 50, 0.20),
      0 32px 64px rgba(27, 67, 50, 0.28),
      0 8px 16px rgba(0, 0, 0, 0.18),
      /* Reflet inner top */
      inset 0 1px 0 rgba(255, 255, 255, 0.18),
      inset 0 -1px 0 rgba(255, 255, 255, 0.04),
      /* Bord externe */
      0 0 0 1.5px rgba(0, 0, 0, 0.6);
  }

  /* Reflet brillant subtil */
  .phone-rim {
    position: absolute;
    inset: 4px;
    border-radius: 52px;
    pointer-events: none;
    background: linear-gradient(135deg,
      rgba(255, 255, 255, 0.16) 0%,
      transparent 30%,
      transparent 70%,
      rgba(255, 255, 255, 0.06) 100%);
    z-index: 3;
  }

  /* Boutons latéraux */
  .phone-btn {
    position: absolute;
    background: linear-gradient(180deg, #3a3a3c 0%, #1a1a1c 50%, #3a3a3c 100%);
    border-radius: 1.5px;
    box-shadow:
      inset 0 1px 0 rgba(255,255,255,0.15),
      inset 0 -1px 0 rgba(0,0,0,0.4);
  }
  .phone-btn-action {
    left: -2px;
    top: 90px;
    width: 4px;
    height: 28px;
  }
  .phone-btn-volup {
    left: -2px;
    top: 130px;
    width: 4px;
    height: 50px;
  }
  .phone-btn-voldown {
    left: -2px;
    top: 188px;
    width: 4px;
    height: 50px;
  }
  .phone-btn-side {
    right: -2px;
    top: 130px;
    width: 4px;
    height: 80px;
  }

  /* Écran */
  .phone-screen {
    position: relative;
    width: 100%;
    height: 100%;
    background: #000;
    border-radius: 44px;
    overflow: hidden;
    z-index: 2;
  }

  /* Dynamic Island — proportionnée à la largeur d'écran (≈ 30 %) */
  .phone-island {
    position: absolute;
    top: 10px;
    left: 50%;
    transform: translateX(-50%);
    width: 30%;
    max-width: 100px;
    min-width: 76px;
    height: 26px;
    background: #000;
    border-radius: 18px;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding-right: 7px;
  }
  .phone-island-camera {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: radial-gradient(circle at 30% 30%, #2a3a40, #050a0c);
    box-shadow: inset 0 0 0 1px rgba(255,255,255,0.1);
  }

  /* Status bar */
  .phone-status {
    position: absolute;
    top: 13px;
    left: 0;
    right: 0;
    z-index: 9;
    padding: 0 16px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: #fff;
    font-size: 11px;
    font-weight: 600;
    pointer-events: none;
  }
  .status-time { color: #fff; font-variant-numeric: tabular-nums; }
  .status-icons {
    display: flex;
    align-items: center;
    gap: 4px;
  }
  .status-signal {
    width: 13px; height: 8px;
    background:
      linear-gradient(to right,
        #fff 0 2.5px, transparent 2.5px 3.5px,
        #fff 3.5px 6px, transparent 6px 7px,
        #fff 7px 9.5px, transparent 9.5px 10.5px,
        #fff 10.5px 13px);
    -webkit-mask: linear-gradient(to top, #000 0 100%, transparent 100% 100%);
  }
  .status-wifi {
    width: 11px; height: 8px;
    background: #fff;
    -webkit-mask:
      radial-gradient(circle at 50% 100%, #000 35%, transparent 36%) center/100% 100% no-repeat;
    mask: radial-gradient(circle at 50% 100%, #000 35%, transparent 36%) center/100% 100% no-repeat;
  }
  .status-battery {
    width: 20px;
    height: 9px;
    border: 1px solid rgba(255,255,255,0.85);
    border-radius: 2.5px;
    position: relative;
    padding: 1px;
  }
  .status-battery::before {
    content: "";
    display: block;
    width: 80%;
    height: 100%;
    background: #fff;
    border-radius: 1px;
  }
  .status-battery::after {
    content: "";
    position: absolute;
    right: -3px;
    top: 3px;
    width: 2px;
    height: 5px;
    background: rgba(255,255,255,0.85);
    border-radius: 0 2px 2px 0;
  }

  /* Screen content */
  .screen {
    position: absolute;
    inset: 0;
    background: var(--bg);
    will-change: opacity, transform;
    overflow: hidden;
  }

  /* ===== ÉCRAN LIVE (Phase 1) ===== */
  .screen-live {
    padding-top: 56px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding-left: 14px;
    padding-right: 14px;
    padding-bottom: 14px;
  }

  .live-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 6px 0 8px;
    border-bottom: 1px solid var(--line);
  }
  .live-club {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .live-club-logo {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--primary-bg);
    object-fit: contain;
    padding: 2px;
    border: 1px solid var(--accent);
  }
  .live-club-name {
    font-family: var(--font-serif);
    font-size: 12px;
    font-weight: 700;
    color: var(--primary);
    line-height: 1.1;
  }
  .live-club-meta {
    font-size: 8px;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-top: 1px;
  }
  .live-pill {
    background: #C0392B;
    color: #fff;
    font-size: 8px;
    font-weight: 800;
    letter-spacing: 0.12em;
    padding: 3px 7px;
    border-radius: var(--radius-full);
    position: relative;
  }
  .live-pill::before {
    content: "";
