---
import { useT, type Locale } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useT(locale);
---

<section class="benefits" id="benefits">
  <div class="container">
    <div class="section-header" data-anim="section-header">
      <span class="section-eyebrow">{t.benefits.eyebrow}</span>
      <h2 class="section-title">{t.benefits.title}</h2>
      <p class="section-lead">{t.benefits.lead}</p>
    </div>

    <div class="benefit-grid">
      {t.benefits.items.map((item) => (
        <article class="benefit-card" data-anim="benefit-card">
          <span class="benefit-num">{item.num}</span>
          <h3 class="benefit-title">{item.title}</h3>
          <p class="benefit-body">{item.body}</p>
          <span class="benefit-rule" aria-hidden="true"></span>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .benefits {
    background:
      linear-gradient(180deg,
        var(--bg) 0%,
        rgba(212, 165, 116, 0.07) 50%,
        var(--bg) 100%);
    padding: clamp(80px, 12vh, 140px) 0;
    position: relative;
  }
  .section-header {
    text-align: center;
    max-width: 720px;
    margin: 0 auto var(--space-8);
  }
  .section-header .section-eyebrow,
  .section-header .section-title,
  .section-header .section-lead {
    margin-left: auto;
    margin-right: auto;
  }
  .section-header .section-lead {
    margin-top: var(--space-3);
  }

  .benefit-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }
  @media (min-width: 768px) {
    .benefit-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-5);
    }
  }

  .benefit-card {
    position: relative;
    padding: var(--space-7) var(--space-5) var(--space-5);
    text-align: left;
    transition: transform 0.4s var(--ease-out);
  }
  .benefit-card:hover {
    transform: translateY(-4px);
  }
  .benefit-card:hover .benefit-rule {
    width: 64px;
    opacity: 1;
  }

  .benefit-num {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(3rem, 6vw, 4.6rem);
    line-height: 1;
    color: var(--accent);
    letter-spacing: -0.05em;
    display: block;
    margin-bottom: var(--space-3);
  }
  .benefit-title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(1.4rem, 2.2vw, 1.75rem);
    line-height: 1.15;
    color: var(--primary);
    letter-spacing: -0.025em;
    margin: 0 0 var(--space-3);
  }
  .benefit-body {
    font-size: var(--text-base);
    line-height: 1.55;
    color: var(--ink);
    max-width: 38ch;
    margin: 0 0 var(--space-4);
  }
  .benefit-rule {
    display: block;
    width: 36px;
    height: 2px;
    background: var(--accent);
    opacity: 0.5;
    transition: width 0.4s var(--ease-out), opacity 0.3s var(--ease-out);
  }

  /* Dividers vertical entre cartes en desktop, subtils */
  @media (min-width: 768px) {
    .benefit-card + .benefit-card {
      border-left: 1px dashed rgba(27, 67, 50, 0.14);
      padding-left: var(--space-6);
    }
  }
</style>
