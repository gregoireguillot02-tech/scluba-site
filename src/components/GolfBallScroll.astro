---
// Balle de golf scroll-driven — apparaît après le hero, descend
// avec le scroll et atterrit près du QR de la CTA.
// Animée par initGolfBallScroll() dans src/scripts/animations.ts
---

<div class="ball-scroll" data-ball-scroll aria-hidden="true">
  <svg viewBox="0 0 32 32" width="28" height="28">
    <defs>
      <radialGradient id="ballScrollGrad" cx="35%" cy="30%" r="65%">
        <stop offset="0%" stop-color="#FFFFFF"/>
        <stop offset="60%" stop-color="#F5E6CF"/>
        <stop offset="100%" stop-color="#D4A574"/>
      </radialGradient>
    </defs>
    <circle cx="16" cy="16" r="14" fill="url(#ballScrollGrad)" stroke="#D4A574" stroke-width="0.8"/>
    <g fill="#D4A574" opacity="0.45">
      <circle cx="11" cy="12" r="1.2"/>
      <circle cx="20" cy="12" r="1.2"/>
      <circle cx="16" cy="17" r="1.2"/>
      <circle cx="11" cy="22" r="1.2"/>
      <circle cx="20" cy="22" r="1.2"/>
      <circle cx="14" cy="9" r="0.9"/>
      <circle cx="22" cy="17" r="0.9"/>
    </g>
  </svg>
</div>

<style>
  .ball-scroll {
    position: fixed;
    top: 120px;
    right: clamp(16px, 4vw, 64px);
    width: 28px;
    height: 28px;
    z-index: 90;
    opacity: 0;
    pointer-events: none;
    will-change: transform, opacity;
    filter: drop-shadow(2px 6px 10px rgba(27, 67, 50, 0.35));
  }
  .ball-scroll svg { width: 100%; height: 100%; display: block; }

  @media (max-width: 640px) {
    .ball-scroll {
      right: 12px;
      width: 22px;
      height: 22px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .ball-scroll { display: none; }
  }
</style>
