---
import type { Locale } from '../i18n';

interface Props {
  locale: Locale;
  animate?: boolean;
}

const { animate = true } = Astro.props;
---

<div class={`hero-phone-stage${animate ? '' : ' no-anim'}`} {...animate ? { 'data-anim': 'hero-phone' } : {}} aria-hidden="true">
  <div class="hero-phone-img">
    <div class="hero-phone-screen-mask">
      <img class="hero-phone-screen-img"
           src="/photos/phone-screen-start.png"
           alt=""
           width="982" height="1900"
           loading="eager" decoding="async" fetchpriority="high" />
    </div>
    <img class="hero-phone-frame-img"
         src="/photos/phone-frame.png"
         alt=""
         width="420" height="861"
         loading="eager" decoding="async" fetchpriority="high" />
  </div>
</div>

<style>
  .hero-phone-stage {
    position: relative;
    display: inline-block;
    line-height: 0;
    /* drop shadow appliquée ici, pas dans le PNG — cohérence avec le design system */
    filter:
      drop-shadow(0 18px 36px rgba(70, 50, 30, 0.28))
      drop-shadow(0 36px 80px rgba(70, 50, 30, 0.18));
    will-change: transform;
  }

  /* Animation scroll-driven d'entrée (optionnelle, désactivable via prop animate=false) */
  @media (prefers-reduced-motion: no-preference) {
    @supports (animation-timeline: view()) {
      .hero-phone-stage:not(.no-anim) {
        animation: heroPhoneRise linear both;
        animation-timeline: view();
        animation-range: entry 0% cover 30%;
      }
      @keyframes heroPhoneRise {
        from { transform: translateY(28px); }
        to   { transform: translateY(0); }
      }
    }
  }

  /* Container = frame image aspect ratio (420 × 861) */
  .hero-phone-img {
    position: relative;
    width: clamp(240px, 30vw, 320px);
    aspect-ratio: 420 / 861;
  }

  /* Screen mask : positionné légèrement en retrait du frame extérieur,
     coins arrondis pour matcher la dalle iPhone Pro. Le screenshot vit
     dedans et déborde latéralement (caché par overflow). */
  .hero-phone-screen-mask {
    position: absolute;
    inset: 1.6% 1.4%;
    border-radius: 11.5% / 5.6%;
    overflow: hidden;
    z-index: 1;
    background: #F4EEDD; /* fallback couleur app si l'image met du temps à charger */
  }

  /* Screenshot : on remplit la hauteur du masque, la largeur s'auto-déborde
     latéralement et est masquée par overflow. La status bar iOS du top est
     couverte par la dynamic island du frame qui passe au-dessus (z-index 2). */
  .hero-phone-screen-img {
    position: absolute;
    height: 100%;
    width: auto;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    display: block;
  }

  /* Frame iPhone par-dessus : transparente au centre, opaque sur les
     contours + dynamic island + boutons */
  .hero-phone-frame-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    pointer-events: none;
    z-index: 2;
    display: block;
  }

  /* HeroSplit-specific size override : un poil plus compact dans le hero */
  :global(.hero-split) .hero-phone-img {
    width: clamp(220px, 28vw, 300px);
  }
</style>
