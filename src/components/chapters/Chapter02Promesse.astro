---
/**
 * Chapitre II — La Promesse
 *
 * Refonte éditoriale des anciens PhoneShowcase + showcase i18n. Layout split
 * éditorial :
 *   - Gauche : titre + body Newsreader avec drop-cap "S" bois géant + 4
 *     palettes en mini-strip (Maritime/Forestier/Méditerranée/Heritage)
 *   - Droite : photo golfer-phone-app.jpg full-bleed crop (golfeur tenant son
 *     phone avec mockup d'app)
 *
 * Sur mobile : la photo passe en haut pleine largeur, le texte dessous.
 */
import { useT, type Locale } from '../../i18n';
import ChapterHeading from './ChapterHeading.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useT(locale);
---

<section id="chapter-2" class="chapter chapter-02">
  <div class="container chapter-02-grid">
    <div class="chapter-02-text" data-anim="ch2-text">
      <ChapterHeading
        numeral="II"
        eyebrow={t.showcase.eyebrow}
        title={t.showcase.title}
      />

      <p class="chapter-02-body">
        <span class="dropcap" aria-hidden="true">S</span>{t.showcase.lead}
      </p>

      <ul class="chapter-02-palettes" aria-label="Palettes de clubs">
        {t.showcase.palettes.map((p) => (
          <li class="palette-chip">
            <span class="palette-swatches" aria-hidden="true">
              <span class="palette-swatch" style={`background:${p.primary}`}></span>
              <span class="palette-swatch" style={`background:${p.accent}`}></span>
              <span class="palette-swatch" style={`background:${p.ground}`}></span>
            </span>
            <span class="palette-meta">
              <em class="palette-name">{p.name}</em>
              <span class="palette-tagline">{p.tagline}</span>
            </span>
          </li>
        ))}
      </ul>
    </div>

    <figure class="chapter-02-figure" data-anim="ch2-figure">
      <picture>
        <img
          src="/brand/golfer-phone-app.jpg"
          alt=""
          width="1904"
          height="544"
          loading="lazy"
          decoding="async"
          class="chapter-02-figure-img"
        />
      </picture>
      <figcaption class="chapter-02-figure-caption">
        <span class="chapter-02-figure-caption-rule" aria-hidden="true"></span>
        <em>{t.flow.phase3Lead}</em>
      </figcaption>
    </figure>
  </div>
</section>

<style>
  .chapter-02 {
    background: var(--paper);
    padding-top: var(--space-9);
    padding-bottom: var(--space-9);
    position: relative;
  }

  .chapter-02-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-7);
    align-items: start;
  }
  @media (min-width: 960px) {
    .chapter-02-grid {
      grid-template-columns: 1fr 1.05fr;
      gap: var(--space-8);
      align-items: center;
    }
  }

  .chapter-02-text {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    max-width: 56ch;
  }

  /* Body avec drop-cap "S" bois éditorial */
  .chapter-02-body {
    margin: 0;
    font-family: var(--font-body-serif);
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--wood-soft);
    /* Permet à la dropcap de flotter à gauche du premier paragraphe. */
    overflow: hidden;
  }
  .dropcap {
    float: left;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 800;
    font-size: 4.5em;
    line-height: 0.85;
    color: var(--wood);
    margin: 0.08em 0.12em 0 0;
    padding-right: 0.04em;
    font-variation-settings: 'opsz' 144, 'SOFT' 30, 'WONK' 1;
    /* Optical alignment pour que le S commence pile sur la baseline. */
    transform: translateY(0.06em);
  }

  /* Palettes — mini-strip 4 cards (Maritime, Forestier, ...) */
  .chapter-02-palettes {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-3);
  }
  @media (min-width: 480px) {
    .chapter-02-palettes {
      grid-template-columns: repeat(4, 1fr);
    }
  }
  .palette-chip {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-3);
    background: var(--paper-deep);
    border: 1px solid var(--rule-wood);
    border-radius: 2px;
  }
  .palette-swatches {
    display: flex;
    gap: 2px;
    height: 12px;
    border-radius: 2px;
    overflow: hidden;
  }
  .palette-swatch {
    flex: 1;
  }
  .palette-meta {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .palette-name {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--wood);
  }
  .palette-tagline {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--graphite);
  }

  /* Figure droite */
  .chapter-02-figure {
    margin: 0;
    padding: 0;
    background: var(--paper-warm);
    position: relative;
  }
  .chapter-02-figure picture {
    display: block;
    line-height: 0;
  }
  .chapter-02-figure-img {
    width: 100%;
    height: clamp(280px, 50vh, 480px);
    object-fit: cover;
    object-position: center 40%;
    display: block;
  }
  .chapter-02-figure-caption {
    display: flex;
    align-items: center;
    gap: 1em;
    padding: var(--space-3) var(--space-5);
    font-family: var(--font-body-serif);
    font-size: 0.85rem;
    color: var(--graphite);
    background: var(--paper);
    border-bottom: 1px solid var(--rule-wood);
  }
  .chapter-02-figure-caption-rule {
    display: inline-block;
    width: 24px;
    height: 1px;
    background: var(--brass);
    flex-shrink: 0;
  }
  .chapter-02-figure-caption em {
    font-style: italic;
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!prefersReduced) {
    gsap.registerPlugin(ScrollTrigger);

    const text = document.querySelector<HTMLElement>('[data-anim="ch2-text"]');
    const figure = document.querySelector<HTMLElement>('[data-anim="ch2-figure"]');

    if (text) {
      gsap.fromTo(
        text,
        { opacity: 0, y: 20 },
        {
          opacity: 1, y: 0, duration: 0.85, ease: 'power2.out',
          scrollTrigger: { trigger: text, start: 'top 82%' },
        }
      );
    }
    if (figure) {
      gsap.fromTo(
        figure,
        { opacity: 0, y: 30, scale: 0.98 },
        {
          opacity: 1, y: 0, scale: 1, duration: 1.0, ease: 'power3.out', delay: 0.12,
          scrollTrigger: { trigger: figure, start: 'top 85%' },
        }
      );
    }
  }
</script>
