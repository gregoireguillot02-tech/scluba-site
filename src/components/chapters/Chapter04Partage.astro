---
/**
 * Chapitre IV — Le Partage
 *
 * Refonte de ClubsShowcase + transposition magazine du "magic moment"
 * partage. Trois temps :
 *   1. ChapterHeading
 *   2. Photo grand format full-bleed (golf-du-soleil.jpg) + citation
 *      italic XL en overlay (style magazine spread)
 *   3. "Founding members" — bandeau brass listant les clubs partenaires
 *      avec leurs logos SVG
 *
 * Note : l'iOS Share Sheet GSAP scrub (250 lignes CSS + 80 JS) de
 * l'ancien Hero n'est pas réimporté dans cette PR. Reviendra en PR
 * follow-up si Grégoire le souhaite — c'est un asset unique de Scluba
 * qui mérite sa propre scène dédiée.
 */
import { useT, type Locale } from '../../i18n';
import ChapterHeading from './ChapterHeading.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useT(locale);

const foundingClubs = [
  { name: 'Golf du Soleil', logo: '/logos/golf-du-soleil.svg' },
  { name: 'Golf de Caen-la-Mer', logo: '/logos/golf-de-caen.svg' },
];

const testimonial = locale === 'fr'
  ? {
      quote: `Chaque carte partagée par un joueur, c'est notre club qui apparaît dans le feed de ses amis. C'est un canal de visibilité qu'on n'avait pas avant.`,
      cite: 'Direction commerciale, Golf du Soleil',
    }
  : {
      quote: `Every card shared by a player is our club appearing in their friends' feed. That's a visibility channel we never had before.`,
      cite: 'Sales Director, Golf du Soleil',
    };
---

<section id="chapter-4" class="chapter chapter-04">
  <div class="container chapter-04-heading">
    <ChapterHeading
      numeral="IV"
      eyebrow={locale === 'fr' ? 'Le partage' : 'The share'}
      title={locale === 'fr'
        ? 'Quand une carte sort du parcours, le club entre dans le feed.'
        : 'When a card leaves the course, the club enters the feed.'}
    />
  </div>

  <!-- Photo full-bleed + témoignage overlay -->
  <figure class="chapter-04-spread" data-anim="ch4-spread">
    <picture>
      <img
        src="/photos/golf-du-soleil.jpg"
        alt=""
        width="1920"
        height="1080"
        loading="lazy"
        decoding="async"
        class="chapter-04-spread-img"
      />
    </picture>
    <blockquote class="chapter-04-testimonial">
      <p class="testimonial-quote">{testimonial.quote}</p>
      <footer class="testimonial-cite">
        <span class="testimonial-cite-rule" aria-hidden="true"></span>
        <cite>{testimonial.cite}</cite>
      </footer>
    </blockquote>
  </figure>

  <!-- Founding members bandeau -->
  <div class="container chapter-04-founding">
    <p class="founding-eyebrow">
      <span class="founding-eyebrow-rule"></span>
      {locale === 'fr' ? 'Founding members — saison 2026' : 'Founding members — 2026 season'}
    </p>
    <ul class="founding-list">
      {foundingClubs.map((club) => (
        <li class="founding-club">
          <img src={club.logo} alt={club.name} width="56" height="56" class="founding-logo" />
          <span class="founding-name">{club.name}</span>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .chapter-04 {
    background: var(--paper);
    padding-top: var(--space-9);
    padding-bottom: var(--space-9);
  }

  .chapter-04-heading {
    margin-bottom: var(--space-8);
  }

  /* === Magazine spread : photo full-bleed + témoignage overlay ====== */
  .chapter-04-spread {
    margin: 0;
    padding: 0;
    position: relative;
    width: 100%;
    height: clamp(420px, 70vh, 720px);
    overflow: hidden;
    background: var(--wood);
  }
  .chapter-04-spread picture {
    position: absolute;
    inset: 0;
    line-height: 0;
  }
  .chapter-04-spread-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    filter: brightness(0.78) saturate(1.05);
  }
  /* Vignette dégradée pour la lisibilité du texte overlay */
  .chapter-04-spread::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(15, 14, 12, 0.45) 0%,
      rgba(15, 14, 12, 0.12) 55%,
      rgba(15, 14, 12, 0.55) 100%
    );
    pointer-events: none;
  }

  .chapter-04-testimonial {
    position: absolute;
    inset: 0;
    margin: 0;
    padding: clamp(var(--space-6), 6vw, var(--space-9));
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    z-index: 2;
    color: var(--paper);
    max-width: 64ch;
  }
  .testimonial-quote {
    margin: 0;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 600;
    font-size: clamp(1.5rem, 3.8vw, 2.5rem);
    line-height: 1.22;
    letter-spacing: -0.015em;
    color: var(--paper);
    text-wrap: balance;
    text-shadow: 0 2px 24px rgba(0, 0, 0, 0.35);
    font-variation-settings: 'opsz' 96, 'SOFT' 60, 'WONK' 1;
    /* Guillemets typographiques en marqueur visuel */
    quotes: '« ' ' »';
  }
  .testimonial-quote::before { content: open-quote; color: var(--brass); opacity: 0.85; }
  .testimonial-quote::after { content: close-quote; color: var(--brass); opacity: 0.85; }

  .testimonial-cite {
    display: flex;
    align-items: center;
    gap: 0.8em;
    margin-top: var(--space-4);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--brass);
  }
  .testimonial-cite cite {
    font-style: normal;
  }
  .testimonial-cite-rule {
    display: inline-block;
    width: 24px;
    height: 1px;
    background: var(--brass);
  }

  /* === Founding members ============================================ */
  .chapter-04-founding {
    margin-top: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }
  .founding-eyebrow {
    margin: 0;
    display: flex;
    align-items: center;
    gap: 0.8em;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--brass);
  }
  .founding-eyebrow-rule {
    display: inline-block;
    width: 24px;
    height: 1px;
    background: var(--brass);
  }
  .founding-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-6);
  }
  .founding-club {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }
  .founding-logo {
    width: 56px;
    height: 56px;
    object-fit: contain;
    filter: drop-shadow(0 2px 8px rgba(61, 41, 20, 0.18));
  }
  .founding-name {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 600;
    font-size: 1.125rem;
    color: var(--wood);
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  function initChapter04() {
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReduced) return;

    gsap.registerPlugin(ScrollTrigger);

    const spread = document.querySelector<HTMLElement>('[data-anim="ch4-spread"]');
    if (!spread) return;

    // Ken Burns subtil sur l'image (scale + parallax lent)
    const img = spread.querySelector<HTMLElement>('.chapter-04-spread-img');
    if (img) {
      gsap.fromTo(
        img,
        { scale: 1.0, y: 0 },
        {
          scale: 1.06,
          y: -20,
          ease: 'none',
          scrollTrigger: {
            trigger: spread,
            start: 'top bottom',
            end: 'bottom top',
            scrub: 0.8,
          },
        }
      );
    }

    // Fade-in du testimonial à l'entry
    const blockquote = spread.querySelector<HTMLElement>('.chapter-04-testimonial');
    if (blockquote) {
      gsap.fromTo(
        blockquote,
        { opacity: 0, y: 30 },
        {
          opacity: 1, y: 0, duration: 1.1, ease: 'power3.out',
          scrollTrigger: { trigger: spread, start: 'top 70%' },
        }
      );
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initChapter04);
  } else {
    initChapter04();
  }
</script>
