---
/**
 * Chapitre V — L'Offre
 *
 * Refonte éditoriale de Pricing. Plus de table 3-col SaaS. Plutôt :
 *   1. ChapterHeading avec titre tagline
 *   2. Paragraphe rédigé "L'offre fondatrice" en Newsreader (lead)
 *   3. Prix en monospace géant aligné sur baseline + period + engagement
 *   4. Liste features en <details> disclosure (n'alourdit pas la page)
 *   5. CTA brass-plate vers #cta
 *
 * Une seule offre = un seul price block, centré. Pas de comparaison
 * 3-tiers artificielle.
 */
import { useT, type Locale } from '../../i18n';
import ChapterHeading from './ChapterHeading.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useT(locale);
const plan = t.pricing.plans[0];
---

<section id="pricing" class="chapter chapter-05">
  <div class="container chapter-05-inner">
    <ChapterHeading
      numeral="V"
      eyebrow={t.pricing.eyebrow}
      title={t.pricing.title}
      subtitle={t.pricing.lead}
      align="center"
    />

    <article class="offer" data-anim="ch5-offer">
      <header class="offer-header">
        <p class="offer-launch-badge">{t.pricing.launchBadge}</p>
        <p class="offer-tagline">{plan.tagline}</p>
      </header>

      <div class="offer-price-row">
        <span class="offer-price">{plan.price}</span>
        <span class="offer-period">{plan.period}</span>
      </div>
      <p class="offer-engagement">{plan.engagement}</p>

      <details class="offer-details">
        <summary>
          <span>{locale === 'fr' ? 'Tout ce que ça comprend' : 'Everything included'}</span>
          <svg width="12" height="12" viewBox="0 0 12 12" aria-hidden="true">
            <path d="M3 4.5 6 7.5 9 4.5" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" />
          </svg>
        </summary>
        <ul class="offer-features">
          {plan.features.map((feature) => (
            <li>
              <svg width="14" height="14" viewBox="0 0 14 14" aria-hidden="true" class="offer-tick">
                <path d="M2.5 7.5 6 11 11.5 4" stroke="currentColor" stroke-width="1.8" fill="none" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              <span>{feature}</span>
            </li>
          ))}
        </ul>
      </details>

      <div class="offer-cta-row">
        <a href="#cta" class="btn-brass">
          <span>{t.cta.form.submit}</span>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14" />
            <path d="m12 5 7 7-7 7" />
          </svg>
        </a>
      </div>
    </article>
  </div>
</section>

<style>
  .chapter-05 {
    background: var(--paper-warm);
    padding-top: var(--space-9);
    padding-bottom: var(--space-9);
  }
  .chapter-05-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
    align-items: center;
  }

  .offer {
    background: var(--paper);
    border: 1px solid var(--rule-wood);
    border-radius: 2px;
    padding: clamp(var(--space-6), 5vw, var(--space-8));
    max-width: 620px;
    width: 100%;
    text-align: center;
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.6) inset,
      0 24px 56px rgba(61, 41, 20, 0.10),
      0 4px 12px rgba(61, 41, 20, 0.06);
    position: relative;
  }

  .offer-header {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    align-items: center;
  }
  .offer-launch-badge {
    margin: 0;
    display: inline-block;
    padding: 4px 12px;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ink-editorial);
    background: var(--brass);
    border: 1px solid var(--brass-deep);
    border-radius: 2px;
  }
  .offer-tagline {
    margin: 0;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 600;
    font-size: clamp(1.125rem, 2.4vw, 1.5rem);
    line-height: 1.3;
    color: var(--wood);
    max-width: 32ch;
    text-wrap: balance;
  }

  .offer-price-row {
    margin-top: var(--space-6);
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 0.2em;
  }
  .offer-price {
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: clamp(4rem, 10vw, 6.5rem);
    line-height: 1;
    color: var(--wood);
    font-variant-numeric: tabular-nums;
    letter-spacing: -0.02em;
  }
  .offer-period {
    font-family: var(--font-mono);
    font-size: 1rem;
    color: var(--graphite);
    letter-spacing: 0.04em;
  }
  .offer-engagement {
    margin: var(--space-2) 0 0 0;
    font-family: var(--font-body-serif);
    font-style: italic;
    font-size: 0.9rem;
    color: var(--graphite);
  }

  .offer-details {
    margin-top: var(--space-6);
    border-top: 1px solid var(--rule-wood);
    padding-top: var(--space-4);
    text-align: left;
  }
  .offer-details > summary {
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    cursor: pointer;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--brass);
    padding: var(--space-2) 0;
    transition: color var(--motion-fast) var(--ease-out);
  }
  .offer-details > summary::-webkit-details-marker { display: none; }
  .offer-details > summary:hover { color: var(--brass-deep); }
  .offer-details > summary svg {
    transition: transform var(--motion-fast) var(--ease-out);
  }
  .offer-details[open] > summary svg {
    transform: rotate(180deg);
  }

  .offer-features {
    list-style: none;
    margin: var(--space-4) 0 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .offer-features li {
    display: grid;
    grid-template-columns: 18px 1fr;
    gap: var(--space-3);
    align-items: baseline;
    font-family: var(--font-body-serif);
    font-size: 1rem;
    line-height: 1.55;
    color: var(--wood-soft);
  }
  .offer-tick {
    color: var(--sage-deep);
    transform: translateY(2px);
  }

  .offer-cta-row {
    margin-top: var(--space-7);
    display: flex;
    justify-content: center;
  }
</style>
