---
/**
 * Q&A — refonte FAQ en 2-col éditorial.
 *
 * Plus d'accordion. Question en italic Fraunces, réponse en Newsreader.
 * 2 colonnes sur desktop, single column sur mobile. Plus court à lire,
 * plus magazine, plus scannable.
 */
import { useT, type Locale } from '../../i18n';
import ChapterHeading from './ChapterHeading.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useT(locale);
---

<section id="faq" class="qanda">
  <div class="container qanda-inner">
    <ChapterHeading
      numeral="VI"
      eyebrow={t.faq.eyebrow}
      title={t.faq.title}
    />

    <div class="qanda-grid">
      {t.faq.items.map((item) => (
        <article class="qanda-item">
          <h3 class="qanda-question">{item.q}</h3>
          <p class="qanda-answer">{item.a}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .qanda {
    background: var(--paper);
    padding-top: var(--space-9);
    padding-bottom: var(--space-9);
  }
  .qanda-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .qanda-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-7);
  }
  @media (min-width: 820px) {
    .qanda-grid {
      grid-template-columns: 1fr 1fr;
      column-gap: var(--space-8);
    }
  }

  .qanda-item {
    border-top: 1px solid var(--rule-wood);
    padding-top: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .qanda-question {
    margin: 0;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 600;
    font-size: 1.25rem;
    line-height: 1.3;
    color: var(--wood);
    letter-spacing: -0.01em;
    text-wrap: balance;
    font-variation-settings: 'opsz' 96, 'SOFT' 50, 'WONK' 0;
  }
  .qanda-answer {
    margin: 0;
    font-family: var(--font-body-serif);
    font-size: 1rem;
    line-height: 1.6;
    color: var(--wood-soft);
  }
</style>
