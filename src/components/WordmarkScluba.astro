---
/**
 * WordmarkScluba — V4 "Tech Bold" (2026-05-19).
 *
 * Sentence case "Scluba" en Geist 900 — convention Vercel / Linear pour
 * les wordmarks tech premium SaaS (vs SCLUBA caps qui faisait industrial).
 * Tracking serré (-0.05em) pour lit "marque tech" et non "magazine".
 *
 * La police Geist est chargée dans Base.astro (Google Fonts, weights
 * 400-900, ~25kb gzipped pour la stack landing).
 *
 * Props:
 *   size      → hauteur cible en px (Nav: 28, Footer: 48)
 *   tone      → 'wood' (cream sur dark, override par body[data-landing-mode]
 *               qui s'occupe de la couleur contextuelle) | 'inverted'.
 *               API conservée pour compat Nav/Footer existants.
 *   withBall  → afficher la balle de golf après "Scluba" (default false, Footer)
 */

interface Props {
  size?: number;
  tone?: 'wood' | 'inverted';
  withBall?: boolean;
  class?: string;
}

const {
  size = 28,
  tone = 'wood',
  withBall = false,
  class: className = '',
} = Astro.props;

// Geist a une hauteur visuelle plus contenue que BSD → ratio plus proche de 1
const fontSize = Math.round(size * 1.0);
const ballSize = Math.round(size * 0.36);
const uid = Math.random().toString(36).slice(2, 8);
---

<span
  class:list={['wordmark-scluba', `tone-${tone}`, className]}
  style={`font-size:${fontSize}px;`}
  aria-label="Scluba"
>
  <span class="ws-text">Scluba</span>

  {withBall && (
    <span class="ws-ball" style={`width:${ballSize}px;height:${ballSize}px;`} aria-hidden="true">
      <svg viewBox="0 0 32 32">
        <defs>
          <radialGradient id={`wsBall-${uid}`} cx="32%" cy="28%" r="78%">
            <stop offset="0%"   stop-color="#FFFFFF" />
            <stop offset="55%"  stop-color="#E8E8E8" />
            <stop offset="100%" stop-color="#909090" />
          </radialGradient>
        </defs>
        <circle cx="16" cy="16" r="13.8" fill={`url(#wsBall-${uid})`} />
        <g fill="#000" opacity="0.13">
          <circle cx="11" cy="10" r="0.8" /><circle cx="16" cy="10" r="0.8" /><circle cx="21" cy="10" r="0.8" />
          <circle cx="11" cy="16" r="0.8" /><circle cx="16" cy="16" r="0.8" /><circle cx="21" cy="16" r="0.8" />
          <circle cx="11" cy="22" r="0.8" /><circle cx="16" cy="22" r="0.8" /><circle cx="21" cy="22" r="0.8" />
        </g>
        <ellipse cx="11.5" cy="9" rx="3.6" ry="2.2" fill="#FFFFFF" opacity="0.6" />
      </svg>
    </span>
  )}
</span>

<style>
  .wordmark-scluba {
    display: inline-flex;
    align-items: baseline;
    line-height: 1;
  }
  .ws-text {
    font-family: 'Geist', system-ui, -apple-system, sans-serif;
    font-weight: 900;
    letter-spacing: -0.05em;
    line-height: 1;
  }
  /* tone-wood / tone-inverted : couleurs par défaut en contexte light
     (pages non-landing). En landing dark, body[data-landing-mode="dark"]
     dans global.css override les deux en --cream. */
  .tone-wood .ws-text {
    color: #2D1B0E;
  }
  .tone-inverted .ws-text {
    color: #F5F5F5;
  }
  .ws-ball {
    display: inline-block;
    margin-left: 0.08em;
    align-self: center;
    flex-shrink: 0;
  }
  .ws-ball svg { width: 100%; height: 100%; display: block; }
</style>
