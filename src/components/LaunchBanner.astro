---
import { useT, type Locale } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useT(locale);
---

<div class="launch-banner" role="region" aria-label="Launch offer">
  <div class="container launch-inner">
    <span class="launch-pulse" aria-hidden="true"></span>
    <span class="launch-tag">{t.launch.tag}</span>
    <span class="launch-text">{t.launch.text}</span>
    <a href="#cta" class="launch-cta">
      {t.launch.cta}
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
      </svg>
    </a>
  </div>
</div>

<style>
  .launch-banner {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 110;
    background: linear-gradient(90deg, var(--primary-deep) 0%, var(--primary) 50%, var(--primary-soft) 100%);
    color: var(--bg);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }
  .launch-inner {
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
    font-size: 13px;
    flex-wrap: wrap;
    text-align: center;
  }
  .launch-pulse {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 0 0 var(--accent);
    animation: pulse 2s ease-in-out infinite;
    flex-shrink: 0;
  }
  @keyframes pulse {
    0% { box-shadow: 0 0 0 0 rgba(212, 165, 116, 0.6); }
    70% { box-shadow: 0 0 0 8px rgba(212, 165, 116, 0); }
    100% { box-shadow: 0 0 0 0 rgba(212, 165, 116, 0); }
  }
  .launch-tag {
    color: var(--accent);
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-size: 11px;
  }
  .launch-text {
    color: rgba(255, 255, 255, 0.92);
  }
  .launch-cta {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    color: var(--accent);
    font-weight: 700;
    border-bottom: 1px solid transparent;
    transition: border-color 0.2s var(--ease-out);
  }
  .launch-cta:hover { border-color: var(--accent); }

  @media (max-width: 640px) {
    .launch-inner {
      font-size: 11.5px;
      gap: var(--space-2);
      padding: 0 12px;
    }
    .launch-tag { font-size: 10px; }
  }
</style>
