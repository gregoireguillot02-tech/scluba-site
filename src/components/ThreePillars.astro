---
import { useT, type Locale } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useT(locale);
---

<section class="pillars" id="product">
  <div class="container">
    <div class="section-header" data-anim="section-header">
      <span class="section-eyebrow">{t.pillars.eyebrow}</span>
      <h2 class="section-title">{t.pillars.title}</h2>
      <p class="section-lead">{t.pillars.lead}</p>
    </div>

    <div class="pillar-layout">
      <div class="pillar-grid">
        {t.pillars.items.map((item) => (
          <article class="pillar-card depth-card" data-anim="pillar-card">
            <span class="pillar-num">{item.num}</span>
            <h3 class="pillar-title">{item.title}</h3>
            <p class="pillar-body">{item.body}</p>
            <div class="pillar-icon" aria-hidden="true">
              {item.num === '01' && (
                <svg viewBox="0 0 80 80" fill="none">
                  <rect x="14" y="14" width="52" height="52" rx="6" stroke="currentColor" stroke-width="1.5" />
                  <rect x="22" y="22" width="36" height="10" rx="2" fill="currentColor" opacity="0.18" />
                  <line x1="22" y1="40" x2="58" y2="40" stroke="currentColor" stroke-width="1.2" opacity="0.4" />
                  <line x1="22" y1="46" x2="58" y2="46" stroke="currentColor" stroke-width="1.2" opacity="0.4" />
                  <line x1="22" y1="52" x2="46" y2="52" stroke="currentColor" stroke-width="1.2" opacity="0.4" />
                  <circle cx="58" cy="58" r="3" fill="currentColor" />
                </svg>
              )}
              {item.num === '02' && (
                <svg viewBox="0 0 80 80" fill="none">
                  <rect x="22" y="14" width="36" height="52" rx="4" stroke="currentColor" stroke-width="1.5" />
                  <rect x="26" y="20" width="28" height="40" fill="currentColor" opacity="0.08" />
                  <rect x="28" y="24" width="18" height="3" fill="currentColor" />
                  <rect x="28" y="30" width="14" height="3" fill="currentColor" opacity="0.7" />
                  <rect x="28" y="36" width="20" height="3" fill="currentColor" opacity="0.5" />
                  <rect x="28" y="42" width="12" height="3" fill="currentColor" opacity="0.35" />
                  <path d="M48 50 L52 54 L56 46" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none" />
                </svg>
              )}
              {item.num === '03' && (
                <svg viewBox="0 0 80 80" fill="none">
                  <rect x="14" y="14" width="52" height="52" rx="6" stroke="currentColor" stroke-width="1.5" />
                  <rect x="22" y="22" width="12" height="12" stroke="currentColor" stroke-width="1.2" />
                  <rect x="25" y="25" width="6" height="6" fill="currentColor" />
                  <rect x="46" y="22" width="12" height="12" stroke="currentColor" stroke-width="1.2" />
                  <rect x="49" y="25" width="6" height="6" fill="currentColor" />
                  <rect x="22" y="46" width="12" height="12" stroke="currentColor" stroke-width="1.2" />
                  <rect x="25" y="49" width="6" height="6" fill="currentColor" />
                  <rect x="40" y="40" width="4" height="4" fill="currentColor" />
                  <rect x="48" y="40" width="4" height="4" fill="currentColor" />
                  <rect x="56" y="40" width="4" height="4" fill="currentColor" />
                  <rect x="40" y="48" width="4" height="4" fill="currentColor" />
                  <rect x="48" y="48" width="4" height="4" fill="currentColor" />
                  <rect x="40" y="56" width="4" height="4" fill="currentColor" />
                  <rect x="56" y="56" width="4" height="4" fill="currentColor" />
                </svg>
              )}
            </div>
          </article>
        ))}
      </div>

      <aside class="founders-quote" aria-label="Mot des fondateurs">
        <svg class="founders-mark" width="32" height="24" viewBox="0 0 32 24" fill="none" aria-hidden="true">
          <path d="M0 24V14C0 6.27 4.85 0.85 12 0V4C7.6 4.62 4.85 7.27 4.85 12H12V24H0ZM20 24V14C20 6.27 24.85 0.85 32 0V4C27.6 4.62 24.85 7.27 24.85 12H32V24H20Z" fill="currentColor"/>
        </svg>
        <blockquote class="founders-quote-text">{t.pillars.founders_quote.text}</blockquote>
        <footer class="founders-quote-attrib">
          <strong>{t.pillars.founders_quote.authors}</strong>
          <span>{t.pillars.founders_quote.role}</span>
        </footer>
      </aside>
    </div>
  </div>
</section>

<style>
  .pillars {
    background: var(--bg);
  }
  .section-header {
    text-align: center;
    max-width: 720px;
    margin: 0 auto var(--space-8);
  }
  .section-header .section-eyebrow,
  .section-header .section-title,
  .section-header .section-lead {
    margin-left: auto;
    margin-right: auto;
  }
  .section-header .section-lead {
    margin-top: var(--space-3);
  }

  .pillar-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    align-items: center;
  }
  @media (min-width: 1024px) {
    .pillar-layout {
      grid-template-columns: minmax(0, 1fr) 260px;
      gap: var(--space-7);
    }
  }

  .pillar-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
  }
  @media (min-width: 768px) {
    .pillar-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-5);
    }
  }

  .founders-quote {
    padding: var(--space-5);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(8px) saturate(115%);
    -webkit-backdrop-filter: blur(8px) saturate(115%);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    max-width: 420px;
    margin: 0 auto;
  }
  @media (min-width: 1024px) {
    .founders-quote {
      max-width: none;
      margin: 0;
    }
  }
  .founders-mark { color: var(--accent); opacity: 0.85; }
  .founders-quote-text {
    margin: 0;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--text-md);
    line-height: 1.4;
    color: var(--primary);
    letter-spacing: -0.01em;
  }
  .founders-quote-attrib {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding-top: var(--space-3);
    border-top: 1px dashed var(--line);
  }
  .founders-quote-attrib strong {
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: var(--text-sm);
    color: var(--primary);
  }
  .founders-quote-attrib span {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .pillar-card {
    position: relative;
    background: var(--paper, var(--bg));
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    padding: var(--space-7) var(--space-5) var(--space-5);
    transition: transform 0.4s var(--ease-out), box-shadow 0.4s var(--ease-out), border-color 0.4s var(--ease-out);
    overflow: hidden;
  }
  .pillar-card::before {
    content: "";
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--grass-bright, var(--primary)), var(--accent));
    opacity: 0;
    transition: opacity 0.3s var(--ease-out);
  }
  .pillar-card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-lg);
    border-color: var(--accent);
  }
  .pillar-card:hover::before { opacity: 1; }

  .pillar-num {
    font-family: var(--font-display);
    font-size: clamp(3.5rem, 7vw, 5.5rem);
    font-weight: 900;
    color: var(--accent);
    line-height: 0.85;
    letter-spacing: -0.045em;
    display: block;
    margin-bottom: var(--space-3);
  }
  .pillar-title {
    font-size: var(--text-xl);
    margin: var(--space-3) 0 var(--space-3);
    color: var(--primary);
    letter-spacing: -0.025em;
  }
  .pillar-body {
    font-size: var(--text-base);
    color: var(--muted);
    line-height: 1.5;
    max-width: 32ch;
  }
  .pillar-icon {
    position: absolute;
    right: var(--space-4);
    top: var(--space-4);
    width: 64px;
    height: 64px;
    color: var(--primary);
    opacity: 0.30;
    transition: opacity 0.4s var(--ease-out);
  }
  .pillar-card:hover .pillar-icon { opacity: 0.85; }
</style>
