---
import { useT, type Locale } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useT(locale);
---

<section id="problem" class="problem">
  <div class="problem-wrap" data-anim="problem">
    <div class="container problem-inner">
      <span class="eyebrow-mono problem-eyebrow">{t.problem.eyebrow}</span>

      <div class="problem-stack">
        {t.problem.lines.map((line, i) => (
          <p class={`problem-line ${i === t.problem.lines.length - 1 ? 'is-last' : ''}`} data-line>{line}</p>
        ))}
      </div>

      <p class="problem-punch" data-punch>
        <span class="problem-punch-rule" aria-hidden="true"></span>
        {t.problem.punchline}
      </p>
    </div>
  </div>
</section>

<style>
  .problem {
    padding: 0;
  }
  .problem-wrap {
    min-height: 110vh; /* Plus d'air pour que la balle voyage haut → bas dans la section */
    display: flex;
    align-items: center;
    padding: var(--space-9) 0;
    /* Gradient atmosphérique repris des tokens dark — laisse passer la balle 3D derrière */
    background:
      radial-gradient(ellipse 80% 50% at 50% 50%, rgba(212, 165, 116, 0.06), transparent 60%);
  }
  .problem-inner {
    text-align: center;
    position: relative;
    z-index: 2;
  }

  /* Eyebrow : utility .eyebrow-mono (déjà stylée global) + spacing */
  .problem-eyebrow {
    display: inline-block;
    margin-bottom: var(--space-9);
  }

  /* Stack des lignes — typo XXL Fraunces italic, tracking serré (pattern donmolinico) */
  .problem-stack {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    margin-bottom: var(--space-9);
  }
  .problem-line {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 5.5vw, 4rem);
    line-height: 1.05;
    letter-spacing: -0.045em;
    color: var(--cream-soft);
    max-width: 22ch;
    margin: 0 auto;
    font-weight: 700;
    font-style: italic;
    font-variation-settings: 'opsz' 144, 'SOFT' 60;
  }
  /* Dernière ligne = la chute du poème : honey accent + plus de poids */
  .problem-line.is-last {
    color: var(--accent);
    font-weight: 900;
    font-style: normal;
    font-variation-settings: 'opsz' 144, 'SOFT' 40;
  }

  /* Punchline avec rule décorative au-dessus (pattern jeskojets) */
  .problem-punch {
    font-size: var(--text-md);
    color: var(--muted);
    font-style: italic;
    max-width: 48ch;
    margin: 0 auto;
    line-height: 1.55;
    position: relative;
  }
  .problem-punch-rule {
    display: block;
    width: 48px;
    height: 1px;
    background: var(--accent);
    opacity: 0.55;
    margin: 0 auto var(--space-5);
  }
</style>
