---
import { useT, type Locale } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useT(locale);
---

<section class="faq">
  <div class="container">
    <div class="faq-grid">
      <aside class="faq-side" data-anim="section-header">
        <span class="section-eyebrow">{t.faq.eyebrow}</span>
        <h2 class="section-title">{t.faq.title}</h2>
        {t.faq.lead && <p class="section-lead faq-side-lead">{t.faq.lead}</p>}

        <div class="faq-support">
          <span class="faq-support-eyebrow eyebrow-mono">{t.faq.support_eyebrow}</span>
          <a class="faq-support-email" href={`mailto:${t.faq.support_email}`}>
            {t.faq.support_email}
          </a>
          <span class="faq-support-note">{t.faq.support_note}</span>
        </div>
      </aside>

      <div class="faq-list">
        {t.faq.items.map((item) => (
          <details class="faq-item depth-inset" data-anim="faq-item">
            <summary>
              <span class="faq-q">{item.q}</span>
              <span class="faq-icon" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                  <path d="M12 5v14"/>
                  <path d="M5 12h14"/>
                </svg>
              </span>
            </summary>
            <div class="faq-answer">
              <p>{item.a}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .faq {
    background: var(--bg);
  }

  /* Layout 2-col desktop : sidebar gauche (header + contact) + items à droite.
     Sur mobile (≤900px), 1-col (sidebar dessus, items dessous). */
  .faq-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-7);
    align-items: start;
  }
  @media (min-width: 900px) {
    .faq-grid {
      grid-template-columns: 320px 1fr;
      gap: var(--space-8);
    }
  }

  .faq-side {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  @media (min-width: 900px) {
    .faq-side {
      position: sticky;
      top: 96px;
    }
  }
  .faq-side .section-title {
    margin: 0;
  }
  .faq-side-lead {
    color: var(--muted);
    line-height: 1.55;
  }

  /* Mini-bloc contact direct en bas de la sidebar. */
  .faq-support {
    margin-top: var(--space-4);
    padding: var(--space-5);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    background: rgba(255, 255, 255, 0.55);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .faq-support-eyebrow {
    color: var(--accent);
  }
  .faq-support-email {
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: var(--text-md);
    color: var(--primary);
    text-decoration: none;
    transition: color 0.2s var(--ease-out);
  }
  .faq-support-email:hover {
    color: var(--accent);
  }
  .faq-support-note {
    font-size: var(--text-sm);
    color: var(--muted);
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    max-width: 760px;
  }

  .faq-item {
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    background: var(--paper, var(--bg));
    transition: border-color 0.3s var(--ease-out), box-shadow 0.3s var(--ease-out), background 0.3s var(--ease-out);
    overflow: hidden;
  }
  .faq-item:hover {
    border-color: var(--accent);
  }
  .faq-item[open] {
    border-color: var(--accent);
    background: var(--paper-deep, var(--bg));
    box-shadow: var(--shadow-md);
  }

  .faq-item summary {
    list-style: none;
    cursor: pointer;
    padding: var(--space-5) var(--space-5);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-4);
    user-select: none;
  }
  .faq-item summary::-webkit-details-marker { display: none; }

  .faq-q {
    font-family: var(--font-serif);
    font-size: var(--text-md);
    font-weight: 700;
    color: var(--primary);
    line-height: 1.3;
  }
  .faq-icon {
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--primary-bg);
    color: var(--primary);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.3s var(--ease-out), background 0.3s var(--ease-out);
  }
  .faq-item[open] .faq-icon {
    transform: rotate(45deg);
    background: var(--accent);
    color: var(--primary);
  }

  .faq-answer {
    overflow: hidden;
    padding: 0 var(--space-5);
  }
  .faq-answer p {
    padding-bottom: var(--space-5);
    color: var(--ink);
    font-size: var(--text-base);
    line-height: 1.6;
    max-width: 60ch;
  }
</style>
