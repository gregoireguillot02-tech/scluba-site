---
/**
 * Variant B — Editorial Solid
 *
 * Fraunces 900 italic en couleur unie warm-charcoal (pas de gradient,
 * pas de texture wood). Tracking serré -0.045em, opsz max + SOFT 100
 * pour un rendu sculpté mais lisse. Le wood reste suggéré par le ton
 * espresso (#2D1B0E) mais l'effet "matière" est évacué au profit d'une
 * lisibilité éditoriale stricte façon jeskojets / donmolinico.
 *
 * Léger, scalable, contraste AAA garanti.
 */

interface Props {
  size?: number;
  tone?: 'wood' | 'inverted';
  withBall?: boolean;
  class?: string;
}

const {
  size = 28,
  tone = 'wood',
  withBall = false,
  class: className = '',
} = Astro.props;

const fontSize = Math.round(size * 1.08);
const ballSize = Math.round(size * 0.34);
const uid = Math.random().toString(36).slice(2, 8);
---

<span
  class:list={['ws-editorial', `tone-${tone}`, className]}
  style={`font-size:${fontSize}px;`}
  aria-label="Scluba"
>
  <span class="ws-text">Scluba</span>

  {withBall && (
    <span class="ws-ball" style={`width:${ballSize}px;height:${ballSize}px;`} aria-hidden="true">
      <svg viewBox="0 0 32 32">
        <defs>
          <radialGradient id={`ed-ball-${uid}`} cx="32%" cy="28%" r="78%">
            <stop offset="0%"   stop-color="#FFFFFF" />
            <stop offset="55%"  stop-color="#F2F0E8" />
            <stop offset="100%" stop-color="#A8A296" />
          </radialGradient>
        </defs>
        <circle cx="16" cy="16" r="13.8" fill={`url(#ed-ball-${uid})`} />
        <g fill="#000" opacity="0.13">
          <circle cx="11" cy="10" r="0.8" /><circle cx="16" cy="10" r="0.8" /><circle cx="21" cy="10" r="0.8" />
          <circle cx="11" cy="16" r="0.8" /><circle cx="16" cy="16" r="0.8" /><circle cx="21" cy="16" r="0.8" />
          <circle cx="11" cy="22" r="0.8" /><circle cx="16" cy="22" r="0.8" /><circle cx="21" cy="22" r="0.8" />
        </g>
        <ellipse cx="11.5" cy="9" rx="3.6" ry="2.2" fill="#FFFFFF" opacity="0.6" />
      </svg>
    </span>
  )}
</span>

<style>
  .ws-editorial {
    display: inline-flex;
    align-items: baseline;
    line-height: 0.95;
  }
  .ws-text {
    font-family: 'Fraunces', Georgia, 'Times New Roman', serif;
    font-weight: 900;
    font-style: italic;
    font-variation-settings: 'opsz' 144, 'SOFT' 100, 'WONK' 0;
    letter-spacing: -0.045em;
    line-height: 0.9;
  }
  .tone-wood .ws-text {
    color: #2D1B0E; /* espresso warm — pas pur noir, pas pur bois */
  }
  .tone-inverted .ws-text {
    color: #F4EEDD; /* cream */
  }
  .ws-ball {
    display: inline-block;
    margin-left: 0.06em;
    align-self: baseline;
    flex-shrink: 0;
  }
  .ws-ball svg { width: 100%; height: 100%; display: block; }
</style>
