---
/**
 * Variant A — Wood Sculpted
 *
 * Vrai SVG inline avec texture grain bois via filter SVG (feTurbulence +
 * feDisplacementMap). Garde l'ADN bois Midjourney mais rend une matière
 * réelle (le contour des lettres est déformé par le bruit, comme une
 * sculpture sur bois).
 *
 * Upgrade vs WordmarkScluba actuel (Fraunces italic + CSS background-clip) :
 * le rendu n'est plus seulement coloré comme du bois — il EST sculpté.
 */

interface Props {
  size?: number;
  tone?: 'wood' | 'inverted';
  withBall?: boolean;
  class?: string;
}

const {
  size = 28,
  tone = 'wood',
  withBall = false,
  class: className = '',
} = Astro.props;

const ballSize = Math.round(size * 0.36);
const uid = Math.random().toString(36).slice(2, 8);

// Palette par tone
const stops = tone === 'wood'
  ? ['#3D2914', '#6B4F33', '#2A1A0A', '#5C4435', '#1F1409', '#4D3520']
  : ['#F4EEDD', '#E8C089', '#FAF5E8', '#D4A574', '#F4EEDD', '#E8C089'];
---

<span class:list={['ws-sculpted', `tone-${tone}`, className]} aria-label="Scluba">
  <svg
    viewBox="0 0 320 90"
    preserveAspectRatio="xMinYMid meet"
    role="img"
    aria-hidden="true"
    style={`height:${Math.round(size * 1.15)}px;`}
  >
    <defs>
      <!-- Texture grain bois : turbulence haute fréquence horizontale + displacement subtle -->
      <filter id={`grain-${uid}`} x="-5%" y="-10%" width="110%" height="120%">
        <feTurbulence
          type="fractalNoise"
          baseFrequency="0.022 0.08"
          numOctaves="3"
          seed="11"
          result="noise"
        />
        <feDisplacementMap
          in="SourceGraphic"
          in2="noise"
          scale="2.4"
          xChannelSelector="R"
          yChannelSelector="G"
        />
      </filter>

      <linearGradient id={`fill-${uid}`} x1="0%" y1="0%" x2="100%" y2="80%">
        <stop offset="0%"   stop-color={stops[0]} />
        <stop offset="22%"  stop-color={stops[1]} />
        <stop offset="45%"  stop-color={stops[2]} />
        <stop offset="65%"  stop-color={stops[3]} />
        <stop offset="85%"  stop-color={stops[4]} />
        <stop offset="100%" stop-color={stops[5]} />
      </linearGradient>
    </defs>

    <text
      x="0"
      y="70"
      font-family="Fraunces, Georgia, serif"
      font-weight="900"
      font-style="italic"
      font-size="80"
      letter-spacing="-2"
      fill={`url(#fill-${uid})`}
      filter={`url(#grain-${uid})`}
      style="font-variation-settings: 'opsz' 144, 'SOFT' 80;"
    >Scluba</text>
  </svg>

  {withBall && (
    <span class="ws-ball" style={`width:${ballSize}px;height:${ballSize}px;`} aria-hidden="true">
      <svg viewBox="0 0 32 32">
        <defs>
          <radialGradient id={`ball-${uid}`} cx="32%" cy="28%" r="78%">
            <stop offset="0%"   stop-color="#FFFFFF" />
            <stop offset="55%"  stop-color="#F2F0E8" />
            <stop offset="100%" stop-color="#A8A296" />
          </radialGradient>
        </defs>
        <circle cx="16" cy="16" r="13.8" fill={`url(#ball-${uid})`} />
        <g fill="#000" opacity="0.13">
          <circle cx="11" cy="10" r="0.8" /><circle cx="16" cy="10" r="0.8" /><circle cx="21" cy="10" r="0.8" />
          <circle cx="11" cy="16" r="0.8" /><circle cx="16" cy="16" r="0.8" /><circle cx="21" cy="16" r="0.8" />
          <circle cx="11" cy="22" r="0.8" /><circle cx="16" cy="22" r="0.8" /><circle cx="21" cy="22" r="0.8" />
        </g>
        <ellipse cx="11.5" cy="9" rx="3.6" ry="2.2" fill="#FFFFFF" opacity="0.6" />
        <circle cx="16" cy="16" r="13.8" fill="none" stroke="#7A7468" stroke-width="0.5" opacity="0.45" />
      </svg>
    </span>
  )}
</span>

<style>
  .ws-sculpted {
    display: inline-flex;
    align-items: center;
    line-height: 1;
    filter: drop-shadow(0 1px 2px rgba(0, 0, 0, 0.18));
  }
  .ws-sculpted svg {
    display: block;
    width: auto;
  }
  .ws-ball {
    display: inline-block;
    margin-left: 0.08em;
    flex-shrink: 0;
    filter: drop-shadow(1px 2px 3px rgba(0, 0, 0, 0.22));
  }
  .tone-inverted {
    filter: drop-shadow(0 1px 3px rgba(0, 0, 0, 0.45));
  }
  .tone-inverted .ws-ball {
    filter: drop-shadow(1px 2px 3px rgba(0, 0, 0, 0.5));
  }
  .ws-ball svg { width: 100%; height: 100%; display: block; }
</style>
