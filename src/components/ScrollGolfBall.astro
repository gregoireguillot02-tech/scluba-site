---
/**
 * ScrollGolfBall — scène Three.js plein écran avec balle de golf 3D au centre
 * et caméra qui orbite autour de la balle au scroll de la page.
 *
 * Inspiration : oryzo.ai — canvas WebGL fixed inset 0 derrière le DOM, scroll
 * pilote la caméra dans une timeline pré-animée. Step 1a refonte landing
 * 2026-05-19 (V2 — V1 SVG remplacée).
 *
 * Architecture :
 *   - <canvas> position:fixed inset:0 z-index:1 pointer-events:none
 *   - Le contenu HTML (Nav z:100, sections z:auto) reste cliquable au-dessus
 *   - Balle 3D au centre du monde 3D (origine), caméra à distance ~3.5
 *   - scrollProgress [0..1] → theta (0→360°) + phi (70°→90°→70°)
 *
 * Stack :
 *   - Three.js WebGLRenderer alpha:true antialias:true dpr capé 2
 *   - GLTFLoader → public/models/golf_ball.glb (4.2 MB — V1, DRACO si besoin)
 *   - RoomEnvironment pour reflections subtiles
 *   - ACESFilmicToneMapping exposure 1.1
 *   - 3-point lighting (key + fill + rim + ambient)
 *   - frameloop 'demand' — re-render sur scroll/resize uniquement
 *   - GSAP ScrollTrigger scrub 0.6 + sync Lenis via window.__lenis
 *
 * Guards :
 *   - prefers-reduced-motion : balle visible immobile (camera fixée à 0%)
 *   - mobile portrait < 640px : canvas masqué (perf + encombrement)
 *   - lazy import three + GLTFLoader pour ne pas bloquer LCP
 *
 * Inclusion : conditionnelle depuis Base.astro — uniquement sur la home (/, /en/).
 */
---

<canvas data-scroll-golfball aria-hidden="true"></canvas>

<style>
  canvas[data-scroll-golfball] {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    z-index: 1;
    pointer-events: none;
    /* Légère opacité pendant le chargement, fade-in via JS quand le modèle est prêt */
    opacity: 0;
    transition: opacity 600ms ease-out;
  }
  canvas[data-scroll-golfball][data-ready="true"] {
    opacity: 1;
  }

  /* Masquer sur mobile portrait — perf + encombrement */
  @media (max-width: 640px) {
    canvas[data-scroll-golfball] {
      display: none;
    }
  }
</style>

<script>
  // Lazy import : Three.js + GLTFLoader + RoomEnvironment + GSAP/ScrollTrigger
  // chargés uniquement après DOMContentLoaded pour ne pas bloquer LCP du Hero.
  async function initScrollGolfBall() {
    const canvas = document.querySelector<HTMLCanvasElement>('canvas[data-scroll-golfball]');
    if (!canvas) return;

    // Skip mobile portrait (cohérent avec le display:none CSS)
    if (window.innerWidth <= 640) return;

    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const [THREE, { GLTFLoader }, { RoomEnvironment }, { gsap }, { ScrollTrigger }] = await Promise.all([
      import('three'),
      import('three/examples/jsm/loaders/GLTFLoader.js'),
      import('three/examples/jsm/environments/RoomEnvironment.js'),
      import('gsap'),
      import('gsap/ScrollTrigger'),
    ]);

    gsap.registerPlugin(ScrollTrigger);

    // === Renderer ====================================================
    const renderer = new THREE.WebGLRenderer({
      canvas,
      antialias: true,
      alpha: true,
      powerPreference: 'high-performance',
    });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.setSize(window.innerWidth, window.innerHeight, false);
    renderer.outputColorSpace = THREE.SRGBColorSpace;
    renderer.toneMapping = THREE.ACESFilmicToneMapping;
    renderer.toneMappingExposure = 1.1;

    // === Scene + Camera =============================================
    const scene = new THREE.Scene();
    // Pas de scene.background — alpha:true rend le canvas transparent.

    const camera = new THREE.PerspectiveCamera(
      35, // FOV serré pour minimiser la perspective extrême (balle plus "stable")
      window.innerWidth / window.innerHeight,
      0.1,
      100
    );

    // Position initiale (theta=0, phi=70°, distance=3.5)
    const camState = { theta: 0, phi: 70, distance: 3.5 };
    function applyCameraState() {
      const phiRad = (camState.phi * Math.PI) / 180;
      const thetaRad = (camState.theta * Math.PI) / 180;
      const sinPhi = Math.sin(phiRad);
      camera.position.x = camState.distance * sinPhi * Math.sin(thetaRad);
      camera.position.y = camState.distance * Math.cos(phiRad);
      camera.position.z = camState.distance * sinPhi * Math.cos(thetaRad);
      camera.lookAt(0, 0, 0);
    }
    applyCameraState();

    // === Environment + Lighting =====================================
    // PMREMGenerator transforme la RoomEnvironment en cube IBL pour les
    // reflections subtiles sur la balle (clearcoat plus convaincant).
    const pmremGenerator = new THREE.PMREMGenerator(renderer);
    scene.environment = pmremGenerator.fromScene(new RoomEnvironment(), 0.04).texture;

    // 3-point lighting classique studio
    const keyLight = new THREE.DirectionalLight(0xffffff, 2.0);
    keyLight.position.set(3, 4, 5);
    scene.add(keyLight);

    const fillLight = new THREE.DirectionalLight(0xfff4e6, 0.8);
    fillLight.position.set(-4, 2, 3);
    scene.add(fillLight);

    const rimLight = new THREE.DirectionalLight(0xe6f0ff, 0.4);
    rimLight.position.set(0, -2, -5);
    scene.add(rimLight);

    const ambient = new THREE.AmbientLight(0xffffff, 0.15);
    scene.add(ambient);

    // === Render à la demande ========================================
    // frameloop: 'demand' équivalent — on ne redessine que quand quelque
    // chose a bougé (scroll, resize, model load).
    let renderRequested = false;
    function requestRender() {
      if (renderRequested) return;
      renderRequested = true;
      requestAnimationFrame(() => {
        renderer.render(scene, camera);
        renderRequested = false;
      });
    }

    // === Load GLB ===================================================
    const loader = new GLTFLoader();
    loader.load(
      '/models/golf_ball.glb',
      (gltf) => {
        const ball = gltf.scene;

        // Auto-center + fit : on calcule la bounding box et on normalise
        // la taille pour que la balle ait un diamètre de ~1.6 units quelle
        // que soit l'échelle du .glb source.
        const box = new THREE.Box3().setFromObject(ball);
        const size = new THREE.Vector3();
        box.getSize(size);
        const center = new THREE.Vector3();
        box.getCenter(center);

        const maxDim = Math.max(size.x, size.y, size.z);
        const targetDiameter = 1.6;
        const scale = targetDiameter / maxDim;

        ball.scale.setScalar(scale);
        ball.position.set(-center.x * scale, -center.y * scale, -center.z * scale);

        scene.add(ball);
        canvas.dataset.ready = 'true';
        requestRender();

        // Rotation auto continue (toujours active sauf reduced-motion)
        if (!prefersReduced) {
          let lastTime = performance.now();
          function tick(time: number) {
            const delta = (time - lastTime) / 1000;
            lastTime = time;
            ball.rotation.y += delta * 0.15; // ~9° par seconde
            renderer.render(scene, camera);
            requestAnimationFrame(tick);
          }
          requestAnimationFrame(tick);
        }
      },
      undefined,
      (err) => {
        console.error('[ScrollGolfBall] Failed to load golf_ball.glb', err);
      }
    );

    // === Camera orbit au scroll (GSAP + ScrollTrigger) ==============
    if (!prefersReduced) {
      // Sync ScrollTrigger avec Lenis si présent (smooth-scroll cohérent)
      const lenis = (window as unknown as { __lenis?: { on: (ev: string, cb: () => void) => void } }).__lenis;
      if (lenis && typeof lenis.on === 'function') {
        lenis.on('scroll', ScrollTrigger.update);
      }

      // Animation principale : theta 0→360° sur la totalité du scroll du document.
      gsap.to(camState, {
        theta: 360,
        ease: 'none',
        scrollTrigger: {
          trigger: document.documentElement,
          start: 'top top',
          end: 'bottom bottom',
          scrub: 0.6,
          invalidateOnRefresh: true,
          onUpdate: () => {
            applyCameraState();
            requestRender();
          },
        },
      });

      // Sub-animation : phi varie en cloche (70 → 90 → 70) pour donner un effet
      // "survol au-dessus" en milieu de page.
      gsap.to(camState, {
        phi: 90,
        ease: 'sine.inOut',
        scrollTrigger: {
          trigger: document.documentElement,
          start: 'top top',
          end: '50% center',
          scrub: 0.6,
        },
      });
      gsap.to(camState, {
        phi: 70,
        ease: 'sine.inOut',
        scrollTrigger: {
          trigger: document.documentElement,
          start: '50% center',
          end: 'bottom bottom',
          scrub: 0.6,
        },
      });

      // Sub-animation : distance varie en cloche (3.5 → 4.2 → 3.5)
      gsap.to(camState, {
        distance: 4.2,
        ease: 'sine.inOut',
        scrollTrigger: {
          trigger: document.documentElement,
          start: 'top top',
          end: '50% center',
          scrub: 0.6,
        },
      });
      gsap.to(camState, {
        distance: 3.5,
        ease: 'sine.inOut',
        scrollTrigger: {
          trigger: document.documentElement,
          start: '50% center',
          end: 'bottom bottom',
          scrub: 0.6,
        },
      });
    }

    // === Resize handler =============================================
    window.addEventListener('resize', () => {
      // Si on passe en mobile portrait après resize, on stoppe (rare)
      if (window.innerWidth <= 640) return;

      camera.aspect = window.innerWidth / window.innerHeight;
      camera.updateProjectionMatrix();
      renderer.setSize(window.innerWidth, window.innerHeight, false);
      requestRender();
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initScrollGolfBall);
  } else {
    initScrollGolfBall();
  }
</script>
