---
/**
 * ScrollGolfBall — scène Three.js plein écran avec balle de golf 3D qui
 * VOYAGE dans le viewport au scroll (pattern oryzo.ai — V3 2026-05-19).
 *
 * Architecture :
 *   - <canvas> position:fixed inset:0 z-index:1 pointer-events:none
 *   - Contenu HTML (Nav z:100, sections z:auto) reste cliquable au-dessus
 *   - Camera FIXÉE à (0, 0, 5) lookAt origin — pas d'orbite, la balle
 *     elle-même se déplace dans le monde 3D selon les keyframes scroll
 *   - 10 keyframes (x, y, scale) interpolées smoothement → balle "voyage"
 *
 * Camera FOV 35°, distance 5 → viewport vertical visible ≈ 3.15 units,
 * horizontal ≈ 5.6 units sur 16:9. Donc :
 *   x = ±2.5  = bords gauche/droite du viewport
 *   y = ±1.5  = haut/bas du viewport
 *
 * Map des 10 keyframes (scroll % → position) :
 *   ┌─────────┬────────────────┬──────┬──────┬───────┐
 *   │ scroll% │ section        │   x  │   y  │ scale │
 *   ├─────────┼────────────────┼──────┼──────┼───────┤
 *   │ 0%      │ Hero start     │ +2.0 │ -0.2 │  1.0  │
 *   │ 10%     │ Problem (haut) │  0   │ +1.4 │ 0.55  │
 *   │ 20%     │ Problem (bas)  │  0   │ -1.4 │ 0.55  │
 *   │ 25%     │ ThreeSteps     │ +2.6 │  0   │ 0.50  │
 *   │ 38%     │ → PhoneSh.     │ +2.6 │  0   │  0    │ ← HIDDEN
 *   │ 55%     │ Clubs (h-gche) │ -2.4 │ +0.8 │ 0.65  │
 *   │ 68%     │ HowItWorks     │  0   │ +1.8 │ 0.50  │
 *   │ 78%     │ Pricing        │ +2.3 │ -0.9 │ 0.40  │
 *   │ 86%     │ FAQ            │ -2.0 │  0   │ 0.55  │
 *   │ 93%     │ → CTAForm      │  0   │  0   │  1.0  │
 *   │ 100%    │ CTAForm final  │  0   │  0   │  1.3  │
 *   └─────────┴────────────────┴──────┴──────┴───────┘
 *
 * Rendu :
 *   - WebGLRenderer alpha:true antialias:true dpr capé 2
 *   - RoomEnvironment (PMREMGenerator) → reflections IBL subtiles
 *   - 3-point lighting (key + fill + rim + ambient)
 *   - ACESFilmicToneMapping exposure 1.1, SRGBColorSpace
 *   - frameloop on-demand (re-render sur scroll/resize/load uniquement)
 *
 * Guards :
 *   - prefers-reduced-motion : balle figée à la position initiale (K0)
 *   - mobile portrait < 640px : canvas display:none
 *   - lazy import three + addons + GSAP/ScrollTrigger après DOMContentLoaded
 */
---

<div data-ball-shadow aria-hidden="true"></div>
<canvas data-scroll-golfball aria-hidden="true"></canvas>

<style>
  canvas[data-scroll-golfball] {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    z-index: 1;
    pointer-events: none;
    opacity: 0;
    transition: opacity 600ms ease-out;
  }
  canvas[data-scroll-golfball][data-ready="true"] {
    opacity: 1;
  }

  /* Ombre portée HTML synchronisée — projection 3D→2D du ballState
     (le canvas Three.js est transparent, donc un radial-gradient sous
     la balle donne un "sol" sans coût GPU des shadow maps WebGL). */
  [data-ball-shadow] {
    position: fixed;
    top: 0;
    left: 0;
    width: 240px;
    height: 60px;
    pointer-events: none;
    background: radial-gradient(
      ellipse at center,
      rgba(15, 8, 4, 0.65) 0%,
      rgba(15, 8, 4, 0.28) 35%,
      rgba(15, 8, 4, 0) 70%
    );
    filter: blur(12px);
    transform: translate(-1000px, -1000px);
    transform-origin: 50% 50%;
    will-change: transform, opacity;
    /* Même z que le canvas → fixed positionné AVANT canvas dans le DOM,
       donc le canvas (et donc la balle) passe au-dessus à l'overlap. */
    z-index: 1;
    opacity: 0;
    transition: opacity 400ms ease-out;
    /* Multiply pour que l'ombre s'intègre quel que soit le bg de section */
    mix-blend-mode: multiply;
  }
  [data-ball-shadow][data-ready="true"] {
    opacity: 1;
  }

  @media (max-width: 640px) {
    canvas[data-scroll-golfball],
    [data-ball-shadow] {
      display: none;
    }
  }
</style>

<script>
  async function initScrollGolfBall() {
    const canvas = document.querySelector<HTMLCanvasElement>('canvas[data-scroll-golfball]');
    const shadow = document.querySelector<HTMLDivElement>('[data-ball-shadow]');
    if (!canvas) return;
    if (window.innerWidth <= 640) return;

    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const [THREE, { GLTFLoader }, { RoomEnvironment }, { DecalGeometry }, { gsap }, { ScrollTrigger }] = await Promise.all([
      import('three'),
      import('three/examples/jsm/loaders/GLTFLoader.js'),
      import('three/examples/jsm/environments/RoomEnvironment.js'),
      import('three/examples/jsm/geometries/DecalGeometry.js'),
      import('gsap'),
      import('gsap/ScrollTrigger'),
    ]);

    gsap.registerPlugin(ScrollTrigger);

    // === Renderer ====================================================
    const renderer = new THREE.WebGLRenderer({
      canvas,
      antialias: true,
      alpha: true,
      powerPreference: 'high-performance',
    });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.setSize(window.innerWidth, window.innerHeight, false);
    renderer.outputColorSpace = THREE.SRGBColorSpace;
    renderer.toneMapping = THREE.ACESFilmicToneMapping;
    // Exposure plus basse → highlights moins éclatants, surface plus mate
    renderer.toneMappingExposure = 0.95;

    // === Scene + Camera (FIXÉE) =====================================
    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(
      35,
      window.innerWidth / window.innerHeight,
      0.1,
      100
    );
    camera.position.set(0, 0, 5);
    camera.lookAt(0, 0, 0);

    // === Environment + Lighting =====================================
    const pmremGenerator = new THREE.PMREMGenerator(renderer);
    // Blur 0.18 (vs 0.04) → reflets atmosphériques plus diffus, moins studio
    scene.environment = pmremGenerator.fromScene(new RoomEnvironment(), 0.18).texture;

    const keyLight = new THREE.DirectionalLight(0xffffff, 2.0);
    keyLight.position.set(3, 4, 5);
    scene.add(keyLight);

    const fillLight = new THREE.DirectionalLight(0xfff4e6, 0.8);
    fillLight.position.set(-4, 2, 3);
    scene.add(fillLight);

    const rimLight = new THREE.DirectionalLight(0xe6f0ff, 0.4);
    rimLight.position.set(0, -2, -5);
    scene.add(rimLight);

    const ambient = new THREE.AmbientLight(0xffffff, 0.15);
    scene.add(ambient);

    // === Ball state (voyage scroll-tied) ============================
    // ballGroup wrap le gltf.scene → on anime le groupe, pas la balle
    // (la rotation auto Y reste sur la balle interne).
    const ballGroup = new THREE.Group();
    scene.add(ballGroup);

    // État initial = K0 (Hero start) : droite, scale plein
    const ballState = {
      x: 2.0,
      y: -0.2,
      scale: 1.0,
    };
    // Vecteur réutilisable pour la projection 3D→écran de l'ombre
    const projVec = new THREE.Vector3();
    const SHADOW_W = 240;
    const SHADOW_H = 60;

    function applyBallState() {
      ballGroup.position.x = ballState.x;
      ballGroup.position.y = ballState.y;
      ballGroup.scale.setScalar(Math.max(ballState.scale, 0));
      ballGroup.visible = ballState.scale > 0.01;

      // Sync ombre portée HTML : projection du point sous la balle
      if (shadow) {
        if (ballState.scale > 0.01) {
          // Point cible = sous la balle (y - rayon * scale), z=0
          projVec.set(ballState.x, ballState.y - 0.45 * ballState.scale, 0);
          projVec.project(camera);
          const sx = (projVec.x + 1) / 2 * window.innerWidth;
          const sy = (1 - projVec.y) / 2 * window.innerHeight;
          // Ombre plus large/écrasée quand balle proche du sol visuel
          const scaleX = ballState.scale * 1.0;
          const scaleY = ballState.scale * 0.55;
          shadow.style.transform = `translate(${sx - SHADOW_W / 2}px, ${sy - SHADOW_H / 2}px) scale(${scaleX}, ${scaleY})`;
          shadow.style.opacity = String(Math.max(0, Math.min(1, ballState.scale * 0.85)));
        } else {
          shadow.style.opacity = '0';
        }
      }
    }
    applyBallState();

    // === Render à la demande ========================================
    let renderRequested = false;
    function requestRender() {
      if (renderRequested) return;
      renderRequested = true;
      requestAnimationFrame(() => {
        renderer.render(scene, camera);
        renderRequested = false;
      });
    }

    // === Logo SCLUBA (DecalGeometry × 2 sur la surface de la balle) =
    // Vrai decal qui épouse la courbure du mesh cible. Deux décals
    // opposés (front +Z + back -Z) pour que le logo soit visible
    // quel que soit l'angle de rotation Y.
    function createLogoTexture() {
      const cnv = document.createElement('canvas');
      cnv.width = 1024;
      cnv.height = 256;
      const ctx = cnv.getContext('2d');
      if (!ctx) return null;

      ctx.clearRect(0, 0, 1024, 256);
      ctx.fillStyle = '#2D1B0E'; // warm-charcoal cohérent wordmark
      ctx.font = '900 170px "Big Shoulders Display", "Arial Black", system-ui, sans-serif';
      ctx.textBaseline = 'middle';

      // Tracked-out caps : letter-spacing manuel
      const text = 'SCLUBA';
      const letterSpacing = 22;
      const widths = text.split('').map((c) => ctx.measureText(c).width);
      const totalW = widths.reduce((a, b) => a + b, 0) + letterSpacing * (text.length - 1);
      let cursor = (1024 - totalW) / 2;
      text.split('').forEach((c, i) => {
        ctx.fillText(c, cursor, 138);
        cursor += widths[i] + letterSpacing;
      });

      const texture = new THREE.CanvasTexture(cnv);
      texture.colorSpace = THREE.SRGBColorSpace;
      texture.anisotropy = renderer.capabilities.getMaxAnisotropy();
      texture.needsUpdate = true;
      return texture;
    }

    async function addLogoDecals(ball: any) {
      try {
        await document.fonts.load('900 170px "Big Shoulders Display"');
        await document.fonts.ready;
      } catch {
        /* fallback police */
      }

      const texture = createLogoTexture();
      if (!texture) return;

      // Trouve le mesh principal (le plus gros par volume bbox)
      let targetMesh: any = null;
      let maxVolume = 0;
      ball.traverse((child: any) => {
        if (child.isMesh) {
          const sz = new THREE.Vector3();
          new THREE.Box3().setFromObject(child).getSize(sz);
          const vol = sz.x * sz.y * sz.z;
          if (vol > maxVolume) {
            maxVolume = vol;
            targetMesh = child;
          }
        }
      });
      if (!targetMesh) return;

      // Reset transforms ballGroup à identité → DecalGeometry calcule
      // en target-local clean. On restaure après.
      const savedPos = ballGroup.position.clone();
      const savedScale = ballGroup.scale.clone();
      const savedRot = ballGroup.rotation.clone();
      ballGroup.position.set(0, 0, 0);
      ballGroup.scale.set(1, 1, 1);
      ballGroup.rotation.set(0, 0, 0);
      ballGroup.updateMatrixWorld(true);

      const decalMaterial = new THREE.MeshStandardMaterial({
        map: texture,
        transparent: true,
        alphaTest: 0.08,
        depthTest: true,
        depthWrite: false,
        polygonOffset: true,
        polygonOffsetFactor: -4,
        roughness: 0.7,
        metalness: 0,
      });

      // Decal size : (largeur, hauteur, profondeur projection)
      // Aspect 4:1 → 0.55 × 0.137. Profondeur 0.2 pour limiter le wrap.
      const decalSize = new THREE.Vector3(0.55, 0.137, 0.2);

      // K_front : face +Z
      const decalGeomFront = new DecalGeometry(
        targetMesh,
        new THREE.Vector3(0, 0, 0.5),
        new THREE.Euler(0, 0, 0),
        decalSize
      );
      const decalFront = new THREE.Mesh(decalGeomFront, decalMaterial);
      targetMesh.add(decalFront);

      // K_back : face -Z (rotation Y de π pour orienter le texte lisible)
      const decalGeomBack = new DecalGeometry(
        targetMesh,
        new THREE.Vector3(0, 0, -0.5),
        new THREE.Euler(0, Math.PI, 0),
        decalSize
      );
      const decalBack = new THREE.Mesh(decalGeomBack, decalMaterial);
      targetMesh.add(decalBack);

      // Restaure ballState
      ballGroup.position.copy(savedPos);
      ballGroup.scale.copy(savedScale);
      ballGroup.rotation.copy(savedRot);
      ballGroup.updateMatrixWorld(true);

      requestRender();
    }

    // Matière "plus réelle" : roughness ↑ sur les MeshStandardMaterial
    // du glTF (la balle paraît moins miroir, plus usée).
    function dirtifyBallMaterials(ball: any) {
      ball.traverse((child: any) => {
        if (child.isMesh && child.material) {
          const mat = child.material;
          if (mat instanceof THREE.MeshStandardMaterial) {
            mat.roughness = Math.min(mat.roughness * 1.4, 1);
            mat.needsUpdate = true;
          }
        }
      });
    }

    // === Load GLB ===================================================
    const loader = new GLTFLoader();
    loader.load(
      '/models/golf_ball.glb',
      (gltf) => {
        const ball = gltf.scene;

        const box = new THREE.Box3().setFromObject(ball);
        const size = new THREE.Vector3();
        box.getSize(size);
        const center = new THREE.Vector3();
        box.getCenter(center);

        const maxDim = Math.max(size.x, size.y, size.z);
        const targetDiameter = 1.0;
        const baseScale = targetDiameter / maxDim;

        ball.scale.setScalar(baseScale);
        ball.position.set(-center.x * baseScale, -center.y * baseScale, -center.z * baseScale);

        ballGroup.add(ball);
        dirtifyBallMaterials(ball);
        addLogoDecals(ball);
        applyBallState();
        canvas.dataset.ready = 'true';
        if (shadow) shadow.dataset.ready = 'true';
        requestRender();

        // Rotation auto continue Y ralentie (~3°/s) — balle + logo
        // restent "vivants" mais le logo reste lisible plus longtemps.
        // On rotate ballGroup (pas ball) pour que les décals suivent.
        if (!prefersReduced) {
          let lastTime = performance.now();
          function tick(time: number) {
            const delta = (time - lastTime) / 1000;
            lastTime = time;
            ballGroup.rotation.y += delta * 0.05;
            if (ballGroup.visible) {
              renderer.render(scene, camera);
            }
            requestAnimationFrame(tick);
          }
          requestAnimationFrame(tick);
        }
      },
      undefined,
      (err) => {
        console.error('[ScrollGolfBall] Failed to load golf_ball.glb', err);
      }
    );

    // === Voyage timeline (10 keyframes) =============================
    if (!prefersReduced) {
      // Sync ScrollTrigger avec Lenis si présent
      const lenis = (window as unknown as { __lenis?: { on: (ev: string, cb: () => void) => void } }).__lenis;
      if (lenis && typeof lenis.on === 'function') {
        lenis.on('scroll', ScrollTrigger.update);
      }

      // Master timeline qui couvre 0% → 100% du scroll document.
      // Chaque .to() interpole smoothement vers la prochaine keyframe.
      // Easing power2.inOut pour mouvement organique entre positions.
      // scrub 0.6 = léger lag "physique" derrière le scroll utilisateur.
      const tl = gsap.timeline({
        defaults: { ease: 'power2.inOut' },
        scrollTrigger: {
          trigger: document.documentElement,
          start: 'top top',
          end: 'bottom bottom',
          scrub: 0.6,
          invalidateOnRefresh: true,
          onUpdate: () => {
            applyBallState();
            requestRender();
          },
        },
      });

      // K0 → K1 (0% → 10%) : Hero droite → ProblemNarrative haut centre
      tl.to(ballState, { duration: 0.10, x: 0, y: 1.4, scale: 0.55 });

      // K1 → K2 (10% → 20%) : Problem haut → bas (traverse vertical)
      tl.to(ballState, { duration: 0.10, x: 0, y: -1.4, scale: 0.55 });

      // K2 → K3 (20% → 25%) : transition vers ThreeSteps droite
      tl.to(ballState, { duration: 0.05, x: 2.6, y: 0, scale: 0.50 });

      // K3 → K4 (25% → 38%) : ThreeSteps stable puis fade vers PhoneShowcase HIDDEN
      tl.to(ballState, { duration: 0.13, x: 2.6, y: 0, scale: 0 });

      // K4 → K5 (38% → 55%) : HIDDEN, puis transition vers ClubsShowcase haut-gauche
      // Pendant PhoneShowcase (focus phone mockup), balle invisible.
      // Au début de Clubs, elle réapparaît grandit haut-gauche.
      tl.to(ballState, { duration: 0.17, x: -2.4, y: 0.8, scale: 0.65 });

      // K5 → K6 (55% → 68%) : Clubs haut-gauche → HowItWorks haut centre (suit la line)
      tl.to(ballState, { duration: 0.13, x: 0, y: 1.8, scale: 0.50 });

      // K6 → K7 (68% → 78%) : HowItWorks → Pricing droite-bas (petit)
      tl.to(ballState, { duration: 0.10, x: 2.3, y: -0.9, scale: 0.40 });

      // K7 → K8 (78% → 86%) : Pricing → FAQ gauche
      tl.to(ballState, { duration: 0.08, x: -2.0, y: 0, scale: 0.55 });

      // K8 → K9 (86% → 93%) : FAQ gauche → CTAForm transition retour centre
      tl.to(ballState, { duration: 0.07, x: 0, y: 0, scale: 1.0 });

      // K9 → K10 (93% → 100%) : CTAForm grandit final glory (scale 1.3)
      tl.to(ballState, { duration: 0.07, x: 0, y: 0, scale: 1.3 });
    }

    // === Resize handler =============================================
    window.addEventListener('resize', () => {
      if (window.innerWidth <= 640) return;
      camera.aspect = window.innerWidth / window.innerHeight;
      camera.updateProjectionMatrix();
      renderer.setSize(window.innerWidth, window.innerHeight, false);
      requestRender();
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initScrollGolfBall);
  } else {
    initScrollGolfBall();
  }
</script>
