---
/**
 * ScrollGolfBall — scène Three.js plein écran avec balle de golf 3D 3D pilotée
 * par 5 keyframes scroll précises (apparait au Hero, disparait dans les
 * sections texte, réapparait grosse au CTA final).
 *
 * Inspiration : oryzo.ai — canvas WebGL fixed inset 0 derrière le DOM, scroll
 * pilote une timeline d'états (position + scale + visibilité) de la balle.
 *
 * Architecture :
 *   - <canvas> position:fixed inset:0 z-index:1 pointer-events:none
 *   - Contenu HTML (Nav z:100, sections z:auto) reste cliquable au-dessus
 *   - Cam fixée distance 5, FOV 35° + orbite ¼ tour (theta 0→60°, phi 75→85→75)
 *   - Balle au centre 3D, scale & visibility pilotés par 5 keyframes scroll
 *
 * Keyframes scroll (timeline GSAP scrub 0.6) :
 *   ┌─────────┬──────────┬─────────────────────────────────┐
 *   │ scroll% │ section  │ balle                            │
 *   ├─────────┼──────────┼─────────────────────────────────┤
 *   │ 0-12%   │ Hero     │ centrée, scale 1.0, OPAQUE      │
 *   │ 12-22%  │ Problem  │ shrink + fade (scale 1→0)       │
 *   │ 22-78%  │ texte sections │ HIDDEN (scale 0)         │
 *   │ 78-92%  │ FAQ→CTA  │ grow + fade in (scale 0→1.2)   │
 *   │ 92-100% │ CTAForm  │ centrée scale 1.2, OPAQUE       │
 *   └─────────┴──────────┴─────────────────────────────────┘
 *
 * Rendu :
 *   - WebGLRenderer alpha:true antialias:true dpr capé 2
 *   - RoomEnvironment (PMREMGenerator) → reflections IBL subtiles
 *   - 3-point lighting (key 2.0 + fill warm 0.8 + rim cool 0.4 + ambient 0.15)
 *   - ACESFilmicToneMapping exposure 1.1, SRGBColorSpace
 *   - frameloop on-demand (re-render sur scroll/resize/load uniquement)
 *
 * Guards :
 *   - prefers-reduced-motion : balle visible immobile au centre
 *   - mobile portrait < 640px : canvas display:none
 *   - lazy import three + addons + GSAP/ScrollTrigger après DOMContentLoaded
 *
 * Inclusion : conditionnelle depuis Base.astro — uniquement sur la home (/, /en/).
 */
---

<canvas data-scroll-golfball aria-hidden="true"></canvas>

<style>
  canvas[data-scroll-golfball] {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    z-index: 1;
    pointer-events: none;
    opacity: 0;
    transition: opacity 600ms ease-out;
  }
  canvas[data-scroll-golfball][data-ready="true"] {
    opacity: 1;
  }

  @media (max-width: 640px) {
    canvas[data-scroll-golfball] {
      display: none;
    }
  }
</style>

<script>
  async function initScrollGolfBall() {
    const canvas = document.querySelector<HTMLCanvasElement>('canvas[data-scroll-golfball]');
    if (!canvas) return;
    if (window.innerWidth <= 640) return;

    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const [THREE, { GLTFLoader }, { RoomEnvironment }, { gsap }, { ScrollTrigger }] = await Promise.all([
      import('three'),
      import('three/examples/jsm/loaders/GLTFLoader.js'),
      import('three/examples/jsm/environments/RoomEnvironment.js'),
      import('gsap'),
      import('gsap/ScrollTrigger'),
    ]);

    gsap.registerPlugin(ScrollTrigger);

    // === Renderer ====================================================
    const renderer = new THREE.WebGLRenderer({
      canvas,
      antialias: true,
      alpha: true,
      powerPreference: 'high-performance',
    });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.setSize(window.innerWidth, window.innerHeight, false);
    renderer.outputColorSpace = THREE.SRGBColorSpace;
    renderer.toneMapping = THREE.ACESFilmicToneMapping;
    renderer.toneMappingExposure = 1.1;

    // === Scene + Camera =============================================
    const scene = new THREE.Scene();

    const camera = new THREE.PerspectiveCamera(
      35,
      window.innerWidth / window.innerHeight,
      0.1,
      100
    );

    // Distance 5 (au lieu de 3.5 V1) → balle ~32% du viewport au lieu de 72%.
    // Orbite limitée à ¼ tour (theta 0→60°, phi 75→85→75) — moins envahissant
    // que le 360° complet de V1.
    const camState = { theta: 0, phi: 75, distance: 5 };
    function applyCameraState() {
      const phiRad = (camState.phi * Math.PI) / 180;
      const thetaRad = (camState.theta * Math.PI) / 180;
      const sinPhi = Math.sin(phiRad);
      camera.position.x = camState.distance * sinPhi * Math.sin(thetaRad);
      camera.position.y = camState.distance * Math.cos(phiRad);
      camera.position.z = camState.distance * sinPhi * Math.cos(thetaRad);
      camera.lookAt(0, 0, 0);
    }
    applyCameraState();

    // === Environment + Lighting =====================================
    const pmremGenerator = new THREE.PMREMGenerator(renderer);
    scene.environment = pmremGenerator.fromScene(new RoomEnvironment(), 0.04).texture;

    const keyLight = new THREE.DirectionalLight(0xffffff, 2.0);
    keyLight.position.set(3, 4, 5);
    scene.add(keyLight);

    const fillLight = new THREE.DirectionalLight(0xfff4e6, 0.8);
    fillLight.position.set(-4, 2, 3);
    scene.add(fillLight);

    const rimLight = new THREE.DirectionalLight(0xe6f0ff, 0.4);
    rimLight.position.set(0, -2, -5);
    scene.add(rimLight);

    const ambient = new THREE.AmbientLight(0xffffff, 0.15);
    scene.add(ambient);

    // === Ball state (driven by scroll keyframes) ====================
    // ballGroup wrap le gltf.scene → on anime le groupe, pas la balle elle-même
    // (ça nous permet de garder la rotation auto Y sur la balle interne).
    const ballGroup = new THREE.Group();
    scene.add(ballGroup);

    const ballState = {
      x: 0,
      y: 0,
      scale: 1.0, // 0 = hidden, 1.0 = normal, 1.2 = final
    };
    function applyBallState() {
      ballGroup.position.x = ballState.x;
      ballGroup.position.y = ballState.y;
      ballGroup.scale.setScalar(Math.max(ballState.scale, 0));
      ballGroup.visible = ballState.scale > 0.01;
    }

    // === Render à la demande ========================================
    let renderRequested = false;
    function requestRender() {
      if (renderRequested) return;
      renderRequested = true;
      requestAnimationFrame(() => {
        renderer.render(scene, camera);
        renderRequested = false;
      });
    }

    // === Load GLB ===================================================
    const loader = new GLTFLoader();
    loader.load(
      '/models/golf_ball.glb',
      (gltf) => {
        const ball = gltf.scene;

        // Auto-center + fit : diamètre cible 1.0 (au lieu de 1.6 V1)
        const box = new THREE.Box3().setFromObject(ball);
        const size = new THREE.Vector3();
        box.getSize(size);
        const center = new THREE.Vector3();
        box.getCenter(center);

        const maxDim = Math.max(size.x, size.y, size.z);
        const targetDiameter = 1.0;
        const baseScale = targetDiameter / maxDim;

        ball.scale.setScalar(baseScale);
        ball.position.set(-center.x * baseScale, -center.y * baseScale, -center.z * baseScale);

        ballGroup.add(ball);
        applyBallState();
        canvas.dataset.ready = 'true';
        requestRender();

        // Rotation auto continue (~9°/s) — donne la "vie" même quand stationnaire
        if (!prefersReduced) {
          let lastTime = performance.now();
          function tick(time: number) {
            const delta = (time - lastTime) / 1000;
            lastTime = time;
            ball.rotation.y += delta * 0.15;
            // Re-render seulement si la balle est visible (perf : sinon on
            // anime sans afficher)
            if (ballGroup.visible) {
              renderer.render(scene, camera);
            }
            requestAnimationFrame(tick);
          }
          requestAnimationFrame(tick);
        }
      },
      undefined,
      (err) => {
        console.error('[ScrollGolfBall] Failed to load golf_ball.glb', err);
      }
    );

    // === Scroll-driven animations ===================================
    if (!prefersReduced) {
      // Sync ScrollTrigger avec Lenis si présent
      const lenis = (window as unknown as { __lenis?: { on: (ev: string, cb: () => void) => void } }).__lenis;
      if (lenis && typeof lenis.on === 'function') {
        lenis.on('scroll', ScrollTrigger.update);
      }

      // === Master timeline pour la balle (scale + position) ===
      // 5 keyframes précis pilotés par le scrollProgress de la page.
      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: document.documentElement,
          start: 'top top',
          end: 'bottom bottom',
          scrub: 0.6,
          invalidateOnRefresh: true,
          onUpdate: () => {
            applyBallState();
            requestRender();
          },
        },
      });

      // Helper : convertit un % du scroll en position sur la timeline.
      // La durée totale de la timeline = 1 (normalisée). Les .to() prennent
      // des durations qui sont des fractions de cette durée totale.
      //   0%  → Hero : centrée scale 1.0
      //  12%  → début sortie Hero : commence à shrink
      //  22%  → tout petit, off-screen droite (préparé à disparaître)
      //  25%  → HIDDEN (scale 0)
      //  78%  → encore HIDDEN
      //  85%  → réapparait du centre (scale 0 → 0.8)
      //  92%  → grosse au centre (scale 1.2)
      // 100%  → final, reste scale 1.2

      // Segment 1 : 0% → 12% — balle stable centrée
      tl.to(ballState, { duration: 0.12, scale: 1.0, x: 0, y: 0, ease: 'none' });

      // Segment 2 : 12% → 22% — slide-out vers la droite + shrink
      tl.to(ballState, {
        duration: 0.10,
        scale: 0.4,
        x: 2.5,
        y: 0,
        ease: 'power2.in',
      });

      // Segment 3 : 22% → 25% — disparait complètement (scale 0)
      tl.to(ballState, {
        duration: 0.03,
        scale: 0,
        x: 2.5,
        y: 0,
        ease: 'power2.in',
      });

      // Segment 4 : 25% → 78% — HIDDEN (long plateau pour les sections texte)
      tl.to(ballState, {
        duration: 0.53,
        scale: 0,
        x: 0,
        y: 0,
        ease: 'none',
      });

      // Segment 5 : 78% → 85% — réapparition depuis le centre (scale 0 → 0.8)
      tl.to(ballState, {
        duration: 0.07,
        scale: 0.8,
        x: 0,
        y: 0,
        ease: 'power2.out',
      });

      // Segment 6 : 85% → 92% — grossit jusqu'à scale 1.2 (final glory)
      tl.to(ballState, {
        duration: 0.07,
        scale: 1.2,
        x: 0,
        y: 0,
        ease: 'power2.out',
      });

      // Segment 7 : 92% → 100% — reste stable centrée scale 1.2
      tl.to(ballState, {
        duration: 0.08,
        scale: 1.2,
        x: 0,
        y: 0,
        ease: 'none',
      });

      // === Cam orbite subtile (parallèle, ¼ tour total) ===
      // Donne un léger mouvement "vivant" sans masquer les écritures.
      gsap.to(camState, {
        theta: 60,
        ease: 'none',
        scrollTrigger: {
          trigger: document.documentElement,
          start: 'top top',
          end: 'bottom bottom',
          scrub: 0.6,
          invalidateOnRefresh: true,
          onUpdate: () => {
            applyCameraState();
            requestRender();
          },
        },
      });

      // Phi cloche (75 → 85 → 75) — léger survol au-dessus au milieu de page
      gsap.to(camState, {
        phi: 85,
        ease: 'sine.inOut',
        scrollTrigger: {
          trigger: document.documentElement,
          start: 'top top',
          end: '50% center',
          scrub: 0.6,
        },
      });
      gsap.to(camState, {
        phi: 75,
        ease: 'sine.inOut',
        scrollTrigger: {
          trigger: document.documentElement,
          start: '50% center',
          end: 'bottom bottom',
          scrub: 0.6,
        },
      });
    }

    // === Resize handler =============================================
    window.addEventListener('resize', () => {
      if (window.innerWidth <= 640) return;
      camera.aspect = window.innerWidth / window.innerHeight;
      camera.updateProjectionMatrix();
      renderer.setSize(window.innerWidth, window.innerHeight, false);
      requestRender();
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initScrollGolfBall);
  } else {
    initScrollGolfBall();
  }
</script>
