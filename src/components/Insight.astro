---
import { useT, type Locale } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useT(locale);
---

<section class="insight" id="insight">
  <div class="container insight-content">
    <span class="insight-eyebrow" data-anim="insight-eyebrow">{t.insight.eyebrow}</span>
    <h2 class="insight-title" data-anim="insight-title">{t.insight.title}</h2>
    <p class="insight-sub" data-anim="insight-sub">{t.insight.sub}</p>

    <div class="insight-mark" aria-hidden="true">
      <span class="insight-dot"></span>
      <span class="insight-dot insight-dot-mid"></span>
      <span class="insight-dot"></span>
    </div>
  </div>
</section>

<style>
  .insight {
    position: relative;
    background:
      radial-gradient(circle at 20% 30%, rgba(212, 165, 116, 0.10) 0%, transparent 50%),
      radial-gradient(circle at 80% 70%, rgba(212, 165, 116, 0.06) 0%, transparent 45%),
      linear-gradient(180deg, #0F2A1E 0%, #1B4332 100%);
    padding: clamp(80px, 14vh, 160px) 0;
    overflow: hidden;
    isolation: isolate;
    color: #F4EEDD;
  }
  .insight::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image:
      repeating-linear-gradient(0deg,
        rgba(255, 255, 255, 0.015) 0px,
        rgba(255, 255, 255, 0.015) 1px,
        transparent 1px,
        transparent 4px);
    opacity: 0.5;
    z-index: 0;
  }
  .insight-content {
    position: relative;
    z-index: 1;
    text-align: center;
    max-width: 900px;
  }
  .insight-eyebrow {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: #D4A574;
    margin-bottom: var(--space-6);
    padding-bottom: 6px;
    border-bottom: 1px solid rgba(212, 165, 116, 0.50);
  }
  .insight-title {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(2rem, 5.4vw, 4.4rem);
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: #F4EEDD;
    margin: 0 auto var(--space-5);
    max-width: 22ch;
  }
  .insight-sub {
    font-size: clamp(1rem, 1.6vw, 1.25rem);
    line-height: 1.55;
    color: rgba(244, 238, 221, 0.78);
    max-width: 52ch;
    margin: 0 auto;
  }
  .insight-mark {
    margin-top: var(--space-7);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
  }
  .insight-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgba(212, 165, 116, 0.45);
  }
  .insight-dot-mid {
    width: 10px;
    height: 10px;
    background: #D4A574;
    box-shadow: 0 0 0 4px rgba(212, 165, 116, 0.20);
  }

  @media (prefers-reduced-motion: no-preference) {
    @supports (animation-timeline: view()) {
      .insight-title {
        animation: insightTitleRise linear both;
        animation-timeline: view();
        animation-range: entry 0% cover 40%;
      }
      @keyframes insightTitleRise {
        from { opacity: 0; transform: translateY(28px); }
        to   { opacity: 1; transform: translateY(0); }
      }
      .insight-sub {
        animation: insightSubFade linear both;
        animation-timeline: view();
        animation-range: entry 10% cover 50%;
      }
      @keyframes insightSubFade {
        from { opacity: 0; }
        to   { opacity: 0.78; }
      }
    }
  }
</style>
