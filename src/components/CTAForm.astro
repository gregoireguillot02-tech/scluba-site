---
import { useT, type Locale } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useT(locale);

// Endpoint Formspree à brancher via PUBLIC_FORMSPREE_ENDPOINT (.env)
const formspreeEndpoint = import.meta.env.PUBLIC_FORMSPREE_ENDPOINT || 'https://formspree.io/f/YOUR_FORMSPREE_ID';
---

<section id="cta" class="cta">
  <div class="container">
    <div class="cta-card">
      <div class="cta-content">
        <span class="section-eyebrow cta-eyebrow">{t.cta.eyebrow}</span>
        <h2 class="cta-title">{t.cta.title}</h2>
        <p class="cta-lead">{t.cta.lead}</p>

        <form
          class="cta-form"
          data-anim="cta-form"
          action={formspreeEndpoint}
          method="POST"
        >
          <div class="form-row">
            <div class="form-field">
              <input type="text" name="name" required placeholder={t.cta.form.name} aria-label={t.cta.form.name} />
            </div>
            <div class="form-field">
              <input type="text" name="club" required placeholder={t.cta.form.club} aria-label={t.cta.form.club} />
            </div>
          </div>
          <div class="form-field">
            <input type="email" name="email" required placeholder={t.cta.form.email} aria-label={t.cta.form.email} />
          </div>
          <button type="submit" class="btn btn-accent form-submit" data-loading={t.cta.form.loading}>
            {t.cta.form.submit}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14"/>
              <path d="m12 5 7 7-7 7"/>
            </svg>
          </button>

          <div class="form-success" data-form-success>{t.cta.form.success}</div>
          <div class="form-error" data-form-error>{t.cta.form.error}</div>
        </form>
      </div>

      <div class="cta-qr" aria-hidden="true">
        <div class="cta-qr-frame">
          <svg viewBox="0 0 80 80" width="100%" height="auto">
            <rect width="80" height="80" fill="#FFFFFF" rx="2"/>
            <rect x="4" y="4" width="20" height="20" fill="#1B4332"/>
            <rect x="8" y="8" width="12" height="12" fill="#FFFFFF"/>
            <rect x="11" y="11" width="6" height="6" fill="#1B4332"/>
            <rect x="56" y="4" width="20" height="20" fill="#1B4332"/>
            <rect x="60" y="8" width="12" height="12" fill="#FFFFFF"/>
            <rect x="63" y="11" width="6" height="6" fill="#1B4332"/>
            <rect x="4" y="56" width="20" height="20" fill="#1B4332"/>
            <rect x="8" y="60" width="12" height="12" fill="#FFFFFF"/>
            <rect x="11" y="63" width="6" height="6" fill="#1B4332"/>
            <g fill="#1B4332">
              <rect x="28" y="4" width="4" height="4"/><rect x="36" y="4" width="4" height="4"/>
              <rect x="44" y="4" width="4" height="4"/><rect x="52" y="4" width="4" height="4"/>
              <rect x="28" y="12" width="4" height="4"/><rect x="40" y="12" width="4" height="4"/>
              <rect x="48" y="12" width="4" height="4"/><rect x="32" y="20" width="4" height="4"/>
              <rect x="44" y="20" width="4" height="4"/><rect x="52" y="20" width="4" height="4"/>
              <rect x="4" y="28" width="4" height="4"/><rect x="12" y="28" width="4" height="4"/>
              <rect x="24" y="28" width="4" height="4"/><rect x="32" y="28" width="4" height="4"/>
              <rect x="44" y="28" width="4" height="4"/><rect x="56" y="28" width="4" height="4"/>
              <rect x="64" y="28" width="4" height="4"/><rect x="72" y="28" width="4" height="4"/>
              <rect x="8" y="36" width="4" height="4"/><rect x="20" y="36" width="4" height="4"/>
              <rect x="28" y="36" width="4" height="4"/><rect x="36" y="36" width="4" height="4"/>
              <rect x="48" y="36" width="4" height="4"/><rect x="60" y="36" width="4" height="4"/>
              <rect x="68" y="36" width="4" height="4"/><rect x="4" y="44" width="4" height="4"/>
              <rect x="16" y="44" width="4" height="4"/><rect x="24" y="44" width="4" height="4"/>
              <rect x="40" y="44" width="4" height="4"/><rect x="52" y="44" width="4" height="4"/>
              <rect x="64" y="44" width="4" height="4"/><rect x="72" y="44" width="4" height="4"/>
              <rect x="12" y="52" width="4" height="4"/><rect x="28" y="52" width="4" height="4"/>
              <rect x="36" y="52" width="4" height="4"/><rect x="44" y="52" width="4" height="4"/>
              <rect x="56" y="52" width="4" height="4"/><rect x="68" y="52" width="4" height="4"/>
              <rect x="28" y="60" width="4" height="4"/><rect x="40" y="60" width="4" height="4"/>
              <rect x="48" y="60" width="4" height="4"/><rect x="60" y="60" width="4" height="4"/>
              <rect x="72" y="60" width="4" height="4"/><rect x="32" y="68" width="4" height="4"/>
              <rect x="40" y="68" width="4" height="4"/><rect x="52" y="68" width="4" height="4"/>
              <rect x="68" y="68" width="4" height="4"/>
            </g>
          </svg>
        </div>
        <p class="cta-qr-label">{t.cta.qrLabel}</p>
      </div>
    </div>
  </div>
</section>

<style>
  .cta {
    background: var(--bg);
  }

  .cta-card {
    background: linear-gradient(135deg, var(--primary) 0%, var(--primary-deep) 100%);
    border-radius: var(--radius-xl);
    padding: var(--space-8) var(--space-6);
    color: var(--bg);
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-7);
    align-items: center;
    box-shadow: var(--shadow-xl);
    overflow: hidden;
    position: relative;
  }
  .cta-card::before {
    content: "";
    position: absolute;
    top: -100px; right: -100px;
    width: 300px; height: 300px;
    background: radial-gradient(circle, rgba(212, 165, 116, 0.25), transparent 70%);
  }
  @media (min-width: 900px) {
    .cta-card {
      grid-template-columns: 1.5fr auto;
      padding: var(--space-9) var(--space-8);
    }
  }

  .cta-content {
    position: relative;
    z-index: 1;
  }
  .cta-eyebrow {
    color: var(--accent) !important;
    margin-bottom: var(--space-3);
  }
  .cta-title {
    font-family: var(--font-serif);
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    line-height: 1.15;
    color: var(--bg);
    margin-bottom: var(--space-3);
    max-width: 18ch;
  }
  .cta-lead {
    color: var(--accent-soft);
    font-size: var(--text-md);
    margin-bottom: var(--space-6);
    max-width: 48ch;
    line-height: 1.5;
  }

  .cta-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    max-width: 480px;
  }
  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3);
  }
  @media (max-width: 480px) {
    .form-row { grid-template-columns: 1fr; }
  }

  .form-field input {
    width: 100%;
    padding: 14px 16px;
    border-radius: var(--radius-md);
    border: 1px solid rgba(255, 255, 255, 0.18);
    background: rgba(255, 255, 255, 0.06);
    color: var(--bg);
    font-size: var(--text-base);
    transition: background 0.2s var(--ease-out), border-color 0.2s var(--ease-out);
  }
  .form-field input::placeholder {
    color: rgba(255, 255, 255, 0.45);
  }
  .form-field input:focus {
    outline: none;
    background: rgba(255, 255, 255, 0.12);
    border-color: var(--accent);
  }

  .form-submit {
    margin-top: var(--space-2);
    align-self: flex-start;
    padding: 14px 28px;
  }
  .form-submit:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .form-success,
  .form-error {
    display: none;
    padding: 14px 16px;
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    margin-top: var(--space-3);
  }
  .form-success {
    background: rgba(212, 165, 116, 0.18);
    border: 1px solid var(--accent);
    color: var(--accent-soft);
  }
  .form-error {
    background: rgba(192, 57, 43, 0.18);
    border: 1px solid #C0392B;
    color: #FFB4AC;
  }

  .cta-qr {
    position: relative;
    z-index: 1;
    text-align: center;
    justify-self: center;
  }
  .cta-qr-frame {
    width: 160px;
    height: 160px;
    background: var(--bg);
    padding: var(--space-3);
    border-radius: var(--radius-lg);
    box-shadow: 0 10px 32px rgba(0, 0, 0, 0.3);
  }
  .cta-qr-label {
    margin-top: var(--space-3);
    color: var(--accent-soft);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.16em;
  }
</style>
