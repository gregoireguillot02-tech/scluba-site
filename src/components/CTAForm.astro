---
import QRCode from 'qrcode';
import { useT, type Locale } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useT(locale);

// QR fonctionnel — pointe vers la page de démo "Golf du Soleil" (carte récap fictive).
const demoUrl = (import.meta.env.PUBLIC_DEMO_URL as string | undefined) ?? 'https://scluba.com/demo';
const qrSvg = await QRCode.toString(demoUrl, {
  type: 'svg',
  errorCorrectionLevel: 'M',
  margin: 0,
  color: { dark: '#1B4332', light: '#FFFFFF' },
});
---

<section id="cta" class="cta">
  <div class="container">
    <div class="cta-card">
      <div class="cta-content">
        <span class="section-eyebrow cta-eyebrow">{t.cta.eyebrow}</span>
        <h2 class="cta-title">{t.cta.title}</h2>
        <p class="cta-lead">{t.cta.lead}</p>

        <form
          class="cta-form"
          data-anim="cta-form"
          data-error-required={t.cta.form.errors.required}
          data-error-email={t.cta.form.errors.email}
          novalidate
        >
          <div class="form-row">
            <div class="form-field">
              <label for="cta-name" class="sr-only">{t.cta.form.name}</label>
              <input
                id="cta-name"
                type="text"
                name="name"
                required
                aria-required="true"
                autocomplete="name"
                placeholder={t.cta.form.name}
                aria-describedby="cta-name-error"
              />
              <span class="form-field-error" id="cta-name-error" data-field-error="name" role="alert" aria-live="polite"></span>
            </div>
            <div class="form-field">
              <label for="cta-club" class="sr-only">{t.cta.form.club}</label>
              <input
                id="cta-club"
                type="text"
                name="club"
                required
                aria-required="true"
                autocomplete="organization"
                placeholder={t.cta.form.club}
                aria-describedby="cta-club-error"
              />
              <span class="form-field-error" id="cta-club-error" data-field-error="club" role="alert" aria-live="polite"></span>
            </div>
          </div>
          <div class="form-field">
            <label for="cta-email" class="sr-only">{t.cta.form.email}</label>
            <input
              id="cta-email"
              type="email"
              name="email"
              required
              aria-required="true"
              autocomplete="email"
              inputmode="email"
              placeholder={t.cta.form.email}
              aria-describedby="cta-email-error"
            />
            <span class="form-field-error" id="cta-email-error" data-field-error="email" role="alert" aria-live="polite"></span>
          </div>
          <p class="form-required-hint" aria-hidden="true">{t.cta.form.requiredHint}</p>
          <button type="submit" class="btn btn-accent form-submit" data-loading={t.cta.form.loading}>
            {t.cta.form.submit}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14"/>
              <path d="m12 5 7 7-7 7"/>
            </svg>
          </button>

          <div class="form-success" data-form-success role="status" aria-live="polite">{t.cta.form.success}</div>
          <div class="form-error" data-form-error role="alert" aria-live="assertive">{t.cta.form.error}</div>
        </form>
      </div>

      <a href="/demo" class="cta-qr" aria-label={t.cta.qrLabel} target="_blank" rel="noopener">
        <div class="cta-qr-frame" set:html={qrSvg}></div>
        <p class="cta-qr-label">{t.cta.qrLabel}</p>
      </a>
    </div>
  </div>
</section>

<style>
  .cta {
    background: var(--bg);
  }

  .cta-card {
    background: linear-gradient(135deg, var(--primary) 0%, var(--primary-deep) 100%);
    border-radius: var(--radius-xl);
    padding: var(--space-8) var(--space-6);
    color: var(--bg);
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-7);
    align-items: center;
    box-shadow: var(--shadow-xl);
    overflow: hidden;
    position: relative;
  }
  .cta-card::before {
    content: "";
    position: absolute;
    top: -100px; right: -100px;
    width: 300px; height: 300px;
    background: radial-gradient(circle, rgba(212, 165, 116, 0.25), transparent 70%);
  }
  @media (min-width: 900px) {
    .cta-card {
      grid-template-columns: 1.5fr auto;
      padding: var(--space-9) var(--space-8);
    }
  }

  .cta-content {
    position: relative;
    z-index: 1;
  }
  .cta-eyebrow {
    color: var(--accent) !important;
    margin-bottom: var(--space-3);
  }
  .cta-title {
    font-family: var(--font-serif);
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    line-height: 1.15;
    color: var(--bg);
    margin-bottom: var(--space-3);
    max-width: 18ch;
  }
  .cta-lead {
    color: var(--accent-soft);
    font-size: var(--text-md);
    margin-bottom: var(--space-6);
    max-width: 48ch;
    line-height: 1.5;
  }

  .cta-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    max-width: 480px;
  }
  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3);
  }
  @media (max-width: 480px) {
    .form-row { grid-template-columns: 1fr; }
  }

  .form-field {
    position: relative;
  }
  .form-field input {
    width: 100%;
    padding: 14px 16px;
    border-radius: var(--radius-md);
    border: 1px solid rgba(255, 255, 255, 0.22);
    background: rgba(255, 255, 255, 0.06);
    color: var(--bg);
    font-size: var(--text-base);
    transition: background 0.2s var(--ease-out), border-color 0.2s var(--ease-out);
  }
  .form-field input::placeholder {
    color: rgba(255, 255, 255, 0.78);
  }
  .form-field input:focus {
    outline: none;
    background: rgba(255, 255, 255, 0.12);
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(212, 165, 116, 0.35);
  }
  .form-field input[aria-invalid="true"] {
    border-color: #FFB4AC;
    background: rgba(192, 57, 43, 0.10);
  }
  .form-field-error {
    display: block;
    min-height: 0;
    margin-top: 4px;
    font-size: var(--text-xs);
    color: #FFB4AC;
    line-height: 1.4;
  }
  .form-field-error:empty {
    margin-top: 0;
  }

  .form-required-hint {
    margin: 0;
    font-size: var(--text-xs);
    color: rgba(255, 255, 255, 0.7);
  }

  .form-submit {
    margin-top: var(--space-2);
    align-self: flex-start;
    padding: 14px 28px;
  }
  .form-submit:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .form-success,
  .form-error {
    display: none;
    padding: 14px 16px;
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    margin-top: var(--space-3);
  }
  .form-success {
    background: rgba(212, 165, 116, 0.18);
    border: 1px solid var(--accent);
    color: var(--accent-soft);
  }
  .form-error {
    background: rgba(192, 57, 43, 0.18);
    border: 1px solid #C0392B;
    color: #FFB4AC;
  }

  .cta-qr {
    position: relative;
    z-index: 1;
    text-align: center;
    justify-self: center;
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    text-decoration: none;
    color: inherit;
    transition: transform 0.3s var(--ease-out);
  }
  .cta-qr:hover { transform: translateY(-3px); }
  .cta-qr:hover .cta-qr-frame {
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.42);
  }
  .cta-qr-frame {
    width: 160px;
    height: 160px;
    background: var(--bg);
    padding: var(--space-3);
    border-radius: var(--radius-lg);
    box-shadow: 0 10px 32px rgba(0, 0, 0, 0.3);
    transition: box-shadow 0.3s var(--ease-out);
  }
  .cta-qr-frame :global(svg) {
    width: 100%;
    height: 100%;
    display: block;
    shape-rendering: crispEdges;
  }
  .cta-qr-label {
    margin-top: var(--space-3);
    color: var(--accent-soft);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.16em;
  }
</style>
