---
import QRCode from 'qrcode';
import { useT, type Locale } from '../i18n';
import Honeypot from './Honeypot.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useT(locale);

// QR du landing — pointe sur /demo, page teaser générique.
const demoUrl = (import.meta.env.PUBLIC_DEMO_URL as string | undefined) ?? 'https://scluba.com/demo';
// QR couleur wood (encre éditoriale) sur fond paper pour cohérence avec
// l'identité "The Golfer's Journal". Plus de forest tech-green.
const qrSvg = await QRCode.toString(demoUrl, {
  type: 'svg',
  errorCorrectionLevel: 'M',
  margin: 0,
  color: { dark: '#3D2914', light: '#FAF5E8' },
});
---

<section id="cta" class="cta-editorial">
  <div class="container">
    <div class="cta-plate">
      <div class="cta-content">
        <p class="cta-eyebrow">
          <span class="cta-eyebrow-rule" aria-hidden="true"></span>
          <span>{t.cta.eyebrow}</span>
        </p>
        <h2 class="cta-title">{t.cta.title}</h2>
        <p class="cta-lead">{t.cta.lead}</p>

        <form class="cta-form" data-anim="cta-form" novalidate>
          <div class="form-row">
            <div class="form-field">
              <input
                type="text"
                name="name"
                required
                maxlength="120"
                placeholder={t.cta.form.name}
                aria-label={t.cta.form.name}
              />
            </div>
            <div class="form-field">
              <input
                type="text"
                name="club"
                required
                maxlength="120"
                placeholder={t.cta.form.club}
                aria-label={t.cta.form.club}
              />
            </div>
          </div>
          <div class="form-field">
            <input
              type="email"
              name="email"
              required
              maxlength="254"
              placeholder={t.cta.form.email}
              aria-label={t.cta.form.email}
            />
          </div>
          <Honeypot />
          <button
            type="submit"
            class="cta-submit"
            data-loading={t.cta.form.loading}
          >
            <span>{t.cta.form.submit}</span>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14" />
              <path d="m12 5 7 7-7 7" />
            </svg>
          </button>

          <div class="form-success" data-form-success>{t.cta.form.success}</div>
          <div class="form-error" data-form-error>{t.cta.form.error}</div>
        </form>
      </div>

      <a href="/demo" class="cta-qr" aria-label={t.cta.qrLabel} target="_blank" rel="noopener">
        <div class="cta-qr-frame" set:html={qrSvg}></div>
        <p class="cta-qr-label">{t.cta.qrLabel}</p>
      </a>
    </div>
  </div>
</section>

<style>
  .cta-editorial {
    background: var(--paper);
    padding-top: var(--space-9);
    padding-bottom: var(--space-9);
  }

  .cta-plate {
    background: var(--paper-warm);
    border: 1px solid var(--rule-wood);
    border-radius: 4px;
    padding: clamp(var(--space-6), 5vw, var(--space-8));
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-7);
    align-items: center;
    /* Plaque gravée — pas un card SaaS brillant. Shadow tinté wood. */
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.6),
      0 24px 48px rgba(61, 41, 20, 0.10),
      0 6px 14px rgba(61, 41, 20, 0.06);
    position: relative;
  }
  @media (min-width: 900px) {
    .cta-plate {
      grid-template-columns: 1.5fr auto;
      padding: var(--space-9) var(--space-8);
    }
  }

  .cta-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .cta-eyebrow {
    margin: 0;
    display: flex;
    align-items: center;
    gap: 0.8em;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--brass);
  }
  .cta-eyebrow-rule {
    display: inline-block;
    width: 24px;
    height: 1px;
    background: var(--brass);
  }

  .cta-title {
    margin: 0;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 700;
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    line-height: 1.15;
    color: var(--wood);
    letter-spacing: -0.02em;
    text-wrap: balance;
    max-width: 22ch;
    font-variation-settings: 'opsz' 96, 'SOFT' 50, 'WONK' 0;
  }
  .cta-lead {
    margin: 0;
    font-family: var(--font-body-serif);
    font-size: 1.0625rem;
    color: var(--wood-soft);
    max-width: 48ch;
    line-height: 1.6;
  }

  /* === Form fields paper ============================================ */
  .cta-form {
    margin-top: var(--space-3);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    max-width: 480px;
  }
  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3);
  }
  @media (max-width: 480px) {
    .form-row { grid-template-columns: 1fr; }
  }

  .form-field input {
    width: 100%;
    padding: 14px 16px;
    border-radius: 2px;
    border: 1px solid var(--rule-wood);
    background: var(--paper);
    color: var(--wood);
    font-family: var(--font-body-serif);
    font-size: 1rem;
    transition:
      background var(--motion-fast) var(--ease-out),
      border-color var(--motion-fast) var(--ease-out),
      box-shadow var(--motion-fast) var(--ease-out);
  }
  .form-field input::placeholder {
    color: var(--graphite);
    opacity: 0.7;
    font-style: italic;
  }
  .form-field input:focus {
    outline: none;
    background: #FFFEF9;
    border-color: var(--brass);
    box-shadow: 0 0 0 3px rgba(176, 141, 87, 0.18);
  }

  /* CTA submit — brass-plate identique au Hero. */
  .cta-submit {
    margin-top: var(--space-2);
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: 0.6em;
    padding: 14px 28px;
    background: var(--brass);
    color: var(--ink-editorial);
    font-family: var(--font-mono);
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    border: 1px solid var(--brass-deep);
    border-radius: 2px;
    cursor: pointer;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.28),
      inset 0 -1px 0 rgba(0, 0, 0, 0.12),
      0 8px 18px rgba(61, 41, 20, 0.18);
    transition: transform var(--motion-fast) var(--ease-out), background var(--motion-fast) var(--ease-out);
  }
  .cta-submit:hover {
    background: var(--brass-deep);
    transform: translateY(-1px);
  }
  .cta-submit:active { transform: translateY(0); }
  .cta-submit:disabled {
    opacity: 0.55;
    cursor: not-allowed;
    transform: none;
  }
  .cta-submit:focus-visible {
    outline: 2px solid var(--sage-deep);
    outline-offset: 3px;
  }

  /* Feedback states */
  .form-success,
  .form-error {
    display: none;
    padding: 12px 16px;
    border-radius: 2px;
    font-family: var(--font-body-serif);
    font-size: 0.95rem;
    margin-top: var(--space-3);
  }
  .form-success {
    background: rgba(92, 122, 74, 0.10);
    border: 1px solid var(--sage);
    color: var(--sage-deep);
    font-style: italic;
  }
  .form-error {
    background: rgba(192, 57, 43, 0.08);
    border: 1px solid #C0392B;
    color: #8B2A1F;
  }

  /* === QR code — encadrement plaque cream ========================== */
  .cta-qr {
    text-align: center;
    justify-self: center;
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    text-decoration: none;
    color: var(--wood);
    transition: transform var(--motion-mid) var(--ease-out);
  }
  .cta-qr:hover { transform: translateY(-2px); }
  .cta-qr-frame {
    width: 160px;
    height: 160px;
    background: var(--paper);
    padding: var(--space-3);
    border: 1px solid var(--rule-wood);
    border-radius: 2px;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.6),
      0 8px 20px rgba(61, 41, 20, 0.12);
    transition: box-shadow var(--motion-mid) var(--ease-out);
  }
  .cta-qr:hover .cta-qr-frame {
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.6),
      0 14px 30px rgba(61, 41, 20, 0.18);
  }
  .cta-qr-frame :global(svg) {
    width: 100%;
    height: 100%;
    display: block;
    shape-rendering: crispEdges;
  }
  .cta-qr-label {
    margin-top: var(--space-3);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 500;
    color: var(--graphite);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    max-width: 18ch;
  }
</style>
