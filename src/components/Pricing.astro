---
import { useT, type Locale } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useT(locale);
---

<section id="pricing" class="pricing">
  <div class="container">
    <div class="section-header" data-anim="section-header">
      <span class="section-eyebrow">{t.pricing.eyebrow}</span>
      <h2 class="section-title">{t.pricing.title}</h2>
      <p class="section-lead">{t.pricing.lead}</p>
    </div>

    <div class="pricing-grid">
      <aside class="pricing-trust" aria-label="Garanties">
        <div class="trust-badge">
          <span class="trust-icon" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 12l2 2 4-4"/>
              <circle cx="12" cy="12" r="9"/>
            </svg>
          </span>
          <div class="trust-text">
            <strong>{t.pricing.trust.engagement_label}</strong>
            <span>{t.pricing.trust.engagement_note}</span>
          </div>
        </div>

        <div class="trust-badge">
          <span class="trust-icon" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="9"/>
              <path d="M12 7v5l3 2"/>
            </svg>
          </span>
          <div class="trust-text">
            <strong>{t.pricing.trust.setup_label}</strong>
            <span>{t.pricing.trust.setup_note}</span>
          </div>
        </div>

        <div class="trust-badge">
          <span class="trust-icon" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2v4"/>
              <path d="M12 18v4"/>
              <path d="M4.93 4.93l2.83 2.83"/>
              <path d="M16.24 16.24l2.83 2.83"/>
              <path d="M2 12h4"/>
              <path d="M18 12h4"/>
              <circle cx="12" cy="12" r="3"/>
            </svg>
          </span>
          <div class="trust-text">
            <strong>{t.pricing.trust.trial_label}</strong>
            <span>{t.pricing.trust.trial_note}</span>
          </div>
        </div>

        <div class="trust-badge">
          <span class="trust-icon" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2L3 6v6c0 5 4 9 9 10 5-1 9-5 9-10V6l-9-4z"/>
            </svg>
          </span>
          <div class="trust-text">
            <strong>{t.pricing.trust.rgpd_label}</strong>
            <span>{t.pricing.trust.rgpd_note}</span>
          </div>
        </div>
      </aside>

      <div class="pricing-single">
        {t.pricing.plans.map((plan) => (
          <article class="plan plan-featured" data-anim="plan">
            <div class="plan-launch-badge">
              <span class="launch-pulse-mini" aria-hidden="true"></span>
              {t.pricing.launchBadge}
            </div>

            <div class="plan-head">
              <div>
                <h3 class="plan-name">{plan.name}</h3>
                <p class="plan-tagline">{plan.tagline}</p>
              </div>
              <div class="plan-price">
                <span class="plan-price-num">{plan.price}</span>
                <span class="plan-price-period">{plan.period}</span>
              </div>
            </div>

            <p class="plan-engagement">{plan.engagement}</p>

            <ul class="plan-features">
              {plan.features.map((feature) => (
                <li>
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M20 6 9 17l-5-5"/>
                  </svg>
                  <span>{feature}</span>
                </li>
              ))}
            </ul>

            <a href="#cta" class="btn btn-primary plan-cta">
              {t.nav.demo}
            </a>
          </article>
        ))}
      </div>

      <aside class="pricing-contact" aria-label="Contact">
        <div class="contact-block">
          <span class="contact-label">{t.pricing.trust.contact_label}</span>
          <a href={`mailto:${t.pricing.trust.contact_email}`} class="contact-email">
            {t.pricing.trust.contact_email}
          </a>
        </div>
      </aside>
    </div>
  </div>
</section>

<style>
  .pricing {
    background: var(--bg);
  }

  /* Layout 3-col desktop : trust badges gauche, pricing card centre, contact
     droite. Sur mobile (≤900px), retombe en 1-col stack. */
  .pricing-grid {
    display: grid;
    grid-template-columns: 1fr;
    /* gap mobile > 48px pour que l'aura honey de .plan-featured::before
       (inset -24px + blur 24px) ne déborde pas sur la contact card en dessous */
    gap: var(--space-8);
    align-items: start;
    padding-top: var(--space-4);
    justify-content: center;
  }
  @media (min-width: 900px) {
    .pricing-grid {
      grid-template-columns: 220px minmax(360px, 460px) 220px;
      gap: var(--space-6);
    }
  }

  /* === Trust badges (sidebar gauche) === */
  .pricing-trust {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  @media (min-width: 900px) {
    .pricing-trust {
      padding-top: var(--space-6);
    }
  }
  .trust-badge {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    padding: var(--space-4);
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    background: rgba(255, 255, 255, 0.55);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }
  .trust-icon {
    flex-shrink: 0;
    color: var(--accent);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-top: 2px;
  }
  .trust-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }
  .trust-text strong {
    font-family: var(--font-serif);
    font-size: var(--text-base);
    font-weight: 700;
    color: var(--primary);
    line-height: 1.2;
  }
  .trust-text span {
    font-size: var(--text-xs);
    color: var(--muted);
    line-height: 1.4;
  }

  /* === Contact bloc (sidebar droite, ancré en bas) === */
  .pricing-contact {
    display: flex;
    align-items: flex-end;
    height: 100%;
  }
  @media (max-width: 899px) {
    .pricing-contact {
      align-items: stretch;
    }
  }
  .contact-block {
    width: 100%;
    padding: var(--space-4);
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    /* bg plus opaque (0.92 vs 0.55) : empêche l'aura honey du plan-featured
       de bleed visuellement à travers le contact card en mobile stack */
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }
  .contact-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent);
    font-weight: 500;
  }
  .contact-email {
    font-family: var(--font-serif);
    font-size: var(--text-md);
    font-weight: 700;
    color: var(--primary);
    text-decoration: none;
    word-break: break-all;
    transition: color 0.2s var(--ease-out);
  }
  .contact-email:hover {
    color: var(--accent);
  }

  .pricing-single {
    display: flex;
    justify-content: center;
    width: 100%;
  }
  .pricing-single .plan { width: 100%; }

  .plan {
    position: relative;
    background: var(--paper, var(--bg));
    border: 1.5px solid var(--line);
    border-radius: var(--radius-lg);
    padding: var(--space-7) var(--space-6);
    display: flex;
    flex-direction: column;
    transition: transform 0.4s var(--ease-out), box-shadow 0.4s var(--ease-out), border-color 0.4s var(--ease-out);
    isolation: isolate;
  }
  .plan:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
    border-color: var(--accent);
  }

  .plan-featured {
    border-color: var(--accent);
    background: var(--paper-deep, var(--bg));
    box-shadow: var(--shadow-md);
  }

  /* V6 — Aura pulsée vert néon autour de la card (signature Pricing).
     Radial-gradient animé qui respire 4s. Désactivé en reduced-motion. */
  .plan-featured::before {
    content: "";
    position: absolute;
    inset: -24px;
    z-index: -1;
    border-radius: calc(var(--radius-lg) + 24px);
    background: radial-gradient(
      ellipse at center,
      rgba(212, 165, 116, 0.22) 0%,
      rgba(212, 165, 116, 0.08) 35%,
      transparent 70%
    );
    filter: blur(24px);
    opacity: 0.65;
    pointer-events: none;
    animation: planAuraPulse 4s ease-in-out infinite;
  }
  @keyframes planAuraPulse {
    0%, 100% {
      opacity: 0.55;
      transform: scale(0.97);
    }
    50% {
      opacity: 0.85;
      transform: scale(1.02);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .plan-featured::before {
      animation: none;
      opacity: 0.45;
    }
  }

  /* Badge "1er mois offert" */
  .plan-launch-badge {
    position: absolute;
    top: 16px;
    right: 16px;
    background: var(--primary-deep);
    color: var(--accent);
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.14em;
    padding: 5px 10px 5px 14px;
    border-radius: var(--radius-full);
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .launch-pulse-mini {
    position: absolute;
    left: 6px;
    top: 50%;
    transform: translateY(-50%);
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 0 0 var(--accent);
    animation: pulseMini 2s ease-in-out infinite;
  }
  @keyframes pulseMini {
    0% { box-shadow: 0 0 0 0 rgba(212, 165, 116, 0.7); }
    70% { box-shadow: 0 0 0 5px rgba(212, 165, 116, 0); }
    100% { box-shadow: 0 0 0 0 rgba(212, 165, 116, 0); }
  }

  .plan-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-3);
    margin-bottom: var(--space-3);
    margin-top: var(--space-3);
  }
  .plan-name {
    font-size: var(--text-xl);
    color: var(--primary);
    line-height: 1;
    margin-bottom: 4px;
  }
  .plan-tagline {
    font-size: var(--text-sm);
    color: var(--muted);
    max-width: 24ch;
    line-height: 1.3;
  }
  .plan-price {
    text-align: right;
    flex-shrink: 0;
  }
  .plan-price-num {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: 900;
    color: var(--primary);
    line-height: 1;
    letter-spacing: -0.03em;
  }
  .plan-price-period {
    font-size: var(--text-sm);
    color: var(--muted);
    margin-left: 2px;
  }

  .plan-engagement {
    font-size: var(--text-sm);
    color: var(--primary-soft);
    padding-bottom: var(--space-4);
    border-bottom: 1px dashed var(--line);
    margin-bottom: var(--space-4);
  }

  .plan-features {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    flex: 1;
  }
  .plan-features li {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    font-size: var(--text-sm);
    color: var(--ink);
    line-height: 1.45;
  }
  .plan-features svg {
    color: var(--accent);
    flex-shrink: 0;
    margin-top: 4px;
  }
  .plan-featured .plan-features svg {
    color: var(--primary);
  }

  .plan-cta {
    width: 100%;
    text-align: center;
    margin-top: auto;
  }
</style>
