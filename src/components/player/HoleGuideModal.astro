---
/**
 * Modale PLEIN ÉCRAN affichant le visuel du carnet de parcours d'un trou.
 * Exposée globalement via window.openHoleGuideModal(url, holeNumber) ; appelée
 * depuis le bouton "Voir le trou" de play.astro. L'image vit dans le bucket
 * public club-assets (même origine que le logo club → couverte par la CSP img-src).
 *
 * Un carnet de trou a des détails fins (distances, tracé) → la modale occupe
 * tout l'écran et l'image est mise à l'échelle pour le remplir (object-fit:
 * contain sur une box 100%×100% : elle grandit même si sa résolution est
 * modeste, au lieu de rester à sa taille naturelle). Un tap dessus bascule en
 * zoom 2x avec défilement (pan) pour inspecter le détail.
 */
---

<div class="hg-modal" id="hole-guide-modal" data-hole-guide-modal hidden>
  <div class="hg-overlay" data-hg-close>
    <div class="hg-sheet" role="dialog" aria-modal="true" aria-label="Vue du trou">
      <header class="hg-head">
        <span class="hg-title" data-hg-title>Trou</span>
        <span class="hg-hint" data-hg-hint>Tapez l'image pour zoomer</span>
        <button type="button" class="hg-close" data-hg-close aria-label="Fermer">✕</button>
      </header>
      <div class="hg-body" data-hg-body>
        <img class="hg-img" data-hg-img alt="" />
      </div>
    </div>
  </div>
</div>

<style>
  .hg-modal[hidden] { display: none; }
  .hg-overlay {
    position: fixed;
    inset: 0;
    background: rgba(15, 42, 30, 0.92);
    backdrop-filter: blur(8px) saturate(120%);
    -webkit-backdrop-filter: blur(8px) saturate(120%);
    display: flex;
    z-index: 1000;
    padding: 0;
  }
  /* Plein écran : pas de carte centrée, on prend tout l'espace. */
  .hg-sheet {
    background: rgba(250, 247, 238, 0.96);
    width: 100%;
    height: 100dvh;
    max-height: 100dvh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  .hg-head {
    flex: 0 0 auto;
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 16px;
    border-bottom: 1px solid rgba(15, 42, 30, 0.08);
  }
  .hg-title {
    font-family: var(--font-display, var(--font-serif));
    font-weight: 800;
    font-size: 16px;
    color: var(--primary, #1B4332);
    letter-spacing: 0.01em;
  }
  .hg-hint {
    flex: 1 1 auto;
    font-size: 11px;
    color: var(--muted, #6B7280);
    text-align: center;
  }
  .hg-close {
    appearance: none;
    border: none;
    background: transparent;
    font-size: 22px;
    line-height: 1;
    cursor: pointer;
    color: var(--muted, #6B7280);
    padding: 4px 10px;
    border-radius: 8px;
    touch-action: manipulation;
  }
  .hg-close:hover { color: var(--ink, #0F2A1E); background: rgba(15, 42, 30, 0.06); }
  .hg-body {
    flex: 1 1 auto;
    min-height: 0;
    overflow: auto;
    -webkit-overflow-scrolling: touch;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 6px;
  }
  /* Par défaut : la box image remplit toute la surface ; object-fit: contain
     met l'image à l'échelle (vers le haut si besoin) en gardant le ratio. */
  .hg-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    cursor: zoom-in;
    touch-action: manipulation;
  }
  /* Zoomé : l'image dépasse le cadre, le body devient scrollable (pan). */
  .hg-body.is-zoomed {
    align-items: flex-start;
    justify-content: flex-start;
  }
  .hg-body.is-zoomed .hg-img {
    width: 200%;
    height: auto;
    object-fit: contain;
    cursor: zoom-out;
  }
</style>

<script>
  const modal = document.querySelector<HTMLElement>('[data-hole-guide-modal]');
  if (modal) {
    const img = modal.querySelector<HTMLImageElement>('[data-hg-img]');
    const titleEl = modal.querySelector<HTMLElement>('[data-hg-title]');
    const body = modal.querySelector<HTMLElement>('[data-hg-body]');

    function resetZoom() {
      body?.classList.remove('is-zoomed');
      if (body) body.scrollTo(0, 0);
    }
    function close() {
      modal!.hidden = true;
      resetZoom();
      if (img) img.removeAttribute('src');
    }
    (window as any).openHoleGuideModal = function (url: string, holeNumber: number) {
      if (!url) return;
      resetZoom();
      if (img) { img.src = url; img.alt = `Trou ${holeNumber}`; }
      if (titleEl) titleEl.textContent = `Trou ${holeNumber}`;
      modal.hidden = false;
    };
    // Tap sur l'image : bascule zoom 2x ↔ ajusté, recentré sur le point tapé.
    img?.addEventListener('click', (e) => {
      if (!body) return;
      const zooming = !body.classList.contains('is-zoomed');
      body.classList.toggle('is-zoomed', zooming);
      if (zooming) {
        const rect = img.getBoundingClientRect();
        const relX = (e.clientX - rect.left) / rect.width;
        const relY = (e.clientY - rect.top) / rect.height;
        requestAnimationFrame(() => {
          body.scrollLeft = relX * (body.scrollWidth - body.clientWidth);
          body.scrollTop = relY * (body.scrollHeight - body.clientHeight);
        });
      }
    });
    // Ferme via le bouton ✕ (clic direct dessus). En plein écran l'overlay est
    // entièrement couvert par la sheet, donc le ✕ est la sortie principale.
    modal.querySelectorAll<HTMLElement>('[data-hg-close]').forEach((el) => {
      el.addEventListener('click', (e) => {
        if (e.target === el) close();
      });
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !modal.hidden) close();
    });
  }
</script>
