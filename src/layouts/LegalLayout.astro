---
import '../styles/tokens.css';
import '../styles/global.css';

interface Props {
  locale: 'fr' | 'en';
  title: string;
  description: string;
  altPathname: string;
  eyebrow: string;
  updated: string;
}

const { locale, title, description, altPathname, eyebrow, updated } = Astro.props;

const homeHref = locale === 'fr' ? '/' : '/en/';
const homeLabel = locale === 'fr' ? 'Accueil' : 'Home';
const updatedLabel = locale === 'fr' ? 'Dernière mise à jour' : 'Last updated';
const updatedDate = new Date(updated).toLocaleDateString(
  locale === 'fr' ? 'fr-FR' : 'en-US',
  { year: 'numeric', month: 'long', day: 'numeric' },
);
---

<!doctype html>
<html lang={locale}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title>{title} · Scluba</title>
  <meta name="description" content={description} />
  <meta name="theme-color" content="#FAF7EE" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="alternate" hreflang={locale === 'fr' ? 'en' : 'fr'} href={altPathname} />
</head>
<body>
  <main class="legal">
    <header class="legal-head">
      <a href={homeHref} class="legal-back">← {homeLabel}</a>
      <p class="legal-eyebrow">{eyebrow}</p>
      <div class="legal-rail" aria-hidden="true"></div>
      <h1 class="legal-title">{title}</h1>
      <div class="legal-rail" aria-hidden="true"></div>
      <p class="legal-updated">{updatedLabel} : <time datetime={updated}>{updatedDate}</time></p>
    </header>

    <article class="legal-body">
      <slot />
    </article>

    <footer class="legal-colophon">
      <span class="colophon-rail" aria-hidden="true"></span>
      <span class="colophon-text">
        <span>by</span>
        <strong>SCLUBA</strong>
        <span class="colophon-dot" aria-hidden="true"></span>
      </span>
      <span class="colophon-rail" aria-hidden="true"></span>
    </footer>
  </main>

  <style>
    body { background: #FAF7EE; min-height: 100dvh; margin: 0; }
    .legal {
      max-width: 720px;
      margin: 0 auto;
      padding: var(--space-7) var(--space-5) var(--space-7);
    }
    .legal-head { text-align: center; margin-bottom: var(--space-7); }
    .legal-back {
      display: inline-block;
      font-size: 13px;
      color: var(--muted);
      text-decoration: none;
      margin-bottom: var(--space-5);
    }
    .legal-back:hover { color: var(--primary); }
    .legal-eyebrow {
      margin: 0 0 var(--space-2);
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--accent);
    }
    .legal-rail {
      width: 64px; height: 1px;
      margin: 0 auto;
      background: var(--accent);
      opacity: 0.55;
    }
    .legal-title {
      margin: var(--space-3) auto;
      font-family: var(--font-serif);
      font-weight: 700;
      font-size: clamp(1.6rem, 5.5vw, 2.4rem);
      line-height: 1.2;
      letter-spacing: -0.005em;
      color: var(--primary);
    }
    .legal-updated {
      margin: var(--space-3) 0 0;
      font-size: 12px;
      color: var(--muted);
    }

    .legal-body {
      color: var(--ink);
      font-size: 15px;
      line-height: 1.65;
    }
    .legal-body :global(h2) {
      font-family: var(--font-serif);
      font-size: 22px;
      color: var(--primary);
      margin: var(--space-6) 0 var(--space-3);
      letter-spacing: 0.005em;
    }
    .legal-body :global(h3) {
      font-family: var(--font-serif);
      font-size: 17px;
      color: var(--primary);
      margin: var(--space-5) 0 var(--space-2);
    }
    .legal-body :global(p),
    .legal-body :global(ul),
    .legal-body :global(ol) {
      margin: 0 0 var(--space-3);
    }
    .legal-body :global(ul),
    .legal-body :global(ol) {
      padding-left: 1.5rem;
    }
    .legal-body :global(li) { margin-bottom: 6px; }
    .legal-body :global(a) {
      color: var(--primary);
      text-decoration: underline;
      text-underline-offset: 2px;
    }
    .legal-body :global(.legal-callout) {
      background: rgba(212, 165, 116, 0.10);
      border-left: 3px solid var(--accent);
      padding: var(--space-3) var(--space-4);
      border-radius: 4px;
      margin: var(--space-3) 0 var(--space-5);
      font-size: 14px;
    }
    .legal-body :global(.legal-callout strong) {
      display: block;
      color: var(--primary);
      margin-bottom: 4px;
    }
    .legal-body :global(.placeholder) {
      background: #FEF3C7;
      color: #78350F;
      padding: 1px 6px;
      border-radius: 3px;
      font-size: 13px;
      font-weight: 600;
    }
    .legal-body :global(code) {
      font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
      background: var(--line-soft);
      padding: 1px 6px;
      border-radius: 3px;
      font-size: 13px;
    }
    .legal-body :global(strong) { font-weight: 600; color: var(--ink); }

    .legal-colophon {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: var(--space-3);
      margin-top: var(--space-7);
      max-width: 260px;
      margin-left: auto;
      margin-right: auto;
    }
    .colophon-rail { flex: 1; height: 1px; background: var(--accent); opacity: 0.45; }
    .colophon-text {
      display: inline-flex; align-items: center; gap: 6px;
      font-family: var(--font-serif); font-size: 12px;
      color: var(--muted); white-space: nowrap;
    }
    .colophon-text strong { font-weight: 700; color: var(--primary); letter-spacing: 0.08em; }
    .colophon-dot { width: 6px; height: 6px; background: var(--accent); border-radius: 1px; }
  </style>
</body>
</html>
