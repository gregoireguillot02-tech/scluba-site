---
import '../styles/tokens.css';
import OpsIcon from '../components/ops/OpsIcon.astro';

interface NavItem { id: string; label: string; href: string; icon: string; }
interface NavGroup { label: string; items: NavItem[]; }

// Shell générique : /ops par défaut, réutilisable (ex. portail club) en passant
// brand / homeHref / signoutAction / navGroups / thème. Les valeurs par défaut
// reproduisent exactement le comportement ops → les pages /ops sont inchangées.
interface Props {
  title: string;
  active?: string;
  brand?: string;
  homeHref?: string;
  signoutAction?: string;
  themeKey?: string;
  defaultTheme?: 'light' | 'dark';
  navGroups?: NavGroup[];
}

const OPS_NAV_GROUPS: NavGroup[] = [
  {
    label: 'Commercial',
    items: [
      { id: 'home', label: 'Todo commerciale', href: '/ops', icon: 'inbox' },
      { id: 'todo', label: 'Todo générale', href: '/ops/todo', icon: 'check-square' },
      { id: 'calendrier', label: 'Calendrier', href: '/ops/calendrier', icon: 'calendar' },
      { id: 'appels', label: "Liste d'appel", href: '/ops/appels', icon: 'phone' },
      { id: 'prospects', label: 'Prospection clubs', href: '/ops/prospects', icon: 'flag' },
      { id: 'reseau', label: 'Prospection réseau', href: '/ops/reseau', icon: 'share' },
    ],
  },
  {
    label: 'Clubs',
    items: [
      { id: 'clubs', label: 'Clubs', href: '/ops/clubs', icon: 'building' },
      { id: 'signups', label: 'Leads CTA', href: '/ops/signups', icon: 'user-plus' },
    ],
  },
  {
    label: 'Système',
    items: [
      { id: 'activite', label: 'Activité', href: '/ops/activite', icon: 'activity' },
      { id: 'stats', label: 'Stats', href: '/ops/stats', icon: 'bar-chart' },
      { id: 'parametres', label: 'Paramètres', href: '/ops/parametres', icon: 'settings' },
    ],
  },
];

const {
  title,
  active,
  brand = 'Scluba Ops',
  homeHref = '/ops',
  signoutAction = '/ops/auth/signout',
  themeKey = 'ops-theme',
  defaultTheme = 'dark',
  navGroups = OPS_NAV_GROUPS,
} = Astro.props;
const user = Astro.locals.user;
---

<!doctype html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex,nofollow" />
  <title>{title} — {brand}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <script define:vars={{ themeKey, defaultTheme }}>
    (function () {
      try {
        var t = localStorage.getItem(themeKey);
        if (t !== 'light' && t !== 'dark') t = defaultTheme;
        document.documentElement.dataset.theme = t;
      } catch (e) {
        document.documentElement.dataset.theme = defaultTheme;
      }
    })();
  </script>
</head>
<body>
  <a href="#ops-content" class="ops-skip">Aller au contenu</a>

  <div class="ops-shell">
    <aside class="ops-sidebar" id="ops-sidebar">
      <div class="ops-sidebar-head">
        <a href={homeHref} class="ops-brand">
          <span class="ops-brand-mark">S</span>
          <span class="ops-brand-text">{brand}</span>
        </a>
        <button class="ops-sidebar-close" type="button" aria-label="Fermer le menu">
          <OpsIcon name="x" size={20} />
        </button>
      </div>

      <nav class="ops-nav" aria-label="Navigation ops">
        {navGroups.map((group) => (
          <div class="ops-nav-group">
            <span class="ops-nav-group-label">{group.label}</span>
            {group.items.map((item) => (
              <a
                href={item.href}
                class="ops-nav-link"
                aria-current={active === item.id ? 'page' : undefined}
              >
                <OpsIcon name={item.icon} size={18} />
                <span>{item.label}</span>
              </a>
            ))}
          </div>
        ))}
      </nav>

      <div class="ops-sidebar-foot">
        <button class="ops-theme-toggle" type="button" aria-label="Basculer le thème clair ou sombre">
          <OpsIcon name="sun" size={18} class="ops-theme-ic ops-theme-ic-light" />
          <OpsIcon name="moon" size={18} class="ops-theme-ic ops-theme-ic-dark" />
          <span class="ops-theme-label ops-theme-label-light">Mode clair</span>
          <span class="ops-theme-label ops-theme-label-dark">Mode sombre</span>
        </button>
        {user && <div class="ops-user-email" title={user.email}>{user.email}</div>}
        <form action={signoutAction} method="post" class="ops-signout-form">
          <button type="submit" class="ops-signout">
            <OpsIcon name="log-out" size={18} />
            <span>Déconnexion</span>
          </button>
        </form>
      </div>
    </aside>

    <div class="ops-content-wrap">
      <header class="ops-topbar">
        <button class="ops-menu-btn" type="button" aria-label="Ouvrir le menu">
          <OpsIcon name="menu" size={22} />
        </button>
        <a href={homeHref} class="ops-topbar-brand">
          <span class="ops-brand-mark">S</span>
          <span>{brand}</span>
        </a>
      </header>

      <main class="ops-main" id="ops-content">
        <slot />
      </main>
    </div>
  </div>

  <div class="ops-scrim" aria-hidden="true"></div>

  <script define:vars={{ themeKey }}>
    const root = document.documentElement;

    document.querySelector('.ops-theme-toggle')?.addEventListener('click', () => {
      const next = root.dataset.theme === 'dark' ? 'light' : 'dark';
      root.dataset.theme = next;
      try { localStorage.setItem(themeKey, next); } catch (e) {}
    });

    const openNav = () => document.body.classList.add('ops-nav-open');
    const closeNav = () => document.body.classList.remove('ops-nav-open');
    document.querySelector('.ops-menu-btn')?.addEventListener('click', openNav);
    document.querySelector('.ops-sidebar-close')?.addEventListener('click', closeNav);
    document.querySelector('.ops-scrim')?.addEventListener('click', closeNav);
    document.querySelectorAll('.ops-nav-link').forEach((a) => a.addEventListener('click', closeNav));
  </script>
</body>
</html>

<style is:global>
  /* ============================================================
     OPS THEME TOKENS — slate base + Scluba green accent.
     Scoped to the ops document only (OpsLayout renders its own
     <html>); the public site keeps tokens.css forest values.
     ============================================================ */
  :root {
    --ops-page-bg: #F8FAFC;
    --bg: #FFFFFF;
    --bg-soft: #F1F5F9;
    --ink: #0F172A;
    --ink-soft: #334155;
    --muted: #64748B;
    --muted-soft: #94A3B8;
    --line: #E2E8F0;
    --line-soft: #F1F5F9;
    --primary: #2D6A4F;
    --primary-soft: #2D6A4F;
    --primary-deep: #1B4332;
    --primary-bg: #ECF3EE;
    --accent: #C68A4E;
    --accent-soft: #F5E6CF;
    --accent-bright: #E8C089;
    --danger: #DC2626;
    --danger-soft: #FEF2F2;
    --danger-line: #FECACA;
    --ok: #059669;
    --ok-soft: #ECFDF5;
    --card-bg: #FFFFFF;
    --card-border: var(--line);
    --card-blur: 0px;
    --primary-glow: rgba(45,106,79,0.28);
    --radius-card: 16px;
    --shadow-sm: 0 1px 2px rgba(15,23,42,0.06);
    --shadow-md: 0 1px 2px rgba(15,23,42,0.06), 0 6px 16px rgba(15,23,42,0.08);
    --ring: 0 0 0 3px rgba(45,106,79,0.22);
    color-scheme: light;
  }
  :root[data-theme="dark"] {
    --ops-page-bg:
      radial-gradient(1100px 560px at 84% -8%, rgba(94,106,210,0.20), transparent 60%),
      radial-gradient(820px 520px at 2% 108%, rgba(52,211,153,0.10), transparent 55%),
      linear-gradient(180deg, #0C1030 0%, #080A20 100%);
    --bg: #141A35;
    --bg-soft: #1C2447;
    --ink: #EEF1FB;
    --ink-soft: #C3C9E4;
    --muted: #8B93B8;
    --muted-soft: #5E6790;
    --line: rgba(255,255,255,0.10);
    --line-soft: rgba(255,255,255,0.06);
    --primary: #34D399;
    --primary-soft: #6EE7B7;
    --primary-deep: #10B981;
    --primary-bg: #14271F;
    --accent: #E0B074;
    --accent-soft: #2A2418;
    --accent-bright: #F0C893;
    --danger: #FB7185;
    --danger-soft: #2A1620;
    --danger-line: #5B2733;
    --ok: #34D399;
    --ok-soft: #112A22;
    --card-bg: linear-gradient(160deg, rgba(255,255,255,0.06), rgba(255,255,255,0.02));
    --card-border: rgba(255,255,255,0.10);
    --card-blur: 14px;
    --primary-glow: rgba(52,211,153,0.40);
    --radius-card: 16px;
    --shadow-sm: 0 1px 2px rgba(0,0,0,0.45);
    --shadow-md: 0 10px 30px -10px rgba(0,0,0,0.6);
    --ring: 0 0 0 3px rgba(52,211,153,0.32);
    color-scheme: dark;
  }

  body {
    margin: 0;
    background: var(--ops-page-bg);
    background-attachment: fixed;
    background-repeat: no-repeat;
    color: var(--ink);
    font-family: var(--font-sans);
    -webkit-font-smoothing: antialiased;
  }
  *, *::before, *::after { box-sizing: border-box; }
  a { color: inherit; }

  .ops-shell { position: relative; z-index: 1; }

  .ops-icon { display: inline-block; vertical-align: middle; flex-shrink: 0; }

  .ops-skip {
    position: fixed;
    left: 12px;
    top: -48px;
    z-index: 100;
    background: var(--primary);
    color: #fff;
    padding: 8px 14px;
    border-radius: 8px;
    font-size: 14px;
    text-decoration: none;
    transition: top 0.15s;
  }
  .ops-skip:focus { top: 12px; }

  /* ---- Shell ---- */
  .ops-shell {
    display: flex;
    min-height: 100vh;
    min-height: 100dvh;
  }

  .ops-sidebar {
    width: 248px;
    flex-shrink: 0;
    position: sticky;
    top: 0;
    height: 100vh;
    height: 100dvh;
    background: var(--bg);
    border-right: 1px solid var(--line);
    display: flex;
    flex-direction: column;
    z-index: 60;
  }
  .ops-sidebar-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 16px 12px;
  }
  .ops-brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: var(--ink);
    font-weight: 700;
    font-size: 15px;
    letter-spacing: 0.01em;
  }
  .ops-brand-mark {
    width: 30px;
    height: 30px;
    border-radius: 9px;
    background: linear-gradient(135deg, var(--primary), var(--primary-deep));
    color: #fff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    font-weight: 700;
    flex-shrink: 0;
    box-shadow: 0 4px 14px -3px var(--primary-glow);
  }
  .ops-sidebar-close,
  .ops-menu-btn {
    display: none;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border: 1px solid var(--line);
    background: var(--bg);
    color: var(--ink-soft);
    border-radius: 8px;
    cursor: pointer;
  }

  .ops-nav {
    flex: 1;
    overflow-y: auto;
    padding: 6px 12px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .ops-nav-group { display: flex; flex-direction: column; gap: 2px; }
  .ops-nav-group-label {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--muted-soft);
    padding: 6px 10px 4px;
  }
  .ops-nav-link {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 10px;
    border-radius: 8px;
    text-decoration: none;
    color: var(--ink-soft);
    font-size: 14px;
    font-weight: 500;
    transition: background 0.12s, color 0.12s;
  }
  .ops-nav-link .ops-icon { color: var(--muted); }
  .ops-nav-link:hover { background: var(--bg-soft); color: var(--ink); }
  .ops-nav-link:hover .ops-icon { color: var(--ink-soft); }
  .ops-nav-link[aria-current="page"] {
    background: linear-gradient(135deg, color-mix(in srgb, var(--primary) 26%, transparent), color-mix(in srgb, var(--primary) 9%, transparent));
    color: var(--primary);
    font-weight: 600;
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--primary) 28%, transparent);
  }
  .ops-nav-link[aria-current="page"] .ops-icon { color: var(--primary); }
  .ops-nav-link:focus-visible { outline: none; box-shadow: var(--ring); }

  .ops-sidebar-foot {
    padding: 12px;
    border-top: 1px solid var(--line);
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .ops-theme-toggle {
    display: flex;
    align-items: center;
    gap: 10px;
    width: 100%;
    padding: 8px 10px;
    border: 1px solid var(--line);
    background: var(--bg);
    color: var(--ink-soft);
    border-radius: 8px;
    font-size: 13px;
    font-weight: 500;
    font-family: inherit;
    cursor: pointer;
    transition: background 0.12s, border-color 0.12s;
  }
  .ops-theme-toggle:hover { background: var(--bg-soft); border-color: var(--muted-soft); }
  .ops-theme-toggle:focus-visible { outline: none; box-shadow: var(--ring); }
  .ops-theme-ic-dark, .ops-theme-label-dark { display: none; }
  :root[data-theme="dark"] .ops-theme-ic-light,
  :root[data-theme="dark"] .ops-theme-label-light { display: none; }
  :root[data-theme="dark"] .ops-theme-ic-dark { display: inline-block; }
  :root[data-theme="dark"] .ops-theme-label-dark { display: inline; }

  .ops-user-email {
    font-size: 12px;
    color: var(--muted);
    padding: 2px 10px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .ops-signout-form { margin: 0; }
  .ops-signout {
    display: flex;
    align-items: center;
    gap: 10px;
    width: 100%;
    padding: 8px 10px;
    border: 0;
    background: none;
    color: var(--muted);
    border-radius: 8px;
    font-size: 13px;
    font-weight: 500;
    font-family: inherit;
    text-align: left;
    cursor: pointer;
    transition: background 0.12s, color 0.12s;
  }
  .ops-signout:hover { background: var(--danger-soft); color: var(--danger); }
  .ops-signout:focus-visible { outline: none; box-shadow: var(--ring); }

  /* ---- Content area ---- */
  .ops-content-wrap { flex: 1; min-width: 0; display: flex; flex-direction: column; }
  .ops-topbar {
    display: none;
    align-items: center;
    gap: 12px;
    padding: 10px 16px;
    background: var(--bg);
    border-bottom: 1px solid var(--line);
    position: sticky;
    top: 0;
    z-index: 40;
  }
  .ops-topbar-brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: var(--ink);
    font-weight: 700;
    font-size: 15px;
  }
  .ops-main {
    flex: 1;
    width: 100%;
    max-width: 1280px;
    margin: 0 auto;
    padding: 28px 28px 80px;
  }

  .ops-scrim {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(2, 6, 23, 0.5);
    z-index: 55;
  }

  /* ---- Responsive: off-canvas sidebar under 900px ---- */
  @media (max-width: 900px) {
    .ops-sidebar {
      position: fixed;
      left: 0;
      top: 0;
      transform: translateX(-100%);
      transition: transform 0.22s ease;
      box-shadow: var(--shadow-md);
    }
    body.ops-nav-open .ops-sidebar { transform: translateX(0); }
    body.ops-nav-open .ops-scrim { display: block; }
    .ops-sidebar-close, .ops-menu-btn { display: inline-flex; }
    .ops-topbar { display: flex; }
    .ops-main { padding: 20px 16px 64px; }
  }
  @media (prefers-reduced-motion: reduce) {
    .ops-sidebar { transition: none; }
  }

  /* ============================================================
     Shared ops UI primitives
     ============================================================ */
  .ops-page-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 24px;
  }
  .ops-page-title {
    font-family: var(--font-sans);
    font-size: 22px;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--ink);
    margin: 0;
  }
  .ops-page-subtitle {
    color: var(--muted);
    margin: 6px 0 0;
    font-size: 14px;
  }

  .ops-card {
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: var(--radius-card, 16px);
    padding: 20px;
    box-shadow: var(--shadow-sm);
    backdrop-filter: blur(var(--card-blur, 0px));
    -webkit-backdrop-filter: blur(var(--card-blur, 0px));
  }
  .ops-card h2 {
    font-family: var(--font-sans);
    font-size: 16px;
    font-weight: 600;
    margin: 0 0 12px;
    color: var(--ink);
  }

  .ops-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 9px 16px;
    border-radius: 8px;
    border: 1px solid var(--line);
    background: var(--bg);
    color: var(--ink);
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    text-decoration: none;
    transition: background 0.15s, border-color 0.15s, color 0.15s;
  }
  .ops-btn:hover { background: var(--bg-soft); border-color: var(--muted-soft); }
  .ops-btn:focus-visible { outline: none; box-shadow: var(--ring); }
  .ops-btn-primary {
    background: linear-gradient(135deg, var(--primary), var(--primary-deep));
    color: #fff;
    border-color: transparent;
    box-shadow: 0 6px 18px -8px var(--primary-glow);
  }
  .ops-btn-primary:hover { filter: brightness(1.06); }
  .ops-btn-ghost {
    border-color: transparent;
    background: transparent;
    color: var(--muted);
  }
  .ops-btn-ghost:hover { background: var(--bg-soft); color: var(--ink); }

  .ops-input,
  .ops-select,
  .ops-textarea {
    width: 100%;
    padding: 9px 12px;
    border-radius: 8px;
    border: 1px solid var(--line);
    background: var(--bg);
    font-size: 14px;
    font-family: var(--font-sans);
    color: var(--ink);
  }
  .ops-input::placeholder, .ops-textarea::placeholder { color: var(--muted-soft); }
  .ops-input:focus,
  .ops-select:focus,
  .ops-textarea:focus {
    outline: none;
    border-color: var(--primary);
    box-shadow: var(--ring);
  }
  .ops-textarea { resize: vertical; min-height: 80px; }

  .ops-label {
    display: block;
    font-size: 13px;
    font-weight: 500;
    color: var(--ink-soft);
    margin-bottom: 6px;
  }

  .ops-tag {
    display: inline-flex;
    align-items: center;
    padding: 3px 10px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 500;
    background: var(--bg-soft);
    color: var(--ink-soft);
  }

  /* Canonical status pill — drive with `--pill-color: <hex>` inline */
  .ops-pill {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 3px 10px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 600;
    background: color-mix(in srgb, var(--pill-color, var(--muted)) 16%, transparent);
    color: var(--pill-color, var(--muted));
  }

  /* Canonical owner chip */
  .ops-chip {
    display: inline-flex;
    align-items: center;
    padding: 2px 9px;
    border-radius: 999px;
    font-size: 11px;
    font-weight: 600;
  }
  .ops-chip-greg { background: color-mix(in srgb, var(--primary) 14%, transparent); color: var(--primary); }
  .ops-chip-paul { background: color-mix(in srgb, var(--accent) 22%, transparent); color: var(--accent); }
  .ops-chip-shared { background: var(--bg-soft); color: var(--ink-soft); }

  /* Canonical data table */
  .ops-table { width: 100%; border-collapse: collapse; font-size: 14px; }
  .ops-table th {
    text-align: left;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--muted);
    padding: 10px 12px;
    border-bottom: 1px solid var(--line);
  }
  .ops-table td {
    padding: 11px 12px;
    border-bottom: 1px solid var(--line-soft);
    color: var(--ink);
    font-variant-numeric: tabular-nums;
  }
  .ops-table tbody tr:hover { background: var(--bg-soft); }

  .ops-empty {
    text-align: center;
    padding: 48px 24px;
    color: var(--muted);
    font-size: 14px;
  }

  .ops-flash {
    padding: 12px 14px;
    border-radius: 8px;
    font-size: 14px;
    margin-bottom: 16px;
  }
  .ops-flash-ok {
    background: var(--ok-soft);
    border: 1px solid color-mix(in srgb, var(--ok) 35%, transparent);
    color: var(--ok);
  }
  .ops-flash-err {
    background: var(--danger-soft);
    border: 1px solid var(--danger-line);
    color: var(--danger);
  }

  /* ============================================================
     Vivid KPI cards + donut (inspiré dashboards analytics)
     Drive la couleur avec une classe .ops-kpi-<teinte>.
     ============================================================ */
  .ops-kpi {
    position: relative;
    overflow: hidden;
    border-radius: 16px;
    padding: 16px 18px;
    color: #fff;
    background: linear-gradient(140deg, var(--kpi-1, #3B82F6), var(--kpi-2, #22D3EE));
    border: 1px solid rgba(255,255,255,0.16);
    box-shadow: 0 12px 28px -12px var(--kpi-glow, rgba(0,0,0,0.5));
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }
  .ops-kpi::after {
    content: '';
    position: absolute;
    top: -40%;
    right: -10%;
    width: 140px;
    height: 140px;
    border-radius: 50%;
