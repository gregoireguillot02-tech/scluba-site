---
/**
 * Layout partagé des 4 pages du flow joueur (/r/[shortCode]/*) :
 * join, lobby (index), play, recap.
 *
 * Encapsule :
 *  - <head> commun (charset, viewport, fonts preload Fraunces + JetBrains Mono,
 *    favicon, robots noindex, theme-color, imports CSS).
 *  - <body> avec background paper-friendly + clubColor exposé en CSS var.
 *
 * Le contenu spécifique de chaque page est passé via le slot par défaut.
 * Les <style> spécifiques à chaque page restent dans la page (define:vars
 * fonctionnent uniquement au niveau de la page, pas du layout).
 */

import '../styles/tokens.css';
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  /** theme-color meta (mobile browser chrome). Default = paper. */
  themeColor?: string;
  /** Couleur primaire du club (exposée en --clubColor pour les inline styles). */
  clubColor?: string;
  /** Classes additionnelles sur <body>. */
  bodyClass?: string;
  /** Verrouille le scroll overscroll-behavior-y (utile pour /play). */
  lockOverscroll?: boolean;
}

const {
  title,
  themeColor = '#FFFFFF',
  clubColor = '#0EA968',
  bodyClass = '',
  lockOverscroll = false,
} = Astro.props;

// Strava Light Green — flow joueur sur fond white avec accent vert vibrant.
// Le data-attribute `player-flow` permet aux tokens.css de scoper les
// overrides à /r/* + /[slug] (pas la landing, pas /ops).
const bodyStyle = [
  `--clubColor: ${clubColor}`,
  'background: #FFFFFF',
  'color: #0A0A0A',
  'min-height: 100dvh',
  'margin: 0',
  'overflow-x: hidden',
  lockOverscroll ? 'overscroll-behavior-y: none' : null,
].filter(Boolean).join('; ');
---

<!doctype html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title>{title}</title>
  <meta name="robots" content="noindex, nofollow" />
  <meta name="theme-color" content={themeColor} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- === Fonts Athletic Pro Dark : Inter (body) + Sora (display) ===
       Switch direction "Variant B golf vert" : on remplace Fraunces
       (serif éditorial) par Sora pour les titres XL (sans-serif geometric
       énergique) + Inter pour le body (lisibilité optimale sur dark).
       JetBrains Mono reste disponible pour les éventuels eyebrows mono. -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    rel="preload"
    as="style"
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Sora:wght@500;600;700;800&family=JetBrains+Mono:wght@500;600&display=swap"
  />
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Sora:wght@500;600;700;800&family=JetBrains+Mono:wght@500;600&display=swap"
  />

  <!-- === View Transitions (Astro 6 ClientRouter) ===
       Active la View Transitions API native sur les 4 pages joueur.
       Astro 6 intercepte automatiquement les <a> ET les <form> POST :
        - lobby → play : form "C'est parti" → /api/rounds/[code]/start
          redirige vers /play, Astro suit le redirect + swap DOM avec VT
        - play → recap : form "Terminer" → /api/rounds/[code]/finish
          redirige vers /recap, idem
        - join → lobby : form claim → /api/rounds/[code]/claim
          redirige vers /, idem
       Les éléments avec transition:name="X" sont matched cross-pages
       et morphent visuellement (logo, photo, code, masthead).
       Browsers sans View Transitions API (Firefox < 122) : fade par
       défaut, comportement gracieusement dégradé. -->
  <ClientRouter />
</head>
<body style={bodyStyle} class={bodyClass} data-player-flow>
  <slot />
</body>
</html>
