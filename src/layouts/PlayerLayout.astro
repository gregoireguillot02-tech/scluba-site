---
/**
 * Layout partagé des 4 pages du flow joueur (/r/[shortCode]/*) :
 * join, lobby (index), play, recap.
 *
 * Encapsule :
 *  - <head> commun (charset, viewport, fonts preload Fraunces + JetBrains Mono,
 *    favicon, robots noindex, theme-color, imports CSS).
 *  - <body> avec background paper-friendly + clubColor exposé en CSS var.
 *
 * Le contenu spécifique de chaque page est passé via le slot par défaut.
 * Les <style> spécifiques à chaque page restent dans la page (define:vars
 * fonctionnent uniquement au niveau de la page, pas du layout).
 */

import '../styles/tokens.css';
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  /** theme-color meta (mobile browser chrome). Default = paper. */
  themeColor?: string;
  /** Couleur primaire du club (exposée en --clubColor pour les inline styles). */
  clubColor?: string;
  /** Classes additionnelles sur <body>. */
  bodyClass?: string;
  /** Verrouille le scroll overscroll-behavior-y (utile pour /play). */
  lockOverscroll?: boolean;
}

const {
  title,
  themeColor = '#FAF7EE',
  clubColor = '#1B4332',
  bodyClass = '',
  lockOverscroll = false,
} = Astro.props;

// Inline style sur <body> : expose --clubColor + bg + overscroll.
// On garde #FAF7EE en bg pour la parité visuelle PR1 — le swap vers --paper
// (#FAF5E8) se fera en PR2 où les pages joueur basculent sur le crème.
const bodyStyle = [
  `--clubColor: ${clubColor}`,
  'background: #FAF7EE',
  'min-height: 100dvh',
  'margin: 0',
  'overflow-x: hidden',
  lockOverscroll ? 'overscroll-behavior-y: none' : null,
].filter(Boolean).join('; ');
---

<!doctype html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title>{title}</title>
  <meta name="robots" content="noindex, nofollow" />
  <meta name="theme-color" content={themeColor} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- === Fonts : Fraunces (display) + JetBrains Mono (labels) ===
       Strategy PR5 :
        1. preconnect aux 2 origines Google Fonts (DNS + TLS warm-up)
        2. preload de la CSS comme "style" (discovery prioritaire avant
           le HTML parser n'atteigne le <link rel="stylesheet"> classique)
        3. stylesheet load standard avec font-display: swap (fallback
           Georgia immédiat, swap silencieux quand Fraunces arrive)
        4. URL Fraunces réduite aux 3 weights effectivement utilisés
           (700 titres / 800 chiffres / 900 code XL) — les autres
           weights (400/500/600) ne sont jamais référencés en CSS,
           pas la peine de générer leurs @font-face.
        5. Fraunces étant un variable font, le browser télécharge UN
           SEUL woff2 qui couvre toute la range wght 100-900. Les
           weights listés ne changent pas la taille du fichier — juste
           la taille de la CSS Google (économie marginale mais propre).

       JetBrains Mono : un seul weight 500 suffit pour les eyebrow micro-caps. -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    rel="preload"
    as="style"
    href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,700;9..144,800;9..144,900&family=JetBrains+Mono:wght@500&display=swap"
  />
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,700;9..144,800;9..144,900&family=JetBrains+Mono:wght@500&display=swap"
  />

  <!-- === View Transitions (Astro 6 ClientRouter) ===
       Active la View Transitions API native sur les 4 pages joueur.
       Astro 6 intercepte automatiquement les <a> ET les <form> POST :
        - lobby → play : form "C'est parti" → /api/rounds/[code]/start
          redirige vers /play, Astro suit le redirect + swap DOM avec VT
        - play → recap : form "Terminer" → /api/rounds/[code]/finish
          redirige vers /recap, idem
        - join → lobby : form claim → /api/rounds/[code]/claim
          redirige vers /, idem
       Les éléments avec transition:name="X" sont matched cross-pages
       et morphent visuellement (logo, photo, code, masthead).
       Browsers sans View Transitions API (Firefox < 122) : fade par
       défaut, comportement gracieusement dégradé. -->
  <ClientRouter />
</head>
<body style={bodyStyle} class={bodyClass}>
  <slot />
</body>
</html>
