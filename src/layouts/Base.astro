---
import '../styles/global.css';
import LaunchBanner from '../components/LaunchBanner.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { useT, type Locale } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useT(locale);
---

<!doctype html>
<html lang={locale}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />
  <title>{t.meta.title}</title>
  <meta name="description" content={t.meta.description} />
  <meta property="og:title" content={t.meta.title} />
  <meta property="og:description" content={t.meta.description} />
  <meta property="og:type" content="website" />
  <meta name="theme-color" content="#1B4332" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Fonts éditoriales "The Golfer's Journal" — Fraunces italic pour le
       wordmark bois. Charge minimum en PR #1 (Nav + Footer). PR #2 étendra
       avec Newsreader (body éditorial) et JetBrains Mono (eyebrows chapitres).
       display=swap : pas de FOIT, fallback Georgia visible jusqu'au load. -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@1,9..144,700..900&display=swap"
  />
</head>
<body>
  <LaunchBanner locale={locale} />
  <Nav locale={locale} />
  <main>
    <slot />
  </main>
  <Footer locale={locale} />

  <script>
    // Smooth scroll global via Lenis (~4 KB gzipped). Respecte prefers-reduced-motion.
    import Lenis from 'lenis';

    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (!prefersReduced) {
      const lenis = new Lenis({
        duration: 1.1,
        easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
        smoothWheel: true,
        touchMultiplier: 2,
      });

      function raf(time: number) {
        lenis.raf(time);
        requestAnimationFrame(raf);
      }
      requestAnimationFrame(raf);

      (window as unknown as { __lenis?: unknown }).__lenis = lenis;
    }
  </script>

  <script>
    import '../scripts/animations';
  </script>
</body>
</html>
