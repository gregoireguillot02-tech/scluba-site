---
import '../styles/global.css';
import LaunchBanner from '../components/LaunchBanner.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import ScrollGolfBall from '../components/ScrollGolfBall.astro';
import { useT, type Locale } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useT(locale);

// La balle de golf scroll-tied (oryzo.ai-inspired) apparaît uniquement
// sur la home (FR + EN). Pas sur les pages utilitaires servies par Base
// (legal, /demo, etc.) où elle distrayerait du contenu.
const pathname = Astro.url.pathname;
const isHomeRoute = pathname === '/' || pathname === '/en' || pathname === '/en/';
---

<!doctype html>
<html lang={locale}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />
  <title>{t.meta.title}</title>
  <meta name="description" content={t.meta.description} />
  <meta property="og:title" content={t.meta.title} />
  <meta property="og:description" content={t.meta.description} />
  <meta property="og:type" content="website" />
  <meta name="theme-color" content="#1B4332" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Fonts landing :
       - Fraunces 900 italic : titres + display tokens dans la majorité
         des composants landing (Hero, Chapters, CTA, etc.).
       - Big Shoulders Display 800 : wordmark SCLUBA (Nav + Footer),
         direction Modern Mono validée 2026-05-19 (PR #95).
       display=swap : fallback Georgia/Impact visible jusqu'au load. -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@1,9..144,900&family=Big+Shoulders+Display:wght@800&display=swap"
  />
</head>
<body data-landing-mode={isHomeRoute ? 'dark' : undefined}>
  {isHomeRoute && <canvas class="grain-overlay" aria-hidden="true"></canvas>}
  <LaunchBanner locale={locale} />
  <Nav locale={locale} />
  {isHomeRoute && <ScrollGolfBall />}
  <main>
    <slot />
  </main>
  <Footer locale={locale} />

  <script>
    // Smooth scroll global via Lenis (~4 KB gzipped). Respecte prefers-reduced-motion.
    import Lenis from 'lenis';

    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (!prefersReduced) {
      const lenis = new Lenis({
        duration: 1.1,
        easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
        smoothWheel: true,
        touchMultiplier: 2,
      });

      function raf(time: number) {
        lenis.raf(time);
        requestAnimationFrame(raf);
      }
      requestAnimationFrame(raf);

      (window as unknown as { __lenis?: unknown }).__lenis = lenis;
    }
  </script>

  <script>
    import '../scripts/animations';
  </script>

  <script>
    // Grain overlay canvas (drinksom-inspired) — drawing once-only au boot.
    // Pattern fractalNoise procédural via Canvas API. ~3 KB, exécuté après
    // LCP pour ne pas bloquer le rendu critique. Re-draw au resize avec
    // throttle pour garder l'effet net sur tous les écrans.
    function paintGrain() {
      const canvas = document.querySelector('canvas.grain-overlay');
      if (!canvas) return;

      const ctx = canvas.getContext('2d', { alpha: true });
      if (!ctx) return;

      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      const w = window.innerWidth;
      const h = window.innerHeight;
      canvas.width = w * dpr;
      canvas.height = h * dpr;
      canvas.style.width = w + 'px';
      canvas.style.height = h + 'px';
      ctx.scale(dpr, dpr);

      const imageData = ctx.createImageData(w, h);
      const data = imageData.data;
      // Bruit blanc subtle — alpha varie. Le mix-blend-mode: overlay du
      // CSS fait que les pixels apparaissent comme grain filmique.
      for (let i = 0; i < data.length; i += 4) {
        const v = (Math.random() * 255) | 0;
        data[i] = v;
        data[i + 1] = v;
        data[i + 2] = v;
        data[i + 3] = (Math.random() * 60) | 0;
      }
      ctx.putImageData(imageData, 0, 0);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', paintGrain);
    } else {
      paintGrain();
    }

    // Re-draw au resize (throttle ~200ms) pour rester net sur tous les écrans
    let resizeTimer: number | undefined;
    window.addEventListener('resize', () => {
      if (resizeTimer) window.clearTimeout(resizeTimer);
      resizeTimer = window.setTimeout(paintGrain, 200);
    });
  </script>
</body>
</html>
