---
import '../styles/global.css';
import LaunchBanner from '../components/LaunchBanner.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import ScrollGolfBall from '../components/ScrollGolfBall.astro';
import { useT, type Locale } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useT(locale);

// La balle de golf scroll-tied apparaît uniquement sur la home (FR et EN).
// Pas sur les pages joueur /r/*, /[slug], /demo, /legal/*, /ops/* — ce sont
// des contextes utilitaires où elle ne ferait que distraire.
const pathname = Astro.url.pathname;
const isHomeRoute = pathname === '/' || pathname === '/en' || pathname === '/en/';
---

<!doctype html>
<html lang={locale}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />
  <title>{t.meta.title}</title>
  <meta name="description" content={t.meta.description} />
  <meta property="og:title" content={t.meta.title} />
  <meta property="og:description" content={t.meta.description} />
  <meta property="og:type" content="website" />
  <meta name="theme-color" content="#1B4332" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>
  <LaunchBanner locale={locale} />
  <Nav locale={locale} />
  {isHomeRoute && <ScrollGolfBall />}
  <main>
    <slot />
  </main>
  <Footer locale={locale} />

  <script>
    // Smooth scroll global via Lenis (~4 KB gzipped). Respecte prefers-reduced-motion.
    import Lenis from 'lenis';

    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (!prefersReduced) {
      const lenis = new Lenis({
        duration: 1.1,
        easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
        smoothWheel: true,
        touchMultiplier: 2,
      });

      function raf(time: number) {
        lenis.raf(time);
        requestAnimationFrame(raf);
      }
      requestAnimationFrame(raf);

      (window as unknown as { __lenis?: unknown }).__lenis = lenis;
    }
  </script>

  <script>
    import '../scripts/animations';
  </script>
</body>
</html>
