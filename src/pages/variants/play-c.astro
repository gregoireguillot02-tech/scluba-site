---
/**
 * Prototype C — « Ultra-rapide » (habitués). Chrome minimal : un tap enchaîne
 * joueur → joueur → trou en continu (round-robin host), confirmation discrète
 * (toast), swipe ← → pour changer de trou. Pas de CTA. Interactif, mock, éphémère.
 */
import Shell from './_Shell.astro';
import './_proto.css';
import { FIXTURE, REL_OFFSETS } from './_fixture';
---

<Shell title="Proto C · Ultra-rapide — Scluba" clubColor={FIXTURE.club.primary_color} active="c">
  <main class="proto-main proto-c" data-swipe>
    <section class="c-head">
      <span class="c-meta" data-hole-meta></span>
      <span class="c-who">à&nbsp;: <strong data-cur-name></strong></span>
    </section>
    <div class="c-par"><span class="c-par-label">PAR</span> <span data-par></span></div>

    <div class="rel-buttons" data-rel-buttons>
      {REL_OFFSETS.map((offset) => (
        <button type="button" class="rel-btn" data-rel={offset}>
          <span class="rel-label" data-rel-label></span>
          <span class="rel-strokes" data-rel-strokes></span>
        </button>
      ))}
    </div>
    <button type="button" class="pickup-btn" data-pickup>Abandonner</button>

    <p class="c-hint">Tape un score → ça enchaîne tout seul. Swipe&nbsp;←&nbsp;→&nbsp;pour changer de trou.</p>
  </main>
  <div class="toast" data-toast aria-live="polite"></div>
</Shell>

<style>
  .proto-c { gap: 16px; padding-top: 20px; }
  .c-head { display: flex; align-items: baseline; justify-content: space-between; margin: 0 18px; }
  .c-meta { font-family: var(--font-mono); font-size: 12px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--accent); }
  .c-who { font-family: var(--font-serif); font-size: 15px; color: var(--ink); }
  .c-who strong { color: var(--accent); font-weight: 800; }
  .c-par { text-align: center; font-family: var(--font-serif); font-size: 56px; font-weight: 800; color: var(--ink); line-height: 0.95; }
  .c-par-label { display: block; font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.3em; color: var(--muted); font-weight: 600; }
  .proto-c .rel-buttons { margin: 0 16px; }
  .c-hint { text-align: center; margin: 4px 24px 0; font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.08em; color: var(--muted); }
</style>

<script>
  import { createMockStore } from './_mock-store';
  import { relLabel } from './_fixture';
  import { initialOf } from '../../lib/avatar';
  import { flashSelected } from '../../lib/animations/play';

  const store = createMockStore();
  const holeMeta = document.querySelector<HTMLElement>('[data-hole-meta]')!;
  const curName = document.querySelector<HTMLElement>('[data-cur-name]')!;
  const parEl = document.querySelector<HTMLElement>('[data-par]')!;
  const relBtns = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-rel]'));
  const pickupBtn = document.querySelector<HTMLButtonElement>('[data-pickup]')!;
  const toastEl = document.querySelector<HTMLElement>('[data-toast]')!;
  const swipeEl = document.querySelector<HTMLElement>('[data-swipe]')!;

  let toastTimer: number | undefined;
  function toast(msg: string) {
    toastEl.textContent = msg;
    toastEl.classList.add('is-show');
    window.clearTimeout(toastTimer);
    toastTimer = window.setTimeout(() => toastEl.classList.remove('is-show'), 1100);
  }

  function render() {
    const hole = store.currentHole;
    const par = store.parOf(hole);
    const cur = store.currentPlayerId;
    holeMeta.textContent = `Trou ${hole}/${store.holeCount}`;
    curName.textContent = store.nameById.get(cur) ?? '';
    parEl.textContent = String(par);
    for (const btn of relBtns) {
      const off = Number(btn.dataset.rel);
      const strokes = par + off;
      btn.querySelector<HTMLElement>('[data-rel-strokes]')!.textContent = String(strokes);
      btn.querySelector<HTMLElement>('[data-rel-label]')!.textContent = relLabel(par, off);
      btn.classList.toggle('is-par', off === 0);
      btn.classList.toggle('is-selected', store.scoreOf(cur, hole) === strokes && !store.isPickup(cur, hole));
    }
  }

  // Enchaînement continu : après chaque saisie, on saute au prochain slot
  // (round-robin host : finir le trou pour tous, puis trou suivant).
  function chain(label: string) {
    toast(label);
    window.setTimeout(() => {
      const slot = store.nextSlotHost();
      if (slot) store.setCurrent(slot.pid, slot.hole);
    }, 240);
  }

  for (const btn of relBtns) {
    btn.addEventListener('click', () => {
      const hole = store.currentHole;
      const cur = store.currentPlayerId;
      const strokes = store.parOf(hole) + Number(btn.dataset.rel);
      store.setScore(cur, hole, strokes);
      flashSelected(btn);
      chain(`${store.nameById.get(cur)} · ${strokes} ✓`);
    });
  }
  pickupBtn.addEventListener('click', () => {
    const cur = store.currentPlayerId;
    store.setPickup(cur, store.currentHole);
    chain(`${store.nameById.get(cur)} · abandon`);
  });

  // Swipe horizontal = changer de trou (1er joueur du trou ciblé).
  let startX = 0;
  let startY = 0;
  swipeEl.addEventListener('touchstart', (e) => {
    startX = e.changedTouches[0].clientX;
    startY = e.changedTouches[0].clientY;
  }, { passive: true });
  swipeEl.addEventListener('touchend', (e) => {
    const dx = e.changedTouches[0].clientX - startX;
    const dy = e.changedTouches[0].clientY - startY;
    if (Math.abs(dx) < 60 || Math.abs(dy) > 50) return;
    const dir = dx < 0 ? 1 : -1;
    store.setCurrent(store.orderedPlayerIds[0], store.currentHole + dir);
  }, { passive: true });

  store.subscribe(render);
  render();
</script>
