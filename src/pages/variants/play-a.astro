---
/**
 * Variant A — Whoop-style (data-dense, mono caps)
 *
 * Mood : athletic recovery dashboard, scientifique, data-driven.
 * Inspirations : Whoop app, Arc'teryx Veilance, Form Smart Goggles.
 *
 * Caractéristiques :
 *  - Fond near-black #0A0E0C, surfaces #141A17, accents honey #F0B570 vif
 *  - Geist Mono partout pour les chiffres et eyebrows
 *  - Geist Sans pour body
 *  - Tabular numbers XL, micro-caps eyebrows
 *  - Cards très layered avec borders subtiles
 *  - Pas de fioritures décoratives
 */
export const prerender = false;

import { FIXTURE, orderedLeaderboard, totalsFor, scoreFor } from './_fixture';

const currentHoleObj = FIXTURE.holes.find((h) => h.number === FIXTURE.currentHole)!;
const me = FIXTURE.players.find((p) => p.id === FIXTURE.currentPlayerId)!;
const leaderboard = orderedLeaderboard();
const totalPar = FIXTURE.holes.reduce((s, h) => s + h.par, 0);
const myTotals = totalsFor(me.id);
---

<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="robots" content="noindex,nofollow" />
  <meta name="color-scheme" content="dark" />
  <title>Variant A · Whoop-style</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700;800;900&family=Geist+Mono:wght@400;500;600;700&display=swap" />
  <style is:global>
    :root {
      --bg: #0A0E0C;
      --surface: #141A17;
      --surface-2: #1C2421;
      --line: rgba(255, 255, 255, 0.06);
      --line-strong: rgba(255, 255, 255, 0.12);
      --text: #F5F5F4;
      --text-soft: #B8B8B5;
      --text-muted: #7A7A77;
      --honey: #F0B570;
      --honey-deep: #C98F4C;
      --honey-soft: rgba(240, 181, 112, 0.12);
      --green-good: #6EE7B7;
      --red-bad: #FB7185;
      --font-sans: 'Geist', -apple-system, BlinkMacSystemFont, sans-serif;
      --font-mono: 'Geist Mono', 'SF Mono', Menlo, monospace;
    }
    * { box-sizing: border-box; }
    html, body { margin: 0; padding: 0; }
    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--font-sans);
      -webkit-font-smoothing: antialiased;
      min-height: 100dvh;
    }
  </style>
</head>
<body>
  <main class="play">
    <!-- Top bar : club + round meta -->
    <header class="topbar">
      <div class="topbar-club">
        <span class="club-mark" style={`--club: ${FIXTURE.club.primary_color}`}></span>
        <div class="club-info">
          <p class="club-eyebrow">ROUND · 18 HOLES</p>
          <p class="club-name">{FIXTURE.club.name}</p>
        </div>
      </div>
      <div class="topbar-meta">
        <span class="meta-cell">
          <span class="meta-label">HOLE</span>
          <span class="meta-value">{FIXTURE.currentHole}<span class="meta-sep">/</span>{FIXTURE.holes.length}</span>
        </span>
      </div>
    </header>

    <!-- Live leaderboard -->
    <section class="board">
      <header class="board-head">
        <span class="board-eyebrow">LIVE</span>
        <span class="board-eyebrow board-eyebrow-right">SCORE · DIFF</span>
      </header>
      <ul class="board-list">
        {leaderboard.map((row, i) => (
          <li class={`board-row${row.id === FIXTURE.currentPlayerId ? ' is-current' : ''}${i === 0 ? ' is-leader' : ''}`}>
            <span class="row-rank">{String(i + 1).padStart(2, '0')}</span>
            <div class="row-info">
              <span class="row-name">{row.name.toUpperCase()}{row.is_me && <span class="row-me"> · ME</span>}</span>
              <span class="row-sub">{row.played} HOLES PLAYED</span>
            </div>
            <span class="row-strokes">{row.strokes}</span>
            <span class={`row-diff ${row.diff < 0 ? 'is-under' : row.diff > 0 ? 'is-over' : 'is-even'}`}>
              {row.diff === 0 ? '±0' : row.diff > 0 ? `+${row.diff}` : row.diff}
            </span>
          </li>
        ))}
      </ul>
    </section>

    <!-- Banner : current player -->
    <div class="cpb">
      <span class="cpb-dot" aria-hidden="true"></span>
      <div class="cpb-text">
        <span class="cpb-eyebrow">NOW SCORING</span>
        <span class="cpb-name">{me.name.toUpperCase()}</span>
      </div>
      <span class="cpb-hole">H{FIXTURE.currentHole}</span>
    </div>

    <!-- Hole stat blocks -->
    <section class="hole-stats">
      <div class="stat">
        <span class="stat-label">PAR</span>
        <span class="stat-value stat-value-xl">{currentHoleObj.par}</span>
      </div>
      <div class="stat">
        <span class="stat-label">HOLE</span>
        <span class="stat-value stat-value-xl">{FIXTURE.currentHole}</span>
        <span class="stat-sub">{currentHoleObj.name}</span>
      </div>
      <div class="stat">
        <span class="stat-label">DIFF</span>
        <span class={`stat-value stat-value-xl ${myTotals.diff > 0 ? 'is-over' : myTotals.diff < 0 ? 'is-under' : 'is-even'}`}>
          {myTotals.diff === 0 ? '±0' : myTotals.diff > 0 ? `+${myTotals.diff}` : myTotals.diff}
        </span>
        <span class="stat-sub">VS PAR</span>
      </div>
    </section>

    <!-- Par-relative buttons -->
    <section class="rel-buttons">
      <button type="button" class="rel-btn">
        <span class="rel-label">EAGLE</span>
        <span class="rel-strokes">{currentHoleObj.par - 2}</span>
      </button>
      <button type="button" class="rel-btn">
        <span class="rel-label">BIRDIE</span>
        <span class="rel-strokes">{currentHoleObj.par - 1}</span>
      </button>
      <button type="button" class="rel-btn is-par">
        <span class="rel-label">PAR</span>
        <span class="rel-strokes">{currentHoleObj.par}</span>
      </button>
      <button type="button" class="rel-btn">
        <span class="rel-label">BOGEY</span>
        <span class="rel-strokes">{currentHoleObj.par + 1}</span>
      </button>
      <button type="button" class="rel-btn">
        <span class="rel-label">DOUBLE</span>
        <span class="rel-strokes">{currentHoleObj.par + 2}</span>
      </button>
    </section>

    <!-- Pill row -->
    <div class="pill-row">
      <button type="button" class="pill">OTHER</button>
      <button type="button" class="pill pill-warn">PICK UP</button>
    </div>

    <!-- Scorecard -->
    <section class="card">
      <header class="card-head">
        <span class="card-eyebrow">SCORECARD</span>
        <span class="card-total">{myTotals.strokes} <span class="card-total-sep">·</span> PAR {totalPar}</span>
      </header>
      <div class="grid">
        {FIXTURE.holes.map((h) => {
          const s = scoreFor(me.id, h.number);
          const cls = s === null
            ? 'cell-empty'
            : s < h.par ? 'cell-under'
            : s === h.par ? 'cell-par'
            : s === h.par + 1 ? 'cell-bogey' : 'cell-over';
          return (
            <div class={`cell ${cls}${h.number === FIXTURE.currentHole ? ' cell-current' : ''}`}>
              <span class="cell-num">{h.number}</span>
              <span class="cell-strokes">{s ?? '·'}</span>
            </div>
          );
        })}
      </div>
    </section>

    <p class="proto-note">VARIANT A · WHOOP-STYLE · DATA-DENSE</p>
  </main>

  <style>
    /* === Layout === */
    .play {
      max-width: 480px;
      margin: 0 auto;
      padding: 0 16px 80px;
      min-height: 100dvh;
    }

    /* === Topbar === */
    .topbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 18px 0 12px;
      border-bottom: 1px solid var(--line);
      margin-bottom: 16px;
    }
    .topbar-club { display: flex; align-items: center; gap: 10px; }
    .club-mark {
      width: 28px; height: 28px;
      border-radius: 6px;
      background: var(--club, #1A4490);
      box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.06);
    }
    .club-eyebrow {
      margin: 0 0 2px;
      font-family: var(--font-mono);
      font-size: 9px;
      font-weight: 600;
      letter-spacing: 0.18em;
      color: var(--text-muted);
    }
    .club-name {
      margin: 0;
      font-family: var(--font-sans);
      font-size: 13.5px;
      font-weight: 600;
      letter-spacing: -0.005em;
      color: var(--text);
    }
    .topbar-meta { display: flex; align-items: center; }
    .meta-cell { display: flex; flex-direction: column; align-items: flex-end; gap: 2px; }
    .meta-label {
      font-family: var(--font-mono);
      font-size: 9px;
      font-weight: 600;
      letter-spacing: 0.18em;
      color: var(--text-muted);
    }
    .meta-value {
      font-family: var(--font-mono);
      font-size: 18px;
      font-weight: 600;
      color: var(--text);
      font-variant-numeric: tabular-nums;
    }
    .meta-sep { color: var(--text-muted); margin: 0 1px; }

    /* === Live board === */
    .board { margin-bottom: 16px; }
    .board-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 4px 8px;
    }
    .board-eyebrow {
      font-family: var(--font-mono);
      font-size: 9px;
      font-weight: 600;
      letter-spacing: 0.22em;
      color: var(--honey);
    }
    .board-eyebrow-right { color: var(--text-muted); }
    .board-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 6px; }
    .board-row {
      display: grid;
      grid-template-columns: 32px 1fr auto auto;
      align-items: center;
      gap: 12px;
      padding: 12px 14px;
      background: var(--surface);
      border: 1px solid var(--line);
      border-radius: 8px;
      transition: background 0.15s, border-color 0.15s;
    }
    .board-row.is-leader { border-color: rgba(240, 181, 112, 0.35); }
    .board-row.is-current {
      background: var(--surface-2);
      border-color: rgba(240, 181, 112, 0.55);
      box-shadow: inset 2px 0 0 var(--honey);
    }
    .row-rank {
      font-family: var(--font-mono);
      font-size: 12px;
      font-weight: 500;
      color: var(--text-muted);
      font-variant-numeric: tabular-nums;
    }
    .board-row.is-leader .row-rank { color: var(--honey); font-weight: 600; }
    .row-info { display: flex; flex-direction: column; min-width: 0; gap: 2px; }
    .row-name {
      font-family: var(--font-mono);
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.06em;
      color: var(--text);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .row-me { color: var(--honey); font-weight: 500; }
    .row-sub {
      font-family: var(--font-mono);
      font-size: 9.5px;
      letter-spacing: 0.16em;
      color: var(--text-muted);
    }
    .row-strokes {
      font-family: var(--font-mono);
      font-size: 18px;
      font-weight: 700;
      color: var(--text);
      font-variant-numeric: tabular-nums;
      min-width: 28px;
      text-align: right;
    }
    .row-diff {
      font-family: var(--font-mono);
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.04em;
      min-width: 32px;
      text-align: right;
    }
    .row-diff.is-under { color: var(--green-good); }
    .row-diff.is-over  { color: var(--red-bad); }
    .row-diff.is-even  { color: var(--text-muted); }

    /* === Current player banner === */
    .cpb {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 14px 14px;
      background: var(--surface);
      border: 1px solid rgba(240, 181, 112, 0.35);
      border-radius: 8px;
      margin-bottom: 16px;
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.03),
        0 8px 24px -8px rgba(240, 181, 112, 0.18);
    }
    .cpb-dot {
      width: 8px; height: 8px;
      border-radius: 50%;
      background: var(--honey);
      box-shadow: 0 0 0 3px rgba(240, 181, 112, 0.18);
      animation: dot-pulse 1.4s ease-in-out infinite;
    }
    @keyframes dot-pulse {
      0%, 100% { opacity: 0.55; transform: scale(1); }
      50%      { opacity: 1;    transform: scale(1.18); }
    }
    .cpb-text { display: flex; flex-direction: column; gap: 2px; flex: 1; }
    .cpb-eyebrow {
      font-family: var(--font-mono);
      font-size: 9px;
      font-weight: 600;
      letter-spacing: 0.22em;
      color: var(--text-muted);
    }
    .cpb-name {
      font-family: var(--font-mono);
      font-size: 18px;
      font-weight: 700;
      letter-spacing: 0.04em;
      color: var(--honey);
    }
    .cpb-hole {
      font-family: var(--font-mono);
      font-size: 18px;
      font-weight: 700;
      color: var(--text);
    }

    /* === Hole stats === */
    .hole-stats {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 8px;
      margin-bottom: 20px;
    }
    .stat {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 4px;
      padding: 14px 14px 16px;
      background: var(--surface);
      border: 1px solid var(--line);
      border-radius: 8px;
    }
    .stat-label {
      font-family: var(--font-mono);
      font-size: 9px;
      font-weight: 600;
      letter-spacing: 0.22em;
      color: var(--text-muted);
    }
    .stat-value {
      font-family: var(--font-mono);
      font-weight: 700;
      color: var(--text);
      font-variant-numeric: tabular-nums;
      line-height: 1;
    }
    .stat-value-xl { font-size: 36px; }
    .stat-sub {
      font-family: var(--font-mono);
      font-size: 9.5px;
      letter-spacing: 0.14em;
      color: var(--text-muted);
    }
    .stat-value.is-over { color: var(--red-bad); }
    .stat-value.is-under { color: var(--green-good); }

    /* === Par-relative buttons === */
    .rel-buttons {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 6px;
      margin-bottom: 12px;
    }
    .rel-btn {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 4px;
      padding: 14px 4px 12px;
      background: var(--surface);
      border: 1px solid var(--line);
      border-radius: 8px;
      color: var(--text);
      cursor: pointer;
      transition: background 0.15s, border-color 0.15s, transform 0.15s;
      min-height: 88px;
    }
    .rel-btn:hover { background: var(--surface-2); border-color: var(--line-strong); }
    .rel-btn.is-par {
      background: rgba(240, 181, 112, 0.10);
      border-color: rgba(240, 181, 112, 0.55);
    }
    .rel-label {
      font-family: var(--font-mono);
      font-size: 9px;
      font-weight: 600;
      letter-spacing: 0.16em;
      color: var(--text-muted);
    }
    .rel-btn.is-par .rel-label { color: var(--honey); }
    .rel-strokes {
      font-family: var(--font-mono);
      font-size: 26px;
      font-weight: 700;
      color: var(--text);
      font-variant-numeric: tabular-nums;
      line-height: 1;
    }

    /* === Pill row === */
    .pill-row { display: flex; gap: 6px; margin-bottom: 24px; }
    .pill {
      flex: 1;
      padding: 12px 16px;
      background: transparent;
      border: 1px solid var(--line-strong);
      border-radius: 999px;
      color: var(--text-soft);
      font-family: var(--font-mono);
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.18em;
      cursor: pointer;
      transition: background 0.15s, color 0.15s;
    }
    .pill:hover { background: var(--surface); color: var(--text); }
    .pill-warn { border-color: rgba(251, 113, 133, 0.35); color: var(--red-bad); }

    /* === Scorecard === */
    .card {
      background: var(--surface);
      border: 1px solid var(--line);
      border-radius: 8px;
      padding: 14px;
      margin-bottom: 24px;
    }
    .card-head {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      margin-bottom: 12px;
    }
    .card-eyebrow {
      font-family: var(--font-mono);
      font-size: 9px;
      font-weight: 600;
      letter-spacing: 0.22em;
      color: var(--text-muted);
    }
    .card-total {
      font-family: var(--font-mono);
      font-size: 12px;
      font-weight: 600;
      color: var(--text);
      font-variant-numeric: tabular-nums;
    }
    .card-total-sep { color: var(--text-muted); margin: 0 4px; }
    .grid {
      display: grid;
      grid-template-columns: repeat(9, 1fr);
      gap: 4px;
    }
    .cell {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 2px;
      padding: 6px 0;
      background: var(--bg);
      border: 1px solid var(--line);
      border-radius: 4px;
      min-height: 42px;
    }
    .cell-num {
      font-family: var(--font-mono);
      font-size: 9px;
      font-weight: 500;
      color: var(--text-muted);
      letter-spacing: 0.08em;
    }
    .cell-strokes {
      font-family: var(--font-mono);
      font-size: 14px;
      font-weight: 700;
      color: var(--text);
      font-variant-numeric: tabular-nums;
      line-height: 1;
    }
    .cell-empty .cell-strokes { color: var(--text-muted); opacity: 0.4; }
    .cell-under { background: rgba(110, 231, 183, 0.10); border-color: rgba(110, 231, 183, 0.30); }
    .cell-under .cell-strokes { color: var(--green-good); }
    .cell-par   { border-color: rgba(240, 181, 112, 0.30); }
    .cell-par   .cell-strokes { color: var(--honey); }
    .cell-bogey .cell-strokes { color: var(--text-soft); }
    .cell-over  .cell-strokes { color: var(--red-bad); }
    .cell-current { box-shadow: 0 0 0 1px var(--honey); }

    /* === Proto footer === */
    .proto-note {
      text-align: center;
      font-family: var(--font-mono);
      font-size: 9px;
      letter-spacing: 0.3em;
      color: var(--text-muted);
      opacity: 0.4;
      margin-top: 40px;
    }
  </style>
</body>
</html>
