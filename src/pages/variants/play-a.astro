---
/**
 * Prototype A — « Grille ». Le trou = l'écran : tous les joueurs empilés. On
 * tape une ligne (= joueur sélectionné) puis un score ; la ligne passe ✓. CTA
 * sticky « Trou suivant → (N/M) » toujours dispo (on avance quand on veut).
 * Interactif, mock, éphémère.
 */
import Shell from './_Shell.astro';
import './_proto.css';
import { FIXTURE, REL_OFFSETS } from './_fixture';
---

<Shell title="Proto A · Grille — Scluba" clubColor={FIXTURE.club.primary_color} active="a">
  <main class="proto-main">
    <section class="glass">
      <div class="holebar">
        <div class="holebar-meta" data-hole-meta></div>
        <div class="holebar-par-label">PAR</div>
        <div class="holebar-par" data-par></div>
      </div>
      <ul class="a-roster" data-roster></ul>
    </section>

    <section class="glass a-entry">
      <p class="a-entry-for">Score de <strong data-sel-name></strong></p>
      <div class="rel-buttons" data-rel-buttons>
        {REL_OFFSETS.map((offset) => (
          <button type="button" class="rel-btn" data-rel={offset}>
            <span class="rel-label" data-rel-label></span>
            <span class="rel-strokes" data-rel-strokes></span>
          </button>
        ))}
      </div>
      <button type="button" class="pickup-btn" data-pickup>Abandonner</button>
    </section>

    <button type="button" class="next-cta" data-next-cta>
      <span class="nc-progress" data-nc-progress></span>
      <span class="nc-label">Trou suivant →</span>
    </button>
  </main>
</Shell>

<style>
  .a-roster { display: flex; flex-direction: column; gap: 6px; margin-top: 10px; }
  .a-row {
    display: grid; grid-template-columns: 34px 1fr auto; align-items: center; gap: 10px;
    padding: 9px 10px; border-radius: 12px; border: 1px solid var(--line); background: #fff;
    cursor: pointer; touch-action: manipulation; transition: border-color 150ms, box-shadow 150ms, background 150ms;
  }
  .a-row.is-selected { border-color: var(--accent); box-shadow: 0 0 0 2px color-mix(in srgb, var(--accent) 35%, transparent); }
  .a-row.is-done { background: rgba(16, 210, 119, 0.07); }
  .a-avatar { width: 34px; height: 34px; border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; color: #fff; font-family: var(--font-serif); font-weight: 700; font-size: 14px; }
  .a-name { font-family: var(--font-serif); font-weight: 600; font-size: 15px; color: var(--ink); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .a-val { display: inline-flex; align-items: baseline; gap: 6px; }
  .a-strokes { font-family: var(--font-serif); font-weight: 800; font-size: 20px; color: var(--ink); font-variant-numeric: tabular-nums; min-width: 24px; text-align: center; }
  .a-strokes.is-empty { color: var(--muted); opacity: 0.4; }
  .a-tag { font-family: var(--font-mono); font-size: 10px; font-weight: 700; color: var(--accent); }
  .a-entry-for { text-align: center; margin: 0 0 10px; font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted); }
  .a-entry-for strong { color: var(--accent); font-weight: 700; }
</style>

<script>
  import { createMockStore } from './_mock-store';
  import { relLabel } from './_fixture';
  import { initialOf, avatarColor } from '../../lib/avatar';
  import { flashSelected } from '../../lib/animations/play';

  const store = createMockStore();
  const holeMeta = document.querySelector<HTMLElement>('[data-hole-meta]')!;
  const parEl = document.querySelector<HTMLElement>('[data-par]')!;
  const roster = document.querySelector<HTMLElement>('[data-roster]')!;
  const selName = document.querySelector<HTMLElement>('[data-sel-name]')!;
  const relBtns = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-rel]'));
  const pickupBtn = document.querySelector<HTMLButtonElement>('[data-pickup]')!;
  const nextCta = document.querySelector<HTMLButtonElement>('[data-next-cta]')!;
  const ncProgress = document.querySelector<HTMLElement>('[data-nc-progress]')!;
  const ncLabel = nextCta.querySelector<HTMLElement>('.nc-label')!;

  // 1re ligne non saisie du trou courant (ou 1er joueur).
  function firstUnfilled(hole: number): string {
    return store.orderedPlayerIds.find((pid) => !store.hasEntry(pid, hole)) ?? store.orderedPlayerIds[0];
  }
  let selectedPid = firstUnfilled(store.currentHole);

  function render() {
    const hole = store.currentHole;
    const par = store.parOf(hole);

    holeMeta.textContent = `Trou ${hole} / ${store.holeCount}`;
    parEl.textContent = String(par);

    roster.innerHTML = '';
    for (const pid of store.orderedPlayerIds) {
      const li = document.createElement('li');
      const done = store.hasEntry(pid, hole);
      li.className = `a-row${pid === selectedPid ? ' is-selected' : ''}${done ? ' is-done' : ''}`;
      li.dataset.pid = pid;
      let valHtml: string;
      if (store.isPickup(pid, hole)) valHtml = '<span class="a-strokes">C</span><span class="a-tag">✓</span>';
      else if (store.scoreOf(pid, hole) != null) valHtml = `<span class="a-strokes">${store.scoreOf(pid, hole)}</span><span class="a-tag">✓</span>`;
      else valHtml = '<span class="a-strokes is-empty">—</span>';
      li.innerHTML =
        `<span class="a-avatar" style="background:${avatarColor(pid)}">${initialOf(store.nameById.get(pid) ?? '')}</span>` +
        `<span class="a-name">${store.nameById.get(pid)}</span>` +
        `<span class="a-val">${valHtml}</span>`;
      roster.appendChild(li);
    }

    selName.textContent = store.nameById.get(selectedPid) ?? '';
    for (const btn of relBtns) {
      const off = Number(btn.dataset.rel);
      const strokes = par + off;
      btn.querySelector<HTMLElement>('[data-rel-strokes]')!.textContent = String(strokes);
      btn.querySelector<HTMLElement>('[data-rel-label]')!.textContent = relLabel(par, off);
      btn.classList.toggle('is-par', off === 0);
      btn.classList.toggle('is-selected', store.scoreOf(selectedPid, hole) === strokes && !store.isPickup(selectedPid, hole));
    }

    const atLast = hole >= store.holeCount;
    ncProgress.textContent = `${store.playedCountOnHole(hole)}/${store.orderedPlayerIds.length} saisis`;
    ncLabel.textContent = atLast ? 'Partie terminée' : 'Trou suivant →';
    nextCta.disabled = atLast;
  }

  roster.addEventListener('click', (e) => {
    const row = (e.target as HTMLElement).closest<HTMLElement>('.a-row');
    if (!row?.dataset.pid) return;
    selectedPid = row.dataset.pid;
    render();
  });

  function afterEntry() {
    const hole = store.currentHole;
    const np = store.nextPlayerOnHole(selectedPid, hole);
    if (np) selectedPid = np;
    render();
  }
  for (const btn of relBtns) {
    btn.addEventListener('click', () => {
      store.setScore(selectedPid, store.currentHole, store.parOf(store.currentHole) + Number(btn.dataset.rel));
      flashSelected(btn);
      afterEntry();
    });
  }
  pickupBtn.addEventListener('click', () => {
    store.setPickup(selectedPid, store.currentHole);
    afterEntry();
  });
  nextCta.addEventListener('click', () => {
    if (store.currentHole >= store.holeCount) return;
    store.setCurrent(store.orderedPlayerIds[0], store.currentHole + 1);
    selectedPid = firstUnfilled(store.currentHole);
    render();
  });

  store.subscribe(render);
  render();
</script>
