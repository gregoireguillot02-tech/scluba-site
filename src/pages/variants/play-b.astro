---
/**
 * Variant B — Strava-style adapté golf (energetic, vert fairway vibrant)
 *
 * Mood : activity tracking premium énergique, motivant.
 * Inspirations : Strava (mood), Nike Run Club, Hoka. Palette adaptée golf
 * — orange Strava remplacé par vert fairway vibrant #10D277 (pop sur dark).
 *
 * Caractéristiques :
 *  - Fond #0F0F0F + surface #1C1C1E, accents vert vibrant #10D277
 *  - Inter pour body + Sora pour titres XL (Google Fonts)
 *  - Gros chiffres tabulaires, hover lift marqué
 *  - Boutons CTA gradient vert punchy
 *  - Gradient subtil vert sur card leader
 *  - Scorecard grid type "fairway map"
 */
export const prerender = false;

import { FIXTURE, orderedLeaderboard, totalsFor, scoreFor } from './_fixture';

const currentHoleObj = FIXTURE.holes.find((h) => h.number === FIXTURE.currentHole)!;
const me = FIXTURE.players.find((p) => p.id === FIXTURE.currentPlayerId)!;
const leaderboard = orderedLeaderboard();
const totalPar = FIXTURE.holes.reduce((s, h) => s + h.par, 0);
const myTotals = totalsFor(me.id);
---

<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="robots" content="noindex,nofollow" />
  <meta name="color-scheme" content="dark" />
  <title>Variant B · Strava-style golf vert</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Sora:wght@600;700;800&display=swap" />
  <style is:global>
    :root {
      --bg: #0F0F0F;
      --surface: #1C1C1E;
      --surface-2: #28282A;
      --line: rgba(255, 255, 255, 0.08);
      --line-strong: rgba(255, 255, 255, 0.16);
      --text: #FAFAFA;
      --text-soft: #B5B5B5;
      --text-muted: #7E7E7E;
      /* Accent vert fairway vibrant — pop sur fond dark, signature golf
         moderne. Choisi pour rester "Strava energetic" mais lié au sport. */
      --green: #10D277;
      --green-soft: rgba(16, 210, 119, 0.14);
      --green-deep: #0A9D5C;
      /* Mint pour les diffs under-par (différencier du vert accent UI). */
      --green-good: #5EEAD4;
      --red-bad: #FB7185;
      --font-sans: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      --font-display: 'Sora', 'Inter', sans-serif;
    }
    * { box-sizing: border-box; }
    html, body { margin: 0; padding: 0; }
    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--font-sans);
      -webkit-font-smoothing: antialiased;
      min-height: 100dvh;
    }
  </style>
</head>
<body>
  <main class="play">
    <!-- Top hero strip -->
    <header class="hero">
      <div class="hero-club">
        <span class="club-mark" style={`--club: ${FIXTURE.club.primary_color}`}></span>
        <div>
          <p class="hero-eyebrow">{FIXTURE.club.name.toUpperCase()}</p>
          <h1 class="hero-title">Round in progress</h1>
        </div>
      </div>
      <div class="hero-counter">
        <span class="counter-current">{FIXTURE.currentHole}</span>
        <span class="counter-sep">/</span>
        <span class="counter-total">{FIXTURE.holes.length}</span>
      </div>
    </header>

    <!-- Live leaderboard -->
    <section class="board">
      <header class="board-head">
        <h2 class="board-title">Live leaderboard</h2>
        <span class="board-pulse">
          <span class="pulse-dot"></span>
          <span class="pulse-text">LIVE</span>
        </span>
      </header>
      <ul class="board-list">
        {leaderboard.map((row, i) => (
          <li class={`row${row.id === FIXTURE.currentPlayerId ? ' is-current' : ''}${i === 0 ? ' is-leader' : ''}`}>
            <div class="row-left">
              <span class="row-rank">{i + 1}</span>
              <div>
                <p class="row-name">{row.name}{row.is_me && <span class="row-me"> · you</span>}</p>
                <p class="row-sub">{row.played} holes · {row.strokes} strokes</p>
              </div>
            </div>
            <div class="row-right">
              <span class={`row-diff ${row.diff < 0 ? 'is-under' : row.diff > 0 ? 'is-over' : 'is-even'}`}>
                {row.diff === 0 ? '±0' : row.diff > 0 ? `+${row.diff}` : row.diff}
              </span>
            </div>
          </li>
        ))}
      </ul>
    </section>

    <!-- Now scoring banner -->
    <div class="cpb">
      <div class="cpb-left">
        <span class="cpb-avatar">{me.name[0].toUpperCase()}</span>
        <div>
          <span class="cpb-eyebrow">NOW SCORING</span>
          <span class="cpb-name">{me.name}</span>
        </div>
      </div>
      <div class="cpb-right">
        <span class="cpb-hole-label">HOLE</span>
        <span class="cpb-hole-num">{FIXTURE.currentHole}</span>
      </div>
    </div>

    <!-- Hole hero card -->
    <section class="hole-hero">
      <div class="hole-hero-top">
        <span class="hole-hero-label">{currentHoleObj.name?.toUpperCase()}</span>
        <span class="hole-hero-par-label">PAR</span>
      </div>
      <div class="hole-hero-num">{currentHoleObj.par}</div>
    </section>

    <!-- Par-relative buttons -->
    <section class="rel-buttons">
      <button type="button" class="rel-btn">
        <span class="rel-label">Eagle</span>
        <span class="rel-strokes">{currentHoleObj.par - 2}</span>
      </button>
      <button type="button" class="rel-btn">
        <span class="rel-label">Birdie</span>
        <span class="rel-strokes">{currentHoleObj.par - 1}</span>
      </button>
      <button type="button" class="rel-btn is-par">
        <span class="rel-label">Par</span>
        <span class="rel-strokes">{currentHoleObj.par}</span>
      </button>
      <button type="button" class="rel-btn">
        <span class="rel-label">Bogey</span>
        <span class="rel-strokes">{currentHoleObj.par + 1}</span>
      </button>
      <button type="button" class="rel-btn">
        <span class="rel-label">Double</span>
        <span class="rel-strokes">{currentHoleObj.par + 2}</span>
      </button>
    </section>

    <div class="pill-row">
      <button type="button" class="pill">Other score</button>
      <button type="button" class="pill pill-warn">Pick up ball</button>
    </div>

    <!-- Big save CTA (Strava-feel) -->
    <button type="button" class="cta">
      <span>Save score</span>
      <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
        <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
      </svg>
    </button>

    <!-- Scorecard track -->
    <section class="card">
      <header class="card-head">
        <h3 class="card-title">Scorecard</h3>
        <span class="card-total">
          <strong>{myTotals.strokes}</strong>
          <span>strokes · par {totalPar}</span>
        </span>
      </header>
      <div class="grid">
        {FIXTURE.holes.map((h) => {
          const s = scoreFor(me.id, h.number);
          const cls = s === null
            ? 'cell-empty'
            : s < h.par ? 'cell-under'
            : s === h.par ? 'cell-par'
            : s === h.par + 1 ? 'cell-bogey' : 'cell-over';
          return (
            <div class={`cell ${cls}${h.number === FIXTURE.currentHole ? ' cell-current' : ''}`}>
              <span class="cell-strokes">{s ?? '–'}</span>
              <span class="cell-num">{h.number}</span>
            </div>
          );
        })}
      </div>
    </section>

    <p class="proto-note">VARIANT B · STRAVA-STYLE GOLF · VERT FAIRWAY</p>
  </main>

  <style>
    /* === Layout === */
    .play {
      max-width: 480px;
      margin: 0 auto;
      padding: 0 16px 80px;
      min-height: 100dvh;
    }

    /* === Hero === */
    .hero {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 20px 0;
      margin-bottom: 20px;
    }
    .hero-club { display: flex; align-items: center; gap: 12px; }
    .club-mark {
      width: 36px; height: 36px;
      border-radius: 10px;
      background: var(--club, #1A4490);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.12),
        0 4px 12px rgba(0, 0, 0, 0.32);
    }
    .hero-eyebrow {
      margin: 0 0 4px;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.22em;
      color: var(--green);
      text-transform: uppercase;
    }
    .hero-title {
      margin: 0;
      font-family: var(--font-display);
      font-size: 22px;
      font-weight: 800;
      letter-spacing: -0.02em;
      color: var(--text);
    }
    .hero-counter {
      display: flex;
      align-items: baseline;
      font-family: var(--font-display);
      color: var(--text);
    }
    .counter-current {
      font-size: 38px;
      font-weight: 800;
      line-height: 1;
      font-variant-numeric: tabular-nums;
    }
    .counter-sep { font-size: 24px; color: var(--text-muted); margin: 0 2px; }
    .counter-total { font-size: 24px; font-weight: 700; color: var(--text-muted); }

    /* === Board === */
    .board {
      background: var(--surface);
      border-radius: 16px;
      padding: 16px;
      margin-bottom: 20px;
      border: 1px solid var(--line);
    }
    .board-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 12px;
    }
    .board-title {
      margin: 0;
      font-family: var(--font-display);
      font-size: 14px;
      font-weight: 700;
      color: var(--text);
      letter-spacing: -0.005em;
    }
    .board-pulse {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      padding: 4px 9px;
      background: var(--green-soft);
      border-radius: 999px;
    }
    .pulse-dot {
      width: 5px; height: 5px; border-radius: 50%;
      background: var(--green);
      animation: dot-pulse 1.4s ease-in-out infinite;
    }
    @keyframes dot-pulse {
      0%, 100% { opacity: 0.6; transform: scale(1); }
      50%      { opacity: 1;   transform: scale(1.2); }
    }
    .pulse-text {
      font-size: 9.5px; font-weight: 700; letter-spacing: 0.16em;
      color: var(--green);
    }
    .board-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 8px; }
    .row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 12px 14px;
      background: var(--bg);
      border: 1px solid var(--line);
      border-radius: 12px;
      transition: transform 0.15s, border-color 0.15s;
    }
    .row:hover { transform: translateX(2px); }
    .row.is-leader {
      background: linear-gradient(90deg, var(--green-soft) 0%, transparent 100%);
      border-color: rgba(16, 210, 119, 0.35);
    }
    .row.is-current { border-color: var(--green); box-shadow: inset 0 0 0 1px var(--green); }
    .row-left { display: flex; align-items: center; gap: 12px; }
    .row-rank {
      font-family: var(--font-display);
      font-size: 22px;
      font-weight: 800;
      color: var(--text-muted);
      min-width: 24px;
      font-variant-numeric: tabular-nums;
    }
    .row.is-leader .row-rank { color: var(--green); }
    .row-name {
      margin: 0;
      font-size: 14px;
      font-weight: 600;
      color: var(--text);
    }
    .row-me { color: var(--green); font-weight: 500; }
    .row-sub {
      margin: 2px 0 0;
      font-size: 11.5px;
      color: var(--text-muted);
    }
    .row-diff {
      font-family: var(--font-display);
      font-size: 22px;
      font-weight: 800;
      font-variant-numeric: tabular-nums;
    }
    .row-diff.is-under { color: var(--green-good); }
    .row-diff.is-over  { color: var(--green); }
    .row-diff.is-even  { color: var(--text-soft); }

    /* === CPB === */
    .cpb {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 16px 18px;
      background: linear-gradient(135deg, var(--green) 0%, var(--green-deep) 100%);
      border-radius: 16px;
      margin-bottom: 20px;
      box-shadow: 0 12px 32px -12px rgba(16, 210, 119, 0.48);
    }
    .cpb-left { display: flex; align-items: center; gap: 12px; }
    .cpb-avatar {
      width: 42px; height: 42px;
      border-radius: 50%;
      background: rgba(0, 0, 0, 0.25);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-family: var(--font-display);
      font-size: 18px;
      font-weight: 800;
      color: #fff;
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.15);
    }
    .cpb-eyebrow {
      display: block;
      font-size: 9.5px;
      font-weight: 700;
      letter-spacing: 0.18em;
      color: rgba(255, 255, 255, 0.7);
      margin-bottom: 2px;
    }
    .cpb-name {
      font-family: var(--font-display);
      font-size: 19px;
      font-weight: 800;
      color: #fff;
      letter-spacing: -0.01em;
    }
    .cpb-right { display: flex; flex-direction: column; align-items: flex-end; }
    .cpb-hole-label {
      font-size: 9.5px;
      font-weight: 700;
      letter-spacing: 0.18em;
      color: rgba(255, 255, 255, 0.7);
    }
    .cpb-hole-num {
      font-family: var(--font-display);
      font-size: 30px;
      font-weight: 800;
      color: #fff;
      line-height: 1;
      font-variant-numeric: tabular-nums;
    }

    /* === Hole hero === */
    .hole-hero {
      background: var(--surface);
      border: 1px solid var(--line);
      border-radius: 16px;
      padding: 20px 20px 24px;
      margin-bottom: 16px;
      text-align: center;
    }
    .hole-hero-top {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      margin-bottom: 10px;
    }
    .hole-hero-label {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.2em;
      color: var(--text-muted);
    }
    .hole-hero-par-label {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.2em;
      color: var(--green);
    }
    .hole-hero-num {
      font-family: var(--font-display);
      font-size: 86px;
      font-weight: 800;
      color: var(--text);
      font-variant-numeric: tabular-nums;
      line-height: 0.9;
    }

    /* === Rel buttons === */
    .rel-buttons {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 6px;
      margin-bottom: 12px;
    }
    .rel-btn {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 6px;
      padding: 14px 4px 14px;
      background: var(--surface);
      border: 1px solid var(--line);
      border-radius: 12px;
      color: var(--text);
      cursor: pointer;
      transition: all 0.15s;
      min-height: 92px;
    }
    .rel-btn:hover { transform: translateY(-2px); border-color: var(--line-strong); }
    .rel-btn.is-par {
      background: linear-gradient(135deg, var(--green) 0%, var(--green-deep) 100%);
      border-color: var(--green);
      box-shadow: 0 8px 24px -8px rgba(16, 210, 119, 0.55);
    }
    .rel-label {
      font-size: 10.5px;
      font-weight: 700;
      letter-spacing: 0.08em;
      color: var(--text-muted);
    }
    .rel-btn.is-par .rel-label { color: rgba(255, 255, 255, 0.85); }
    .rel-strokes {
      font-family: var(--font-display);
      font-size: 28px;
      font-weight: 800;
      color: var(--text);
      font-variant-numeric: tabular-nums;
      line-height: 1;
    }
    .rel-btn.is-par .rel-strokes { color: #fff; }

    /* === Pills === */
    .pill-row { display: flex; gap: 6px; margin-bottom: 16px; }
    .pill {
      flex: 1;
      padding: 12px 16px;
      background: transparent;
      border: 1px solid var(--line-strong);
      border-radius: 999px;
      color: var(--text-soft);
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.15s;
    }
    .pill:hover { background: var(--surface); color: var(--text); }
    .pill-warn { border-color: rgba(251, 113, 133, 0.4); color: var(--red-bad); }

    /* === Big CTA === */
    .cta {
      width: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      padding: 18px;
      background: linear-gradient(135deg, var(--green) 0%, var(--green-deep) 100%);
      border: none;
      border-radius: 14px;
      color: #fff;
      font-family: var(--font-display);
      font-size: 16px;
      font-weight: 700;
      letter-spacing: -0.005em;
      cursor: pointer;
      margin-bottom: 24px;
      box-shadow: 0 12px 32px -8px rgba(16, 210, 119, 0.55);
      transition: transform 0.15s, box-shadow 0.15s;
    }
    .cta:hover { transform: translateY(-2px); }

    /* === Scorecard === */
    .card {
      background: var(--surface);
      border: 1px solid var(--line);
      border-radius: 16px;
      padding: 16px;
      margin-bottom: 24px;
    }
    .card-head {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      margin-bottom: 12px;
    }
    .card-title {
      margin: 0;
      font-family: var(--font-display);
      font-size: 14px;
      font-weight: 700;
      color: var(--text);
    }
    .card-total strong {
      font-family: var(--font-display);
      font-size: 18px;
      font-weight: 800;
      color: var(--green);
    }
    .card-total span { font-size: 11px; color: var(--text-muted); margin-left: 6px; }
    .grid {
      display: grid;
      grid-template-columns: repeat(9, 1fr);
      gap: 5px;
    }
    .cell {
      aspect-ratio: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 2px;
      background: var(--bg);
      border: 1px solid var(--line);
      border-radius: 8px;
    }
    .cell-strokes {
      font-family: var(--font-display);
      font-size: 16px;
      font-weight: 800;
      color: var(--text);
      line-height: 1;
      font-variant-numeric: tabular-nums;
    }
    .cell-num {
      font-size: 9px;
      font-weight: 600;
      color: var(--text-muted);
    }
    .cell-empty .cell-strokes { color: var(--text-muted); opacity: 0.4; }
    .cell-under { background: rgba(94, 234, 212, 0.10); border-color: rgba(94, 234, 212, 0.30); }
    .cell-under .cell-strokes { color: var(--green-good); }
    .cell-par .cell-strokes { color: var(--green); }
    .cell-bogey .cell-strokes { color: var(--text-soft); }
    .cell-over .cell-strokes { color: var(--red-bad); }
    .cell-current { box-shadow: 0 0 0 2px var(--green); }

    .proto-note {
      text-align: center;
      font-size: 9px;
      letter-spacing: 0.3em;
      color: var(--text-muted);
      opacity: 0.4;
      margin-top: 40px;
    }
  </style>
</body>
</html>
