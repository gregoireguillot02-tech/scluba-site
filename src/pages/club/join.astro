---
export const prerender = false;
import '../../styles/tokens.css';
import '../../styles/global.css';
import { serviceClient } from '../../lib/supabase';
import { isInviteUsable } from '../../lib/club-auth';

const token = Astro.url.searchParams.get('token') ?? '';
const user = Astro.locals.user;

let state: 'need-login' | 'invalid' | 'done' = 'invalid';
let clubName = '';

if (token) {
  const sb = serviceClient();
  const { data: invite } = await sb
    .from('club_invites')
    .select('id, club_id, role, expires_at, used_at')
    .eq('token', token)
    .maybeSingle();

  if (invite && isInviteUsable(invite, new Date())) {
    const { data: club } = await sb.from('clubs').select('name').eq('id', invite.club_id).maybeSingle();
    clubName = club?.name ?? '';
    if (!user) {
      state = 'need-login';
    } else {
      // Idempotent : si déjà membre, ne pas dupliquer (unique user_id+club_id).
      const { data: existing } = await sb
        .from('club_users')
        .select('id')
        .eq('user_id', user.id)
        .eq('club_id', invite.club_id)
        .maybeSingle();
      if (!existing) {
        await sb.from('club_users').insert({
          user_id: user.id,
          club_id: invite.club_id,
          role: invite.role,
        });
      }
      // Marque l'invite consommée (guard `is used_at null` = anti double-consommation).
      await sb
        .from('club_invites')
        .update({ used_at: new Date().toISOString(), used_by: user.id })
        .eq('id', invite.id)
        .is('used_at', null);
      state = 'done';
    }
  }
}

const loginHref = `/auth/login?next=${encodeURIComponent('/club/join?token=' + token)}`;
---
<html lang="fr">
  <head><meta charset="utf-8" /><meta name="viewport" content="width=device-width, initial-scale=1" /><title>Rejoindre le portail club</title></head>
  <body style="font-family:system-ui;max-width:520px;margin:80px auto;padding:0 20px;color:#1B4332">
    {state === 'done' && (
      <>
        <h1>Bienvenue{clubName ? `, ${clubName}` : ''} 👋</h1>
        <p>Votre accès au portail club est activé.</p>
        <p><a href="/club" style="color:#D4A574">Accéder au portail →</a></p>
      </>
    )}
    {state === 'need-login' && (
      <>
        <h1>Rejoindre {clubName}</h1>
        <p>Connectez-vous pour activer votre accès.</p>
        <p><a href={loginHref} style="color:#D4A574">Recevoir un lien de connexion →</a></p>
      </>
    )}
    {state === 'invalid' && (
      <>
        <h1>Invitation invalide</h1>
        <p>Ce lien est expiré ou a déjà été utilisé. Demandez-en un nouveau au club.</p>
      </>
    )}
  </body>
</html>
