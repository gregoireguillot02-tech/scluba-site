---
export const prerender = false;

import '../../../styles/tokens.css';
import '../../../styles/global.css';
import { serviceClient } from '../../../lib/supabase';
import type { Club, Round, RoundPlayer, Score } from '../../../lib/clubs-types';
import { totalPar } from '../../../lib/clubs-types';

const { shortCode } = Astro.params;
const sb = serviceClient();

const { data: round } = await sb
  .from('rounds')
  .select('*, club:clubs(*)')
  .eq('short_code', shortCode)
  .maybeSingle();

if (!round) {
  return new Response('Partie introuvable', { status: 404 });
}

const r = round as Round & { club: Club };

if (r.status === 'finished') {
  return Astro.redirect(`/r/${shortCode}/recap`, 302);
}

const playerId = Astro.cookies.get(`scluba_player_${shortCode}`)?.value ?? null;

const [{ data: player }, { data: rawScores }] = await Promise.all([
  playerId
    ? sb.from('round_players').select('*').eq('id', playerId).eq('round_id', r.id).maybeSingle()
    : Promise.resolve({ data: null }),
  playerId
    ? sb.from('scores').select('*').eq('round_player_id', playerId).order('hole_number')
    : Promise.resolve({ data: [] }),
]);

if (!player) {
  return new Response('Tu n\'es pas joueur dans cette partie. Reviens depuis la page du club pour démarrer.', { status: 403 });
}

const me = player as RoundPlayer;
const myScores = (rawScores ?? []) as Score[];
const par = totalPar(r.club.course_data);
const heroColor = r.club.primary_color ?? '#1B4332';

const scoresByHole: Record<number, number> = {};
for (const s of myScores) scoresByHole[s.hole_number] = s.strokes;
---

<!doctype html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title>{r.club.name} — Saisie en cours · Scluba</title>
  <meta name="robots" content="noindex, nofollow" />
  <meta name="theme-color" content={heroColor} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <style define:vars={{ heroColor }}>
    body {
      background: #FAF7EE;
      min-height: 100dvh;
      overflow-x: hidden;
      overscroll-behavior-y: none;
    }
  </style>
</head>
<body>
  <main class="play">
    <header class="play-header" style={`background: ${heroColor}`}>
      <div class="play-header-inner">
        {r.club.logo_url && (
          <img class="play-header-logo" src={r.club.logo_url} alt="" />
        )}
        <div class="play-header-text">
          <p class="play-club">{r.club.name}</p>
          <p class="play-player">{me.display_name}</p>
        </div>
      </div>
    </header>

    <section
      class="hole-card"
      data-play-root
      data-short-code={r.short_code}
      data-course={JSON.stringify(r.club.course_data)}
      data-scores={JSON.stringify(scoresByHole)}
      data-par={String(par)}
      data-hole-count={String(r.club.course_data.holes.length)}
    >
      <div class="hole-meta">
        <span class="hole-meta-label">Trou</span>
        <span class="hole-meta-count">
          <span data-hole-number>1</span> / {r.club.course_data.holes.length}
        </span>
      </div>

      <div class="hole-par-block">
        <div class="hole-par-label">PAR</div>
        <div class="hole-par-value" data-par-value>4</div>
      </div>

      <div class="score-control">
        <button type="button" class="score-step" data-step="-1" aria-label="Diminuer">−</button>
        <div class="score-display" data-strokes-display>—</div>
        <button type="button" class="score-step" data-step="+1" aria-label="Augmenter">+</button>
      </div>

      <p class="score-hint" data-score-hint>Choisis ton score</p>

      <div class="quick-buttons">
        {[1, 2, 3, 4, 5, 6, 7, 8, 9].map((n) => (
          <button type="button" class="quick-btn" data-quick={n}>{n}</button>
        ))}
      </div>

      <div class="nav-buttons">
        <button type="button" class="nav-btn nav-prev" data-nav="prev">← Précédent</button>
        <button type="button" class="nav-btn nav-next" data-nav="next">Suivant →</button>
      </div>
    </section>

    <section class="leaderboard">
      <header class="leaderboard-head">
        <span>Carte</span>
        <span data-total-strokes>—</span>
      </header>
      <div class="grid">
        <div class="grid-row">
          <span class="grid-label">F9</span>
          {Array.from({ length: 9 }).map((_, i) => (
            <span class="grid-cell" data-cell-hole={i + 1}>—</span>
          ))}
        </div>
        <div class="grid-row">
          <span class="grid-label">B9</span>
          {Array.from({ length: 9 }).map((_, i) => (
            <span class="grid-cell" data-cell-hole={i + 10}>—</span>
          ))}
        </div>
      </div>
    </section>

    <form method="POST" action={`/api/rounds/${r.short_code}/finish`} class="finish-form" data-finish-form hidden>
      <button type="submit" class="finish-btn">Terminer la partie</button>
    </form>

    <p class="play-status" data-status></p>
  </main>

  <script>
    type CourseData = { holes: { number: number; par: number }[] };

    const root = document.querySelector<HTMLElement>('[data-play-root]');
    if (root) {
      const shortCode = root.dataset.shortCode!;
      const course = JSON.parse(root.dataset.course!) as CourseData;
      const initialScores = JSON.parse(root.dataset.scores!) as Record<number, number>;
      const totalPar = Number(root.dataset.par);
      const holeCount = Number(root.dataset.holeCount);

      const scores: Record<number, number> = { ...initialScores };
      let currentHole = nextEmptyHole();

      const holeNumberEl = root.querySelector<HTMLElement>('[data-hole-number]')!;
      const parValueEl = root.querySelector<HTMLElement>('[data-par-value]')!;
      const strokesEl = root.querySelector<HTMLElement>('[data-strokes-display]')!;
      const hintEl = root.querySelector<HTMLElement>('[data-score-hint]')!;
      const totalStrokesEl = document.querySelector<HTMLElement>('[data-total-strokes]')!;
      const finishForm = document.querySelector<HTMLFormElement>('[data-finish-form]')!;
      const statusEl = document.querySelector<HTMLElement>('[data-status]')!;
      const cells = Array.from(document.querySelectorAll<HTMLElement>('[data-cell-hole]'));

      function nextEmptyHole(): number {
        for (let h = 1; h <= holeCount; h++) {
          if (scores[h] === undefined) return h;
        }
        return holeCount;
      }

      function holeAt(n: number) {
        return course.holes.find((h) => h.number === n) ?? course.holes[0];
      }

      function diffLabel(strokes: number, par: number): string {
        const d = strokes - par;
        if (d <= -2) return 'Eagle';
        if (d === -1) return 'Birdie';
        if (d === 0) return 'Par';
        if (d === 1) return 'Bogey';
        if (d === 2) return 'Double bogey';
        return `+${d}`;
      }

      function diffClass(strokes: number, par: number): string {
        const d = strokes - par;
        if (d <= -1) return 'cell-birdie';
        if (d === 0) return 'cell-par';
        if (d === 1) return 'cell-bogey';
        return 'cell-double';
      }

      function render() {
        const hole = holeAt(currentHole);
        holeNumberEl.textContent = String(currentHole);
        parValueEl.textContent = String(hole.par);

        const s = scores[currentHole];
        if (s === undefined) {
          strokesEl.textContent = '—';
          hintEl.textContent = 'Choisis ton score';
        } else {
          strokesEl.textContent = String(s);
          hintEl.textContent = diffLabel(s, hole.par);
        }

        let total = 0;
        let played = 0;
        for (let h = 1; h <= holeCount; h++) {
          const cell = cells.find((c) => Number(c.dataset.cellHole) === h);
          if (!cell) continue;
          cell.className = 'grid-cell';
          if (scores[h] !== undefined) {
            cell.textContent = String(scores[h]);
            cell.classList.add(diffClass(scores[h], holeAt(h).par));
            total += scores[h];
            played++;
          } else {
            cell.textContent = '—';
          }
        }
        totalStrokesEl.textContent = played === 0 ? '—' : `${total} (par ${totalPar})`;

        const allDone = played === holeCount;
        finishForm.hidden = !allDone;

        const prevBtn = root!.querySelector<HTMLButtonElement>('[data-nav="prev"]')!;
        const nextBtn = root!.querySelector<HTMLButtonElement>('[data-nav="next"]')!;
        prevBtn.disabled = currentHole === 1;
        nextBtn.disabled = currentHole === holeCount;
      }

      async function saveScore(strokes: number) {
        scores[currentHole] = strokes;
        render();
        statusEl.textContent = 'Sauvegarde…';
        try {
          const res = await fetch(`/api/rounds/${shortCode}/scores`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ hole: currentHole, strokes }),
          });
          if (!res.ok) throw new Error(await res.text());
          statusEl.textContent = '✓ Enregistré';
          setTimeout(() => { statusEl.textContent = ''; }, 1200);
        } catch (e) {
          statusEl.textContent = `Erreur : ${(e as Error).message}`;
        }
      }

      root.querySelectorAll<HTMLElement>('[data-quick]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const n = Number(btn.dataset.quick);
          saveScore(n);
        });
      });

      root.querySelectorAll<HTMLElement>('[data-step]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const delta = Number(btn.dataset.step);
          const current = scores[currentHole] ?? holeAt(currentHole).par;
          const next = Math.max(1, Math.min(20, current + delta));
          saveScore(next);
        });
      });

      root.querySelectorAll<HTMLElement>('[data-nav]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const dir = btn.dataset.nav;
          if (dir === 'prev' && currentHole > 1) currentHole--;
          if (dir === 'next' && currentHole < holeCount) currentHole++;
          render();
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });
      });

      render();
    }
  </script>

  <style>
    .play {
      max-width: 480px;
      margin: 0 auto;
      min-height: 100dvh;
      background: linear-gradient(180deg, #FAF7EE 0%, #F4F8F5 100%);
      box-shadow: 0 32px 80px rgba(27, 67, 50, 0.18);
      display: flex;
      flex-direction: column;
    }

    .play-header {
      color: #FAF7EE;
      padding: var(--space-4) var(--space-5);
    }
    .play-header-inner {
      display: flex;
      align-items: center;
      gap: var(--space-3);
    }
    .play-header-logo {
      width: 36px;
      height: 36px;
      object-fit: contain;
      background: rgba(250, 247, 238, 0.92);
      border-radius: 50%;
      padding: 4px;
      flex-shrink: 0;
    }
    .play-header-text {
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 2px;
      min-width: 0;
    }
    .play-club {
      margin: 0;
      font-family: var(--font-serif);
      font-size: var(--text-md);
      font-weight: 600;
      letter-spacing: 0.02em;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .play-player {
      margin: 0;
      font-size: 11px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      opacity: 0.85;
    }

    .hole-card {
      padding: var(--space-7) var(--space-5) var(--space-6);
      text-align: center;
    }
    .hole-meta {
      display: flex;
      align-items: baseline;
      justify-content: center;
      gap: var(--space-2);
      color: var(--accent);
      font-size: 11px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      font-weight: 700;
    }
    .hole-meta-count {
      font-family: var(--font-serif);
      font-size: var(--text-md);
      color: var(--primary);
      font-weight: 700;
      letter-spacing: 0.05em;
    }
    .hole-meta-count > span { font-size: var(--text-lg, 22px); }

    .hole-par-block {
      margin: var(--space-5) 0 var(--space-6);
    }
    .hole-par-label {
      font-size: 11px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--muted);
      font-weight: 700;
    }
    .hole-par-value {
      font-family: var(--font-serif);
      font-size: clamp(3rem, 14vw, 4.5rem);
      font-weight: 800;
      color: var(--primary);
      line-height: 1;
      font-variant-numeric: tabular-nums;
    }

    .score-control {
      display: grid;
      grid-template-columns: 56px 1fr 56px;
      gap: var(--space-4);
      align-items: center;
      max-width: 320px;
      margin: 0 auto;
    }
    .score-step {
      width: 56px;
      height: 56px;
      border-radius: 50%;
      border: 1.5px solid var(--line);
      background: #fff;
      color: var(--primary);
      font-size: 28px;
      font-weight: 600;
      cursor: pointer;
      transition: transform 0.1s, border-color 0.15s;
    }
    .score-step:hover { border-color: var(--primary-soft); }
    .score-step:active { transform: scale(0.95); }
    .score-display {
      font-family: var(--font-serif);
      font-size: clamp(4rem, 18vw, 6rem);
      font-weight: 800;
      color: var(--primary);
      line-height: 1;
      font-variant-numeric: tabular-nums;
    }
    .score-hint {
      margin: var(--space-4) 0 0;
      font-size: var(--text-sm);
      color: var(--muted);
      letter-spacing: 0.04em;
    }

    .quick-buttons {
      display: grid;
      grid-template-columns: repeat(9, 1fr);
      gap: 6px;
      max-width: 360px;
      margin: var(--space-6) auto 0;
    }
    .quick-btn {
      aspect-ratio: 1;
      border-radius: 10px;
      border: 1px solid var(--line);
      background: #fff;
      color: var(--ink);
      font-size: 14px;
      font-weight: 700;
      font-variant-numeric: tabular-nums;
      cursor: pointer;
    }
    .quick-btn:hover { background: var(--bg-soft); }
    .quick-btn:active { transform: scale(0.96); }

    .nav-buttons {
      display: flex;
      justify-content: space-between;
      gap: var(--space-3);
      margin-top: var(--space-6);
    }
    .nav-btn {
      flex: 1;
      padding: 12px 16px;
      border-radius: 10px;
      border: 1px solid var(--line);
      background: #fff;
      color: var(--primary);
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
    }
    .nav-btn:disabled { opacity: 0.4; cursor: not-allowed; }

    .leaderboard {
      margin: 0 var(--space-5) var(--space-5);
      padding: var(--space-4);
      background: rgba(212, 165, 116, 0.08);
      border-top: 1px solid rgba(212, 165, 116, 0.3);
      border-bottom: 1px solid rgba(212, 165, 116, 0.3);
    }
    .leaderboard-head {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: var(--space-3);
    }
    .leaderboard-head span:last-child {
      font-family: var(--font-serif);
      color: var(--primary);
      font-size: var(--text-sm);
      letter-spacing: 0;
      text-transform: none;
    }

    .grid {
      display: flex;
      flex-direction: column;
      gap: 6px;
    }
    .grid-row {
      display: grid;
      grid-template-columns: 28px repeat(9, 1fr);
      gap: 4px;
    }
    .grid-label {
      background: var(--primary);
      color: var(--bg);
      font-size: 11px;
      font-weight: 700;
      border-radius: var(--radius-sm);
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .grid-cell {
      aspect-ratio: 1;
      background: var(--bg);
      border: 1px solid var(--line);
      border-radius: var(--radius-sm);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 13px;
      font-weight: 700;
      color: var(--ink);
      font-variant-numeric: tabular-nums;
    }
    .grid-cell.cell-birdie { color: #C0392B; background: var(--accent-soft); border-color: var(--accent); }
    .grid-cell.cell-par { color: var(--primary); }
    .grid-cell.cell-bogey { color: var(--muted); }
    .grid-cell.cell-double { color: #6B7280; background: rgba(107,114,128,0.08); }

    .finish-form {
      padding: 0 var(--space-5);
    }
    .finish-btn {
      width: 100%;
      padding: 16px 24px;
      border-radius: 12px;
      border: none;
      background: var(--primary);
      color: #FAF7EE;
      font-size: 16px;
      font-weight: 600;
      cursor: pointer;
      box-shadow: 0 8px 24px rgba(27, 67, 50, 0.18);
    }

    .play-status {
      text-align: center;
      padding: var(--space-3);
      font-size: 13px;
      color: var(--muted);
      min-height: 1.2em;
    }
  </style>
</body>
</html>
