      height: 28px;
      object-fit: contain;
      background: rgba(255, 255, 255, 0.96);
      border-radius: 50%;
      padding: 3px;
      flex-shrink: 0;
    }
    .play-club {
      margin: 0;
      font-family: var(--font-display);
      font-size: 14px;
      font-weight: 700;
      letter-spacing: -0.005em;
      color: #FFFFFF;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .play-player {
      margin: 0;
      font-family: var(--font-mono);
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--ink-soft);
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      flex-shrink: 0;
      max-width: 50%;
    }

    /* === Hole card (PAR géant + ScoreInput) ===
       Carte glass complète. Le grand chiffre PAR ressort sur fond glass
       blanc translucide, le quadrillage transparaît subtilement derrière. */
    .hole-card {
      position: relative;
      margin: 0 var(--space-4);
      padding: var(--space-7) var(--space-5) var(--space-6);
      text-align: center;
      background: var(--play-card-bg);
      -webkit-backdrop-filter: var(--play-card-blur);
              backdrop-filter: var(--play-card-blur);
      border: 1px solid rgba(15, 42, 30, 0.06);
      border-radius: 18px;
      box-shadow: var(--play-card-shadow);
    }
    @supports not (backdrop-filter: blur(1px)) {
      .hole-card { background: rgba(255, 255, 255, 0.92); }
    }
    /* Mode spectateur (scoring_mode='host', non-créateur) : le hole-card
       (PAR + ScoreInput) est masqué. Visible si le joueur clique sur
       "Corriger un de mes scores" → toggle .is-revealed. */
    .hole-card[data-spectator="true"]:not(.is-revealed) {
      display: none;
    }

    /* === Bannière de rythme de jeu === Affichée seulement en retard (orange =
       léger, rouge = important). Silence quand le rythme est bon (toggle de
       l'attribut hidden en JS). .pace-banner force display:flex donc on doit
       ré-affirmer display:none sur [hidden]. */
    .pace-banner {
      margin: 0 var(--space-4) var(--space-3);
      padding: 12px 16px;
      border-radius: 14px;
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 14px;
      font-weight: 600;
      line-height: 1.35;
      box-shadow: var(--play-card-shadow);
    }
    .pace-banner[hidden] { display: none; }
    .pace-banner .pace-dot {
      flex-shrink: 0;
      width: 9px;
      height: 9px;
      border-radius: 50%;
      background: currentColor;
    }
    .pace-banner .pace-text { flex: 1; }
    .pace-banner.is-orange {
      color: #92400E;
      background:
        linear-gradient(180deg, rgba(245, 158, 11, 0.18), rgba(245, 158, 11, 0.08)),
        rgba(255, 255, 255, 0.90);
      border: 1px solid rgba(245, 158, 11, 0.5);
    }
    .pace-banner.is-red {
      color: #B91C1C;
      background:
        linear-gradient(180deg, rgba(220, 38, 38, 0.18), rgba(220, 38, 38, 0.08)),
        rgba(255, 255, 255, 0.92);
      border: 1px solid rgba(220, 38, 38, 0.5);
    }
    .pace-banner.is-red .pace-dot {
      animation: pace-dot-pulse 1.2s ease-in-out infinite;
    }
    @keyframes pace-dot-pulse {
      0%, 100% { opacity: 0.5; transform: scale(1); }
      50%      { opacity: 1;   transform: scale(1.25); }
    }
    @media (prefers-reduced-motion: reduce) {
      .pace-banner.is-red .pace-dot { animation: none; }
    }

    /* Spectator banner : honey gradient renforcé pour rester lisible
       au-dessus du quadrillage forest (sinon effet muddy). Border honey
       0.4 → 0.5, fond paper opaque sous le gradient honey. */
    .spectator-banner {
      position: relative;
      margin: 0 var(--space-4);
      padding: 14px 16px;
      border-radius: 14px;
      background:
        linear-gradient(180deg, rgba(212, 165, 116, 0.20), rgba(212, 165, 116, 0.06)),
        rgba(255, 255, 255, 0.62);
      -webkit-backdrop-filter: blur(6px) saturate(115%);
              backdrop-filter: blur(6px) saturate(115%);
      border: 1px solid rgba(212, 165, 116, 0.5);
      box-shadow: var(--play-card-shadow);
      display: flex;
      flex-direction: column;
      gap: 10px;
    }
    @supports not (backdrop-filter: blur(1px)) {
      .spectator-banner {
        background:
          linear-gradient(180deg, rgba(212, 165, 116, 0.20), rgba(212, 165, 116, 0.06)),
          rgba(255, 255, 255, 0.92);
      }
    }
    /* Badge "EN DIRECT" anchored top-right — signal visuel que le
       spectateur regarde en temps réel. Dot honey qui pulse pour
       renforcer le ressenti "live". */
    .spectator-live-badge {
      position: absolute;
      top: 10px;
      right: 12px;
      display: inline-flex;
      align-items: center;
      gap: 5px;
      padding: 4px 9px 4px 8px;
      border-radius: 999px;
      background: rgba(212, 165, 116, 0.22);
      border: 1px solid rgba(212, 165, 116, 0.55);
      font-family: var(--font-mono);
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 0.16em;
      color: var(--accent);
      text-transform: uppercase;
      pointer-events: none;
    }
    .live-badge-dot {
      width: 5px;
      height: 5px;
      border-radius: 50%;
      background: var(--accent);
      box-shadow: 0 0 0 2px rgba(212, 165, 116, 0.28);
      animation: live-dot-pulse 1.4s ease-in-out infinite;
    }
    @keyframes live-dot-pulse {
      0%, 100% { opacity: 0.55; transform: scale(1); }
      50%      { opacity: 1;    transform: scale(1.15); }
    }
    @media (prefers-reduced-motion: reduce) {
      .live-badge-dot { animation: none; }
    }
    .spectator-banner-title {
      margin: 0;
      /* Padding-right pour ne pas chevaucher le badge "EN DIRECT". */
      padding-right: 92px;
      font-family: var(--font-display, var(--font-serif));
      font-size: 16px;
      font-weight: 700;
      color: var(--ink);
    }
    .spectator-banner-sub {
      margin: 4px 0 0;
      font-size: 13px;
      line-height: 1.4;
      color: var(--muted);
    }
    .spectator-toggle-btn {
      align-self: flex-start;
      padding: 8px 14px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.7);
      border: 1px solid rgba(212, 165, 116, 0.55);
      color: var(--accent);
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      transition: background 0.15s, color 0.15s, border-color 0.15s;
    }
    .spectator-toggle-btn:hover { background: #fff; }
    .spectator-toggle-btn:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 3px;
      box-shadow: 0 0 0 5px rgba(15, 42, 30, 0.12);
    }
    .spectator-toggle-btn.is-active {
      background: var(--accent);
      color: #FAF7EE;
      border-color: var(--accent);
    }

    .hole-meta {
      position: absolute;
      top: var(--space-3);
      right: var(--space-4);
      display: flex;
      align-items: baseline;
      justify-content: flex-end;
      gap: var(--space-2);
      color: var(--accent);
      font-size: 11px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      font-weight: 700;
    }
    .hole-meta-count {
      font-family: var(--font-serif);
      font-size: var(--text-md);
      color: var(--accent);
      font-weight: 700;
      letter-spacing: 0.05em;
    }
    .hole-meta-count > span { font-size: var(--text-lg, 22px); }

    .hole-par-block {
      margin: var(--space-5) 0 var(--space-6);
    }
    .hole-par-label {
      font-size: 11px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--muted);
      font-weight: 700;
    }
    .hole-par-value {
      font-family: var(--font-serif);
      font-size: clamp(3rem, 14vw, 4.5rem);
      font-weight: 800;
      color: var(--accent);
      line-height: 1;
      font-variant-numeric: tabular-nums;
    }

    /* === Carnet de parcours : bouton "Voir le trou" ===
       Pill honey discrète sous le PAR. Caché (hidden) quand le trou n'a pas
       de visuel. Centré via le text-align:center du .hole-card parent. */
    .hole-guide-btn {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      margin: 0 0 var(--space-4);
      padding: 8px 16px;
      border-radius: 999px;
      border: 1px solid var(--accent);
      background: rgba(212, 165, 116, 0.10);
      color: var(--primary, #1B4332);
      font-family: var(--font-mono);
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      cursor: pointer;
      touch-action: manipulation;
      transition: background 150ms, transform 100ms;
    }
    .hole-guide-btn[hidden] { display: none; }
    .hole-guide-btn:hover { background: rgba(212, 165, 116, 0.20); }
    .hole-guide-btn:active { transform: scale(0.97); }
    .hole-guide-btn:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 3px;
      box-shadow: 0 0 0 5px rgba(15, 42, 30, 0.12);
    }
    .hole-guide-btn svg { color: var(--accent); }

    /* Score input (par-relative XL, dots, Autre/Abandonner pills)
       → src/components/player/ScoreInput.astro. La saisie + le pickup
       + la navigation entre trous sont concentrés dans ce composant. */

    /* === Scorecard "Carte" ===
       Carte glass blanche. La teinte honey 0.08 d'origine ne suffisait pas
       à se détacher du quadrillage, on passe en glass complet avec accent
       honey préservé sur les borders top/bottom. */
    .leaderboard {
      margin: 0 var(--space-4);
      padding: var(--space-4);
      background: var(--play-card-bg);
      -webkit-backdrop-filter: var(--play-card-blur);
              backdrop-filter: var(--play-card-blur);
      border: 1px solid rgba(15, 42, 30, 0.06);
      border-top: 1px solid rgba(212, 165, 116, 0.4);
      border-bottom: 1px solid rgba(212, 165, 116, 0.4);
      border-radius: 16px;
      box-shadow: var(--play-card-shadow);
    }
    @supports not (backdrop-filter: blur(1px)) {
      .leaderboard { background: rgba(255, 255, 255, 0.92); }
    }
    .leaderboard-head {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: var(--space-3);
    }
    .leaderboard-head span:last-child {
      font-family: var(--font-serif);
      color: var(--accent);
      font-size: var(--text-sm);
      letter-spacing: 0;
      text-transform: none;
    }

    /* La grille scorecard (.grid, .grid-row, .grid-cell, .cell-*) est
       maintenant dans Scorecard.astro (mode="live"). Le JS de cette page
       continue de manipuler les cells via [data-cell-hole] et de toggler
       les classes cell-birdie/par/bogey/double/pickup (les sélecteurs
       scoped dans Scorecard.astro matchent les cells qu'il a rendues). */

    .finish-form {
      padding: 0 var(--space-4);
    }
    .finish-btn {
      width: 100%;
      padding: 16px 24px;
      border-radius: 12px;
      border: none;
      background: var(--accent);
      color: #FAF7EE;
      font-size: 16px;
      font-weight: 600;
      cursor: pointer;
      box-shadow: 0 8px 24px rgba(27, 67, 50, 0.18);
    }

    .play-status {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
      text-align: center;
      padding: var(--space-3);
      font-size: 13px;
      color: var(--accent);
      min-height: 1.2em;
      width: 100%;
      box-sizing: border-box;
    }
    /* SVG checkmark animé — remplace l'ancien '✓' Unicode (PR5).
       Le polyline démarre invisible (stroke-dashoffset = path length),
       puis stroke-dashoffset → 0 en 250ms ease-out → impression de
       dessin à la main. La SVG est recréée à chaque innerHTML donc
       l'animation rejoue à chaque save success. */
    .check-icon {
      display: inline-block;
      color: var(--accent);
      flex-shrink: 0;
    }
    .check-icon polyline {
      stroke-dasharray: 26;
      stroke-dashoffset: 26;
      animation: check-draw 280ms cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    @keyframes check-draw {
      to { stroke-dashoffset: 0; }
    }
    @media (prefers-reduced-motion: reduce) {
      .check-icon polyline {
        animation: none;
        stroke-dashoffset: 0;
      }
    }

    /* Alert icon (triangle ⚠) + wiggle pour les erreurs save.
       Inspiré SF Symbols 'wiggle' effect : le symbole secoue
       gauche-droite 3 fois rapidement → communique l'erreur de
       façon tactile / mémorable, plus qu'un simple texte rouge.
       Transform-only : compositor GPU, zéro repaint. */
    .alert-icon {
      display: inline-block;
      color: #C0392B;
      flex-shrink: 0;
      transform-origin: center;
      animation: alert-wiggle 0.42s cubic-bezier(0.36, 0, 0.66, -0.56) 1;
    }
    .status-text-error {
      color: #C0392B;
      font-weight: 600;
    }
    /* Erreur tinte le bloc entier */
    .play-status:has(.alert-icon) {
      color: #C0392B;
    }
    @keyframes alert-wiggle {
      0%, 100% { transform: translateX(0) rotate(0deg); }
      15%      { transform: translateX(-3px) rotate(-4deg); }
      35%      { transform: translateX(3px)  rotate(4deg); }
      55%      { transform: translateX(-2px) rotate(-3deg); }
      75%      { transform: translateX(2px)  rotate(3deg); }
    }
    @media (prefers-reduced-motion: reduce) {
      .alert-icon { animation: none; }
    }

    /* === Signalement souci parcours (Portail Club) === */
    .report-trigger {
      display: block;
      margin: 12px auto 0;
      background: none;
      border: none;
      color: #9ca3af;
      font-size: 13px;
      cursor: pointer;
      text-decoration: underline;
      padding: 4px 8px;
    }
    .report-trigger:hover { color: #6b7280; }
    .report-dialog {
      border: none;
      border-radius: 14px;
      padding: 20px;
      max-width: 420px;
      width: calc(100% - 32px);
      box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
    }
    .report-dialog::backdrop { background: rgba(0, 0, 0, 0.4); }
    .report-title { margin: 0 0 12px; font-size: 16px; color: #1B4332; }
    .report-fieldset { border: 0; margin: 0 0 12px; padding: 0; min-inline-size: 0; }
    .report-legend { padding: 0; margin: 0 0 6px; font-size: 13px; color: #6b7280; }
    .report-cats {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
    }
    .report-cats label {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 14px;
      padding: 6px 8px;
      border: 1px solid #e5e7eb;
      border-radius: 8px;
      cursor: pointer;
    }
    .report-comment {
      width: 100%;
      min-height: 64px;
      border: 1px solid #e5e7eb;
      border-radius: 8px;
      padding: 8px;
      font: inherit;
      resize: vertical;
      box-sizing: border-box;
    }
    .report-actions {
      display: flex;
      justify-content: flex-end;
      gap: 8px;
      margin: 12px 0 0;
      padding: 0;
    }
    .report-actions button {
      padding: 8px 16px;
      border-radius: 8px;
      border: 1px solid #e5e7eb;
      background: #fff;
      cursor: pointer;
      font-size: 14px;
    }
    .report-send {
      background: #1B4332;
      color: #fff;
      border-color: #1B4332;
    }
    .report-msg { margin: 10px 0 0; font-size: 13px; color: #6b7280; min-height: 1.2em; }
  </style>
</PlayerLayout>
