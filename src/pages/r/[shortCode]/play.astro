---
export const prerender = false;

import PlayerLayout from '../../../layouts/PlayerLayout.astro';
import Scorecard from '../../../components/player/Scorecard.astro';
import ScoreInput from '../../../components/player/ScoreInput.astro';
import HoleGuideModal from '../../../components/player/HoleGuideModal.astro';
import { serviceClient } from '../../../lib/supabase';
import type { Club, Round, RoundPlayer, Score } from '../../../lib/clubs-types';
import { resolveRoundHoles, resolveRoundSections } from '../../../lib/clubs-types';

const { shortCode } = Astro.params;
const sb = serviceClient();

const { data: round } = await sb
  .from('rounds')
  .select('*, club:clubs(*)')
  .eq('short_code', shortCode)
  .maybeSingle();

if (!round) {
  return Astro.rewrite('/404');
}

const r = round as Round & { club: Club };

if (r.status === 'finished') {
  return Astro.redirect(`/r/${shortCode}/recap`, 302);
}

const playerId = Astro.cookies.get(`scluba_player_${shortCode}`)?.value ?? null;

const { data: allPlayersRaw } = await sb
  .from('round_players')
  .select('*')
  .eq('round_id', r.id)
  .order('joined_at');
const allPlayers = (allPlayersRaw ?? []) as RoundPlayer[];

const me = allPlayers.find((p) => p.id === playerId);
if (!me) {
  return new Response('Tu n\'es pas joueur dans cette partie. Reviens depuis la page du club pour démarrer.', { status: 403 });
}

const playerIds = allPlayers.map((p) => p.id);
const { data: allScoresRaw } = playerIds.length
  ? await sb.from('scores').select('*').in('round_player_id', playerIds)
  : { data: [] as Score[] };
const allScores = (allScoresRaw ?? []) as Score[];

// Resolve which holes this round actually plays based on its format_id.
// Falls back to course_data.holes when no format is set (legacy rounds).
const roundHoles = resolveRoundHoles(r, r.club);
const roundSections = resolveRoundSections(r, r.club);
const par = roundHoles.reduce((sum, h) => sum + h.par, 0);
const clubColor = r.club.primary_color ?? '#1B4332';
const iconUrl = r.club.icon_url ?? r.club.logo_url ?? undefined;

const scoresByHole: Record<number, number> = {};
const pickedUpHoles: number[] = [];
for (const s of allScores) {
  if (s.round_player_id !== me.id) continue;
  if (s.picked_up) {
    pickedUpHoles.push(s.hole_number);
  } else if (s.strokes !== null) {
    scoresByHole[s.hole_number] = s.strokes;
  }
}

// État par joueur pour le mode host (saisie sur un seul téléphone). Le host
// (créateur) voit des tabs pour switcher entre les joueurs et saisir au nom
// de chacun. Les non-host gardent leur expérience actuelle (un seul player).
const allScoresByPlayer: Record<string, Record<number, number>> = {};
const allPickedUpByPlayer: Record<string, number[]> = {};
for (const p of allPlayers) {
  allScoresByPlayer[p.id] = {};
  allPickedUpByPlayer[p.id] = [];
}
for (const s of allScores) {
  const bucket = allScoresByPlayer[s.round_player_id];
  const pickups = allPickedUpByPlayer[s.round_player_id];
  if (!bucket || !pickups) continue;
  if (s.picked_up) pickups.push(s.hole_number);
  else if (s.strokes !== null) bucket[s.hole_number] = s.strokes;
}

const canHostSwitch = me.is_creator && allPlayers.length > 1;

// Vue spectateur : quand la partie est en mode "host saisit tout" et que
// le joueur courant n'est pas le créateur, on masque le ScoreInput et
// on met en avant le live leaderboard. Un bouton "Corriger un de mes
// scores" permet de réafficher la saisie en exception.
const isSpectator = r.scoring_mode === 'host' && !me.is_creator;
const hostPlayer = allPlayers.find((p) => p.is_creator) ?? null;

const holesByNumber: Record<number, number> = {};
for (const h of roundHoles) holesByNumber[h.number] = h.par;

// Détermine le trou actif au premier render (premier trou non joué et
// non abandonné). Sans ça, on SSR la page sur le trou 1 et le JS doit
// faire un "saut" visuel après hydratation → flicker. En calculant
// server-side, les boutons par-relative XL affichent les bonnes
// valeurs (par - 2 … par + 2) dès le premier paint.
function nextEmptyHoleSSR(): number {
  for (const h of roundHoles) {
    if (scoresByHole[h.number] === undefined && !pickedUpHoles.includes(h.number)) {
      return h.number;
    }
  }
  return roundHoles[roundHoles.length - 1]?.number ?? 1;
}
const initialHole = nextEmptyHoleSSR();
const initialPar = roundHoles.find((h) => h.number === initialHole)?.par
  ?? roundHoles[0]?.par
  ?? 4;
---

<PlayerLayout
  title={`${r.club.name} — Saisie en cours · Scluba`}
  themeColor={clubColor}
  clubColor={clubColor}
  iconUrl={iconUrl}
  appName={r.club.name}
  manifestHref={`/r/${r.short_code}/manifest.webmanifest`}
  lockOverscroll={true}
  gridBackdrop={true}
>
  <main class="play">
    {/* play-header : carte glass posée sur le quadrillage. Le clubColor
         est isolé sur la pill (logo + nom club) — badge identitaire du
         club. Le nom du joueur reste en eyebrow micro-caps hors pill. */}
    <header class="play-header">
      <div class="play-header-inner">
        <div class="play-header-pill" style={`background: ${clubColor}`}>
          {r.club.logo_url && (
            <img class="play-header-logo" src={r.club.logo_url} alt="" transition:name="player-club-logo" />
          )}
          <p class="play-club" transition:name="player-club-name">{r.club.name}</p>
        </div>
        <p class="play-player">{me.display_name}</p>
      </div>
    </header>

    <section
      class="live-board"
      aria-label="Classement en direct"
      data-live-board
      data-round-id={r.id}
      data-me-id={me.id}
      data-holes={JSON.stringify(holesByNumber)}
      data-players={JSON.stringify(allPlayers.map((p) => ({ id: p.id, name: p.display_name })))}
      data-scores={JSON.stringify(allScores.map((s) => ({ pid: s.round_player_id, hole: s.hole_number, strokes: s.strokes, pickedUp: s.picked_up })))}
    >
      <ul class="live-list" data-live-list></ul>
    </section>

    {/* Template cloné par JS pour chaque row. (Médailles de rang retirées —
        décoratif/peu lisible terrain + toggle [hidden] cassé par
        `.medal-svg{display:block}`. Rang lisible via l'ordre + la sous-ligne.)
        Évite la string interpolation innerHTML côté client. */}
    <template id="live-card-tpl">
      <li class="live-card">
        <span class="live-avatar" aria-hidden="true"></span>
        <div class="live-info">
          <span class="live-name"></span>
          <span class="live-sub"></span>
        </div>
        <span class="live-score">
          <strong class="live-strokes"></strong>
          <span class="live-diff"></span>
        </span>
      </li>
    </template>

    {/* Player-tabs retirés : le live-board (haut) est maintenant le hub
        central pour sélectionner un joueur en mode host. Tap sur une card
        joueur → switche le ScoreInput. Voir le JS plus bas (live-board
        click handler) + le banner "TOUR DE" ci-dessous. */}

    {canHostSwitch && (
      <div class="current-player-banner" data-current-player-banner aria-live="polite">
        <span class="cpb-avatar" data-cpb-avatar aria-hidden="true"></span>
        <div class="cpb-text">
          <span class="cpb-eyebrow">TOUR DE</span>
          <span class="cpb-name" data-cpb-name>{me.display_name}</span>
        </div>
      </div>
    )}

    {isSpectator && (
      <aside class="spectator-banner" data-spectator-banner>
        <span class="spectator-live-badge" aria-hidden="true">
          <span class="live-badge-dot"></span>EN DIRECT
        </span>
        <div class="spectator-banner-text">
          <p class="spectator-banner-title">
            {hostPlayer ? `${hostPlayer.display_name} marque pour toi` : 'Le host marque pour toi'}
          </p>
          <p class="spectator-banner-sub">
            Tu suis la carte en temps réel. Corrige-toi en bas si besoin.
          </p>
        </div>
        <button type="button" class="spectator-toggle-btn" data-spectator-toggle>
          Corriger un de mes scores
        </button>
      </aside>
    )}

    <aside class="pace-banner" data-pace-banner hidden aria-live="polite">
      <span class="pace-dot" aria-hidden="true"></span>
      <span class="pace-text" data-pace-text></span>
    </aside>

    <section
      class="hole-card"
      data-play-root
      data-tee-time={r.tee_time ?? r.started_at ?? ''}
      data-player-count={String(allPlayers.length)}
      data-spectator={String(isSpectator)}
      data-short-code={r.short_code}
      data-me-id={me.id}
      data-can-host-switch={String(canHostSwitch)}
      data-course={JSON.stringify({ holes: roundHoles })}
      data-hole-guides={JSON.stringify(r.club.hole_guides ?? {})}
      data-scores={JSON.stringify(scoresByHole)}
      data-picked-up={JSON.stringify(pickedUpHoles)}
      data-all-scores={JSON.stringify(allScoresByPlayer)}
      data-all-picked-up={JSON.stringify(allPickedUpByPlayer)}
      data-par={String(par)}
      data-hole-count={String(roundHoles.length)}
    >
      <div class="hole-meta">
        <span class="hole-meta-label">Trou</span>
        <span class="hole-meta-count">
          <span data-hole-number>{initialHole}</span> / {roundHoles.length}
        </span>
      </div>

      <div class="hole-par-block">
        <div class="hole-par-label">PAR</div>
        <div class="hole-par-value" data-par-value>{initialPar}</div>
      </div>

      {/* Carnet de parcours : bouton affiché uniquement si le trou courant a
          un visuel (toggle en JS dans render()). Ouvre HoleGuideModal. */}
      <button type="button" class="hole-guide-btn" data-hole-guide-btn hidden>
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        <span>Voir le trou</span>
      </button>

      <ScoreInput
        holeCount={roundHoles.length}
        currentHole={initialHole}
        currentPar={initialPar}
      />
    </section>

    <button type="button" class="report-trigger" data-report-trigger>⚠ Signaler un souci sur le parcours</button>

    <dialog class="report-dialog" data-report-dialog aria-labelledby="report-title">
      <form method="dialog" data-report-form>
        <h3 id="report-title" class="report-title">Signaler un souci — trou <span data-report-hole></span></h3>
        <fieldset class="report-fieldset">
          <legend class="report-legend">Catégorie</legend>
          <div class="report-cats">
            <label><input type="radio" name="category" value="bunker" required /> Bunker</label>
            <label><input type="radio" name="category" value="green" /> Green</label>
            <label><input type="radio" name="category" value="fairway" /> Fairway</label>
            <label><input type="radio" name="category" value="rough" /> Rough</label>
            <label><input type="radio" name="category" value="equipement" /> Équipement</label>
            <label><input type="radio" name="category" value="autre" /> Autre</label>
          </div>
        </fieldset>
        <textarea class="report-comment" data-report-comment maxlength="200" placeholder="Précisez (facultatif)"></textarea>
        <menu class="report-actions">
          <button value="cancel" type="button" class="report-cancel" data-report-cancel>Annuler</button>
          <button value="send" type="submit" class="report-send" data-report-send>Envoyer</button>
        </menu>
        <p class="report-msg" data-report-msg role="status"></p>
      </form>
    </dialog>

    <section class="leaderboard">
      <header class="leaderboard-head">
        <span>Carte</span>
        <span data-total-strokes>—</span>
      </header>
      <Scorecard sections={roundSections} mode="live" />
    </section>

    <form method="POST" action={`/api/rounds/${r.short_code}/finish`} class="finish-form" data-finish-form data-astro-reload>
      <button type="submit" class="finish-btn" data-finish-btn>Terminer maintenant</button>
    </form>

    <p class="play-status" data-status role="status" aria-live="polite"></p>
  </main>

  <HoleGuideModal />

  <script>
    import { subscribeToRound, unsubscribeFromRound } from '../../../lib/realtime';
    import { hueFromId, initialOf } from '../../../lib/avatar';
    import {
      flashPar,
      flashSelected,
      flashFeedback,
      flipLeaderboard,
      countUp,
      pulseLeaderRing,
      flashPlayerSwitch,
    } from '../../../lib/animations/play';
    import { computePace } from '../../../lib/pace';
    import { ScoreSyncQueue } from '../../../lib/score-sync';

    type CourseData = { holes: { number: number; par: number }[] };
    type LivePlayer = { id: string; name: string };
    type LiveScore = { pid: string; hole: number; strokes: number | null; pickedUp: boolean };
    type LiveEntry = { strokes: number | null; pickedUp: boolean };

    /* === Live leaderboard ============================================== */
    const board = document.querySelector<HTMLElement>('[data-live-board]');
    if (board) {
      const roundId = board.dataset.roundId!;
      const meId = board.dataset.meId!;
      const holes = JSON.parse(board.dataset.holes!) as Record<number, number>;
      const players: Map<string, LivePlayer> = new Map(
        (JSON.parse(board.dataset.players!) as LivePlayer[]).map((p) => [p.id, p]),
      );
      const scoresByPlayer: Map<string, Map<number, LiveEntry>> = new Map();
      for (const s of JSON.parse(board.dataset.scores!) as LiveScore[]) {
        if (!scoresByPlayer.has(s.pid)) scoresByPlayer.set(s.pid, new Map());
        scoresByPlayer.get(s.pid)!.set(s.hole, { strokes: s.strokes, pickedUp: s.pickedUp });
      }
      const list = board.querySelector<HTMLElement>('[data-live-list]')!;

      function effective(entry: LiveEntry, par: number): number | null {
        if (entry.pickedUp) return par + 2;
        return entry.strokes;
      }

      function totalsFor(pid: string): { strokes: number; played: number; diff: number } {
        const map = scoresByPlayer.get(pid);
        if (!map) return { strokes: 0, played: 0, diff: 0 };
        let strokes = 0;
        let played = 0;
        let diff = 0;
        for (const [hole, entry] of map) {
          const par = holes[hole] ?? 0;
          const eff = effective(entry, par);
          if (eff === null) continue;
          strokes += eff;
          played++;
          diff += eff - par;
        }
        return { strokes, played, diff };
      }

      function fmtDiff(diff: number, played: number): string {
        if (played === 0) return '—';
        if (diff === 0) return '±0';
        return diff > 0 ? `+${diff}` : String(diff);
      }

      // Avatar : utilise les helpers hueFromId/initialOf importés depuis
      // lib/avatar (couleur HSL stable + initiale, repère visuel constant).

      // Template HTML cloné pour chaque row (cf. <template id="live-card-tpl">
      // dans le markup). Évite la string interpolation innerHTML côté client
      // et le SVG médaille est pré-rendu (toggle [hidden] selon le rang).
      const tpl = document.getElementById('live-card-tpl') as HTMLTemplateElement | null;

      // Cache des strokes par joueur pour détecter les changements et
      // déclencher l'animation count-up. Rempli au premier render sans anim.
      const lastStrokesByPid = new Map<string, number>();
      let lastLeaderId: string | null = null;
      let firstRender = true;

      function buildRow(
        p: LivePlayer,
        isLeader: boolean,
        rankIdx: number,
        t: { strokes: number; played: number; diff: number },
        leaderDiff: number,
      ): HTMLElement {
        const li = (tpl!.content.firstElementChild as HTMLElement).cloneNode(true) as HTMLElement;
        li.dataset.pid = p.id;
        const classes = ['live-card'];
        if (p.id === meId) classes.push('is-me');
        if (isLeader) classes.push('is-leader');
        if (rankIdx === 1) classes.push('is-second');
        if (rankIdx === 2) classes.push('is-third');
        li.className = classes.join(' ');

        // Sub-line micro-caps (eyebrow JetBrains Mono) :
        //  - played===0 → « EN ATTENTE »
        //  - leader → « X TROUS JOUÉS »
        //  - autres → « +N VS LEADER »
        let subLine = '';
        if (t.played === 0) {
          subLine = 'EN ATTENTE';
        } else if (isLeader) {
          subLine = `${t.played} TROU${t.played > 1 ? 'S' : ''} JOUÉ${t.played > 1 ? 'S' : ''}`;
        } else {
          subLine = `+${t.diff - leaderDiff} VS LEADER`;
        }

        const avatarEl = li.querySelector<HTMLElement>('.live-avatar')!;
        avatarEl.style.background = `hsl(${hueFromId(p.id)}, 55%, 55%)`;
        avatarEl.textContent = initialOf(p.name);

        const nameEl = li.querySelector<HTMLElement>('.live-name')!;
        // Le « (vous) » est en <em> stylé en italic muted — pattern récap.
        if (p.id === meId) {
          nameEl.textContent = '';
          nameEl.append(p.name + ' ');
          const em = document.createElement('em');
          em.textContent = '(vous)';
          nameEl.append(em);
        } else {
          nameEl.textContent = p.name;
        }

        li.querySelector<HTMLElement>('.live-sub')!.textContent = subLine;

        const strokesEl = li.querySelector<HTMLElement>('.live-strokes')!;
        strokesEl.textContent = t.played === 0 ? '' : String(t.strokes);

        const diffEl = li.querySelector<HTMLElement>('.live-diff')!;
        diffEl.textContent = fmtDiff(t.diff, t.played);
        diffEl.classList.remove('over', 'under');
        if (t.played > 0) {
          if (t.diff < 0) diffEl.classList.add('under');
          else if (t.diff > 0) diffEl.classList.add('over');
        }

        return li;
      }

      async function renderBoard() {
        const ordered = Array.from(players.values()).sort((a, b) => {
          const ta = totalsFor(a.id);
          const tb = totalsFor(b.id);
          if (ta.played === 0 && tb.played === 0) return a.name.localeCompare(b.name);
          if (ta.played === 0) return 1;
          if (tb.played === 0) return -1;
          if (ta.diff !== tb.diff) return ta.diff - tb.diff;
          return tb.played - ta.played; // à égalité de diff, celui qui a joué + trous d'abord
        });

        const leader = ordered.find((p) => totalsFor(p.id).played > 0);
        const leaderDiff = leader ? totalsFor(leader.id).diff : 0;
        const newLeaderId = leader?.id ?? null;

        // Détecte les changements de strokes pour déclencher countUp() après
        // le DOM rebuild. On capture (prev, next) maintenant et on update le
        // cache pour le prochain render.
        const strokeChanges = new Map<string, { from: number; to: number }>();
        for (const p of ordered) {
          const t = totalsFor(p.id);
          if (t.played === 0) continue;
          const prev = lastStrokesByPid.get(p.id);
          if (!firstRender && prev !== undefined && prev !== t.strokes) {
            strokeChanges.set(p.id, { from: prev, to: t.strokes });
          }
          lastStrokesByPid.set(p.id, t.strokes);
        }

        // Capture old DOM rows pour le Flip (avant rebuildDom).
        const oldItems = Array.from(list.children) as HTMLElement[];

        await flipLeaderboard(oldItems, () => {
          const newItems: HTMLElement[] = [];
          for (let i = 0; i < ordered.length; i++) {
            const p = ordered[i];
            const t = totalsFor(p.id);
            const isLeader = leader?.id === p.id;
            const rankIdx = t.played > 0 ? i : -1;
            newItems.push(buildRow(p, isLeader, rankIdx, t, leaderDiff));
          }
          list.replaceChildren(...newItems);
        });

        // Post-rebuild : count-ups sur les chiffres qui ont bougé, et ring
        // burst sur la card du nouveau leader si la tête a changé. Ces anims
        // se superposent sur les rows finales — c'est intentionnel.
        for (const li of Array.from(list.children) as HTMLElement[]) {
          const pid = li.dataset.pid;
          if (!pid) continue;
          const change = strokeChanges.get(pid);
          if (change) {
            const strokesEl = li.querySelector<HTMLElement>('.live-strokes');
            countUp(strokesEl, change.from, change.to);
          }
        }

        if (!firstRender && newLeaderId && newLeaderId !== lastLeaderId) {
          const leaderCard = list.querySelector<HTMLElement>(`[data-pid="${newLeaderId}"]`);
          pulseLeaderRing(leaderCard);
        }
        lastLeaderId = newLeaderId;
        firstRender = false;
      }

      renderBoard();

      const channel = subscribeToRound(roundId, {
        onPlayersChange: (event, row) => {
          const p = row as { id: string; round_id: string; display_name: string };
          if (p.round_id !== roundId) return;
          if (event === 'DELETE') {
            players.delete(p.id);
            scoresByPlayer.delete(p.id);
          } else {
            players.set(p.id, { id: p.id, name: p.display_name });
          }
          renderBoard();
        },
        onScoresChange: (event, row) => {
          const s = row as { round_player_id: string; hole_number: number; strokes: number | null; picked_up?: boolean };
          if (!players.has(s.round_player_id)) return;
          const map = scoresByPlayer.get(s.round_player_id) ?? new Map<number, LiveEntry>();
          if (event === 'DELETE') {
            map.delete(s.hole_number);
          } else {
            map.set(s.hole_number, { strokes: s.strokes, pickedUp: s.picked_up === true });
          }
          scoresByPlayer.set(s.round_player_id, map);
          renderBoard();
        },
        onRoundUpdate: (row) => {
          if ((row as { status?: string }).status === 'finished') {
            window.location.href = window.location.pathname.replace(/\/play$/, '/recap');
          }
        },
      });

      window.addEventListener('beforeunload', () => unsubscribeFromRound(channel));

      // Source unique : la saisie émet 'scluba:score' à chaque score CONFIRMÉ
      // (POST ok). On l'applique direct au store du classement, sans attendre
      // l'echo Realtime (qui peut sauter sur la 5G du parcours). Le live-board
      // reflète donc immédiatement les saves confirmées — et n'affiche QUE du
      // confirmé, donc ne ment jamais. Fin du « 4 trous en haut / 7 en bas ».
      window.addEventListener('scluba:score', (ev) => {
        const d = (ev as CustomEvent).detail as {
          pid: string;
          hole: number;
          body: Record<string, unknown>;
        };
        if (!players.has(d.pid)) return;
        const map = scoresByPlayer.get(d.pid) ?? new Map<number, LiveEntry>();
        const pickedUp = d.body.picked_up === true;
        map.set(d.hole, {
          strokes: pickedUp ? null : ((d.body.strokes as number | undefined) ?? null),
          pickedUp,
        });
        scoresByPlayer.set(d.pid, map);
        renderBoard();
      });
    }

    /* === Score entry =================================================== */
    const root = document.querySelector<HTMLElement>('[data-play-root]');
    if (root) {
      const shortCode = root.dataset.shortCode!;
      const meIdEntry = root.dataset.meId!;
      const canHostSwitch = root.dataset.canHostSwitch === 'true';
      const course = JSON.parse(root.dataset.course!) as CourseData;
      const holeGuides = JSON.parse(root.dataset.holeGuides ?? '{}') as Record<string, string>;
      const totalPar = Number(root.dataset.par);
      const holeCount = Number(root.dataset.holeCount);

      // En mode host on tient un état par joueur. Sinon on utilise juste
      // les scores du joueur courant (rétro-compat avec le mode mono-tel).
      const allInitialScores = JSON.parse(root.dataset.allScores ?? '{}') as Record<string, Record<number, number>>;
      const allInitialPickedUp = JSON.parse(root.dataset.allPickedUp ?? '{}') as Record<string, number[]>;
      // Fallback : si les data-attrs all-* sont absents (ne devrait pas
      // arriver), on hydrate depuis les anciens data-attrs mono-joueur.
      const initialScores = JSON.parse(root.dataset.scores ?? '{}') as Record<number, number>;
      const initialPickedUp = JSON.parse(root.dataset.pickedUp ?? '[]') as number[];

      const scoresByPlayer: Map<string, Record<number, number>> = new Map();
      const pickedUpByPlayer: Map<string, Set<number>> = new Map();
      // Hydrate from all-* if present, else fall back to me.
      const knownIds = new Set<string>(Object.keys(allInitialScores));
      knownIds.add(meIdEntry);
      for (const pid of knownIds) {
        scoresByPlayer.set(pid, { ...(allInitialScores[pid] ?? (pid === meIdEntry ? initialScores : {})) });
        pickedUpByPlayer.set(pid, new Set(allInitialPickedUp[pid] ?? (pid === meIdEntry ? initialPickedUp : [])));
      }

      let currentPlayerId = meIdEntry;

      function scoresOf(pid: string): Record<number, number> {
        let m = scoresByPlayer.get(pid);
        if (!m) { m = {}; scoresByPlayer.set(pid, m); }
        return m;
      }
      function pickedUpOf(pid: string): Set<number> {
        let s = pickedUpByPlayer.get(pid);
        if (!s) { s = new Set<number>(); pickedUpByPlayer.set(pid, s); }
        return s;
      }

      // File de sync offline-first (cf. lib/score-sync + score-sync.test.ts) :
      // chaque score y passe (pending → saved | failed) + retry auto, et tout
      // est PERSISTÉ dans localStorage par partie. Sur un parcours on peut
      // saisir / continuer / terminer hors-ligne sans rien perdre (même après
      // un reload ou un kill du webapp) ; ça se synchronise au retour réseau.
      const syncQueue = new ScoreSyncQueue({
        storage: window.localStorage,
        key: `scluba:sync:${shortCode}`,
      });
      let flushing = false;

      // Réhydrate l'affichage local depuis le store : les saisies pas encore
      // synchronisées (absentes des données SSR du serveur) sont ré-appliquées
      // sur les cartes, pour ne rien « perdre » visuellement après un reload
      // hors-ligne. Les entrées déjà « saved » viennent du SSR, on les saute.
      for (const e of syncQueue.allEntries()) {
        if (e.status === 'saved') continue;
        const sc = scoresOf(e.pid);
        const pu = pickedUpOf(e.pid);
        if (e.body.picked_up === true) {
          pu.add(e.hole);
          delete sc[e.hole];
        } else if (typeof e.body.strokes === 'number') {
          sc[e.hole] = e.body.strokes as number;
          pu.delete(e.hole);
        }
      }

      let currentHole = nextEmptyHole();
      let lastRenderedHole = currentHole;
      let lastRenderedFeedback = '';

      // === Refs DOM ===
      const holeNumberEl = root.querySelector<HTMLElement>('[data-hole-number]')!;
      const parValueEl = root.querySelector<HTMLElement>('[data-par-value]')!;
      const holeGuideBtn = root.querySelector<HTMLButtonElement>('[data-hole-guide-btn]');
      const totalStrokesEl = document.querySelector<HTMLElement>('[data-total-strokes]')!;
      const finishForm = document.querySelector<HTMLFormElement>('[data-finish-form]')!;
      const statusEl = document.querySelector<HTMLElement>('[data-status]')!;
      const cells = Array.from(document.querySelectorAll<HTMLElement>('[data-cell-hole]'));

      // === Bannière de rythme de jeu (pace) ===
      // Calcul 100% client (src/lib/pace.ts) depuis le tee-time, le nombre de
      // joueurs et le trou courant. On n'affiche QUE le retard (orange/rouge) :
      // silence quand le groupe tient la cadence (règle produit "seulement si
      // en retard").
      const paceBanner = document.querySelector<HTMLElement>('[data-pace-banner]');
      const paceTextEl = document.querySelector<HTMLElement>('[data-pace-text]');
      const teeTimeRaw = root.dataset.teeTime || '';
      const playerCount = Number(root.dataset.playerCount) || 1;
      const teeTimeDate = teeTimeRaw ? new Date(teeTimeRaw) : null;

      function updatePaceBanner() {
        if (!paceBanner || !paceTextEl || !teeTimeDate || Number.isNaN(teeTimeDate.getTime())) return;
        const pace = computePace({
          teeTime: teeTimeDate,
          now: new Date(),
          holeCount,
          playerCount,
          currentHole,
        });
        const show = pace.status === 'orange' || pace.status === 'red';
        paceBanner.hidden = !show;
        if (!show) return;
        paceBanner.classList.toggle('is-orange', pace.status === 'orange');
        paceBanner.classList.toggle('is-red', pace.status === 'red');
        paceTextEl.textContent = pace.message;
      }

      // Le retard évolue avec le temps même sans action du joueur → recalcul/min.
      window.setInterval(updatePaceBanner, 60_000);
      updatePaceBanner();

      // === Signalement souci parcours (Portail Club) ===
      // Le bouton lit `currentHole` au moment du clic (valeur live du trou
      // affiché) et poste via /api/rounds/[shortCode]/report (cookie player
      // + CSRF same-origin assurés par le middleware).
      const reportTrigger = document.querySelector<HTMLButtonElement>('[data-report-trigger]');
      const reportDialog = document.querySelector<HTMLDialogElement>('[data-report-dialog]');
      if (reportTrigger && reportDialog) {
        const reportForm = reportDialog.querySelector<HTMLFormElement>('[data-report-form]')!;
        const reportHoleEl = reportDialog.querySelector<HTMLElement>('[data-report-hole]')!;
        const reportCommentEl = reportDialog.querySelector<HTMLTextAreaElement>('[data-report-comment]')!;
        const reportMsgEl = reportDialog.querySelector<HTMLElement>('[data-report-msg]')!;
        const reportCancelBtn = reportDialog.querySelector<HTMLButtonElement>('[data-report-cancel]')!;
        // « Annuler » est type=button : la validation `required` du radio ne doit
        // pas bloquer la fermeture. On ferme explicitement.
        reportCancelBtn.addEventListener('click', () => reportDialog.close());
        reportTrigger.addEventListener('click', () => {
          reportForm.reset();
          reportHoleEl.textContent = String(currentHole);
          reportMsgEl.textContent = '';
          reportDialog.showModal();
        });
        reportForm.addEventListener('submit', async (e) => {
          const submitter = (e as SubmitEvent).submitter as HTMLButtonElement | null;
          if (submitter?.value !== 'send') return; // « Annuler » : laisse le dialog se fermer
          e.preventDefault();
          const checked = reportForm.querySelector<HTMLInputElement>('input[name="category"]:checked');
          if (!checked) { reportMsgEl.textContent = 'Choisissez une catégorie.'; return; }
          reportMsgEl.textContent = 'Envoi…';
          try {
            const res = await fetch(`/api/rounds/${shortCode}/report`, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                hole_number: currentHole,
                category: checked.value,
                comment: reportCommentEl.value,
              }),
            });
            if (res.ok) {
              reportMsgEl.textContent = 'Merci, signalé au club ✔';
              setTimeout(() => reportDialog.close(), 900);
            } else {
              reportMsgEl.textContent = 'Échec de l\'envoi, réessayez.';
            }
          } catch {
            reportMsgEl.textContent = 'Échec réseau, réessayez.';
          }
        });
      }

      // Banner "TOUR DE [joueur]" (mode host uniquement, null sinon).
      const banner = document.querySelector<HTMLElement>('[data-current-player-banner]');
      const bannerAvatar = banner?.querySelector<HTMLElement>('[data-cpb-avatar]') ?? null;
      const bannerName = banner?.querySelector<HTMLElement>('[data-cpb-name]') ?? null;

      // Lecture de l'ordre des joueurs depuis le data-attr du live-board.
      // Ordre stable (= joined_at DB), nécessaire pour le smart next-slot.
      const liveBoardForOrder = document.querySelector<HTMLElement>('[data-live-board]');
      const orderedPlayerIds: string[] = liveBoardForOrder
        ? (JSON.parse(liveBoardForOrder.dataset.players ?? '[]') as { id: string }[]).map((p) => p.id)
        : [meIdEntry];
      // Map nom par pid pour le banner (sans re-fetcher).
      const playerNameById = new Map<string, string>();
      if (liveBoardForOrder) {
        for (const p of JSON.parse(liveBoardForOrder.dataset.players ?? '[]') as { id: string; name: string }[]) {
          playerNameById.set(p.id, p.name);
        }
      }
      playerNameById.set(meIdEntry, root.querySelector<HTMLElement>('.play-player')?.textContent ?? '');

      // Score input PR3 refs
      const relBtns = Array.from(
        root.querySelectorAll<HTMLButtonElement>('[data-rel-buttons] [data-rel]'),
      );
      const holeDots = Array.from(
        root.querySelectorAll<HTMLButtonElement>('[data-hole-jump]'),
      );
      const feedbackEl = root.querySelector<HTMLElement>('[data-score-feedback]')!;
      const otherPicker = root.querySelector<HTMLElement>('[data-other-picker]')!;
      const otherPickerBtns = Array.from(
        otherPicker.querySelectorAll<HTMLButtonElement>('[data-abs-strokes]'),
      );
      const pillOther = root.querySelector<HTMLButtonElement>('[data-pill="other"]')!;
      const pillPickup = root.querySelector<HTMLButtonElement>('[data-pill="pickup"]')!;

      // Label par-relative (matche le helper SSR dans ScoreInput.astro)
      function relLabelFor(par: number, offset: number): string {
        if (offset === -2 && par === 3) return 'Ace';
        if (offset === -2) return 'Eagle';
        if (offset === -1) return 'Birdie';
        if (offset === 0) return 'Par';
        if (offset === 1) return 'Bogey';
        if (offset === 2) return 'Double';
        return '';
      }

      function nextEmptyHole(): number {
        const scores = scoresOf(currentPlayerId);
        const pickedUp = pickedUpOf(currentPlayerId);
        for (let h = 1; h <= holeCount; h++) {
          if (scores[h] === undefined && !pickedUp.has(h)) return h;
        }
        return holeCount;
      }

      function holeAt(n: number) {
        return course.holes.find((h) => h.number === n) ?? course.holes[0];
      }

      function diffLabel(strokes: number, par: number): string {
        const d = strokes - par;
        if (d <= -2) return 'Eagle';
        if (d === -1) return 'Birdie';
        if (d === 0) return 'Par';
        if (d === 1) return 'Bogey';
        if (d === 2) return 'Double bogey';
        return `+${d}`;
      }

      function diffClass(strokes: number, par: number): string {
        const d = strokes - par;
        if (d <= -1) return 'cell-birdie';
        if (d === 0) return 'cell-par';
        if (d === 1) return 'cell-bogey';
        return 'cell-double';
      }

      function render() {
        const scores = scoresOf(currentPlayerId);
        const pickedUp = pickedUpOf(currentPlayerId);
        const hole = holeAt(currentHole);
        holeNumberEl.textContent = String(currentHole);
        parValueEl.textContent = String(hole.par);
        updatePaceBanner();

        // Carnet de parcours : montre le bouton "Voir le trou" si ce trou a un
        // visuel, sinon le cache. L'URL est stockée pour le handler de clic.
        if (holeGuideBtn) {
          const guideUrl = holeGuides[String(currentHole)];
          holeGuideBtn.hidden = !guideUrl;
          holeGuideBtn.dataset.url = guideUrl ?? '';
        }

        const s = scores[currentHole];
        const isPickup = pickedUp.has(currentHole);

        // === Met à jour les 5 boutons par-relative ===
        // Pour chaque offset (-2..+2), recalcule label + strokes selon
        // le par du trou courant, et applique is-par (defaut)/is-selected
        // (matche le score saisi).
        for (const btn of relBtns) {
          const offset = Number(btn.dataset.rel);
          const strokes = hole.par + offset;
          const label = relLabelFor(hole.par, offset);
          btn.querySelector<HTMLElement>('[data-rel-label]')!.textContent = label;
          btn.querySelector<HTMLElement>('[data-rel-strokes]')!.textContent = String(strokes);
          btn.setAttribute('aria-label', `${label} (${strokes} coup${strokes > 1 ? 's' : ''})`);
          btn.classList.toggle('is-par', offset === 0);
          btn.classList.toggle('is-selected', !isPickup && s !== undefined && s === strokes);
        }

        // === Met à jour la rangée 1-15 du picker "Autre" ===
        for (const btn of otherPickerBtns) {
          const n = Number(btn.dataset.absStrokes);
          btn.classList.toggle('is-selected', !isPickup && s === n);
        }

        // === Met à jour l'état pill Abandonner ===
        pillPickup.classList.toggle('is-selected', isPickup);

        // === Feedback live ===
        if (isPickup) {
          feedbackEl.textContent = `Abandonné · compté ${hole.par + 2} (Par + 2)`;
          feedbackEl.className = 'score-feedback is-over';
        } else if (s !== undefined) {
          const d = s - hole.par;
          const label = relLabelFor(hole.par, d) || diffLabel(s, hole.par);
          if (d < 0) {
            feedbackEl.textContent = `${label} · ${d} vs par`;
            feedbackEl.className = 'score-feedback is-under';
          } else if (d === 0) {
            feedbackEl.textContent = `${label} · ±0`;
            feedbackEl.className = 'score-feedback is-par';
          } else {
            feedbackEl.textContent = `${label} · +${d} vs par`;
            feedbackEl.className = 'score-feedback is-over';
          }
        } else {
          feedbackEl.textContent = '';
          feedbackEl.className = 'score-feedback';
        }

        // === Met à jour les dots progression (current + played) ===
        for (const dot of holeDots) {
          const h = Number(dot.dataset.holeJump);
          const played = scores[h] !== undefined || pickedUp.has(h);
          dot.classList.toggle('is-current', h === currentHole);
          dot.classList.toggle('is-played', played && h !== currentHole);
          dot.setAttribute('aria-current', h === currentHole ? 'true' : 'false');
        }

        // === Cells de la scorecard inline (Scorecard mode='live') ===
        let total = 0;
        let played = 0;
        let playedPar = 0;
        for (let h = 1; h <= holeCount; h++) {
          const cell = cells.find((c) => Number(c.dataset.cellHole) === h);
          if (!cell) continue;
          cell.className = 'grid-cell';
          const hp = holeAt(h).par;
          if (pickedUp.has(h)) {
            cell.textContent = 'C';
            cell.classList.add('cell-pickup');
            total += hp + 2;
            played++;
            playedPar += hp;
          } else if (scores[h] !== undefined) {
            cell.textContent = String(scores[h]);
            cell.classList.add(diffClass(scores[h], hp));
            total += scores[h];
            played++;
            playedPar += hp;
          } else {
            cell.textContent = '—';
          }
          // Statut de sync (anti-perte) : pending = ambre pointillé,
          // failed = rouge. Un score saved/persisté garde son rendu normal.
          const syncSt = syncQueue.statusOf(currentPlayerId, h);
          if (syncSt === 'pending') cell.classList.add('cell-pending');
          else if (syncSt === 'failed') cell.classList.add('cell-failed');
        }
        const diffPlayed = total - playedPar;
        const diffLbl = diffPlayed === 0 ? '±0' : diffPlayed > 0 ? `+${diffPlayed}` : String(diffPlayed);
        totalStrokesEl.textContent = played === 0
          ? '—'
          : played === holeCount
            ? `${total} (${diffLbl} · Par ${totalPar})`
            : `${total} sur ${played}/${holeCount} (${diffLbl})`;

        const allDone = played === holeCount;
        finishForm.hidden = false;
        const finishBtn = finishForm.querySelector<HTMLButtonElement>('[data-finish-btn]');
        if (finishBtn) {
          finishBtn.textContent = allDone ? 'Terminer la partie' : 'Terminer maintenant';
          finishBtn.dataset.allDone = allDone ? '1' : '0';
          finishBtn.dataset.played = String(played);
          finishBtn.dataset.holeCount = String(holeCount);
        }

        // Banner "TOUR DE [joueur]" — syncé avec currentPlayerId (mode host).
        if (banner && bannerAvatar && bannerName) {
          const name = playerNameById.get(currentPlayerId) ?? '';
          const newName = name;
          const oldName = bannerName.textContent;
          bannerAvatar.style.background = `hsl(${hueFromId(currentPlayerId)}, 55%, 55%)`;
          bannerAvatar.textContent = initialOf(name);
          bannerName.textContent = newName;
          if (oldName && oldName !== newName) {
            flashPlayerSwitch(banner);
          }
        }

        // Live-board : highlight la card du joueur courant (mode host).
        if (canHostSwitch) {
          const liveList = document.querySelector<HTMLElement>('[data-live-list]');
          if (liveList) {
            for (const li of Array.from(liveList.children) as HTMLElement[]) {
              li.classList.toggle('is-current', li.dataset.pid === currentPlayerId);
            }
          }
        }

        // === Animations sobres ===
        // PAR : flash quand le trou change (subtile fade-y + back).
        if (currentHole !== lastRenderedHole) {
          flashPar(parValueEl);
          lastRenderedHole = currentHole;
        }
        // Feedback line : fade-in si le contenu a changé.
        if (feedbackEl.textContent && feedbackEl.textContent !== lastRenderedFeedback) {
          flashFeedback(feedbackEl);
        }
        lastRenderedFeedback = feedbackEl.textContent ?? '';
        // Selected button : pulse bounce sur le bouton qui vient de
        // recevoir is-selected (uniquement les rel-buttons, pas le
        // picker "Autre" qui auto-ferme avant le re-render).
        const selectedRelBtn = relBtns.find((b) => b.classList.contains('is-selected'));
        if (selectedRelBtn) flashSelected(selectedRelBtn);
      }

      // Auto-advance : après une sauvegarde réussie, l'app passe au
      // prochain slot vide. Logique :
      //  - Mode solo / each : prochain trou vide pour ME (comportement
      //    historique).
      //  - Mode HOST : prochain (joueur, trou) non-saisi en priorisant
      //    de FINIR le trou courant pour tout le monde avant de passer
      //    au trou suivant. C'est cohérent avec le flow IRL où chaque
      //    joueur termine son trou puis on passe au tee suivant.
      // Délai 250ms : feedback visuel sur le bouton avant transition.
      function isEmptyFor(pid: string, hole: number): boolean {
        const sc = scoresOf(pid);
        const pu = pickedUpOf(pid);
        return sc[hole] === undefined && !pu.has(hole);
      }

      function nextSlotHost(): { pid: string; hole: number } | null {
        // 1. Trou courant : reste-t-il un joueur non-saisi ?
        const currentIdx = orderedPlayerIds.indexOf(currentPlayerId);
        // Boucle depuis le joueur SUIVANT le courant (round-robin) pour
        // privilégier l'ordre naturel du flight.
        for (let i = 1; i <= orderedPlayerIds.length; i++) {
          const pid = orderedPlayerIds[(currentIdx + i) % orderedPlayerIds.length];
          if (isEmptyFor(pid, currentHole)) return { pid, hole: currentHole };
        }
        // 2. Tous saisi pour ce trou → trou suivant, joueur de tête.
        for (let h = currentHole + 1; h <= holeCount; h++) {
          for (const pid of orderedPlayerIds) {
            if (isEmptyFor(pid, h)) return { pid, hole: h };
          }
        }
        // 3. Wrap-around : trous précédents non-saisis.
        for (let h = 1; h < currentHole; h++) {
          for (const pid of orderedPlayerIds) {
            if (isEmptyFor(pid, h)) return { pid, hole: h };
          }
        }
        return null; // partie complète
      }

      function autoAdvance() {
        if (canHostSwitch) {
          const slot = nextSlotHost();
          if (slot) {
            setTimeout(() => {
              currentPlayerId = slot.pid;
              currentHole = slot.hole;
              render();
            }, 250);
          }
          return;
        }
        // Mode solo / each : prochain trou vide pour ME.
        const scores = scoresOf(currentPlayerId);
        const pickedUp = pickedUpOf(currentPlayerId);
        for (let h = currentHole + 1; h <= holeCount; h++) {
          if (scores[h] === undefined && !pickedUp.has(h)) {
            setTimeout(() => { currentHole = h; render(); }, 250);
            return;
          }
        }
        for (let h = 1; h < currentHole; h++) {
          if (scores[h] === undefined && !pickedUp.has(h)) {
            setTimeout(() => { currentHole = h; render(); }, 250);
            return;
          }
        }
        // Tous les trous remplis : on reste sur le trou courant.
      }

      // Fin de partie — offline-first. On intercepte toujours le submit natif :
      //  - tout synchronisé + en ligne → on termine et on ouvre le récap ;
      //  - sinon → on mémorise l'intention (persistée) + message rassurant, et
      //    la sync terminera la partie au retour réseau (puis ouvrira le récap).
      // Plus de blocage : sur un parcours, finir hors-ligne doit marcher.
      finishForm.addEventListener('submit', (e) => {
        e.preventDefault();
        const btn = finishForm.querySelector<HTMLButtonElement>('[data-finish-btn]');
        // Confirmation de fin anticipée (trous non joués → NC).
        if (btn && btn.dataset.allDone !== '1') {
          const remaining = Number(btn.dataset.holeCount) - Number(btn.dataset.played);
          const msg = remaining > 0
            ? `Tu n'as saisi que ${btn.dataset.played} trou(s) sur ${btn.dataset.holeCount}. Les trous restants seront marqués NC. Terminer ?`
            : 'Terminer la partie maintenant ?';
          if (!window.confirm(msg)) return;
        }
        if (!syncQueue.hasUnsaved() && navigator.onLine) {
          void finishRoundNow();
        } else {
          syncQueue.requestFinish();
          showStatusInfo(
            "Partie terminée sur l'appareil · synchronisation en cours, le récap s'ouvrira dès le réseau revenu.",
          );
          void flushSync();
        }
      });

      function targetPlayerHint(): string | null {
        if (!canHostSwitch) return null;
        return currentPlayerId === meIdEntry ? null : currentPlayerId;
      }

      // === Status helpers — SVG checkmark animé (PR5 polish) =============
      // Le checkmark draw via stroke-dasharray + animation CSS (cf. style
      // bloc en bas du fichier). Réutilisable pour les 2 success states.
      // Le `text` est passé en .textContent (anti-XSS) après injection HTML.
      function showStatusSuccess(text: string) {
        statusEl.innerHTML = `
          <svg class="check-icon" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12" /></svg>
          <span class="status-text"></span>
        `;
        const span = statusEl.querySelector<HTMLElement>('.status-text');
        if (span) span.textContent = text;
      }
      function showStatusInfo(text: string) {
        statusEl.textContent = text;
      }
      // Wiggle SVG ⚠ pour les erreurs save (réseau merdique sur le
       // green, etc.) — feedback tactile + a11y plus mémorable qu'un
       // simple texte rouge. Inspiré SF Symbols 'wiggle' effect.
       // Le path SVG triangle d'alerte + animation CSS .alert-icon
       // (cf. style bloc en bas du fichier).
      function showStatusError(text: string) {
        statusEl.innerHTML = `
          <svg class="alert-icon" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
          <span class="status-text status-text-error"></span>
        `;
        const span = statusEl.querySelector<HTMLElement>('.status-text');
        if (span) span.textContent = text;
      }
      function clearStatus() {
        statusEl.textContent = '';
      }

      function buildScoreBody(hole: number, payload: Record<string, unknown>): Record<string, unknown> {
        const body: Record<string, unknown> = { hole, ...payload };
        const hint = targetPlayerHint();
        if (hint) body.player_id = hint;
        return body;
      }

      // Reflète l'état de la file dans la ligne de statut globale. Hors-ligne =
      // état NORMAL sur un parcours (pas une erreur) → message rassurant.
      function reflectSyncStatus(): void {
        const n = syncQueue.unsavedCount();
        if (n === 0) {
          showStatusSuccess('Enregistré');
          setTimeout(clearStatus, 1200);
        } else if (!navigator.onLine) {
          showStatusInfo(
            `Enregistré sur l'appareil · ${n} à synchroniser au retour du réseau`,
          );
        } else {
          showStatusError(`${n} score${n > 1 ? 's' : ''} en attente — on réessaie…`);
        }
      }

      // Rejoue toutes les entrées « due » (pending, + failed dont le backoff
      // est écoulé). Appelée au tap, par l'intervalle, au retour réseau/onglet.
      async function flushSync(): Promise<void> {
        if (flushing) return;
        flushing = true;
        try {
          const due = syncQueue.due(Date.now());
          await Promise.all(
            due.map(async (entry) => {
              try {
                const res = await fetch(`/api/rounds/${shortCode}/scores`, {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify(entry.body),
                });
                if (!res.ok) throw new Error(await res.text());
                syncQueue.markSaved(entry.pid, entry.hole);
                // Source unique : notifie le classement d'un score confirmé.
                window.dispatchEvent(
                  new CustomEvent('scluba:score', {
                    detail: { pid: entry.pid, hole: entry.hole, body: entry.body },
                  }),
                );
              } catch {
                syncQueue.markFailed(entry.pid, entry.hole, Date.now());
              }
            }),
          );
        } finally {
          flushing = false;
        }
        reflectSyncStatus();
        render();
        // Si des saisies sont arrivées pendant ce flush (tap rapide multi-
        // joueurs), on draine tout de suite. Pas de boucle serrée : les
        // entrées « failed » restent en backoff donc non « due ».
        if (syncQueue.due(Date.now()).length > 0) {
          void flushSync();
          return;
        }
        // Tous les scores synchronisés + une fin de partie demandée (peut-être
        // hors-ligne) + réseau dispo → on termine et on ouvre le récap.
        if (syncQueue.isFinishRequested() && !syncQueue.hasUnsaved() && navigator.onLine) {
          await finishRoundNow();
        }
      }

      // POST la fin de partie puis redirige vers le récap.
      //  - panne réseau / 5xx → on garde l'intention, re-tentée au prochain flush ;
      //  - 2xx ou redirect (y c. partie déjà terminée, finish.ts est idempotent) → récap ;
      //  - 4xx (ex. 403 non-organisateur) → on arrête d'insister (pas de boucle).
      async function finishRoundNow(): Promise<void> {
        let res: Response;
        try {
          res = await fetch(`/api/rounds/${shortCode}/finish`, { method: 'POST' });
        } catch {
          return; // réseau KO → retry au prochain flush (online / intervalle)
        }
        if (res.ok || res.redirected) {
          syncQueue.clearFinish();
          window.location.href = window.location.pathname.replace(/\/play$/, '/recap');
          return;
        }
        if (res.status >= 500) return; // serveur en vrac → retry plus tard
        syncQueue.clearFinish();
        showStatusError('Impossible de terminer la partie ici.');
      }

      // Saisie d'un score : écriture optimiste locale + mise en file. L'avance
      // se fait tout de suite (UX terrain), le POST tourne en fond avec retry.
      // Plus de perte silencieuse : un POST échoué reste « failed » (cellule
      // rouge) et est rejoué jusqu'à confirmation.
      function saveScore(strokes: number, options: { advance?: boolean } = {}): void {
        const scores = scoresOf(currentPlayerId);
        const pickedUp = pickedUpOf(currentPlayerId);
        scores[currentHole] = strokes;
        pickedUp.delete(currentHole); // saisir un score annule l'abandon
        syncQueue.enqueue(currentPlayerId, currentHole, buildScoreBody(currentHole, { strokes }));
        render();
        showStatusInfo('Synchronisation…');
        if (options.advance) autoAdvance();
        void flushSync();
      }

      function savePickup(): void {
        const scores = scoresOf(currentPlayerId);
        const pickedUp = pickedUpOf(currentPlayerId);
        delete scores[currentHole];
        pickedUp.add(currentHole);
        syncQueue.enqueue(currentPlayerId, currentHole, buildScoreBody(currentHole, { picked_up: true }));
        render();
        showStatusInfo('Synchronisation…');
        void flushSync();
      }

      // Retry auto : intervalle léger tant qu'il reste des scores non
      // confirmés, + reprises immédiates quand le réseau ou l'onglet revient.
      window.setInterval(() => { if (syncQueue.hasUnsaved()) void flushSync(); }, 4000);
      window.addEventListener('online', () => void flushSync());
      document.addEventListener('visibilitychange', () => {
        if (!document.hidden) void flushSync();
      });

      // === Boutons par-relative (Eagle/Birdie/Par/Bogey/Double) ===
      // Tap = save immédiat (offset → absolute via hole.par) + auto-advance.
      for (const btn of relBtns) {
        btn.addEventListener('click', () => {
          const offset = Number(btn.dataset.rel);
          const strokes = holeAt(currentHole).par + offset;
          saveScore(strokes, { advance: true });
        });
      }

      // === Bouton "Voir le trou" (carnet de parcours) ===
      if (holeGuideBtn) {
        holeGuideBtn.addEventListener('click', () => {
          const url = holeGuideBtn.dataset.url;
          if (url) (window as any).openHoleGuideModal?.(url, currentHole);
        });
      }

      // === Dots progression : tap-to-jump ===
      for (const dot of holeDots) {
        dot.addEventListener('click', () => {
          const h = Number(dot.dataset.holeJump);
          if (h < 1 || h > holeCount || h === currentHole) return;
          currentHole = h;
          // Ferme le picker "Autre" si ouvert
          closeOtherPicker();
          render();
        });
      }

      // === Pill "Autre" : toggle le mini-picker 1-15 ===
      function openOtherPicker() {
        otherPicker.hidden = false;
        pillOther.setAttribute('aria-expanded', 'true');
      }
      function closeOtherPicker() {
        otherPicker.hidden = true;
        pillOther.setAttribute('aria-expanded', 'false');
      }
      pillOther.addEventListener('click', () => {
        if (otherPicker.hidden) openOtherPicker();
        else closeOtherPicker();
      });

      // === Picker "Autre" boutons 1-15 ===
      for (const btn of otherPickerBtns) {
        btn.addEventListener('click', () => {
          const n = Number(btn.dataset.absStrokes);
          closeOtherPicker();
          saveScore(n, { advance: true });
        });
      }

      // === Pill "Abandonner" (pickup) ===
      pillPickup.addEventListener('click', () => {
        if (pickedUpOf(currentPlayerId).has(currentHole)) return; // déjà abandonné
        closeOtherPicker();
        savePickup();
      });

      // === Swipe horizontal entre trous (touch natif) ===
      // Threshold : 25% de la largeur du hole-card OU 80px minimum.
      // Distance verticale > 50px → ignore (l'utilisateur scrolle).
      const swipeRoot = root.querySelector<HTMLElement>('[data-play-root]') ?? root;
      let touchStartX = 0;
      let touchStartY = 0;
      let touchActive = false;
      swipeRoot.addEventListener('touchstart', (e) => {
        if (e.touches.length !== 1) { touchActive = false; return; }
        touchStartX = e.touches[0].clientX;
        touchStartY = e.touches[0].clientY;
        touchActive = true;
      }, { passive: true });
      swipeRoot.addEventListener('touchend', (e) => {
        if (!touchActive) return;
        touchActive = false;
        const t = e.changedTouches[0];
        const dx = t.clientX - touchStartX;
        const dy = t.clientY - touchStartY;
        if (Math.abs(dy) > 50) return; // scroll vertical, pas un swipe
        const threshold = Math.max(80, swipeRoot.clientWidth * 0.25);
        if (Math.abs(dx) < threshold) return;
        if (dx < 0 && currentHole < holeCount) {
          currentHole++;
          closeOtherPicker();
          render();
        } else if (dx > 0 && currentHole > 1) {
          currentHole--;
          closeOtherPicker();
          render();
        }
      }, { passive: true });

      // Sélection joueur (mode host) : passe désormais par tap sur une card
      // du live-board (cf. handler dans le bloc live-board plus haut), pas
      // par des onglets dédiés. Le live-list a data-host-interactive="true"
      // pour activer les styles hover/cursor + ring honey.
      if (canHostSwitch) {
        const liveList = document.querySelector<HTMLElement>('[data-live-list]');
        if (liveList) {
          liveList.dataset.hostInteractive = 'true';
          liveList.addEventListener('click', (e) => {
            const target = (e.target as HTMLElement).closest<HTMLElement>('[data-pid]');
            if (!target) return;
            const pid = target.dataset.pid;
            if (!pid || pid === currentPlayerId) return;
            currentPlayerId = pid;
            currentHole = nextEmptyHole();
            render();
            // Scroll smooth vers le ScoreInput pour ne pas que le joueur
            // ait à scroll lui-même après un switch.
            root.scrollIntoView({ behavior: 'smooth', block: 'start' });
          });
        }
      }

      // === Realtime score sync ===
      // Quand un autre device saisit un score (cas typique : mode 'host'
      // où le créateur marque pour les autres joueurs), on doit le
      // refléter dans la grille Scorecard locale. Sans ça, le spectateur
      // voit son score cumul s'incrémenter dans le live-board (qui a son
      // propre sub) mais sa carte du bas reste figée sur les valeurs SSR
      // du chargement de page.
      //
      // On utilise un suffix 'entry' pour éviter le conflit de channel
      // name avec le sub du live-board (Supabase channels = uniques).
      const liveBoardEl = document.querySelector<HTMLElement>('[data-live-board]');
      const entryRoundId = liveBoardEl?.dataset.roundId;
      if (entryRoundId) {
        const entryChannel = subscribeToRound(entryRoundId, {
          // Late-joiner : play-root fige ses maps (orderedPlayerIds,
          // playerNameById) au chargement. Sans ça, switcher sur un joueur
          // arrivé APRÈS affiche « TOUR DE ? » (initialOf('') === '?') et casse
          // le round-robin. On tient donc les maps à jour ici aussi.
          onPlayersChange: (event, row) => {
            const p = row as { id: string; round_id: string; display_name: string };
            if (event === 'DELETE') return;
            playerNameById.set(p.id, p.display_name);
            if (!orderedPlayerIds.includes(p.id)) orderedPlayerIds.push(p.id);
          },
          onScoresChange: (event, row) => {
            const s = row as {
              round_player_id: string;
              hole_number: number;
              strokes: number | null;
              picked_up?: boolean;
            };
            if (!scoresByPlayer.has(s.round_player_id)) return;
            const scores = scoresOf(s.round_player_id);
            const pickedUp = pickedUpOf(s.round_player_id);
            if (event === 'DELETE') {
              delete scores[s.hole_number];
              pickedUp.delete(s.hole_number);
            } else if (s.picked_up === true) {
              pickedUp.add(s.hole_number);
              delete scores[s.hole_number];
            } else if (s.strokes !== null) {
              scores[s.hole_number] = s.strokes;
              pickedUp.delete(s.hole_number);
            }
            if (s.round_player_id === currentPlayerId) render();
          },
        }, 'entry');
        window.addEventListener('beforeunload', () => unsubscribeFromRound(entryChannel));
      }

      render();

      // Au chargement : s'il reste des scores non synchronisés ou une fin de
      // partie en attente (reprise après reload ou réseau revenu), on relance
      // la sync tout de suite.
      if (syncQueue.hasUnsaved() || syncQueue.isFinishRequested()) void flushSync();
    }

    /* === Spectator toggle (mode 'host' uniquement, côté joueur invité) ===
       Le ScoreInput est caché par CSS quand data-spectator="true" sur
       le hole-card. Le bouton "Corriger un de mes scores" toggle la
       classe is-revealed qui annule le display:none, permettant au
       joueur de corriger son propre score en exception. */
    const spectatorToggle = document.querySelector<HTMLButtonElement>('[data-spectator-toggle]');
    const holeCardEl = document.querySelector<HTMLElement>('[data-play-root]');
    if (spectatorToggle && holeCardEl) {
      spectatorToggle.addEventListener('click', () => {
        const revealed = holeCardEl.classList.toggle('is-revealed');
        spectatorToggle.classList.toggle('is-active', revealed);
        spectatorToggle.textContent = revealed
          ? 'Masquer la saisie'
          : 'Corriger un de mes scores';
        if (revealed) {
          holeCardEl.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });
    }
  </script>

  <style>
