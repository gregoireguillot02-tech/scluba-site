---
export const prerender = false;

import PlayerLayout from '../../../layouts/PlayerLayout.astro';
import Scorecard from '../../../components/player/Scorecard.astro';
import ScoreInput from '../../../components/player/ScoreInput.astro';
import { serviceClient } from '../../../lib/supabase';
import type { Club, Round, RoundPlayer, Score } from '../../../lib/clubs-types';
import { resolveRoundHoles, resolveRoundSections } from '../../../lib/clubs-types';

const { shortCode } = Astro.params;
const sb = serviceClient();

const { data: round } = await sb
  .from('rounds')
  .select('*, club:clubs(*)')
  .eq('short_code', shortCode)
  .maybeSingle();

if (!round) {
  return Astro.rewrite('/404');
}

const r = round as Round & { club: Club };

if (r.status === 'finished') {
  return Astro.redirect(`/r/${shortCode}/recap`, 302);
}

const playerId = Astro.cookies.get(`scluba_player_${shortCode}`)?.value ?? null;

const { data: allPlayersRaw } = await sb
  .from('round_players')
  .select('*')
  .eq('round_id', r.id)
  .order('joined_at');
const allPlayers = (allPlayersRaw ?? []) as RoundPlayer[];

const me = allPlayers.find((p) => p.id === playerId);
if (!me) {
  return new Response('Tu n\'es pas joueur dans cette partie. Reviens depuis la page du club pour démarrer.', { status: 403 });
}

const playerIds = allPlayers.map((p) => p.id);
const { data: allScoresRaw } = playerIds.length
  ? await sb.from('scores').select('*').in('round_player_id', playerIds)
  : { data: [] as Score[] };
const allScores = (allScoresRaw ?? []) as Score[];

// Resolve which holes this round actually plays based on its format_id.
// Falls back to course_data.holes when no format is set (legacy rounds).
const roundHoles = resolveRoundHoles(r, r.club);
const roundSections = resolveRoundSections(r, r.club);
const par = roundHoles.reduce((sum, h) => sum + h.par, 0);
const clubColor = r.club.primary_color ?? '#1B4332';

const scoresByHole: Record<number, number> = {};
const pickedUpHoles: number[] = [];
for (const s of allScores) {
  if (s.round_player_id !== me.id) continue;
  if (s.picked_up) {
    pickedUpHoles.push(s.hole_number);
  } else if (s.strokes !== null) {
    scoresByHole[s.hole_number] = s.strokes;
  }
}

// État par joueur pour le mode host (saisie sur un seul téléphone). Le host
// (créateur) voit des tabs pour switcher entre les joueurs et saisir au nom
// de chacun. Les non-host gardent leur expérience actuelle (un seul player).
const allScoresByPlayer: Record<string, Record<number, number>> = {};
const allPickedUpByPlayer: Record<string, number[]> = {};
for (const p of allPlayers) {
  allScoresByPlayer[p.id] = {};
  allPickedUpByPlayer[p.id] = [];
}
for (const s of allScores) {
  const bucket = allScoresByPlayer[s.round_player_id];
  const pickups = allPickedUpByPlayer[s.round_player_id];
  if (!bucket || !pickups) continue;
  if (s.picked_up) pickups.push(s.hole_number);
  else if (s.strokes !== null) bucket[s.hole_number] = s.strokes;
}

const canHostSwitch = me.is_creator && allPlayers.length > 1;

// Vue spectateur : quand la partie est en mode "host saisit tout" et que
// le joueur courant n'est pas le créateur, on masque le ScoreInput et
// on met en avant le live leaderboard. Un bouton "Corriger un de mes
// scores" permet de réafficher la saisie en exception.
const isSpectator = r.scoring_mode === 'host' && !me.is_creator;
const hostPlayer = allPlayers.find((p) => p.is_creator) ?? null;

const holesByNumber: Record<number, number> = {};
for (const h of roundHoles) holesByNumber[h.number] = h.par;

// Détermine le trou actif au premier render (premier trou non joué et
// non abandonné). Sans ça, on SSR la page sur le trou 1 et le JS doit
// faire un "saut" visuel après hydratation → flicker. En calculant
// server-side, les boutons par-relative XL affichent les bonnes
// valeurs (par - 2 … par + 2) dès le premier paint.
function nextEmptyHoleSSR(): number {
  for (const h of roundHoles) {
    if (scoresByHole[h.number] === undefined && !pickedUpHoles.includes(h.number)) {
      return h.number;
    }
  }
  return roundHoles[roundHoles.length - 1]?.number ?? 1;
}
const initialHole = nextEmptyHoleSSR();
const initialPar = roundHoles.find((h) => h.number === initialHole)?.par
  ?? roundHoles[0]?.par
  ?? 4;
---

<PlayerLayout
  title={`${r.club.name} — Saisie en cours · Scluba`}
  themeColor={clubColor}
  clubColor={clubColor}
  lockOverscroll={true}
>
  <main class="play">
    <header class="play-header" style={`background: ${clubColor}`}>
      <div class="play-header-inner">
        {r.club.logo_url && (
          <img class="play-header-logo" src={r.club.logo_url} alt="" />
        )}
        <div class="play-header-text">
          <p class="play-club">{r.club.name}</p>
          <p class="play-player">{me.display_name}</p>
        </div>
      </div>
    </header>

    <section
      class="live-board"
      aria-label="Classement en direct"
      data-live-board
      data-round-id={r.id}
      data-me-id={me.id}
      data-holes={JSON.stringify(holesByNumber)}
      data-players={JSON.stringify(allPlayers.map((p) => ({ id: p.id, name: p.display_name })))}
      data-scores={JSON.stringify(allScores.map((s) => ({ pid: s.round_player_id, hole: s.hole_number, strokes: s.strokes, pickedUp: s.picked_up })))}
    >
      <ul class="live-list" data-live-list></ul>
    </section>

    {canHostSwitch && (
      <nav class="player-tabs" data-player-tabs aria-label="Saisir le score d'un joueur">
        {allPlayers.map((p) => (
          <button
            type="button"
            class={`player-tab${p.id === me.id ? ' is-me is-active' : ''}`}
            data-player-id={p.id}
            data-player-name={p.display_name}
          >
            {p.display_name}{p.id === me.id ? ' (toi)' : ''}
          </button>
        ))}
      </nav>
    )}

    {isSpectator && (
      <aside class="spectator-banner" data-spectator-banner>
        <div class="spectator-banner-text">
          <p class="spectator-banner-title">
            {hostPlayer ? `${hostPlayer.display_name} tient la carte` : 'Le host tient la carte'}
          </p>
          <p class="spectator-banner-sub">
            Suis le classement en direct. Tes scores apparaissent quand le host les saisit.
          </p>
        </div>
        <button type="button" class="spectator-toggle-btn" data-spectator-toggle>
          Corriger un de mes scores
        </button>
      </aside>
    )}

    <section
      class="hole-card"
      data-play-root
      data-spectator={String(isSpectator)}
      data-short-code={r.short_code}
      data-me-id={me.id}
      data-can-host-switch={String(canHostSwitch)}
      data-course={JSON.stringify({ holes: roundHoles })}
      data-scores={JSON.stringify(scoresByHole)}
      data-picked-up={JSON.stringify(pickedUpHoles)}
      data-all-scores={JSON.stringify(allScoresByPlayer)}
      data-all-picked-up={JSON.stringify(allPickedUpByPlayer)}
      data-par={String(par)}
      data-hole-count={String(roundHoles.length)}
    >
      <div class="hole-meta">
        <span class="hole-meta-label">Trou</span>
        <span class="hole-meta-count">
          <span data-hole-number>{initialHole}</span> / {roundHoles.length}
        </span>
      </div>

      <div class="hole-par-block">
        <div class="hole-par-label">PAR</div>
        <div class="hole-par-value" data-par-value>{initialPar}</div>
      </div>

      <ScoreInput
        holeCount={roundHoles.length}
        currentHole={initialHole}
        currentPar={initialPar}
      />
    </section>

    <section class="leaderboard">
      <header class="leaderboard-head">
        <span>Carte</span>
        <span data-total-strokes>—</span>
      </header>
      <Scorecard sections={roundSections} mode="live" />
    </section>

    <form method="POST" action={`/api/rounds/${r.short_code}/finish`} class="finish-form" data-finish-form>
      <button type="submit" class="finish-btn" data-finish-btn>Terminer maintenant</button>
    </form>

    <p class="play-status" data-status role="status" aria-live="polite"></p>
  </main>

  <script>
    import { subscribeToRound, unsubscribeFromRound } from '../../../lib/realtime';
    import { flashPar, flashSelected, flashFeedback } from '../../../lib/animations/play';

    type CourseData = { holes: { number: number; par: number }[] };
    type LivePlayer = { id: string; name: string };
    type LiveScore = { pid: string; hole: number; strokes: number | null; pickedUp: boolean };
    type LiveEntry = { strokes: number | null; pickedUp: boolean };

    /* === Live leaderboard ============================================== */
    const board = document.querySelector<HTMLElement>('[data-live-board]');
    if (board) {
      const roundId = board.dataset.roundId!;
      const meId = board.dataset.meId!;
      const holes = JSON.parse(board.dataset.holes!) as Record<number, number>;
      const players: Map<string, LivePlayer> = new Map(
        (JSON.parse(board.dataset.players!) as LivePlayer[]).map((p) => [p.id, p]),
      );
      const scoresByPlayer: Map<string, Map<number, LiveEntry>> = new Map();
      for (const s of JSON.parse(board.dataset.scores!) as LiveScore[]) {
        if (!scoresByPlayer.has(s.pid)) scoresByPlayer.set(s.pid, new Map());
        scoresByPlayer.get(s.pid)!.set(s.hole, { strokes: s.strokes, pickedUp: s.pickedUp });
      }
      const list = board.querySelector<HTMLElement>('[data-live-list]')!;

      function effective(entry: LiveEntry, par: number): number | null {
        if (entry.pickedUp) return par + 2;
        return entry.strokes;
      }

      function totalsFor(pid: string): { strokes: number; played: number; diff: number } {
        const map = scoresByPlayer.get(pid);
        if (!map) return { strokes: 0, played: 0, diff: 0 };
        let strokes = 0;
        let played = 0;
        let diff = 0;
        for (const [hole, entry] of map) {
          const par = holes[hole] ?? 0;
          const eff = effective(entry, par);
          if (eff === null) continue;
          strokes += eff;
          played++;
          diff += eff - par;
        }
        return { strokes, played, diff };
      }

      function fmtDiff(diff: number, played: number): string {
        if (played === 0) return '—';
        if (diff === 0) return '±0';
        return diff > 0 ? `+${diff}` : String(diff);
      }

      // Avatar : couleur HSL stable dérivée du player_id (hash simple) +
      // initiale du prénom. Même couleur au refresh — repère visuel.
      function hueFromId(id: string): number {
        let h = 0;
        for (let i = 0; i < id.length; i++) h = (h * 31 + id.charCodeAt(i)) % 360;
        return h;
      }
      function initialOf(name: string): string {
        return (name.trim()[0] ?? '?').toUpperCase();
      }

      const MEDALS = ['🥇', '🥈', '🥉'];

      // Cache des strokes par joueur pour détecter les changements et
      // déclencher l'animation flash. Rempli au premier render sans flash.
      const lastStrokesByPid = new Map<string, number>();
      let firstRender = true;

      function renderBoard() {
        const ordered = Array.from(players.values()).sort((a, b) => {
          const ta = totalsFor(a.id);
          const tb = totalsFor(b.id);
          if (ta.played === 0 && tb.played === 0) return a.name.localeCompare(b.name);
          if (ta.played === 0) return 1;
          if (tb.played === 0) return -1;
          if (ta.diff !== tb.diff) return ta.diff - tb.diff;
          return tb.played - ta.played; // à égalité de diff, celui qui a joué + trous d'abord
        });

        // Diff du leader = premier joueur avec played > 0
        const leader = ordered.find((p) => totalsFor(p.id).played > 0);
        const leaderDiff = leader ? totalsFor(leader.id).diff : 0;

        // ÉTAPE 1 (FLIP) : capturer les positions actuelles des `<li>` par pid
        const oldPositions = new Map<string, number>();
        for (const child of Array.from(list.children) as HTMLElement[]) {
          const pid = child.dataset.pid;
          if (pid) oldPositions.set(pid, child.getBoundingClientRect().top);
        }

        // ÉTAPE 2 : reconstruction du DOM
        const newItems: HTMLElement[] = [];
        const flashPids = new Set<string>();
        for (let i = 0; i < ordered.length; i++) {
          const p = ordered[i];
          const t = totalsFor(p.id);
          const isLeader = leader?.id === p.id;
          const rankIdx = t.played > 0 ? i : -1; // -1 = pas classé (NC)

          // Détection changement de strokes → flash (sauf au premier render)
          const prevStrokes = lastStrokesByPid.get(p.id);
          if (!firstRender && prevStrokes !== undefined && prevStrokes !== t.strokes && t.played > 0) {
            flashPids.add(p.id);
          }
          lastStrokesByPid.set(p.id, t.strokes);

          const li = document.createElement('li');
          li.dataset.pid = p.id;
          const classes = ['live-card'];
          if (p.id === meId) classes.push('is-me');
          if (isLeader) classes.push('is-leader');
          if (rankIdx === 1) classes.push('is-second');
          if (rankIdx === 2) classes.push('is-third');
          li.className = classes.join(' ');

          // Sub-line : leader → « X trous joués » ; non-leader avec played → « +N / leader » ; played===0 → « en attente »
          let subLine = '';
          if (t.played === 0) {
            subLine = 'en attente';
          } else if (isLeader) {
            subLine = `${t.played} trou${t.played > 1 ? 's' : ''} joué${t.played > 1 ? 's' : ''}`;
          } else {
            const gap = t.diff - leaderDiff;
            subLine = `+${gap} vs leader`;
          }

          const hue = hueFromId(p.id);
          const initial = initialOf(p.name);
          const medal = rankIdx >= 0 && rankIdx < 3 ? MEDALS[rankIdx] : '';
          const diffClass = t.played === 0 ? '' : t.diff < 0 ? ' under' : t.diff > 0 ? ' over' : '';

          li.innerHTML = `
            <span class="live-avatar" aria-hidden="true"></span>
            <div class="live-info">
              <span class="live-name"></span>
              <span class="live-sub"></span>
            </div>
            <span class="live-medal" aria-hidden="true"></span>
            <span class="live-score">
              <strong class="live-strokes"></strong>
              <span class="live-diff${diffClass}"></span>
            </span>
          `;
          const avatarEl = li.querySelector<HTMLElement>('.live-avatar')!;
          avatarEl.style.background = `hsl(${hue}, 55%, 55%)`;
          avatarEl.textContent = initial;

          li.querySelector('.live-name')!.innerHTML = p.id === meId
            ? `${p.name} <em>(vous)</em>`
            : p.name;
          li.querySelector('.live-sub')!.textContent = subLine;
          li.querySelector('.live-medal')!.textContent = medal;
          li.querySelector('.live-strokes')!.textContent = t.played === 0 ? '' : String(t.strokes);
          li.querySelector('.live-diff')!.textContent = fmtDiff(t.diff, t.played);

          newItems.push(li);
        }

        list.replaceChildren(...newItems);

        // ÉTAPE 3 (FLIP) : pour chaque nouvelle <li>, calculer la diff de
        // position vs l'ancienne et appliquer translateY inverse, puis
        // animer le retour à 0.
        for (const li of newItems) {
          const pid = li.dataset.pid!;
          const oldTop = oldPositions.get(pid);
          if (oldTop === undefined) continue;
          const newTop = li.getBoundingClientRect().top;
          const delta = oldTop - newTop;
          if (Math.abs(delta) < 1) continue;
          li.style.transform = `translateY(${delta}px)`;
          li.style.transition = 'none';
          requestAnimationFrame(() => {
            li.style.transition = 'transform 320ms cubic-bezier(0.2, 0.6, 0.2, 1)';
            li.style.transform = '';
          });
        }

        // Flash pour les joueurs qui ont eu un changement de strokes
        for (const li of newItems) {
          const pid = li.dataset.pid!;
          if (flashPids.has(pid)) {
            li.classList.add('is-flash');
            setTimeout(() => li.classList.remove('is-flash'), 1200);
          }
        }

        firstRender = false;
      }

      renderBoard();

      const channel = subscribeToRound(roundId, {
        onPlayersChange: (event, row) => {
          const p = row as { id: string; round_id: string; display_name: string };
          if (p.round_id !== roundId) return;
          if (event === 'DELETE') {
            players.delete(p.id);
            scoresByPlayer.delete(p.id);
          } else {
            players.set(p.id, { id: p.id, name: p.display_name });
          }
          renderBoard();
        },
        onScoresChange: (event, row) => {
          const s = row as { round_player_id: string; hole_number: number; strokes: number | null; picked_up?: boolean };
          if (!players.has(s.round_player_id)) return;
          const map = scoresByPlayer.get(s.round_player_id) ?? new Map<number, LiveEntry>();
          if (event === 'DELETE') {
            map.delete(s.hole_number);
          } else {
            map.set(s.hole_number, { strokes: s.strokes, pickedUp: s.picked_up === true });
          }
          scoresByPlayer.set(s.round_player_id, map);
          renderBoard();
        },
        onRoundUpdate: (row) => {
          if ((row as { status?: string }).status === 'finished') {
            window.location.href = window.location.pathname.replace(/\/play$/, '/recap');
          }
        },
      });

      window.addEventListener('beforeunload', () => unsubscribeFromRound(channel));
    }

    /* === Score entry =================================================== */
    const root = document.querySelector<HTMLElement>('[data-play-root]');
    if (root) {
      const shortCode = root.dataset.shortCode!;
      const meIdEntry = root.dataset.meId!;
      const canHostSwitch = root.dataset.canHostSwitch === 'true';
      const course = JSON.parse(root.dataset.course!) as CourseData;
      const totalPar = Number(root.dataset.par);
      const holeCount = Number(root.dataset.holeCount);

      // En mode host on tient un état par joueur. Sinon on utilise juste
      // les scores du joueur courant (rétro-compat avec le mode mono-tel).
      const allInitialScores = JSON.parse(root.dataset.allScores ?? '{}') as Record<string, Record<number, number>>;
      const allInitialPickedUp = JSON.parse(root.dataset.allPickedUp ?? '{}') as Record<string, number[]>;
      // Fallback : si les data-attrs all-* sont absents (ne devrait pas
      // arriver), on hydrate depuis les anciens data-attrs mono-joueur.
      const initialScores = JSON.parse(root.dataset.scores ?? '{}') as Record<number, number>;
      const initialPickedUp = JSON.parse(root.dataset.pickedUp ?? '[]') as number[];

      const scoresByPlayer: Map<string, Record<number, number>> = new Map();
      const pickedUpByPlayer: Map<string, Set<number>> = new Map();
      // Hydrate from all-* if present, else fall back to me.
      const knownIds = new Set<string>(Object.keys(allInitialScores));
      knownIds.add(meIdEntry);
      for (const pid of knownIds) {
        scoresByPlayer.set(pid, { ...(allInitialScores[pid] ?? (pid === meIdEntry ? initialScores : {})) });
        pickedUpByPlayer.set(pid, new Set(allInitialPickedUp[pid] ?? (pid === meIdEntry ? initialPickedUp : [])));
      }

      let currentPlayerId = meIdEntry;

      function scoresOf(pid: string): Record<number, number> {
        let m = scoresByPlayer.get(pid);
        if (!m) { m = {}; scoresByPlayer.set(pid, m); }
        return m;
      }
      function pickedUpOf(pid: string): Set<number> {
        let s = pickedUpByPlayer.get(pid);
        if (!s) { s = new Set<number>(); pickedUpByPlayer.set(pid, s); }
        return s;
      }

      let currentHole = nextEmptyHole();
      let lastRenderedHole = currentHole;
      let lastRenderedFeedback = '';

      // === Refs DOM ===
      const holeNumberEl = root.querySelector<HTMLElement>('[data-hole-number]')!;
      const parValueEl = root.querySelector<HTMLElement>('[data-par-value]')!;
      const totalStrokesEl = document.querySelector<HTMLElement>('[data-total-strokes]')!;
      const finishForm = document.querySelector<HTMLFormElement>('[data-finish-form]')!;
      const statusEl = document.querySelector<HTMLElement>('[data-status]')!;
      const cells = Array.from(document.querySelectorAll<HTMLElement>('[data-cell-hole]'));
      const tabs = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-player-tabs] [data-player-id]'));

      // Score input PR3 refs
      const relBtns = Array.from(
        root.querySelectorAll<HTMLButtonElement>('[data-rel-buttons] [data-rel]'),
      );
      const holeDots = Array.from(
        root.querySelectorAll<HTMLButtonElement>('[data-hole-jump]'),
      );
      const feedbackEl = root.querySelector<HTMLElement>('[data-score-feedback]')!;
      const otherPicker = root.querySelector<HTMLElement>('[data-other-picker]')!;
      const otherPickerBtns = Array.from(
        otherPicker.querySelectorAll<HTMLButtonElement>('[data-abs-strokes]'),
      );
      const pillOther = root.querySelector<HTMLButtonElement>('[data-pill="other"]')!;
      const pillPickup = root.querySelector<HTMLButtonElement>('[data-pill="pickup"]')!;

      // Label par-relative (matche le helper SSR dans ScoreInput.astro)
      function relLabelFor(par: number, offset: number): string {
        if (offset === -2 && par === 3) return 'Ace';
        if (offset === -2) return 'Eagle';
        if (offset === -1) return 'Birdie';
        if (offset === 0) return 'Par';
        if (offset === 1) return 'Bogey';
        if (offset === 2) return 'Double';
        return '';
      }

      function nextEmptyHole(): number {
        const scores = scoresOf(currentPlayerId);
        const pickedUp = pickedUpOf(currentPlayerId);
        for (let h = 1; h <= holeCount; h++) {
          if (scores[h] === undefined && !pickedUp.has(h)) return h;
        }
        return holeCount;
      }

      function holeAt(n: number) {
        return course.holes.find((h) => h.number === n) ?? course.holes[0];
      }

      function diffLabel(strokes: number, par: number): string {
        const d = strokes - par;
        if (d <= -2) return 'Eagle';
        if (d === -1) return 'Birdie';
        if (d === 0) return 'Par';
        if (d === 1) return 'Bogey';
        if (d === 2) return 'Double bogey';
        return `+${d}`;
      }

      function diffClass(strokes: number, par: number): string {
        const d = strokes - par;
        if (d <= -1) return 'cell-birdie';
        if (d === 0) return 'cell-par';
        if (d === 1) return 'cell-bogey';
        return 'cell-double';
      }

      function render() {
        const scores = scoresOf(currentPlayerId);
        const pickedUp = pickedUpOf(currentPlayerId);
        const hole = holeAt(currentHole);
        holeNumberEl.textContent = String(currentHole);
        parValueEl.textContent = String(hole.par);

        const s = scores[currentHole];
        const isPickup = pickedUp.has(currentHole);

        // === Met à jour les 5 boutons par-relative ===
        // Pour chaque offset (-2..+2), recalcule label + strokes selon
        // le par du trou courant, et applique is-par (defaut)/is-selected
        // (matche le score saisi).
        for (const btn of relBtns) {
          const offset = Number(btn.dataset.rel);
          const strokes = hole.par + offset;
          const label = relLabelFor(hole.par, offset);
          btn.querySelector<HTMLElement>('[data-rel-label]')!.textContent = label;
          btn.querySelector<HTMLElement>('[data-rel-strokes]')!.textContent = String(strokes);
          btn.setAttribute('aria-label', `${label} (${strokes} coup${strokes > 1 ? 's' : ''})`);
          btn.classList.toggle('is-par', offset === 0);
          btn.classList.toggle('is-selected', !isPickup && s !== undefined && s === strokes);
        }

        // === Met à jour la rangée 1-15 du picker "Autre" ===
        for (const btn of otherPickerBtns) {
          const n = Number(btn.dataset.absStrokes);
          btn.classList.toggle('is-selected', !isPickup && s === n);
        }

        // === Met à jour l'état pill Abandonner ===
        pillPickup.classList.toggle('is-selected', isPickup);

        // === Feedback live ===
        if (isPickup) {
          feedbackEl.textContent = `Abandonné · compté ${hole.par + 2} (Par + 2)`;
          feedbackEl.className = 'score-feedback is-over';
        } else if (s !== undefined) {
          const d = s - hole.par;
          const label = relLabelFor(hole.par, d) || diffLabel(s, hole.par);
          if (d < 0) {
            feedbackEl.textContent = `${label} · ${d} vs par`;
            feedbackEl.className = 'score-feedback is-under';
          } else if (d === 0) {
            feedbackEl.textContent = `${label} · ±0`;
            feedbackEl.className = 'score-feedback is-par';
          } else {
            feedbackEl.textContent = `${label} · +${d} vs par`;
            feedbackEl.className = 'score-feedback is-over';
          }
        } else {
          feedbackEl.textContent = '';
          feedbackEl.className = 'score-feedback';
        }

        // === Met à jour les dots progression (current + played) ===
        for (const dot of holeDots) {
          const h = Number(dot.dataset.holeJump);
          const played = scores[h] !== undefined || pickedUp.has(h);
          dot.classList.toggle('is-current', h === currentHole);
          dot.classList.toggle('is-played', played && h !== currentHole);
          dot.setAttribute('aria-current', h === currentHole ? 'true' : 'false');
        }

        // === Cells de la scorecard inline (Scorecard mode='live') ===
        let total = 0;
        let played = 0;
        let playedPar = 0;
        for (let h = 1; h <= holeCount; h++) {
          const cell = cells.find((c) => Number(c.dataset.cellHole) === h);
          if (!cell) continue;
          cell.className = 'grid-cell';
          const hp = holeAt(h).par;
          if (pickedUp.has(h)) {
            cell.textContent = 'C';
            cell.classList.add('cell-pickup');
            total += hp + 2;
            played++;
            playedPar += hp;
          } else if (scores[h] !== undefined) {
            cell.textContent = String(scores[h]);
            cell.classList.add(diffClass(scores[h], hp));
            total += scores[h];
            played++;
            playedPar += hp;
          } else {
            cell.textContent = '—';
          }
        }
        const diffPlayed = total - playedPar;
        const diffLbl = diffPlayed === 0 ? '±0' : diffPlayed > 0 ? `+${diffPlayed}` : String(diffPlayed);
        totalStrokesEl.textContent = played === 0
          ? '—'
          : played === holeCount
            ? `${total} (${diffLbl} · Par ${totalPar})`
            : `${total} sur ${played}/${holeCount} (${diffLbl})`;

        const allDone = played === holeCount;
        finishForm.hidden = false;
        const finishBtn = finishForm.querySelector<HTMLButtonElement>('[data-finish-btn]');
        if (finishBtn) {
          finishBtn.textContent = allDone ? 'Terminer la partie' : 'Terminer maintenant';
          finishBtn.dataset.allDone = allDone ? '1' : '0';
          finishBtn.dataset.played = String(played);
          finishBtn.dataset.holeCount = String(holeCount);
        }

        // Tabs host mode
        for (const tab of tabs) {
          tab.classList.toggle('is-active', tab.dataset.playerId === currentPlayerId);
        }

        // === Animations sobres ===
        // PAR : flash quand le trou change (subtile fade-y + back).
        if (currentHole !== lastRenderedHole) {
          flashPar(parValueEl);
          lastRenderedHole = currentHole;
        }
        // Feedback line : fade-in si le contenu a changé.
        if (feedbackEl.textContent && feedbackEl.textContent !== lastRenderedFeedback) {
          flashFeedback(feedbackEl);
        }
        lastRenderedFeedback = feedbackEl.textContent ?? '';
        // Selected button : pulse bounce sur le bouton qui vient de
        // recevoir is-selected (uniquement les rel-buttons, pas le
        // picker "Autre" qui auto-ferme avant le re-render).
        const selectedRelBtn = relBtns.find((b) => b.classList.contains('is-selected'));
        if (selectedRelBtn) flashSelected(selectedRelBtn);
      }

      // Auto-advance : après une sauvegarde réussie, si on n'est pas
      // sur le dernier trou ET que tous les autres trous ne sont pas
      // remplis, on saute au prochain trou vide après 250ms. Donne
      // l'impression d'un flow "tap et hop, trou suivant" sans avoir
      // à toucher la nav. Le délai laisse le temps de voir le bouton
      // sélectionné (feedback visuel avant transition).
      function autoAdvance() {
        const scores = scoresOf(currentPlayerId);
        const pickedUp = pickedUpOf(currentPlayerId);
        // Cherche le prochain trou vide APRÈS currentHole, puis avant
        // si on a déjà passé le dernier vide à droite.
        for (let h = currentHole + 1; h <= holeCount; h++) {
          if (scores[h] === undefined && !pickedUp.has(h)) {
            setTimeout(() => { currentHole = h; render(); }, 250);
            return;
          }
        }
        for (let h = 1; h < currentHole; h++) {
          if (scores[h] === undefined && !pickedUp.has(h)) {
            setTimeout(() => { currentHole = h; render(); }, 250);
            return;
          }
        }
        // Tous les trous remplis : on reste sur le trou courant. Le
        // bouton "Terminer la partie" est déjà mis à jour par render().
      }

      // Intercept the early-finish submission to confirm. Skip the confirm
      // when the card is already complete (regular flow).
      finishForm.addEventListener('submit', (e) => {
        const btn = finishForm.querySelector<HTMLButtonElement>('[data-finish-btn]');
        if (!btn || btn.dataset.allDone === '1') return;
        const remaining = Number(btn.dataset.holeCount) - Number(btn.dataset.played);
        const msg = remaining > 0
          ? `Tu n'as saisi que ${btn.dataset.played} trou(s) sur ${btn.dataset.holeCount}. Les trous restants seront marqués NC. Terminer ?`
          : 'Terminer la partie maintenant ?';
        if (!window.confirm(msg)) e.preventDefault();
      });

      function targetPlayerHint(): string | null {
        if (!canHostSwitch) return null;
        return currentPlayerId === meIdEntry ? null : currentPlayerId;
      }

      // === Status helpers — SVG checkmark animé (PR5 polish) =============
      // Le checkmark draw via stroke-dasharray + animation CSS (cf. style
      // bloc en bas du fichier). Réutilisable pour les 2 success states.
      // Le `text` est passé en .textContent (anti-XSS) après injection HTML.
      function showStatusSuccess(text: string) {
        statusEl.innerHTML = `
          <svg class="check-icon" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12" /></svg>
          <span class="status-text"></span>
        `;
        const span = statusEl.querySelector<HTMLElement>('.status-text');
        if (span) span.textContent = text;
      }
      function showStatusInfo(text: string) {
        statusEl.textContent = text;
      }
      // Wiggle SVG ⚠ pour les erreurs save (réseau merdique sur le
       // green, etc.) — feedback tactile + a11y plus mémorable qu'un
       // simple texte rouge. Inspiré SF Symbols 'wiggle' effect.
       // Le path SVG triangle d'alerte + animation CSS .alert-icon
       // (cf. style bloc en bas du fichier).
      function showStatusError(text: string) {
        statusEl.innerHTML = `
          <svg class="alert-icon" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
          <span class="status-text status-text-error"></span>
        `;
        const span = statusEl.querySelector<HTMLElement>('.status-text');
        if (span) span.textContent = text;
      }
      function clearStatus() {
        statusEl.textContent = '';
      }

      async function saveScore(strokes: number, options: { advance?: boolean } = {}) {
        const scores = scoresOf(currentPlayerId);
        const pickedUp = pickedUpOf(currentPlayerId);
        scores[currentHole] = strokes;
        pickedUp.delete(currentHole); // saisir un score annule l'abandon
        render();
        showStatusInfo('Sauvegarde…');
        try {
          const body: Record<string, unknown> = { hole: currentHole, strokes };
          const hint = targetPlayerHint();
          if (hint) body.player_id = hint;
          const res = await fetch(`/api/rounds/${shortCode}/scores`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(body),
          });
          if (!res.ok) throw new Error(await res.text());
          showStatusSuccess('Enregistré');
          setTimeout(clearStatus, 1200);
          // Si la save vient d'un bouton score (par-relative ou Autre),
          // on enchaîne automatiquement sur le prochain trou vide.
          if (options.advance) autoAdvance();
        } catch (e) {
          showStatusError((e as Error).message);
        }
      }

      async function savePickup() {
        const scores = scoresOf(currentPlayerId);
        const pickedUp = pickedUpOf(currentPlayerId);
        delete scores[currentHole];
        pickedUp.add(currentHole);
        render();
        showStatusInfo('Sauvegarde…');
        try {
          const body: Record<string, unknown> = { hole: currentHole, picked_up: true };
          const hint = targetPlayerHint();
          if (hint) body.player_id = hint;
          const res = await fetch(`/api/rounds/${shortCode}/scores`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(body),
          });
          if (!res.ok) throw new Error(await res.text());
          showStatusSuccess('Trou abandonné');
          setTimeout(clearStatus, 1200);
        } catch (e) {
          showStatusError((e as Error).message);
        }
      }

      // === Boutons par-relative (Eagle/Birdie/Par/Bogey/Double) ===
      // Tap = save immédiat (offset → absolute via hole.par) + auto-advance.
      for (const btn of relBtns) {
        btn.addEventListener('click', () => {
          const offset = Number(btn.dataset.rel);
          const strokes = holeAt(currentHole).par + offset;
          saveScore(strokes, { advance: true });
        });
      }

      // === Dots progression : tap-to-jump ===
      for (const dot of holeDots) {
        dot.addEventListener('click', () => {
          const h = Number(dot.dataset.holeJump);
          if (h < 1 || h > holeCount || h === currentHole) return;
          currentHole = h;
          // Ferme le picker "Autre" si ouvert
          closeOtherPicker();
          render();
        });
      }

      // === Pill "Autre" : toggle le mini-picker 1-15 ===
      function openOtherPicker() {
        otherPicker.hidden = false;
        pillOther.setAttribute('aria-expanded', 'true');
      }
      function closeOtherPicker() {
        otherPicker.hidden = true;
        pillOther.setAttribute('aria-expanded', 'false');
      }
      pillOther.addEventListener('click', () => {
        if (otherPicker.hidden) openOtherPicker();
        else closeOtherPicker();
      });

      // === Picker "Autre" boutons 1-15 ===
      for (const btn of otherPickerBtns) {
        btn.addEventListener('click', () => {
          const n = Number(btn.dataset.absStrokes);
          closeOtherPicker();
          saveScore(n, { advance: true });
        });
      }

      // === Pill "Abandonner" (pickup) ===
      pillPickup.addEventListener('click', () => {
        if (pickedUpOf(currentPlayerId).has(currentHole)) return; // déjà abandonné
        closeOtherPicker();
        savePickup();
      });

      // === Swipe horizontal entre trous (touch natif) ===
      // Threshold : 25% de la largeur du hole-card OU 80px minimum.
      // Distance verticale > 50px → ignore (l'utilisateur scrolle).
      const swipeRoot = root.querySelector<HTMLElement>('[data-play-root]') ?? root;
      let touchStartX = 0;
      let touchStartY = 0;
      let touchActive = false;
      swipeRoot.addEventListener('touchstart', (e) => {
        if (e.touches.length !== 1) { touchActive = false; return; }
        touchStartX = e.touches[0].clientX;
        touchStartY = e.touches[0].clientY;
        touchActive = true;
      }, { passive: true });
      swipeRoot.addEventListener('touchend', (e) => {
        if (!touchActive) return;
        touchActive = false;
        const t = e.changedTouches[0];
        const dx = t.clientX - touchStartX;
        const dy = t.clientY - touchStartY;
        if (Math.abs(dy) > 50) return; // scroll vertical, pas un swipe
        const threshold = Math.max(80, swipeRoot.clientWidth * 0.25);
        if (Math.abs(dx) < threshold) return;
        if (dx < 0 && currentHole < holeCount) {
          currentHole++;
          closeOtherPicker();
          render();
        } else if (dx > 0 && currentHole > 1) {
          currentHole--;
          closeOtherPicker();
          render();
        }
      }, { passive: true });

      // Tabs joueurs (mode host) : switch currentPlayerId + reset currentHole
      // au prochain trou vide du joueur sélectionné.
      for (const tab of tabs) {
        tab.addEventListener('click', () => {
          const pid = tab.dataset.playerId;
          if (!pid || pid === currentPlayerId) return;
          currentPlayerId = pid;
          currentHole = nextEmptyHole();
          render();
        });
      }

      render();
    }

    /* === Spectator toggle (mode 'host' uniquement, côté joueur invité) ===
       Le ScoreInput est caché par CSS quand data-spectator="true" sur
       le hole-card. Le bouton "Corriger un de mes scores" toggle la
       classe is-revealed qui annule le display:none, permettant au
       joueur de corriger son propre score en exception. */
    const spectatorToggle = document.querySelector<HTMLButtonElement>('[data-spectator-toggle]');
    const holeCardEl = document.querySelector<HTMLElement>('[data-play-root]');
    if (spectatorToggle && holeCardEl) {
      spectatorToggle.addEventListener('click', () => {
        const revealed = holeCardEl.classList.toggle('is-revealed');
        spectatorToggle.classList.toggle('is-active', revealed);
        spectatorToggle.textContent = revealed
          ? 'Masquer la saisie'
          : 'Corriger un de mes scores';
        if (revealed) {
          holeCardEl.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });
    }
  </script>

