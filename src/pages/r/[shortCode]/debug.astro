---
export const prerender = false;
import { serviceClient } from '../../../lib/supabase';

const { shortCode } = Astro.params;
const env = {
  hasUrl: typeof import.meta.env.PUBLIC_SUPABASE_URL === 'string' && import.meta.env.PUBLIC_SUPABASE_URL.length > 0,
  hasAnon: typeof import.meta.env.PUBLIC_SUPABASE_ANON_KEY === 'string' && import.meta.env.PUBLIC_SUPABASE_ANON_KEY.length > 0,
  hasService: typeof import.meta.env.SUPABASE_SERVICE_ROLE_KEY === 'string' && import.meta.env.SUPABASE_SERVICE_ROLE_KEY.length > 0,
};

let svcResult = 'not-tried';
let qAllRounds = 'not-tried';
let qByShortCode = 'not-tried';
let qWithClubJoin = 'not-tried';
let qClubsTable = 'not-tried';
try {
  const sb = serviceClient();
  svcResult = 'ok';

  const a = await sb.from('rounds').select('id,short_code,club_id').limit(5);
  qAllRounds = a.error ? `error ${a.error.code}: ${a.error.message}` : `rows=${a.data?.length ?? 0} sample=${JSON.stringify(a.data?.slice(0,2))}`;

  const b = await sb.from('rounds').select('id,short_code').eq('short_code', shortCode).limit(1);
  qByShortCode = b.error ? `error ${b.error.code}: ${b.error.message}` : `rows=${b.data?.length ?? 0} data=${JSON.stringify(b.data)}`;

  const c = await sb.from('rounds').select('id, short_code, club:clubs(*)').eq('short_code', shortCode).maybeSingle();
  qWithClubJoin = c.error ? `error ${c.error.code}: ${c.error.message} | ${c.error.details ?? ''} | ${c.error.hint ?? ''}` : `data=${JSON.stringify(c.data).slice(0, 200)}`;

  const d = await sb.from('clubs').select('id,name,slug').limit(3);
  qClubsTable = d.error ? `error ${d.error.code}: ${d.error.message}` : `rows=${d.data?.length ?? 0}`;
} catch (e) {
  svcResult = `THROW: ${e instanceof Error ? e.name + ': ' + e.message : String(e)}`;
}
---
<pre>
debug page reached
shortCode = {shortCode}
env.hasUrl = {String(env.hasUrl)}
env.hasAnon = {String(env.hasAnon)}
env.hasService = {String(env.hasService)}
svcResult = {svcResult}
qAllRounds = {qAllRounds}
qByShortCode = {qByShortCode}
qWithClubJoin = {qWithClubJoin}
qClubsTable = {qClubsTable}
</pre>
