---
export const prerender = false;

import '../../../styles/tokens.css';
import '../../../styles/global.css';
import { serviceClient } from '../../../lib/supabase';
import { qrSvg } from '../../../lib/qr';
import type { Club, Round, RoundPlayer } from '../../../lib/clubs-types';

const { shortCode: rawShortCode } = Astro.params;
const shortCode = (rawShortCode ?? '').toUpperCase();
const sb = serviceClient();

const { data: round } = await sb
  .from('rounds')
  .select('*, club:clubs(*)')
  .eq('short_code', shortCode)
  .maybeSingle();

if (!round) {
  return Astro.rewrite('/404');
}

const r = round as Round & { club: Club };

if (r.status === 'finished') {
  return Astro.redirect(`/r/${shortCode}/recap`, 302);
}
if (r.status === 'playing') {
  return Astro.redirect(`/r/${shortCode}/play`, 302);
}

const cookieKey = `scluba_player_${shortCode}`;
const playerId = Astro.cookies.get(cookieKey)?.value ?? null;

const { data: players } = await sb
  .from('round_players')
  .select('*')
  .eq('round_id', r.id)
  .order('joined_at');
const initialPlayers = (players ?? []) as RoundPlayer[];

const inviteUrl = `${Astro.url.origin}/r/${shortCode}`;
const inviteQr = await qrSvg(inviteUrl, { errorCorrectionLevel: 'M' });

const clubColor = r.club.primary_color ?? '#1B4332';
---

<!doctype html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title>Lobby — {r.club.name} · Scluba</title>
  <meta name="robots" content="noindex, nofollow" />
  <meta name="theme-color" content="#FAF7EE" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>
  <main class="lobby" data-lobby data-round-id={r.id} data-short-code={shortCode}>
    <header class="masthead">
      {r.club.photo_url ? (
        <figure class="photo-card">
          <img src={r.club.photo_url} alt="" loading="eager" decoding="async" />
          <span class="photo-card-fade" aria-hidden="true"></span>
        </figure>
      ) : (
        <div class="photo-card photo-card-placeholder" aria-hidden="true"></div>
      )}

      {r.club.logo_url && (
        <div class="logo-frame">
          <img src={r.club.logo_url} alt="" />
        </div>
      )}

      <p class="masthead-eyebrow">Lobby</p>
      <div class="title-rail" aria-hidden="true"></div>
      <h1 class="masthead-title">{r.club.name}</h1>
      <div class="title-rail" aria-hidden="true"></div>
    </header>

    <section class="code-block" aria-labelledby="code-title">
      <p id="code-title" class="code-eyebrow">Code de la partie</p>
      <p class="code-value" aria-label={`Code ${shortCode}`}>{shortCode}</p>
      <p class="code-hint">Partage ce code à tes copains pour qu'ils rejoignent.</p>

      <div class="invite-actions">
        <button type="button" class="btn-secondary" data-copy-link data-url={inviteUrl}>
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
          </svg>
          <span>Copier le lien</span>
        </button>
        <button type="button" class="btn-secondary" data-toggle-qr>
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
            <rect x="3" y="14" width="7" height="7"/><path d="M14 14h3v3h-3zM18 18h3v3h-3zM14 18h3"/>
          </svg>
          <span>Afficher le QR</span>
        </button>
      </div>

      <div class="qr-popover" data-qr-popover hidden>
        <div class="qr-frame" set:html={inviteQr}></div>
        <p class="qr-popover-hint">Scanne avec un autre tel pour rejoindre.</p>
      </div>
    </section>

    <section class="players-block" aria-labelledby="players-title">
      <header class="players-head">
        <h2 id="players-title" class="players-title">Joueurs</h2>
        <span class="players-count" data-players-count>{initialPlayers.length}</span>
      </header>
      <ul class="players-list" data-players-list>
        {initialPlayers.map((p) => (
          <li
            class={`player-item${p.id === playerId ? ' is-me' : ''}${p.is_creator ? ' is-creator' : ''}`}
            data-player-id={p.id}
          >
            <span class="player-dot" aria-hidden="true"></span>
            <span class="player-name">{p.display_name}</span>
            {p.id === playerId && <span class="player-tag">vous</span>}
            {p.is_creator && p.id !== playerId && <span class="player-tag muted">créateur</span>}
          </li>
        ))}
      </ul>
    </section>

    <form method="POST" action={`/api/rounds/${shortCode}/start`} class="start-form">
      <button type="submit" class="start-btn">
        C'est parti
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
        </svg>
      </button>
    </form>

    <p class="auth-hint">
      <a href={`/auth/login?next=${encodeURIComponent(`/r/${shortCode}`)}`}>
        Se connecter (optionnel)
      </a>
      <span> pour retrouver tes parties plus tard.</span>
    </p>

    <footer class="colophon">
      <span class="colophon-rail" aria-hidden="true"></span>
      <span class="colophon-text">
        <span>carte by</span>
        <strong>SCLUBA</strong>
        <span class="colophon-dot" aria-hidden="true"></span>
      </span>
      <span class="colophon-rail" aria-hidden="true"></span>
    </footer>
  </main>

  <script>
    import { subscribeToRound, unsubscribeFromRound } from '../../../lib/realtime';

    type RoundPlayerRow = {
      id: string;
      round_id: string;
      display_name: string;
      user_id: string | null;
      is_creator: boolean;
      joined_at: string;
    };

    const root = document.querySelector<HTMLElement>('[data-lobby]');
    if (root) {
      const roundId = root.dataset.roundId!;
      const shortCode = root.dataset.shortCode!;
      const list = root.querySelector<HTMLElement>('[data-players-list]')!;
      const countEl = root.querySelector<HTMLElement>('[data-players-count]')!;

      // Read the cookie to identify the current player (set by /api/rounds[/.../join]).
      const me = document.cookie
        .split(';')
        .map((c) => c.trim())
        .find((c) => c.startsWith(`scluba_player_${shortCode}=`))
        ?.split('=')[1];

      function renderPlayer(p: RoundPlayerRow) {
        const li = document.createElement('li');
        li.className = 'player-item';
        if (p.id === me) li.classList.add('is-me');
        if (p.is_creator) li.classList.add('is-creator');
        li.dataset.playerId = p.id;
        li.innerHTML = `
          <span class="player-dot" aria-hidden="true"></span>
          <span class="player-name"></span>
        `;
        li.querySelector('.player-name')!.textContent = p.display_name;
        if (p.id === me) {
          const tag = document.createElement('span');
          tag.className = 'player-tag';
          tag.textContent = 'vous';
          li.appendChild(tag);
        } else if (p.is_creator) {
          const tag = document.createElement('span');
          tag.className = 'player-tag muted';
          tag.textContent = 'créateur';
          li.appendChild(tag);
        }
        return li;
      }

      const channel = subscribeToRound(roundId, {
        onRoundUpdate: (row) => {
          if ((row as { status?: string }).status === 'playing') {
            window.location.href = `/r/${shortCode}/play`;
          }
        },
        onPlayersChange: (event, row) => {
          const p = row as RoundPlayerRow;
          if (p.round_id !== roundId) return;
          const existing = list.querySelector<HTMLElement>(`[data-player-id="${p.id}"]`);
          if (event === 'DELETE') {
            existing?.remove();
          } else if (existing) {
            existing.querySelector<HTMLElement>('.player-name')!.textContent = p.display_name;
          } else {
            list.appendChild(renderPlayer(p));
          }
          const items = list.querySelectorAll('[data-player-id]');
          countEl.textContent = String(items.length);
        },
      });

      window.addEventListener('beforeunload', () => unsubscribeFromRound(channel));
    }

    // Copy invite link
    document.querySelector<HTMLElement>('[data-copy-link]')?.addEventListener('click', async (e) => {
      const btn = e.currentTarget as HTMLElement;
      const url = btn.dataset.url!;
      const label = btn.querySelector('span')!;
      try {
        await navigator.clipboard.writeText(url);
        const prev = label.textContent;
        label.textContent = 'Lien copié ✓';
        setTimeout(() => { label.textContent = prev; }, 1500);
      } catch {
        window.prompt('Copie ce lien :', url);
      }
    });

    // Toggle QR popover
    document.querySelector<HTMLElement>('[data-toggle-qr]')?.addEventListener('click', () => {
      const popover = document.querySelector<HTMLElement>('[data-qr-popover]');
      if (popover) popover.hidden = !popover.hidden;
    });
  </script>

  <style define:vars={{ clubColor }}>
    body {
      background: #FAF7EE;
      min-height: 100dvh;
      overflow-x: hidden;
      margin: 0;
    }

    .lobby {
      max-width: 480px;
      margin: 0 auto;
      min-height: 100dvh;
      display: flex;
      flex-direction: column;
      padding: 0 var(--space-4);
    }

    /* Masthead — same as /c/[slug] */
    .masthead { text-align: center; padding: var(--space-5) 0; }
    .photo-card {
      position: relative;
      margin: 0;
      aspect-ratio: 16 / 9;
      max-height: 200px;
      width: 100%;
      border-radius: 16px;
      overflow: hidden;
      background: #E8E0CB;
      box-shadow: 0 1px 2px rgba(15, 42, 30, 0.06), 0 12px 32px rgba(27, 67, 50, 0.10);
    }
    .photo-card img { width: 100%; height: 100%; object-fit: cover; object-position: center 55%; display: block; }
    .photo-card-fade { position: absolute; inset: auto 0 0 0; height: 40%; background: linear-gradient(180deg, transparent, rgba(15, 42, 30, 0.35)); pointer-events: none; }
    .photo-card-placeholder { background: linear-gradient(135deg, #1B4332 0%, #2D6A4F 100%); }
    .logo-frame {
      position: relative; z-index: 2;
      margin: -32px auto 0;
      width: 68px; height: 68px;
      border-radius: 50%;
      background: #FAF7EE; border: 2px solid var(--accent);
      display: flex; align-items: center; justify-content: center;
      box-shadow: 0 1px 2px rgba(15, 42, 30, 0.08), 0 8px 20px rgba(27, 67, 50, 0.10);
      padding: 8px;
    }
    .logo-frame img { width: 100%; height: 100%; object-fit: contain; }
    .masthead-eyebrow { margin: var(--space-3) 0 var(--space-2); font-size: 11px; font-weight: 700; letter-spacing: 0.22em; text-transform: uppercase; color: var(--accent); }
    .title-rail { width: 64px; height: 1px; margin: 0 auto; background: var(--accent); opacity: 0.55; }
    .masthead-title { margin: var(--space-2) auto var(--space-3); font-family: var(--font-serif); font-weight: 700; font-size: clamp(1.4rem, 5vw, 1.85rem); line-height: 1.15; letter-spacing: 0.04em; text-transform: uppercase; color: var(--clubColor); max-width: 22ch; }

    /* Code block */
    .code-block {
      text-align: center;
      padding: var(--space-5) var(--space-4);
      background: rgba(212, 165, 116, 0.10);
      border-top: 1px solid rgba(212, 165, 116, 0.4);
      border-bottom: 1px solid rgba(212, 165, 116, 0.4);
      margin-bottom: var(--space-5);
    }
    .code-eyebrow { margin: 0 0 var(--space-2); font-size: 11px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: var(--accent); }
    .code-value {
      margin: 0;
      font-family: var(--font-serif);
      font-size: clamp(2.5rem, 11vw, 4rem);
      font-weight: 800;
      letter-spacing: 0.18em;
      color: var(--clubColor);
      font-variant-numeric: tabular-nums;
      line-height: 1;
    }
    .code-hint { margin: var(--space-3) 0 var(--space-4); font-size: 13px; color: var(--muted); }

    .invite-actions {
      display: flex;
      gap: var(--space-2);
      justify-content: center;
      flex-wrap: wrap;
    }
    .btn-secondary {
      display: inline-flex; align-items: center; gap: 8px;
      min-height: 40px;
      padding: 9px 14px;
      border-radius: 10px;
      border: 1px solid var(--line);
      background: #fff;
      color: var(--ink);
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      transition: border-color 0.15s, background 0.15s;
    }
    .btn-secondary:hover { border-color: var(--accent); background: var(--bg-soft); }

    .qr-popover {
      margin: var(--space-4) auto 0;
      max-width: 220px;
      text-align: center;
    }
    .qr-frame {
      width: 100%;
      padding: 14px;
      background: #fff;
      border: 1px solid var(--line);
      border-radius: 12px;
    }
    .qr-frame :global(svg) { width: 100%; height: auto; display: block; }
    .qr-popover-hint { margin-top: var(--space-2); font-size: 12px; color: var(--muted); }

    /* Players block */
    .players-block { padding: 0 var(--space-1) var(--space-5); }
    .players-head { display: flex; align-items: baseline; justify-content: space-between; margin-bottom: var(--space-3); }
    .players-title { font-family: var(--font-serif); font-size: var(--text-md); font-weight: 700; color: var(--ink); margin: 0; letter-spacing: 0.02em; }
    .players-count {
      font-family: var(--font-serif); font-size: var(--text-sm); font-weight: 700; color: var(--clubColor);
      background: rgba(212, 165, 116, 0.15);
      border: 1px solid var(--accent);
      padding: 2px 12px;
      border-radius: 999px;
      font-variant-numeric: tabular-nums;
    }
    .players-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 6px; }
    .player-item {
      display: flex; align-items: center; gap: 10px;
      padding: 12px 14px;
      background: #fff;
      border: 1px solid var(--line);
      border-radius: 12px;
      animation: player-in 240ms ease-out;
    }
    .player-item.is-me { border-color: var(--accent); background: rgba(212, 165, 116, 0.06); }
    .player-dot {
      width: 8px; height: 8px;
      border-radius: 50%;
      background: var(--clubColor);
      flex-shrink: 0;
    }
    .player-name { flex: 1; font-size: 15px; font-weight: 500; color: var(--ink); }
    .player-tag {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--accent);
      background: rgba(212, 165, 116, 0.10);
      padding: 3px 8px;
      border-radius: 4px;
    }
    .player-tag.muted { color: var(--muted); background: var(--line-soft); }

    @keyframes player-in {
      from { opacity: 0; transform: translateY(-4px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @media (prefers-reduced-motion: reduce) {
      .player-item { animation: none; }
    }

    /* Start CTA */
    .start-form { padding: 0 var(--space-2); }
    .start-btn {
      width: 100%;
      display: inline-flex; align-items: center; justify-content: center; gap: 10px;
      min-height: 56px;
      padding: 14px 24px;
      border-radius: 12px; border: none;
      background: var(--clubColor); color: #FAF7EE;
      font-size: 16px; font-weight: 600; letter-spacing: 0.01em;
      cursor: pointer;
      box-shadow: 0 1px 2px rgba(15, 42, 30, 0.08), 0 8px 20px rgba(27, 67, 50, 0.18);
      transition: filter 0.15s, transform 0.12s;
    }
    .start-btn:hover { filter: brightness(0.92); }
    .start-btn:active { transform: translateY(1px); }
    .start-btn:focus-visible { outline: 2px solid var(--accent); outline-offset: 3px; }

    .auth-hint {
      margin: var(--space-4) 0 0;
      text-align: center;
      font-size: 12px;
      color: var(--muted);
    }
    .auth-hint a { color: var(--clubColor); text-decoration: underline; text-underline-offset: 2px; }

    /* Colophon — copied from /c/[slug] for consistency */
    .colophon {
      display: flex; align-items: center; justify-content: center; gap: var(--space-3);
      padding: var(--space-6) 0 var(--space-7);
      max-width: 320px;
      margin: 0 auto;
    }
    .colophon-rail { flex: 1; height: 1px; background: var(--accent); opacity: 0.45; }
    .colophon-text {
      display: inline-flex; align-items: center; gap: 8px;
      font-family: var(--font-serif); font-size: 12px; letter-spacing: 0.04em;
      color: var(--muted); white-space: nowrap;
    }
    .colophon-text strong { font-family: var(--font-serif); font-weight: 700; color: var(--clubColor); letter-spacing: 0.08em; }
    .colophon-dot { width: 6px; height: 6px; background: var(--accent); border-radius: 1px; }
  </style>
</body>
</html>
