---
export const prerender = false;

import PlayerLayout from '../../../layouts/PlayerLayout.astro';
import Masthead from '../../../components/player/Masthead.astro';
import Colophon from '../../../components/player/Colophon.astro';
import { serviceClient } from '../../../lib/supabase';
import { qrSvg } from '../../../lib/qr';
import Honeypot from '../../../components/Honeypot.astro';
import type { Club, Round, RoundPlayer } from '../../../lib/clubs-types';
import { avatarColor, initialOf } from '../../../lib/avatar';

const { shortCode: rawShortCode } = Astro.params;
const shortCode = (rawShortCode ?? '').toUpperCase();
const sb = serviceClient();

const { data: round } = await sb
  .from('rounds')
  .select('*, club:clubs(*)')
  .eq('short_code', shortCode)
  .maybeSingle();

if (!round) {
  return Astro.rewrite('/404');
}

const r = round as Round & { club: Club };

if (r.status === 'finished') {
  return Astro.redirect(`/r/${shortCode}/recap`, 302);
}
if (r.status === 'playing') {
  return Astro.redirect(`/r/${shortCode}/play`, 302);
}

const cookieKey = `scluba_player_${shortCode}`;
const playerId = Astro.cookies.get(cookieKey)?.value ?? null;

const { data: players } = await sb
  .from('round_players')
  .select('*')
  .eq('round_id', r.id)
  .order('joined_at');
const initialPlayers = (players ?? []) as RoundPlayer[];

// Anyone who isn't yet a player in this round (no cookie, or stale cookie)
// gets sent to the join/claim page so they pick a name instead of staring
// at someone else's lobby.
const me = initialPlayers.find((p) => p.id === playerId) ?? null;
const pendingCount = initialPlayers.filter((p) => p.claimed_at === null).length;
if (!me) {
  return Astro.redirect(`/r/${shortCode}/join`, 302);
}

const isCreator = me?.is_creator === true;
const canStart = isCreator && pendingCount === 0;

// QR encodes the join URL so scanners land directly on the claim flow.
const joinUrl = `${Astro.url.origin}/r/${shortCode}/join`;
const inviteQr = await qrSvg(joinUrl, { errorCorrectionLevel: 'M' });

const clubColor = r.club.primary_color ?? '#1B4332';
---

<PlayerLayout
  title={`Lobby — ${r.club.name} · Scluba`}
  themeColor="#FAF7EE"
  clubColor={clubColor}
>
  <main
    class="lobby"
    data-lobby
    data-round-id={r.id}
    data-short-code={shortCode}
    data-player-id={playerId ?? ''}
    data-is-creator={isCreator ? '1' : '0'}
  >
    <Masthead
      photoUrl={r.club.photo_url}
      logoUrl={r.club.logo_url}
      eyebrow="Lobby"
      title={r.club.name}
      size="standard"
    />

    <section class="code-block" aria-labelledby="code-title">
      <p id="code-title" class="code-eyebrow">Code de la partie</p>
      <p class="code-value" aria-label={`Code ${shortCode}`}>{shortCode}</p>
      <p class="code-hint">Partage ce code ou montre le QR à tes copains.</p>

      <div class="invite-actions">
        <button type="button" class="btn-secondary" data-copy-link data-url={joinUrl}>
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
          </svg>
          <span>Copier le lien</span>
        </button>
        <button type="button" class="btn-secondary" data-toggle-qr aria-expanded="false">
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
            <rect x="3" y="14" width="7" height="7"/><path d="M14 14h3v3h-3zM18 18h3v3h-3zM14 18h3"/>
          </svg>
          <span>Afficher le QR</span>
        </button>
      </div>

      <div class="qr-popover" data-qr-popover hidden>
        <div class="qr-frame" set:html={inviteQr}></div>
        <p class="qr-popover-hint">Scanne avec l'appareil photo de ton tel pour rejoindre.</p>
      </div>
    </section>

    <section class="players-block" aria-labelledby="players-title">
      <header class="players-head">
        <h2 id="players-title" class="players-title">Joueurs</h2>
        <span class="players-count" data-players-count>
          <span data-claimed-count>{initialPlayers.length - pendingCount}</span>
          <span class="players-count-sep">/</span>
          <span data-total-count>{initialPlayers.length}</span>
        </span>
      </header>
      <ul class="players-list" data-players-list>
        {initialPlayers.map((p) => {
          const isPlaceholder = p.claimed_at === null;
          const isMe = p.id === playerId;
          return (
            <li
              class={[
                'player-item',
                isPlaceholder && 'is-pending',
                isMe && 'is-me',
                p.is_creator && 'is-creator',
              ].filter(Boolean).join(' ')}
              data-player-id={p.id}
              data-is-creator={p.is_creator ? '1' : '0'}
              data-is-claimed={isPlaceholder ? '0' : '1'}
            >
              <span
                class="player-avatar"
                aria-hidden="true"
                style={`background: ${avatarColor(p.id)}`}
              >{initialOf(p.display_name)}</span>
              <span class="player-name">{p.display_name}</span>
              {isMe && <span class="player-tag">vous</span>}
              {!isMe && p.is_creator && <span class="player-tag muted">créateur</span>}
              {isPlaceholder && <span class="player-tag pending">en attente</span>}
              {isCreator && !p.is_creator && (
                <button
                  type="button"
                  class={`player-remove${isPlaceholder ? '' : ' is-claimed'}`}
                  data-remove-player={p.id}
                  data-claimed={isPlaceholder ? '0' : '1'}
                  data-player-name={p.display_name}
                  aria-label={`Retirer ${p.display_name}`}
                >
                  <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M18 6 6 18"/><path d="m6 6 12 12"/>
                  </svg>
                </button>
              )}
            </li>
          );
        })}
      </ul>

      {isCreator && (
        <form class="add-player-form" data-add-player-form novalidate>
          <Honeypot />
          <input
            type="text"
            name="display_name"
            class="add-player-input"
            placeholder="Ajouter un joueur oublié"
            maxlength="40"
            autocomplete="off"
            data-add-player-input
          />
          <button type="submit" class="add-player-btn">
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M12 5v14"/><path d="M5 12h14"/>
            </svg>
            <span>Ajouter</span>
          </button>
        </form>
      )}
      <p class="add-player-error" data-add-player-error hidden></p>
    </section>

    <form method="POST" action={`/api/rounds/${shortCode}/start`} class="start-form" data-start-form>
      <button
        type="submit"
        class="start-btn"
        data-start-btn
        disabled={!canStart}
      >
        <span data-start-label>
          {canStart ? "C'est parti" : pendingCount > 0 ? `En attente de ${pendingCount} joueur${pendingCount > 1 ? 's' : ''}…` : "Seul l'organisateur peut démarrer"}
        </span>
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
        </svg>
      </button>
    </form>

    <Colophon />
  </main>

  <script>
    import { subscribeToRound, unsubscribeFromRound } from '../../../lib/realtime';
    import { avatarColor, initialOf } from '../../../lib/avatar';
    import { initLobbyAnimations } from '../../../lib/animations/lobby';

    // Reveal éditorial + autoAnimate sur la players list + spring QR.
    initLobbyAnimations().catch((err) => {
      console.warn('[lobby] animations init failed', err);
    });

    type RoundPlayerRow = {
      id: string;
      round_id: string;
      display_name: string;
      user_id: string | null;
      is_creator: boolean;
      joined_at: string;
      claimed_at: string | null;
    };

    const root = document.querySelector<HTMLElement>('[data-lobby]');
    if (root) {
      const roundId = root.dataset.roundId!;
      const shortCode = root.dataset.shortCode!;
      const me = root.dataset.playerId || undefined;
      const isCreator = root.dataset.isCreator === '1';
      const list = root.querySelector<HTMLElement>('[data-players-list]')!;
      const claimedCountEl = root.querySelector<HTMLElement>('[data-claimed-count]')!;
      const totalCountEl = root.querySelector<HTMLElement>('[data-total-count]')!;
      const startBtn = root.querySelector<HTMLButtonElement>('[data-start-btn]')!;
      const startLabel = root.querySelector<HTMLElement>('[data-start-label]')!;

      function updateCountsAndStart() {
        const items = list.querySelectorAll<HTMLElement>('[data-player-id]');
        const total = items.length;
        let claimed = 0;
        for (const it of items) {
          if (it.dataset.isClaimed === '1') claimed += 1;
        }
        const pending = total - claimed;
        claimedCountEl.textContent = String(claimed);
        totalCountEl.textContent = String(total);

        if (!isCreator) {
          startBtn.disabled = true;
          startLabel.textContent = "Seul l'organisateur peut démarrer";
        } else if (pending > 0) {
          startBtn.disabled = true;
          startLabel.textContent = `En attente de ${pending} joueur${pending > 1 ? 's' : ''}…`;
        } else {
          startBtn.disabled = false;
          startLabel.textContent = "C'est parti";
        }
      }

      function renderPlayer(p: RoundPlayerRow): HTMLLIElement {
        const li = document.createElement('li');
        applyPlayerRow(li, p);
        return li;
      }

      function applyPlayerRow(li: HTMLElement, p: RoundPlayerRow) {
        // Be strict against undefined/missing fields — Supabase Realtime can
        // occasionally deliver a payload missing the newest column right after
        // a migration (stale schema cache). Treat anything but a non-empty
        // string as "not claimed" so the row still gets a visible style.
        const isPlaceholder = !(typeof p.claimed_at === 'string' && p.claimed_at.length > 0);
        const isMe = !!me && p.id === me;
        const isRowCreator = p.is_creator === true;
        const classes = ['player-item'];
        if (isPlaceholder) classes.push('is-pending');
        if (isMe) classes.push('is-me');
        if (isRowCreator) classes.push('is-creator');
        // Always rewrite identity attributes so a re-applied row never loses them.
        li.className = classes.join(' ');
        li.dataset.playerId = p.id;
        li.dataset.isCreator = isRowCreator ? '1' : '0';
        li.dataset.isClaimed = isPlaceholder ? '0' : '1';

        // Clear then re-render the row content (cheaper than diffing in JS).
        li.innerHTML = '';

        // Avatar : initiale + couleur HSL stable (matche le SSR).
        // Repère visuel cohérent avec /play et /recap leaderboards.
        const avatar = document.createElement('span');
        avatar.className = 'player-avatar';
        avatar.setAttribute('aria-hidden', 'true');
        avatar.style.background = avatarColor(p.id);
        avatar.textContent = initialOf(p.display_name);
        li.appendChild(avatar);

        const name = document.createElement('span');
        name.className = 'player-name';
        name.textContent = p.display_name;
        li.appendChild(name);

        if (isMe) {
          const tag = document.createElement('span');
          tag.className = 'player-tag';
          tag.textContent = 'vous';
          li.appendChild(tag);
        } else if (isRowCreator) {
          const tag = document.createElement('span');
          tag.className = 'player-tag muted';
          tag.textContent = 'créateur';
          li.appendChild(tag);
        }
        if (isPlaceholder) {
          const tag = document.createElement('span');
          tag.className = 'player-tag pending';
          tag.textContent = 'en attente';
          li.appendChild(tag);
        }
        // Organizer can remove ANY non-creator player while the round is in
        // lobby (claimed players too — same gating as the API). The creator
        // cannot remove themselves.
        if (isCreator && !isRowCreator) {
          const btn = document.createElement('button');
          btn.type = 'button';
          btn.className = isPlaceholder ? 'player-remove' : 'player-remove is-claimed';
          btn.dataset.removePlayer = p.id;
          btn.dataset.claimed = isPlaceholder ? '0' : '1';
          btn.dataset.playerName = p.display_name;
          btn.setAttribute('aria-label', `Retirer ${p.display_name}`);
          btn.innerHTML = `
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M18 6 6 18"/><path d="m6 6 12 12"/>
            </svg>
          `;
          li.appendChild(btn);
        }
      }

      const channel = subscribeToRound(roundId, {
        onRoundUpdate: (row) => {
          if ((row as { status?: string }).status === 'playing') {
            window.location.href = `/r/${shortCode}/play`;
          }
        },
        onPlayersChange: (event, row) => {
          const p = row as RoundPlayerRow;
          if (p.round_id !== roundId) return;
          // Diagnostic log — helps spot stale-schema payloads if a row ever
          // arrives without the claimed_at column.
          console.debug('[lobby] player change', event, p);
          const existing = list.querySelector<HTMLElement>(`[data-player-id="${p.id}"]`);
          if (event === 'DELETE') {
            existing?.remove();
          } else if (existing) {
            applyPlayerRow(existing, p);
          } else {
            const li = renderPlayer(p);
            list.appendChild(li);
            // Smooth scroll the new row into view so the orga sees the addition.
            requestAnimationFrame(() => {
              li.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            });
          }
          updateCountsAndStart();
        },
      });

      window.addEventListener('beforeunload', () => unsubscribeFromRound(channel));

      // Remove a player (creator only, lobby only). Placeholders are removed
      // silently; claimed players need a confirmation. We remove the row from
      // the DOM optimistically on a 2xx response because the realtime DELETE
      // event has been observed to miss this case (likely a publication or
      // RLS filter quirk), and waiting on it leaves stale rows on screen.
      if (isCreator) {
        list.addEventListener('click', async (e) => {
          const target = e.target as HTMLElement;
          const btn = target.closest<HTMLButtonElement>('[data-remove-player]');
          if (!btn) return;
          const id = btn.dataset.removePlayer!;
          const isClaimed = btn.dataset.claimed === '1';
          const name = btn.dataset.playerName || 'ce joueur';
          if (isClaimed && !window.confirm(`Retirer ${name} de la partie ?`)) {
            return;
          }
          btn.disabled = true;
          try {
            const res = await fetch(`/api/rounds/${shortCode}/players?id=${encodeURIComponent(id)}`, {
              method: 'DELETE',
              credentials: 'same-origin',
            });
            if (res.ok) {
              const li = btn.closest<HTMLElement>('[data-player-id]');
              li?.remove();
              updateCountsAndStart();
            } else {
              const text = await res.text();
              alert(text || 'Suppression impossible');
              btn.disabled = false;
            }
          } catch (err) {
            console.error(err);
            btn.disabled = false;
          }
        });
      }

      // Organizer: add a missing teammate from the lobby.
      const addForm = root.querySelector<HTMLFormElement>('[data-add-player-form]');
      const addInput = root.querySelector<HTMLInputElement>('[data-add-player-input]');
      const addErr = root.querySelector<HTMLElement>('[data-add-player-error]');
      if (addForm && addInput && addErr) {
        addForm.addEventListener('submit', async (e) => {
          e.preventDefault();
          const name = addInput.value.trim();
          if (!name) return;
          addErr.hidden = true;
          const fd = new FormData();
          fd.append('display_name', name);
          try {
            const res = await fetch(`/api/rounds/${shortCode}/players`, {
              method: 'POST',
              body: fd,
              credentials: 'same-origin',
            });
            if (!res.ok) {
              const text = await res.text();
              addErr.textContent = text || 'Ajout impossible';
              addErr.hidden = false;
              return;
            }
            addInput.value = '';
            // The realtime INSERT will render the row.
          } catch (err) {
            console.error(err);
            addErr.textContent = 'Réseau indisponible';
            addErr.hidden = false;
          }
        });
      }

      // Surface server-side gating errors on the start form (e.g. someone
      // hasn't joined yet but the user clicked anyway via a stale cache).
      const startForm = root.querySelector<HTMLFormElement>('[data-start-form]');
      if (startForm) {
        startForm.addEventListener('submit', async (e) => {
          if (!isCreator) {
            e.preventDefault();
            return;
          }
          // Let it submit; on error, the API returns a non-redirect response
          // that the browser will display. (Standard form submit semantics.)
        });
      }
    }

    // Copy invite link.
    document.querySelector<HTMLElement>('[data-copy-link]')?.addEventListener('click', async (e) => {
      const btn = e.currentTarget as HTMLElement;
      const url = btn.dataset.url!;
      const label = btn.querySelector('span')!;
      try {
        await navigator.clipboard.writeText(url);
        const prev = label.textContent;
        label.textContent = 'Lien copié ✓';
        setTimeout(() => { label.textContent = prev; }, 1500);
      } catch {
        window.prompt('Copie ce lien :', url);
      }
    });

    // Toggle QR popover.
    document.querySelector<HTMLElement>('[data-toggle-qr]')?.addEventListener('click', (e) => {
      const btn = e.currentTarget as HTMLElement;
      const popover = document.querySelector<HTMLElement>('[data-qr-popover]');
      if (popover) {
        popover.hidden = !popover.hidden;
        btn.setAttribute('aria-expanded', String(!popover.hidden));
      }
    });
  </script>

  <style>
    .lobby {
      max-width: 480px;
      margin: 0 auto;
      min-height: 100dvh;
      display: flex;
      flex-direction: column;
      padding: 0 var(--space-4);
    }

    /* Code block */
    .code-block {
      text-align: center;
      padding: var(--space-5) var(--space-4);
      background: rgba(212, 165, 116, 0.10);
      border-top: 1px solid rgba(212, 165, 116, 0.4);
      border-bottom: 1px solid rgba(212, 165, 116, 0.4);
      margin-bottom: var(--space-5);
    }
    .code-eyebrow {
      margin: 0 0 var(--space-2);
      font-family: var(--font-mono);
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--accent);
    }
    .code-value {
      margin: 0;
      font-family: var(--font-display, var(--font-serif));
      font-size: clamp(2.5rem, 11vw, 4rem);
      font-weight: 900;
      letter-spacing: 0.18em;
      color: var(--clubColor);
      font-variant-numeric: tabular-nums lining-nums;
      line-height: 1;
      /* font-variation-settings pour pousser l'opsz de Fraunces en
         mode "display" (chiffres condensés + cap-height max). */
      font-variation-settings: 'opsz' 144, 'wght' 900, 'SOFT' 0;
    }
    .code-hint { margin: var(--space-3) 0 var(--space-4); font-size: 13px; color: var(--muted); }

    .invite-actions {
      display: flex;
      gap: var(--space-2);
      justify-content: center;
      flex-wrap: wrap;
    }
    .btn-secondary {
      display: inline-flex; align-items: center; gap: 8px;
      min-height: 40px;
      padding: 9px 14px;
      border-radius: 10px;
      border: 1px solid var(--line);
      background: #fff;
      color: var(--ink);
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      transition: border-color 0.15s, background 0.15s;
    }
    .btn-secondary:hover { border-color: var(--accent); background: var(--bg-soft); }

    /* QR popover : surface flottante mais inline (pas overlay), donc
       pas de full Glass Forest (backdrop-filter aurait rien à flouter
       derrière puisque la code-block est en aplat honey). On lui donne
       un traitement "papier ciselé" : ring honey, paper-deep, multi-
       layer shadow pour le sortir du fond. */
    .qr-popover {
      margin: var(--space-4) auto 0;
      max-width: 240px;
      text-align: center;
      padding: 14px;
      background: var(--paper-deep, #F4EEDD);
      border: 1px solid rgba(212, 165, 116, 0.45);
      border-radius: 16px;
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.6),
        0 1px 2px rgba(15, 42, 30, 0.06),
        0 12px 32px rgba(27, 67, 50, 0.14);
    }
    .qr-frame {
      width: 100%;
      padding: 12px;
      background: #fff;
      border: 1px solid var(--accent);
      border-radius: 12px;
      /* Le QR a besoin d'un fond BLANC PUR + bord net pour que les
         scanners téléphone le lisent correctement à n'importe quelle
         distance. Pas de glass / pas de blur ici. */
    }
    .qr-frame :global(svg) { width: 100%; height: auto; display: block; }
    .qr-popover-hint {
      margin-top: var(--space-3);
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--muted);
    }

    /* Players block */
    .players-block { padding: 0 var(--space-1) var(--space-5); }
    .players-head { display: flex; align-items: baseline; justify-content: space-between; margin-bottom: var(--space-3); }
    .players-title { font-family: var(--font-serif); font-size: var(--text-md); font-weight: 700; color: var(--ink); margin: 0; letter-spacing: 0.02em; }
    .players-count {
      display: inline-flex;
      align-items: baseline;
      gap: 2px;
      font-family: var(--font-serif); font-size: var(--text-sm); font-weight: 700; color: var(--clubColor);
      background: rgba(212, 165, 116, 0.15);
      border: 1px solid var(--accent);
      padding: 2px 12px;
      border-radius: 999px;
      font-variant-numeric: tabular-nums;
    }
    .players-count-sep { opacity: 0.5; }
    /* Player rows are inserted dynamically via JS (after a scan/add/remove)
       so the styles below must NOT be Astro-scoped — a fresh document.createElement
       node has no data-astro-cid-* attribute and would otherwise miss every
       scoped selector. Wrapping each selector in :global() exempts the rule
       from scoping while keeping the rest of the component's CSS local. */
    .players-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 6px; }
    :global(.player-item) {
      display: flex; align-items: center; gap: 10px;
      padding: 12px 14px;
      background: #fff;
      border: 1px solid var(--line);
      border-radius: 12px;
    }
    :global(.player-item.is-me) { border-color: var(--accent); background: rgba(212, 165, 116, 0.06); }
    :global(.player-item.is-pending) {
      background: rgba(15, 42, 30, 0.02);
      border-style: dashed;
    }
    :global(.player-item.is-pending .player-name) {
      color: var(--muted);
      font-style: italic;
    }
    :global(.player-item.is-pending .player-avatar) {
      background: transparent !important;
      border: 1.5px dashed var(--muted-soft);
      color: var(--muted-soft);
    }
    :global(.player-avatar) {
      width: 32px;
      height: 32px;
      border-radius: 50%;
      flex-shrink: 0;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      color: #fff;
      font-family: var(--font-display, var(--font-serif));
      font-weight: 800;
      font-size: 14px;
      box-shadow: inset 0 -2px 0 rgba(0, 0, 0, 0.08);
      box-sizing: border-box;
    }
    :global(.player-name) { flex: 1; font-size: 15px; font-weight: 500; color: var(--ink); }
    :global(.player-tag) {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--accent);
      background: rgba(212, 165, 116, 0.10);
      padding: 3px 8px;
      border-radius: 4px;
    }
    :global(.player-tag.muted) { color: var(--muted); background: var(--line-soft); }
    :global(.player-tag.pending) { color: #92400E; background: #FEF3C7; }
    :global(.player-remove) {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 28px;
      height: 28px;
      border-radius: 6px;
      border: 1px solid transparent;
      background: transparent;
      color: var(--muted);
      cursor: pointer;
      transition: background 0.15s, color 0.15s, border-color 0.15s;
    }
    :global(.player-remove:hover) {
      background: #FEF2F2;
      color: #DC2626;
      border-color: #FECACA;
    }
    /* Removing a claimed player is a heavier action — slightly more visible
       so the orga thinks twice (a confirm() also intercepts the click). */
    :global(.player-remove.is-claimed) { color: #B91C1C; }
    :global(.player-remove.is-claimed:hover) { background: #FEE2E2; border-color: #FCA5A5; }
    :global(.player-remove:disabled) { opacity: 0.5; cursor: not-allowed; }

    /* Defensive fallback: if a future change to renderPlayer() ever leaves an
       <li> without `.player-item`, at least keep it boxed and aligned so it
       looks like part of the list rather than a stray text node. */
    .players-list > :global(li:not(.player-item)) {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 12px 14px;
      background: #fff;
      border: 1px solid var(--line);
      border-radius: 12px;
    }

    .add-player-form {
      display: flex;
      gap: 6px;
      margin-top: var(--space-3);
    }
    .add-player-input {
      flex: 1;
      padding: 10px 12px;
      border-radius: 10px;
      border: 1px solid var(--line);
      background: #fff;
      font-size: 14px;
      font-family: var(--font-sans);
      color: var(--ink);
    }
    .add-player-input:focus {
      outline: none;
      border-color: var(--accent);
      box-shadow: 0 0 0 3px rgba(212, 165, 116, 0.15);
    }
    .add-player-btn {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 0 14px;
      border-radius: 10px;
      border: 1px solid var(--clubColor);
      background: transparent;
      color: var(--clubColor);
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      transition: background 0.15s, color 0.15s;
    }
    .add-player-btn:hover {
      background: var(--clubColor);
      color: #FAF7EE;
    }
    .add-player-error {
      margin: var(--space-2) 0 0;
      font-size: 12px;
      color: #DC2626;
    }

    /* Start CTA */
    .start-form { padding: 0 var(--space-2); }
    .start-btn {
      width: 100%;
      display: inline-flex; align-items: center; justify-content: center; gap: 10px;
      min-height: 56px;
      padding: 14px 24px;
      border-radius: 12px; border: none;
      background: var(--clubColor); color: #FAF7EE;
      font-size: 16px; font-weight: 600; letter-spacing: 0.01em;
      cursor: pointer;
      box-shadow: 0 1px 2px rgba(15, 42, 30, 0.08), 0 8px 20px rgba(27, 67, 50, 0.18);
      transition: filter 0.15s, transform 0.12s, opacity 0.15s;
    }
    .start-btn:hover:not(:disabled) { filter: brightness(0.92); }
    .start-btn:active:not(:disabled) { transform: translateY(1px); }
    .start-btn:focus-visible { outline: 2px solid var(--accent); outline-offset: 3px; }
    /* Pulse glow honey quand le CTA est actif (canStart = true).
       Période 2.4s, paused au hover. Signal subtil "prêt à lancer". */
    @keyframes cta-pulse {
      0%, 100% { box-shadow: 0 1px 2px rgba(15, 42, 30, 0.08), 0 8px 20px rgba(27, 67, 50, 0.18); }
      50%      { box-shadow: 0 1px 2px rgba(15, 42, 30, 0.08), 0 8px 30px rgba(212, 165, 116, 0.55), 0 0 0 4px rgba(212, 165, 116, 0.16); }
    }
    /* Breathe : respiration subtile scale 1 → 1.012 — Apple-like
       "le bouton est vivant et t'attend". Période 3.6s décalée du
       pulse pour créer un layered rythm (les 2 courbes se croisent
       au lieu de pulser ensemble). transform-only → GPU compositor,
       zéro repaint. */
    @keyframes cta-breathe {
      0%, 100% { transform: scale(1); }
      50%      { transform: scale(1.012); }
    }
    .start-btn:not(:disabled) {
      animation:
        cta-pulse 2.4s ease-in-out infinite,
        cta-breathe 3.6s ease-in-out infinite;
    }
    .start-btn:not(:disabled):hover {
      animation-play-state: paused;
    }
    @media (prefers-reduced-motion: reduce) {
      .start-btn:not(:disabled) { animation: none; }
    }
    .start-btn:disabled {
      opacity: 0.5;
      cursor: not-allowed;
      box-shadow: none;
    }

    .auth-hint {
      margin: var(--space-4) 0 0;
      text-align: center;
      font-size: 12px;
      color: var(--muted);
    }
    .auth-hint a { color: var(--clubColor); text-decoration: underline; text-underline-offset: 2px; }
  </style>
</PlayerLayout>
