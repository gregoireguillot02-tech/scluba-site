---
export const prerender = false;

import '../../../styles/tokens.css';
import '../../../styles/global.css';
import { serviceClient } from '../../../lib/supabase';
import type { Club, Round, RoundPlayer, Score } from '../../../lib/clubs-types';
import { totalPar, scoreType } from '../../../lib/clubs-types';
import ShareCardModal from '../../../components/ShareCardModal.astro';

const { shortCode } = Astro.params;
const sb = serviceClient();

const { data: round } = await sb
  .from('rounds')
  .select('*, club:clubs(*)')
  .eq('short_code', shortCode)
  .maybeSingle();

if (!round) {
  return new Response('Round not found', { status: 404 });
}

const r = round as Round & { club: Club };

const { data: roster } = await sb.from('round_players').select('id').eq('round_id', r.id);
const playerIds = (roster ?? []).map((p) => p.id);

const [{ data: players }, { data: rawScores }] = await Promise.all([
  sb.from('round_players').select('*').eq('round_id', r.id).order('joined_at'),
  playerIds.length
    ? sb.from('scores').select('*').in('round_player_id', playerIds)
    : Promise.resolve({ data: [] }),
]);

const allPlayers = (players ?? []) as RoundPlayer[];
const allScores = (rawScores ?? []) as Score[];
const par = totalPar(r.club.course_data);

function scoresFor(playerId: string): Record<number, number> {
  const out: Record<number, number> = {};
  for (const s of allScores) if (s.round_player_id === playerId) out[s.hole_number] = s.strokes;
  return out;
}

function totalFor(playerId: string): { strokes: number; played: number; diff: number } {
  let strokes = 0;
  let played = 0;
  let diff = 0;
  const map = scoresFor(playerId);
  for (const h of r.club.course_data.holes) {
    const s = map[h.number];
    if (s !== undefined) {
      strokes += s;
      played++;
      diff += s - h.par;
    }
  }
  return { strokes, played, diff };
}

function fmtDate(iso: string): string {
  return new Date(iso).toLocaleDateString('fr-FR', { weekday: 'short', day: '2-digit', month: 'short', year: 'numeric' });
}
function fmtTime(iso: string | null): string {
  if (!iso) return '—';
  return new Date(iso).toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' });
}

// Identify the visitor via cookie (same as play.astro). Without this, every
// player downloading their recap was getting the creator's scorecard.
const playerId = Astro.cookies.get(`scluba_player_${shortCode}`)?.value ?? null;
const me = allPlayers.find((p) => p.id === playerId) ?? null;
if (!me) {
  // Stranger / stale cookie / shared link: bounce to the claim page so they
  // pick a name before seeing a recap that isn't theirs.
  return Astro.redirect(`/r/${shortCode}/join`, 302);
}

const myMap = scoresFor(me.id);
const myTotal = totalFor(me.id);

const front9 = r.club.course_data.holes.filter((h) => h.number <= 9);
const back9 = r.club.course_data.holes.filter((h) => h.number > 9);

// Multiplayer mini-leaderboard. Solo rounds skip this entirely.
const isMultiplayer = allPlayers.length > 1;
const holesCount = r.club.course_data.holes.length;

interface LeaderboardRow {
  player_id: string;
  display_name: string;
  is_me: boolean;
  strokes: number;
  diff: number;
  played: number;
  finished: boolean;
}

const leaderboard: LeaderboardRow[] = allPlayers.map((p) => {
  const t = totalFor(p.id);
  return {
    player_id: p.id,
    display_name: p.display_name,
    is_me: p.id === me.id,
    strokes: t.strokes,
    diff: t.diff,
    played: t.played,
    finished: t.played === holesCount,
  };
});

// Finished players first (sorted by diff asc), unfinished/NC last (sorted by name).
leaderboard.sort((a, b) => {
  if (a.finished !== b.finished) return a.finished ? -1 : 1;
  if (a.finished && b.finished) return a.diff - b.diff;
  return a.display_name.localeCompare(b.display_name);
});

// Pre-compute the visible rank (1, 2, 3, …) for finished players only.
let rankCounter = 0;
const rankByIndex = leaderboard.map((row) => {
  if (!row.finished) return null;
  rankCounter += 1;
  return rankCounter;
});

const sharePayload = JSON.stringify({
  player: me,
  club: r.club,
  startedAt: r.started_at ?? r.created_at,
  holes: r.club.course_data.holes,
  scoresByHole: myMap,
  totalDiff: myTotal.diff,
  totalStrokes: myTotal.strokes,
  holesPlayed: myTotal.played,
  leaderboard: isMultiplayer
    ? leaderboard.map((row) => ({
        display_name: row.display_name,
        is_me: row.is_me,
        strokes: row.strokes,
        diff: row.diff,
        finished: row.finished,
      }))
    : undefined,
});

const pageUrl = `${Astro.url.origin}/r/${r.short_code}/recap`;
const clubColor = r.club.primary_color ?? '#1B4332';
---

<!doctype html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title>Carte du {fmtDate(r.started_at ?? r.created_at)} — {r.club.name} · Scluba</title>
  <meta name="robots" content="noindex, nofollow" />
  <meta name="theme-color" content="#FAF7EE" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>
  <main class="card">
    <header class="masthead">
      {r.share_photo_url ? (
        <figure class="photo-card">
          <img src={r.share_photo_url} alt="" loading="eager" decoding="async" />
          <span class="photo-card-fade" aria-hidden="true"></span>
        </figure>
      ) : r.club.photo_url ? (
        <figure class="photo-card">
          <img src={r.club.photo_url} alt="" loading="eager" decoding="async" />
          <span class="photo-card-fade" aria-hidden="true"></span>
        </figure>
      ) : (
        <div class="photo-card photo-card-placeholder" aria-hidden="true"></div>
      )}

      {r.club.logo_url && (
        <div class="logo-frame">
          <img src={r.club.logo_url} alt="" />
        </div>
      )}

      <p class="masthead-eyebrow">Carte récapitulative</p>
      <div class="title-rail" aria-hidden="true"></div>
      <h1 class="masthead-title">{r.club.name}</h1>
      <div class="title-rail" aria-hidden="true"></div>
    </header>

    <ul class="meta-strip" aria-label="Détails de la partie">
      <li>
        <span class="meta-l">Date</span>
        <span class="meta-v">{fmtDate(r.started_at ?? r.created_at)}</span>
      </li>
      <li>
        <span class="meta-l">Départ</span>
        <span class="meta-v">{fmtTime(r.started_at)}</span>
      </li>
      <li>
        <span class="meta-l">Réf.</span>
        <span class="meta-v">{r.short_code}</span>
      </li>
    </ul>

    <section class="score-block" aria-labelledby="score-title">
      <p id="score-title" class="sr-only">
        Score final {myTotal.strokes}, {myTotal.diff >= 0 ? '+' : ''}{myTotal.diff} par rapport au par {par}.
      </p>
      <p class="score-eyebrow">Score · {r.club.course_data.holes.length} trous</p>
      <div class="score-value" data-card-score data-target={String(myTotal.strokes)}>0</div>
      <p class="score-meta">
        <span class={`score-diff${myTotal.diff > 0 ? ' over' : myTotal.diff < 0 ? ' under' : ''}`}>
          {myTotal.diff > 0 ? `+${myTotal.diff}` : myTotal.diff < 0 ? String(myTotal.diff) : '±0'}
        </span>
        <span class="score-sep" aria-hidden="true">·</span>
        <span>Par {par}</span>
      </p>
    </section>

    <section class="grid-block" aria-label="Score par trou">
      <div class="grid-row">
        <span class="grid-label">F9</span>
        {front9.map((h) => {
          const s = myMap[h.number];
          const t = s !== undefined ? scoreType(s, h.par) : null;
          return (
            <span class={`grid-cell${t ? ` cell-${t}` : ' cell-empty'}`} aria-label={`Trou ${h.number}: ${s ?? '—'}`}>
              {s ?? '—'}
            </span>
          );
        })}
      </div>
      <div class="grid-row">
        <span class="grid-label">B9</span>
        {back9.map((h) => {
          const s = myMap[h.number];
          const t = s !== undefined ? scoreType(s, h.par) : null;
          return (
            <span class={`grid-cell${t ? ` cell-${t}` : ' cell-empty'}`} aria-label={`Trou ${h.number}: ${s ?? '—'}`}>
              {s ?? '—'}
            </span>
          );
        })}
      </div>
      <ul class="grid-legend" aria-hidden="true">
        <li><span class="legend-swatch cell-birdie"></span>Birdie</li>
        <li><span class="legend-swatch cell-par"></span>Par</li>
        <li><span class="legend-swatch cell-bogey"></span>Bogey</li>
      </ul>
    </section>

    {isMultiplayer && (
      <section class="leaderboard" aria-labelledby="lb-title">
        <header class="leaderboard-head">
          <p class="leaderboard-eyebrow">Multijoueur</p>
          <h2 id="lb-title" class="leaderboard-title">Classement</h2>
        </header>
        <ol class={`leaderboard-list${leaderboard.length >= 4 ? ' cols-2' : ''}`}>
          {leaderboard.map((row, i) => {
            const rank = rankByIndex[i];
            return (
              <li class={`lb-row${row.is_me ? ' is-me' : ''}${!row.finished ? ' is-nc' : ''}`}>
                <span class="lb-rank">{rank !== null ? rank : '—'}</span>
                <span class="lb-name">{row.display_name}</span>
                {row.finished ? (
                  <span class="lb-score">
                    <strong>{row.strokes}</strong>
                    <em>({row.diff === 0 ? '±0' : row.diff > 0 ? `+${row.diff}` : row.diff})</em>
                  </span>
                ) : (
                  <span class="lb-score lb-nc">NC</span>
                )}
              </li>
            );
          })}
        </ol>
      </section>
    )}

    <section class="player-row">
      <div>
        <span class="meta-l">Joueur</span>
        <span class="player-name">{me?.display_name ?? '—'}</span>
      </div>
      <button type="button" class="share-btn" data-share-url={pageUrl} data-share-title={`Carte ${r.club.name}`}>
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/>
          <polyline points="16 6 12 2 8 6"/>
          <line x1="12" y1="2" x2="12" y2="15"/>
        </svg>
        Partager
      </button>
    </section>

    <footer class="colophon">
      <span class="colophon-rail" aria-hidden="true"></span>
      <span class="colophon-text">
        <span>carte by</span>
        <strong>SCLUBA</strong>
        <span class="colophon-dot" aria-hidden="true"></span>
      </span>
      <span class="colophon-rail" aria-hidden="true"></span>
    </footer>

    <ShareCardModal
      initialPhotoUrl={r.share_photo_url}
      shareTitle={`Carte ${r.club.name}`}
      fallbackUrl={pageUrl}
      roundId={r.id}
      payload={sharePayload}
    />
  </main>

  <script>
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const el = document.querySelector<HTMLElement>('[data-card-score]');
    if (el) {
      const target = Number(el.dataset.target ?? '0');
      if (reduced || target === 0) {
        el.textContent = String(target);
      } else {
        const duration = 1600;
        const start = performance.now();
        const easeOut = (t: number) => 1 - Math.pow(1 - t, 3);
        const tick = (now: number) => {
          const t = Math.min(1, (now - start) / duration);
          el.textContent = String(Math.round(target * easeOut(t)));
          if (t < 1) requestAnimationFrame(tick);
        };
        requestAnimationFrame(tick);
      }
    }

    const shareBtn = document.querySelector<HTMLButtonElement>('[data-share-url]');
    if (shareBtn) {
      shareBtn.addEventListener('click', () => {
        const open = (window as unknown as { openShareCardModal?: () => void }).openShareCardModal;
        if (open) {
          open();
          return;
        }
        // Fallback ultra-conservateur si le modal n'a pas chargé (JS error, etc.)
        const url = shareBtn.dataset.shareUrl!;
        const title = shareBtn.dataset.shareTitle!;
        if (navigator.share) {
          navigator.share({ url, title }).catch(() => {});
        }
      });
    }
  </script>

  <style define:vars={{ clubColor }}>
    body {
      background: #FAF7EE;
      min-height: 100dvh;
      overflow-x: hidden;
      margin: 0;
    }

    .sr-only {
      position: absolute;
      width: 1px; height: 1px;
      padding: 0; margin: -1px; overflow: hidden;
      clip: rect(0,0,0,0); white-space: nowrap; border: 0;
    }

    .card {
      max-width: 480px;
      margin: 0 auto;
      min-height: 100dvh;
      display: flex;
      flex-direction: column;
      padding: 0 var(--space-4);
    }

    /* === Masthead === */
    .masthead {
      text-align: center;
      padding-top: var(--space-5);
      padding-bottom: var(--space-5);
    }
    .photo-card {
      position: relative;
      margin: 0;
      aspect-ratio: 16 / 9;
      max-height: 240px;
      width: 100%;
      border-radius: 16px;
      overflow: hidden;
      background: #E8E0CB;
      box-shadow:
        0 1px 2px rgba(15, 42, 30, 0.06),
        0 12px 32px rgba(27, 67, 50, 0.10);
    }
    .photo-card img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center 55%;
      display: block;
    }
    .photo-card-fade {
      position: absolute;
      inset: auto 0 0 0;
      height: 40%;
      background: linear-gradient(180deg, transparent, rgba(15, 42, 30, 0.35));
      pointer-events: none;
    }
    .photo-card-placeholder {
      background: linear-gradient(135deg, #1B4332 0%, #2D6A4F 100%);
    }
    .logo-frame {
      position: relative;
      z-index: 2;
      margin: -36px auto 0;
      width: 76px;
      height: 76px;
      border-radius: 50%;
      background: #FAF7EE;
      border: 2px solid var(--accent);
      display: flex; align-items: center; justify-content: center;
      box-shadow: 0 1px 2px rgba(15, 42, 30, 0.08), 0 8px 20px rgba(27, 67, 50, 0.10);
      padding: 10px;
    }
    .logo-frame img { width: 100%; height: 100%; object-fit: contain; }

    .masthead-eyebrow {
      margin: var(--space-4) 0 var(--space-3);
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--accent);
    }
    .title-rail {
      width: 64px;
      height: 1px;
      margin: 0 auto;
      background: var(--accent);
      opacity: 0.55;
    }
    .masthead-title {
      margin: var(--space-3) auto;
      font-family: var(--font-serif);
      font-weight: 700;
      font-size: clamp(1.6rem, 5.5vw, 2.1rem);
      line-height: 1.15;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      color: var(--clubColor);
      max-width: 22ch;
    }

    /* === Meta strip === */
    .meta-strip {
      list-style: none;
      margin: 0 0 var(--space-6);
      padding: var(--space-3) var(--space-4);
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-3);
      background: rgba(212, 165, 116, 0.10);
      border-top: 1px solid rgba(212, 165, 116, 0.4);
      border-bottom: 1px solid rgba(212, 165, 116, 0.4);
    }
    .meta-strip li {
      display: flex; flex-direction: column; gap: 4px; text-align: center;
    }
    .meta-l {
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 0.2em;
      color: var(--accent);
      text-transform: uppercase;
    }
    .meta-v {
      font-family: var(--font-serif);
      font-size: var(--text-sm);
      color: var(--clubColor);
      font-weight: 700;
      font-variant-numeric: tabular-nums;
    }

    /* === Score block === */
    .score-block {
      text-align: center;
      padding: var(--space-7) 0 var(--space-5);
    }
    .score-eyebrow {
      margin: 0 0 var(--space-4);
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--accent);
    }
    .score-value {
      font-family: var(--font-serif);
      font-size: clamp(5rem, 22vw, 7rem);
      font-weight: 800;
      color: var(--clubColor);
      line-height: 1;
      letter-spacing: -0.03em;
      font-variant-numeric: tabular-nums;
    }
    .score-meta {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      margin-top: var(--space-3);
      font-size: var(--text-sm);
      color: var(--muted);
      letter-spacing: 0.04em;
    }
    .score-diff { font-weight: 700; font-variant-numeric: tabular-nums; }
    .score-diff.over { color: #C0392B; }
    .score-diff.under { color: var(--clubColor); }
    .score-sep { color: var(--accent); font-weight: 700; }

    /* === Grid block === */
    .grid-block {
      padding: var(--space-5) 0 var(--space-4);
      display: flex;
      flex-direction: column;
      gap: var(--space-3);
    }
    .grid-row {
      display: grid;
      grid-template-columns: 28px repeat(9, 1fr);
      gap: 4px;
    }
    .grid-label {
      background: var(--clubColor);
      color: var(--bg);
      font-size: 11px;
      font-weight: 700;
      border-radius: var(--radius-sm);
      display: flex; align-items: center; justify-content: center;
    }
    .grid-cell {
      aspect-ratio: 1;
      background: #fff;
      border: 1px solid var(--line);
      border-radius: var(--radius-sm);
      display: flex; align-items: center; justify-content: center;
      font-size: 13px;
      font-weight: 700;
      color: var(--ink);
      font-variant-numeric: tabular-nums;
    }
    .cell-eagle, .cell-birdie { color: #C0392B; background: var(--accent-soft); border-color: var(--accent); }
    .cell-par { color: var(--clubColor); }
    .cell-bogey { color: var(--muted); }
    .cell-double { color: #6B7280; background: rgba(107,114,128,0.08); }
    .cell-empty { color: var(--muted-soft); opacity: 0.5; }

    .grid-legend {
      list-style: none;
      margin: var(--space-3) 0 0;
      padding: 0;
      display: flex;
      gap: var(--space-4);
      justify-content: center;
      font-size: 11px;
      color: var(--muted);
      letter-spacing: 0.04em;
    }
    .grid-legend li { display: inline-flex; align-items: center; gap: 6px; }
    .legend-swatch {
      width: 14px; height: 14px;
      border-radius: var(--radius-sm);
      border: 1px solid var(--line);
    }

    /* === Mini leaderboard (multiplayer only) === */
    .leaderboard {
      margin: var(--space-5) 0;
      padding: var(--space-4);
      border: 1px solid var(--line);
      border-radius: 12px;
      background: #fff;
    }
    .leaderboard-head {
      text-align: center;
      margin-bottom: var(--space-3);
    }
    .leaderboard-eyebrow {
      margin: 0 0 4px;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--accent);
    }
    .leaderboard-title {
      margin: 0;
      font-family: var(--font-serif);
      font-size: var(--text-md);
      font-weight: 700;
      color: var(--ink);
      letter-spacing: 0.02em;
    }
    .leaderboard-list {
      list-style: none;
      margin: 0;
      padding: 0;
      display: flex;
      flex-direction: column;
      gap: 4px;
    }
    /* 4+ players → 2 columns, row-major (rank 1|2 on top, 3|4 below). Keeps
       the card compact on the recap page without sacrificing legibility. */
    .leaderboard-list.cols-2 {
      display: grid;
      grid-template-columns: 1fr 1fr;
      column-gap: 8px;
      row-gap: 4px;
      grid-auto-flow: row;
    }
    .lb-row {
      display: grid;
      grid-template-columns: 28px 1fr auto;
      align-items: center;
      gap: 12px;
      padding: 8px 10px;
      border-radius: 8px;
      border-left: 3px solid transparent;
      min-width: 0;
    }
    .leaderboard-list.cols-2 .lb-row {
      gap: 8px;
      padding: 6px 8px;
    }
    .leaderboard-list.cols-2 .lb-rank { font-size: 14px; }
    .leaderboard-list.cols-2 .lb-name { font-size: 13px; }
    .leaderboard-list.cols-2 .lb-score { font-size: 12px; }
    .leaderboard-list.cols-2 .lb-score strong { font-size: 15px; margin-right: 2px; }
    .leaderboard-list.cols-2 .lb-score em { font-size: 11px; }
    .lb-row.is-me {
      background: rgba(212, 165, 116, 0.10);
      border-left-color: var(--accent);
    }
    .lb-rank {
      font-family: var(--font-serif);
      font-size: 16px;
      font-weight: 700;
      color: var(--clubColor);
      font-variant-numeric: tabular-nums;
      text-align: center;
    }
    .lb-row.is-nc .lb-rank { color: var(--muted-soft); }
    .lb-name {
      font-size: 15px;
      font-weight: 500;
      color: var(--ink);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .lb-row.is-nc .lb-name { color: var(--muted); }
    .lb-score {
      font-variant-numeric: tabular-nums;
      font-size: 14px;
      color: var(--ink);
    }
    .lb-score strong {
      font-family: var(--font-serif);
      font-size: 18px;
      font-weight: 700;
      color: var(--clubColor);
      margin-right: 4px;
    }
    .lb-score em {
      font-style: normal;
      color: var(--muted);
      font-size: 13px;
    }
    .lb-score.lb-nc {
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.12em;
      color: var(--muted);
      text-transform: uppercase;
    }

    /* === Player row + share === */
    .player-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: var(--space-3);
      padding: var(--space-4) 0;
      margin-top: var(--space-4);
      border-top: 1px dashed rgba(212, 165, 116, 0.5);
      border-bottom: 1px dashed rgba(212, 165, 116, 0.5);
    }
    .player-row > div { display: flex; flex-direction: column; gap: 4px; }
    .player-name {
      font-family: var(--font-serif);
      font-size: var(--text-md);
      color: var(--clubColor);
      font-weight: 700;
    }
    .share-btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      min-height: 44px;
      padding: 10px 18px;
      border-radius: 12px;
      border: none;
      background: var(--clubColor);
      color: var(--bg);
      font-size: var(--text-sm);
      font-weight: 600;
      cursor: pointer;
      box-shadow: 0 1px 2px rgba(15, 42, 30, 0.08), 0 4px 12px rgba(27, 67, 50, 0.10);
      transition: background 0.15s;
    }
    .share-btn:hover { filter: brightness(0.92); }

    /* === Colophon === */
    .colophon {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: var(--space-3);
      padding: var(--space-6) 0 var(--space-7);
      max-width: 320px;
      margin: 0 auto;
