---
export const prerender = false;

import PlayerLayout from '../../../layouts/PlayerLayout.astro';
import Masthead from '../../../components/player/Masthead.astro';
import Colophon from '../../../components/player/Colophon.astro';
import Scorecard from '../../../components/player/Scorecard.astro';
import Leaderboard from '../../../components/player/Leaderboard.astro';
import { serviceClient } from '../../../lib/supabase';
import type { Club, Round, RoundPlayer, Score } from '../../../lib/clubs-types';
import { resolveRoundHoles, resolveRoundSections, effectiveStrokes } from '../../../lib/clubs-types';
import ShareCardModal from '../../../components/ShareCardModal.astro';

const { shortCode } = Astro.params;
const sb = serviceClient();

const { data: round } = await sb
  .from('rounds')
  .select('*, club:clubs(*)')
  .eq('short_code', shortCode)
  .maybeSingle();

if (!round) {
  return new Response('Round not found', { status: 404 });
}

const r = round as Round & { club: Club };

const { data: roster } = await sb.from('round_players').select('id').eq('round_id', r.id);
const playerIds = (roster ?? []).map((p) => p.id);

const [{ data: players }, { data: rawScores }] = await Promise.all([
  sb.from('round_players').select('*').eq('round_id', r.id).order('joined_at'),
  playerIds.length
    ? sb.from('scores').select('*').in('round_player_id', playerIds)
    : Promise.resolve({ data: [] }),
]);

const allPlayers = (players ?? []) as RoundPlayer[];
const allScores = (rawScores ?? []) as Score[];

// Hole list this round actually plays (9 or 18), and the section breakdown
// for the scorecard grid (one section per loop).
const roundHoles = resolveRoundHoles(r, r.club);
const roundSections = resolveRoundSections(r, r.club);
const par = roundHoles.reduce((sum, h) => sum + h.par, 0);
const holesCount = roundHoles.length;

// Score saisi pour chaque trou. `strokes` est null si le trou a été
// abandonné (picked_up = true). Les trous non saisis sont absents.
interface ScoreEntry {
  strokes: number | null;
  picked_up: boolean;
}

function scoresFor(playerId: string): Record<number, ScoreEntry> {
  const out: Record<number, ScoreEntry> = {};
  for (const s of allScores) {
    if (s.round_player_id !== playerId) continue;
    out[s.hole_number] = { strokes: s.strokes, picked_up: s.picked_up };
  }
  return out;
}

// Total + diff calculés avec la règle Maximum Score (Rules of Golf 2023) :
// un trou abandonné compte comme par(trou) + 2. Le `diff` est calculé sur
// la somme des par des trous JOUÉS uniquement (pas le par total du parcours)
// — sans ça, jouer 15/18 trous donne un écart trompeur vs Par 71.
function totalFor(playerId: string): {
  strokes: number;
  played: number;
  pickedUp: number;
  playedPar: number;
  diff: number;
} {
  let strokes = 0;
  let played = 0;
  let pickedUp = 0;
  let playedPar = 0;
  let diff = 0;
  const map = scoresFor(playerId);
  for (const h of roundHoles) {
    const entry = map[h.number];
    if (!entry) continue;
    const eff = effectiveStrokes(entry, h.par);
    if (eff === null) continue;
    strokes += eff;
    played++;
    if (entry.picked_up) pickedUp++;
    playedPar += h.par;
    diff += eff - h.par;
  }
  return { strokes, played, pickedUp, playedPar, diff };
}

function fmtDate(iso: string): string {
  return new Date(iso).toLocaleDateString('fr-FR', { weekday: 'short', day: '2-digit', month: 'short', year: 'numeric' });
}
function fmtTime(iso: string | null): string {
  if (!iso) return '—';
  return new Date(iso).toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' });
}

// Identify the visitor via cookie (same as play.astro). Without this, every
// player downloading their recap was getting the creator's scorecard.
const playerId = Astro.cookies.get(`scluba_player_${shortCode}`)?.value ?? null;
let me = allPlayers.find((p) => p.id === playerId) ?? null;
if (!me) {
  // Round actif : on bounce vers /join pour que le visiteur choisisse un
  // nom avant de voir une carte qui n'est pas la sienne.
  //
  // Round finished : NE PAS bouncer vers /join — join.astro:26-28 redirige
  // les rounds finis vers /recap, ce qui crée une boucle infinie que
  // Cloudflare cape en 404. Fallback sur la carte du créateur (mode partage
  // public : n'importe qui avec le lien voit la carte du créateur du round).
  if (r.status === 'finished') {
    me = allPlayers.find((p) => p.is_creator) ?? allPlayers[0] ?? null;
  }
  if (!me) {
    return Astro.redirect(`/r/${shortCode}/join`, 302);
  }
}

const myScoreMap = scoresFor(me.id);
const myTotal = totalFor(me.id);

// Vue numérique pour l'affichage (rétro-compat avec share-card.ts).
// Les trous abandonnés sont dans `myPickedUpHoles`, pas dans `myMap`.
const myMap: Record<number, number> = {};
const myPickedUpHoles: number[] = [];
for (const [holeNum, entry] of Object.entries(myScoreMap)) {
  const n = Number(holeNum);
  if (entry.picked_up) myPickedUpHoles.push(n);
  else if (entry.strokes !== null) myMap[n] = entry.strokes;
}

// Label shown above the big score number. Prefer the loop name(s) over a
// generic "X trous" so a 9-hole Bois round doesn't read like "18 trous".
// The F9/B9 fallback (no real loops in course_data) reverts to the count.
const isRealSections = roundSections.some((s) => s.loop_id !== 'f9' && s.loop_id !== 'b9');
const formatLabel = isRealSections
  ? roundSections.map((s) => s.loop_name).join(' + ')
  : `${holesCount} trous`;

// Multiplayer mini-leaderboard. Solo rounds skip this entirely.
const isMultiplayer = allPlayers.length > 1;

interface LeaderboardRow {
  player_id: string;
  display_name: string;
  is_me: boolean;
  strokes: number;
  diff: number;
  played: number;
  finished: boolean;
}

const leaderboard: LeaderboardRow[] = allPlayers.map((p) => {
  const t = totalFor(p.id);
  return {
    player_id: p.id,
    display_name: p.display_name,
    is_me: p.id === me.id,
    strokes: t.strokes,
    diff: t.diff,
    played: t.played,
    finished: t.played === holesCount,
  };
});

// Finished players first (sorted by diff asc), unfinished/NC last (sorted by name).
leaderboard.sort((a, b) => {
  if (a.finished !== b.finished) return a.finished ? -1 : 1;
  if (a.finished && b.finished) return a.diff - b.diff;
  return a.display_name.localeCompare(b.display_name);
});

// Rank/medal/avatar helpers et leaderboardLeaderDiff sont maintenant gérés
// par Leaderboard.astro qui consomme `players: LeaderboardRow[]`.

const sharePayload = JSON.stringify({
  player: me,
  club: r.club,
  startedAt: r.started_at ?? r.created_at,
  holes: roundHoles,
  // The share-card uses sections to label each row with the loop name
  // (e.g. "La Plaine", "Le Vallon") instead of the legacy F9/B9.
  sections: roundSections.map((s) => ({ label: s.loop_name, holes: s.holes })),
  totalPar: par,
  // Title above the big score on the PNG (mirrors the on-screen eyebrow).
  formatLabel,
  scoresByHole: myMap,
  pickedUpHoles: myPickedUpHoles,
  totalDiff: myTotal.diff,
  totalStrokes: myTotal.strokes,
  holesPlayed: myTotal.played,
  // Par cumulé des seuls trous joués (utile pour afficher un écart cohérent
  // quand la carte est incomplète : "−1 / Par 28" sur 8 trous au lieu de
  // "−1 / Par 71" pour le parcours complet).
  playedPar: myTotal.playedPar,
  weather: r.weather,
  comment: me.comment,
  // 4 sponsors max, déjà répartis L/R par le SSR. Le PNG les redessine
  // dans le même ordre flanquant le score (cf. share-card.ts).
  sponsors: allSponsors,
  leaderboard: isMultiplayer
    ? leaderboard.map((row) => ({
        display_name: row.display_name,
        is_me: row.is_me,
        strokes: row.strokes,
        diff: row.diff,
        finished: row.finished,
      }))
    : undefined,
});

const pageUrl = `${Astro.url.origin}/r/${r.short_code}/recap`;
const clubColor = r.club.primary_color ?? '#1B4332';

// Sponsors : on récupère les slots non vides et on les répartit gauche/droite
// avec un léger biais à gauche pour un nombre impair, pour rester centré
// visuellement autour du score (cf. choix produit "Centrer les sponsors présents").
interface SponsorEntry { url: string; link: string | null; }
const allSponsors: SponsorEntry[] = [];
for (const i of [1, 2, 3, 4] as const) {
  const url = r.club[`sponsor_${i}_url` as const];
  if (url) {
    allSponsors.push({ url, link: r.club[`sponsor_${i}_link` as const] });
  }
}
const sponsorSplit = Math.ceil(allSponsors.length / 2);
const leftSponsors = allSponsors.slice(0, sponsorSplit);
const rightSponsors = allSponsors.slice(sponsorSplit);
const hasSponsors = allSponsors.length > 0;
---

<PlayerLayout
  title={`Carte du ${fmtDate(r.started_at ?? r.created_at)} — ${r.club.name} · Scluba`}
  themeColor="#FFFFFF"
  clubColor={clubColor}
  gridBackdrop={true}
>
  <main class="card">
    <Masthead
      photoUrl={r.share_photo_url ?? r.club.photo_url}
      logoUrl={r.club.logo_url}
      eyebrow="Carte récapitulative"
      title={r.club.name}
      size="large"
    />

    <ul class="meta-strip" aria-label="Détails de la partie">
      <li>
        <span class="meta-l">Date</span>
        <span class="meta-v">{fmtDate(r.started_at ?? r.created_at)}</span>
      </li>
      <li>
        <span class="meta-l">Réf.</span>
        <span class="meta-v">{r.short_code}</span>
      </li>
      {r.weather ? (
        <li>
          <span class="meta-l">Météo</span>
          <span class="meta-v meta-v-weather">
            <span class="meta-weather-emoji" aria-hidden="true">{r.weather.emoji}</span>
            <span>{r.weather.temp_c}°C</span>
          </span>
        </li>
      ) : (
        <li aria-hidden="true"></li>
      )}
    </ul>

    <section class="score-block" aria-labelledby="score-title" data-has-sponsors={hasSponsors ? 'true' : 'false'}>
      <p id="score-title" class="sr-only">
        Score final {myTotal.strokes}, {myTotal.diff >= 0 ? '+' : ''}{myTotal.diff} par rapport au par {myTotal.played === holesCount ? par : myTotal.playedPar}.
      </p>
      <div class="score-with-sponsors">
        {hasSponsors && (
          <div class="sponsor-flank sponsor-flank-left" aria-label="Sponsors">
            {leftSponsors.map((s) => (
              s.link ? (
                <a class="sponsor-tile" href={s.link} target="_blank" rel="noopener noreferrer sponsored">
                  <img src={s.url} alt="" loading="lazy" decoding="async" />
                </a>
              ) : (
                <div class="sponsor-tile">
                  <img src={s.url} alt="" loading="lazy" decoding="async" />
                </div>
              )
            ))}
          </div>
        )}
        <div class="score-core">
          <p class="score-eyebrow">Score · {formatLabel}</p>
          <div class="score-value" data-card-score data-target={String(myTotal.strokes)}>{myTotal.strokes}</div>
          <p class="score-meta">
            <span class={`score-diff${myTotal.diff > 0 ? ' over' : myTotal.diff < 0 ? ' under' : ''}`}>
              {myTotal.diff > 0 ? `+${myTotal.diff}` : myTotal.diff < 0 ? String(myTotal.diff) : '±0'}
            </span>
            <span class="score-sep" aria-hidden="true">·</span>
            <span>Par {myTotal.played === holesCount ? par : myTotal.playedPar}</span>
            {myTotal.played < holesCount && (
              <>
                <span class="score-sep" aria-hidden="true">·</span>
                <span>{myTotal.played}/{holesCount} trous</span>
              </>
            )}
          </p>
        </div>
        {hasSponsors && (
          <div class="sponsor-flank sponsor-flank-right" aria-label="Sponsors">
            {rightSponsors.map((s) => (
              s.link ? (
                <a class="sponsor-tile" href={s.link} target="_blank" rel="noopener noreferrer sponsored">
                  <img src={s.url} alt="" loading="lazy" decoding="async" />
                </a>
              ) : (
                <div class="sponsor-tile">
                  <img src={s.url} alt="" loading="lazy" decoding="async" />
                </div>
              )
            ))}
          </div>
        )}
      </div>
      {myTotal.pickedUp > 0 && (
        <p class="score-note">
          {myTotal.pickedUp === 1 ? '1 trou abandonné' : `${myTotal.pickedUp} trous abandonnés`} : +{myTotal.pickedUp * 2} coup{myTotal.pickedUp * 2 > 1 ? 's' : ''} ajouté{myTotal.pickedUp * 2 > 1 ? 's' : ''} (Par + 2 chacun, règle Maximum Score)
        </p>
      )}
    </section>

    <section class="grid-block" aria-label="Score par trou">
      <Scorecard sections={roundSections} mode="final" scoreMap={myScoreMap} />
      <ul class="grid-legend" aria-hidden="true">
        <li><span class="legend-swatch legend-birdie"></span>Birdie</li>
        <li><span class="legend-swatch legend-par"></span>Par</li>
        <li><span class="legend-swatch legend-bogey"></span>Bogey</li>
        {myPickedUpHoles.length > 0 && (
          <li><span class="legend-swatch legend-pickup">C</span>Abandonné</li>
        )}
      </ul>
    </section>

    {isMultiplayer && (
      <Leaderboard players={leaderboard} eyebrow="Multijoueur" title="Classement" />
    )}

    {/* Météo : remontée dans la meta-strip Date / Réf / Météo (3 cols).
         Le bandeau weather-strip séparé est retiré pour éviter le doublon. */}

    <section class="comment-block">
      <p class="comment-eyebrow">Ton commentaire</p>
      <form class="comment-form" data-comment-form data-short-code={r.short_code}>
        <textarea
          class="comment-input"
          name="comment"
          maxlength="200"
          rows="2"
          placeholder="Soleil, terrain gras, partie de fou…"
          data-comment-input
        >{me.comment ?? ''}</textarea>
        <div class="comment-actions">
          <span class="comment-count" data-comment-count>{me.comment?.length ?? 0}/200</span>
          <button type="submit" class="comment-btn" data-comment-btn>Enregistrer</button>
        </div>
        <p class="comment-status" data-comment-status></p>
      </form>
    </section>

    <section class="player-row">
      <div>
        <span class="meta-l">Joueur</span>
        <span class="player-name">{me?.display_name ?? '—'}</span>
      </div>
      <button type="button" class="share-btn" data-share-url={pageUrl} data-share-title={`Carte ${r.club.name}`}>
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/>
          <polyline points="16 6 12 2 8 6"/>
          <line x1="12" y1="2" x2="12" y2="15"/>
        </svg>
        Partager
      </button>
    </section>

    <Colophon />

    <ShareCardModal
      initialPhotoUrl={r.share_photo_url}
      shareTitle={`Carte ${r.club.name}`}
      fallbackUrl={pageUrl}
      roundId={r.id}
      payload={sharePayload}
    />
  </main>

  <script>
    import { initRecapAnimations } from '../../../lib/animations/recap';

    // Reveal éditorial en 3 actes + parallax photo + scroll triggers.
    // Le score count-up est géré à l'intérieur (avec motion-blur SVG).
    // Si reduced-motion ON, l'état final est posé instantanément.
    initRecapAnimations().catch((err) => {
      // En cas de fail de l'init (network sur GSAP, etc.), au moins
      // assurer que le score s'affiche correctement.
      console.warn('[recap] animations init failed', err);
      const el = document.querySelector<HTMLElement>('.score-value');
      if (el?.dataset.target) el.textContent = el.dataset.target;
    });

    const shareBtn = document.querySelector<HTMLButtonElement>('[data-share-url]');
    if (shareBtn) {
      shareBtn.addEventListener('click', () => {
        const open = (window as unknown as { openShareCardModal?: () => void }).openShareCardModal;
        if (open) {
          open();
          return;
        }
        // Fallback ultra-conservateur si le modal n'a pas chargé (JS error, etc.)
        const url = shareBtn.dataset.shareUrl!;
        const title = shareBtn.dataset.shareTitle!;
        if (navigator.share) {
          navigator.share({ url, title }).catch(() => {});
        }
      });
    }

    // Commentaire libre — POST asynchrone au /api/rounds/[code]/comment, met
    // à jour le sharePayload de ShareCardModal pour que le PNG suivant
    // intègre le commentaire fraîchement saisi.
    const commentForm = document.querySelector<HTMLFormElement>('[data-comment-form]');
    if (commentForm) {
      const input = commentForm.querySelector<HTMLTextAreaElement>('[data-comment-input]')!;
      const counter = commentForm.querySelector<HTMLElement>('[data-comment-count]')!;
      const status = commentForm.querySelector<HTMLElement>('[data-comment-status]')!;
      const btn = commentForm.querySelector<HTMLButtonElement>('[data-comment-btn]')!;
      const shortCode = commentForm.dataset.shortCode!;

      input.addEventListener('input', () => {
        counter.textContent = `${input.value.length}/200`;
      });

      commentForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        const value = input.value.trim();
        btn.disabled = true;
        status.textContent = 'Enregistrement…';
        try {
          const res = await fetch(`/api/rounds/${shortCode}/comment`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ comment: value }),
          });
          if (!res.ok) throw new Error(await res.text());
          status.textContent = '✓ Enregistré';

          // Sync le commentaire dans le payload du ShareCardModal pour que
          // la prochaine génération de PNG l'inclue.
          const modal = document.getElementById('share-card-modal');
          if (modal && modal.dataset.payload) {
            try {
              const payload = JSON.parse(modal.dataset.payload);
              payload.comment = value.length > 0 ? value : null;
              modal.dataset.payload = JSON.stringify(payload);
            } catch (parseErr) {
              console.warn('[recap] failed to sync comment into share payload', parseErr);
            }
          }
          setTimeout(() => { status.textContent = ''; }, 1500);
        } catch (err) {
          status.textContent = `Erreur : ${(err as Error).message}`;
        } finally {
          btn.disabled = false;
        }
      });
    }
  </script>

  <style>
    .sr-only {
      position: absolute;
      width: 1px; height: 1px;
      padding: 0; margin: -1px; overflow: hidden;
      clip: rect(0,0,0,0); white-space: nowrap; border: 0;
    }

    /* === Container card ===
       Transparent pour laisser passer le quadrillage du body[data-play-grid].
       Les modules (meta-strip, score, comment) flottent en cartes glass au-
       dessus. Masthead + scorecard + colophon restent dans le flow naturel. */
    .card {
      max-width: 480px;
      margin: 0 auto;
      min-height: 100dvh;
      display: flex;
      flex-direction: column;
      padding: 0 var(--space-4);
      background: transparent;
      touch-action: manipulation;
    }

    /* Masthead styles → src/components/player/Masthead.astro (size="large") */

    /* === Meta strip ===
       Carte glass blanche translucide, posée sur le quadrillage. Accent
       honey gardé sur les borders top/bottom pour préserver le rythme
       éditorial (rails subtils). */
    .meta-strip {
      list-style: none;
      margin: 0 0 var(--space-6);
      padding: var(--space-3) var(--space-4);
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-3);
      background: var(--play-card-bg);
      -webkit-backdrop-filter: var(--play-card-blur);
              backdrop-filter: var(--play-card-blur);
      border: 1px solid rgba(15, 42, 30, 0.06);
      border-top: 1px solid color-mix(in srgb, var(--accent) 45%, transparent);
      border-bottom: 1px solid color-mix(in srgb, var(--accent) 45%, transparent);
      border-radius: 14px;
      box-shadow: var(--play-card-shadow);
    }
    @supports not (backdrop-filter: blur(1px)) {
      .meta-strip { background: rgba(255, 255, 255, 0.92); }
    }
    .meta-strip li {
      display: flex; flex-direction: column; gap: 4px; text-align: center;
    }
    .meta-l {
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 0.2em;
      color: var(--accent);
      text-transform: uppercase;
    }
    .meta-v {
      font-family: var(--font-serif);
      font-size: var(--text-sm);
      color: var(--clubColor);
      font-weight: 700;
      font-variant-numeric: tabular-nums;
    }
    /* Météo en 3ème col : emoji + température sur une ligne. L'emoji est
       du contenu sémantique (☁️🌤️☀️🌧️), pas une icône d'UI — OK selon
       l'anti-slop rule. */
    .meta-v-weather {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 4px;
    }
    .meta-weather-emoji {
      font-size: 14px;
      line-height: 1;
    }

    /* === Score block ===
       Le verdict — grand chiffre clubColor sur carte glass blanche. Le
       count-up + motion-blur animation continue de fonctionner (transform/
       opacity only, indépendant du fond). */
    .score-block {
      text-align: center;
      padding: var(--space-7) var(--space-5) var(--space-6);
      margin-bottom: var(--space-5);
      background: var(--play-card-bg);
      -webkit-backdrop-filter: var(--play-card-blur);
              backdrop-filter: var(--play-card-blur);
      border: 1px solid rgba(15, 42, 30, 0.06);
      border-radius: 18px;
      box-shadow: var(--play-card-shadow);
    }
    /* Score flanqué de 0..2 sponsors de chaque côté. Sans sponsor, la colonne
       centrale prend toute la largeur — apparence identique à l'historique. */
    .score-with-sponsors {
      display: grid;
      grid-template-columns: auto 1fr auto;
      align-items: center;
      gap: 10px;
    }
    .score-core { min-width: 0; }
    .sponsor-flank {
      display: flex;
      flex-direction: column;
      gap: 8px;
      align-items: center;
      justify-content: center;
    }
    .sponsor-tile {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 56px;
      height: 40px;
      padding: 4px;
      background: #fff;
      border: 1px solid rgba(15, 42, 30, 0.08);
      border-radius: 8px;
      box-shadow: 0 1px 2px rgba(15, 42, 30, 0.04);
      overflow: hidden;
      text-decoration: none;
    }
    .sponsor-tile img {
      max-width: 100%;
      max-height: 100%;
      object-fit: contain;
      display: block;
    }
    @media (min-width: 380px) {
      .sponsor-tile { width: 64px; height: 44px; }
    }
    @media (max-width: 340px) {
      .sponsor-tile { width: 48px; height: 36px; padding: 3px; }
    }
    @supports not (backdrop-filter: blur(1px)) {
      .score-block { background: rgba(255, 255, 255, 0.92); }
    }
    .score-eyebrow {
      margin: 0 0 var(--space-4);
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--accent);
    }
    .score-value {
