---
import '../styles/global.css';

const front9 = [
  { par: 4, score: 5, type: 'bogey' },
  { par: 5, score: 5, type: 'par' },
  { par: 3, score: 2, type: 'birdie' },
  { par: 4, score: 4, type: 'par' },
  { par: 4, score: 5, type: 'bogey' },
  { par: 5, score: 6, type: 'bogey' },
  { par: 3, score: 3, type: 'par' },
  { par: 4, score: 5, type: 'bogey' },
  { par: 4, score: 5, type: 'bogey' },
];
const back9 = [
  { par: 4, score: 4, type: 'par' },
  { par: 3, score: 3, type: 'par' },
  { par: 5, score: 6, type: 'bogey' },
  { par: 4, score: 5, type: 'bogey' },
  { par: 4, score: 4, type: 'par' },
  { par: 3, score: 4, type: 'bogey' },
  { par: 5, score: 6, type: 'bogey' },
  { par: 4, score: 4, type: 'par' },
  { par: 4, score: 5, type: 'bogey' },
];
---

<!doctype html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title>Golf du Soleil — Carte du 25 avril · Klubba</title>
  <meta name="description" content="Carte récapitulative du 25 avril 2026 au Golf du Soleil — exemple Klubba." />
  <meta name="robots" content="noindex" />
  <meta name="theme-color" content="#1B4332" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <style>
    body {
      background: #FAF7EE;
      min-height: 100dvh;
      overflow-x: hidden;
    }
  </style>
</head>
<body>
  <a href="#main" class="skip-link">Aller au contenu</a>

  <span class="demo-badge" aria-label="Cet écran est un exemple Klubba">Exemple Klubba</span>

  <main id="main" class="demo-card">
    <!-- Photo paysage -->
    <div class="demo-photo">
      <img
        src="/photos/golf-du-soleil.jpg"
        alt=""
        width="1200"
        height="540"
        loading="eager"
        decoding="async"
        fetchpriority="high"
      />
      <div class="demo-photo-fade" aria-hidden="true"></div>
    </div>

    <!-- Logo + club name -->
    <header class="demo-brand">
      <img
        src="/logos/golf-du-soleil.svg"
        alt=""
        class="demo-brand-logo"
        width="76"
        height="76"
        decoding="async"
      />
      <p class="demo-brand-eyebrow">Carte récapitulative</p>
      <h1 class="demo-brand-name">Golf du Soleil</h1>
    </header>

    <!-- Date / time / ref strip -->
    <div class="demo-meta-strip">
      <div>
        <span class="demo-meta-l">DATE</span>
        <span class="demo-meta-v">Sam. 25 avr. 2026</span>
      </div>
      <div>
        <span class="demo-meta-l">DÉPART</span>
        <span class="demo-meta-v">14:30</span>
      </div>
      <div>
        <span class="demo-meta-l">RÉF.</span>
        <span class="demo-meta-v">N° 04287</span>
      </div>
    </div>

    <!-- Score gros + sous-titre -->
    <section class="demo-score-block" aria-labelledby="demo-score-title">
      <div class="demo-divider" aria-hidden="true">
        <span></span><em>SCORE · 18 TROUS</em><span></span>
      </div>
      <div id="demo-score-title" class="sr-only">Score final 87, +15 par rapport au par 72.</div>
      <div class="demo-score" data-demo-score aria-hidden="true">0</div>
      <div class="demo-score-meta">
        <span class="demo-score-over">+15</span>
        <span class="demo-score-sep">·</span>
        <span>Par 72</span>
      </div>
    </section>

    <!-- Stats trio -->
    <section class="demo-stats" aria-label="Statistiques de la partie">
      <div class="demo-stat">
        <span class="demo-stat-v">6,4 km</span>
        <span class="demo-stat-l">Distance</span>
      </div>
      <div class="demo-stat">
        <span class="demo-stat-v">8 432</span>
        <span class="demo-stat-l">Pas</span>
      </div>
      <div class="demo-stat">
        <span class="demo-stat-v">3h42</span>
        <span class="demo-stat-l">Durée</span>
      </div>
    </section>

    <!-- Grille front9 + back9 -->
    <section class="demo-grid" aria-label="Score par trou">
      <div class="demo-grid-row">
        <span class="demo-grid-label">F9</span>
        {front9.map((h, i) => (
          <span class={`demo-cell demo-cell-${h.type}`} aria-label={`Trou ${i + 1}: ${h.score} (${h.type})`}>
            {h.score}
          </span>
        ))}
      </div>
      <div class="demo-grid-row">
        <span class="demo-grid-label">B9</span>
        {back9.map((h, i) => (
          <span class={`demo-cell demo-cell-${h.type}`} aria-label={`Trou ${i + 10}: ${h.score} (${h.type})`}>
            {h.score}
          </span>
        ))}
      </div>
      <ul class="demo-legend" aria-hidden="true">
        <li><span class="demo-legend-swatch demo-cell-birdie"></span>Birdie</li>
        <li><span class="demo-legend-swatch demo-cell-par"></span>Par</li>
        <li><span class="demo-legend-swatch demo-cell-bogey"></span>Bogey</li>
      </ul>
    </section>

    <!-- Joueur + footer brand -->
    <section class="demo-player">
      <div class="demo-player-meta">
        <span class="demo-meta-l">JOUEUR</span>
        <span class="demo-player-name">Antoine Dupré</span>
      </div>
      <button type="button" class="btn btn-primary demo-share">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/>
          <polyline points="16 6 12 2 8 6"/>
          <line x1="12" y1="2" x2="12" y2="15"/>
        </svg>
        Partager la carte
      </button>
    </section>

    <footer class="demo-footer">
      <span>FAIT À</span>
      <strong>Klubba<em>.</em></strong>
    </footer>
  </main>

  <!-- Bandeau "envie de la même pour ton club ?" -->
  <aside class="demo-pitch">
    <p class="demo-pitch-eyebrow">Vous gérez un club&nbsp;?</p>
    <p class="demo-pitch-title">
      Cette carte, à <strong>vos couleurs</strong>, partagée par chaque joueur après sa partie.
    </p>
    <a href="/" class="btn btn-accent">Voir Klubba pour votre club</a>
  </aside>

  <script>
    /* Compteur de score 0 → 87, animé au chargement.
       Pas de scroll-trigger : la page entière est l'expérience. */
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const el = document.querySelector<HTMLElement>('[data-demo-score]');
    if (el) {
      if (reduced) {
        el.textContent = '87';
        el.setAttribute('aria-hidden', 'false');
      } else {
        const target = 87;
        const duration = 1800;
        const start = performance.now();
        const easeOut = (t: number) => 1 - Math.pow(1 - t, 3);
        const tick = (now: number) => {
          const t = Math.min(1, (now - start) / duration);
          const v = Math.round(target * easeOut(t));
          el.textContent = String(v);
          if (t < 1) requestAnimationFrame(tick);
          else el.setAttribute('aria-hidden', 'false');
        };
        requestAnimationFrame(tick);
      }
    }
  </script>

  <style>
    /* === Demo card layout === */
    .demo-card {
      max-width: 480px;
      margin: 0 auto;
      background: linear-gradient(180deg, #FAF7EE 0%, #F4F8F5 100%);
      box-shadow: 0 32px 80px rgba(27, 67, 50, 0.18);
    }

    /* === Demo badge === */
    .demo-badge {
      position: fixed;
      top: 12px;
      left: 12px;
      z-index: 50;
      background: rgba(15, 42, 30, 0.92);
      backdrop-filter: blur(8px);
      color: var(--accent);
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      padding: 6px 12px;
      border-radius: var(--radius-full);
    }

    /* === Photo === */
    .demo-photo {
      position: relative;
      height: clamp(180px, 38vh, 280px);
      overflow: hidden;
    }
    .demo-photo img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center 60%;
    }
    .demo-photo-fade {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      height: 80px;
      background: linear-gradient(180deg, transparent, #FAF7EE);
    }

    /* === Brand === */
    .demo-brand {
      margin-top: -52px;
      text-align: center;
      padding: 0 var(--space-5);
      position: relative;
      z-index: 2;
    }
    .demo-brand-logo {
      display: block;
      margin: 0 auto;
      filter: drop-shadow(0 4px 16px rgba(0, 0, 0, 0.16));
      width: 76px;
      height: 76px;
    }
    .demo-brand-eyebrow {
      font-size: var(--text-xs);
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--accent);
      font-weight: 600;
      margin-top: var(--space-3);
    }
    .demo-brand-name {
      font-family: var(--font-serif);
      font-size: clamp(1.75rem, 6vw, 2.5rem);
      color: var(--primary);
      font-weight: 700;
      letter-spacing: -0.01em;
      margin-top: 4px;
      line-height: 1.1;
    }

    /* === Meta strip === */
    .demo-meta-strip {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-3);
      margin: var(--space-5) var(--space-5) 0;
      padding: var(--space-3) var(--space-4);
      background: rgba(212, 165, 116, 0.08);
      border-top: 1px solid rgba(212, 165, 116, 0.3);
      border-bottom: 1px solid rgba(212, 165, 116, 0.3);
    }
    .demo-meta-strip > div {
      display: flex;
      flex-direction: column;
      gap: 2px;
      text-align: center;
    }
    .demo-meta-l {
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 0.18em;
      color: var(--accent);
      text-transform: uppercase;
    }
    .demo-meta-v {
      font-family: var(--font-serif);
      font-size: var(--text-sm);
      color: var(--primary);
      font-weight: 700;
      font-variant-numeric: tabular-nums;
    }

    /* === Score block === */
    .demo-score-block {
      text-align: center;
      padding: var(--space-7) var(--space-5) var(--space-5);
    }
    .demo-divider {
      display: flex;
      align-items: center;
      gap: var(--space-3);
      margin-bottom: var(--space-4);
      max-width: 280px;
      margin-left: auto;
      margin-right: auto;
    }
    .demo-divider span {
      flex: 1;
      height: 1px;
      background: var(--accent);
      opacity: 0.5;
    }
    .demo-divider em {
      font-style: normal;
      font-size: 10px;
      color: var(--accent);
      letter-spacing: 0.2em;
      font-weight: 600;
    }
    .demo-score {
      font-family: var(--font-serif);
      font-size: clamp(5rem, 22vw, 7rem);
      font-weight: 800;
      color: var(--primary);
      line-height: 1;
      letter-spacing: -0.03em;
      font-variant-numeric: tabular-nums;
    }
    .demo-score-meta {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      margin-top: var(--space-3);
      font-size: var(--text-sm);
      color: var(--muted);
      letter-spacing: 0.04em;
    }
    .demo-score-over {
      font-weight: 700;
      color: #C0392B;
      font-variant-numeric: tabular-nums;
    }
    .demo-score-sep {
      color: var(--accent);
      font-weight: 700;
    }

    /* === Stats === */
    .demo-stats {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-3);
      padding: 0 var(--space-5);
    }
    .demo-stat {
      background: rgba(212, 165, 116, 0.10);
      border-radius: var(--radius-md);
      padding: var(--space-3) var(--space-2);
      text-align: center;
    }
    .demo-stat-v {
      display: block;
      font-family: var(--font-serif);
      font-size: var(--text-md);
      font-weight: 800;
      color: var(--primary);
      line-height: 1.1;
      font-variant-numeric: tabular-nums;
    }
    .demo-stat-l {
      display: block;
      font-size: 10px;
      color: var(--muted);
      letter-spacing: 0.12em;
      text-transform: uppercase;
      margin-top: 4px;
    }

    /* === Grid === */
    .demo-grid {
      padding: var(--space-6) var(--space-5) var(--space-4);
      display: flex;
      flex-direction: column;
      gap: var(--space-3);
    }
    .demo-grid-row {
      display: grid;
      grid-template-columns: 28px repeat(9, 1fr);
      gap: 4px;
    }
    .demo-grid-label {
      background: var(--primary);
      color: var(--bg);
      font-size: 11px;
      font-weight: 700;
      border-radius: var(--radius-sm);
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .demo-cell {
      aspect-ratio: 1;
      background: var(--bg);
      border: 1px solid var(--line);
      border-radius: var(--radius-sm);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 13px;
      font-weight: 700;
      color: var(--ink);
      font-variant-numeric: tabular-nums;
    }
    .demo-cell-birdie {
      color: #C0392B;
      background: var(--accent-soft);
      border-color: var(--accent);
    }
    .demo-cell-par { color: var(--primary); }
    .demo-cell-bogey { color: var(--muted); }
    .demo-legend {
      list-style: none;
      margin: var(--space-3) 0 0;
      padding: 0;
      display: flex;
      gap: var(--space-4);
      justify-content: center;
      font-size: 11px;
      color: var(--muted);
      letter-spacing: 0.04em;
    }
    .demo-legend li {
      display: inline-flex;
      align-items: center;
      gap: 6px;
    }
    .demo-legend-swatch {
      width: 14px;
      height: 14px;
      border-radius: var(--radius-sm);
      border: 1px solid var(--line);
    }

    /* === Player + share === */
    .demo-player {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: var(--space-3);
      margin: 0 var(--space-5);
      padding: var(--space-4) 0 var(--space-5);
      border-top: 1px dashed rgba(212, 165, 116, 0.5);
      border-bottom: 1px dashed rgba(212, 165, 116, 0.5);
    }
    .demo-player-meta {
      display: flex;
      flex-direction: column;
      gap: 2px;
    }
    .demo-player-name {
      font-family: var(--font-serif);
      font-size: var(--text-md);
      color: var(--primary);
      font-weight: 700;
    }
    .demo-share {
      padding: 10px 18px;
      font-size: var(--text-sm);
    }

    /* === Footer === */
    .demo-footer {
      text-align: center;
      padding: var(--space-5) 0 var(--space-7);
      font-size: 11px;
      color: var(--muted);
      letter-spacing: 0.18em;
      text-transform: uppercase;
    }
    .demo-footer strong {
      font-family: var(--font-serif);
      color: var(--primary);
      font-size: var(--text-md);
      font-weight: 700;
      margin-left: 6px;
    }
    .demo-footer em {
      font-style: normal;
      color: var(--accent);
    }

    /* === Pitch après la carte === */
    .demo-pitch {
      max-width: 480px;
      margin: var(--space-7) auto 0;
      padding: var(--space-7) var(--space-5) var(--space-9);
      text-align: center;
    }
    .demo-pitch-eyebrow {
      font-size: var(--text-xs);
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: var(--space-3);
    }
    .demo-pitch-title {
      font-family: var(--font-serif);
      font-size: clamp(1.25rem, 4vw, 1.5rem);
      line-height: 1.3;
      color: var(--primary);
      max-width: 32ch;
      margin: 0 auto var(--space-5);
      letter-spacing: -0.01em;
    }
    .demo-pitch-title strong {
      color: var(--accent);
      font-weight: 700;
    }
  </style>
</body>
</html>
