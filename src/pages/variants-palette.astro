---
import Base from '../layouts/Base.astro';

type Palette = {
  id: string;
  name: string;
  subtitle: string;
  description: string;
  when: string;
  pros: string[];
  cons: string[];
  isCurrent?: boolean;
  tokens: {
    primary: string;
    primarySoft: string;
    primaryDeep: string;
    accent: string;
    accentSoft: string;
    accentBright: string;
    bg: string;
    bgSoft: string;
    ink: string;
    inkSoft: string;
    muted: string;
    line: string;
  };
};

const palettes: Palette[] = [
  {
    id: 'greenroom',
    name: 'Scluba Greenroom',
    subtitle: 'Actuelle — fairway profond + heure dorée',
    description:
      "C'est la palette en place sur le site aujourd'hui. Vert sapin profond pour ancrer le golf, miel pour le côté premium country-club, crème éditoriale pour respirer.",
    when: 'Use case : club premium classique, héritage chaleureux. Le compromis idéal entre golf et SaaS moderne.',
    pros: [
      'Identité forte et reconnaissable',
      'Équilibre vert (golf) ↔ or (premium) très lisible',
      'Cohérent avec les photos de parcours',
    ],
    cons: ['Nécessite des photos de qualité pour briller', 'Risque de « comme tout le monde dans le golf » si mal exécuté'],
    isCurrent: true,
    tokens: {
      primary: '#1B4332',
      primarySoft: '#2D6A4F',
      primaryDeep: '#0F2A1E',
      accent: '#D4A574',
      accentSoft: '#F5E6CF',
      accentBright: '#E8C089',
      bg: '#FFFFFF',
      bgSoft: '#FBFBF9',
      ink: '#1A1A1A',
      inkSoft: '#2D2D2D',
      muted: '#6B7280',
      line: '#E5E7EB',
    },
  },
  {
    id: 'oldcourse',
    name: 'Old Course Slate',
    subtitle: 'Alternative A — heritage nocturne',
    description:
      "Vert plus profond, accent champagne plus discret, fond crème parchemin. Plus introverti, plus château, plus livre cuir. Moins SaaS, plus club anglais.",
    when: 'Use case : positionnement ultra-luxe, golf 4-5 étoiles, atmosphère feutrée club-house. Si Scluba veut viser le segment haut.',
    pros: [
      'Très distinctif — sort du moule golf moderne',
      'Codes du luxe sobre (parchemin, champagne)',
      'Vraie identité éditoriale, lecture longue agréable',
    ],
    cons: [
      'Moins « moderne SaaS » au premier coup d\'œil',
      'Risque pesant si mal équilibré',
      'Photos doivent être très soignées (le fond parchemin pardonne moins)',
    ],
    tokens: {
      primary: '#0F2A1E',
      primarySoft: '#1B3D2D',
      primaryDeep: '#061811',
      accent: '#E8C089',
      accentSoft: '#F2D7B0',
      accentBright: '#F0CC95',
      bg: '#F8F5EE',
      bgSoft: '#F2EFE7',
      ink: '#1A1A1A',
      inkSoft: '#2D2620',
      muted: '#857F73',
      line: '#E2DED4',
    },
  },
  {
    id: 'atelier',
    name: 'Atelier Linen',
    subtitle: 'Alternative B — paper-first',
    description:
      "Fond lin dominant, accent vert profond, accent terre-cuite-miel. Inspiré du magazine, du carnet de bord, de l'édition de luxe. Le digital qui se prend pour un imprimé.",
    when: 'Use case : si Scluba pivote vers un positionnement « boutique éditoriale » — sortir totalement du cliché club-house.',
    pros: [
      'Très différenciant — aucun concurrent golf ne ressemble à ça',
      'Sensation papier / magazine premium',
      'Lecture longue très confortable',
    ],
    cons: [
      'Moins « digital » au premier coup d\'œil',
      'Risque vintage / arts-déco si mal contenu',
      'Force à repenser certains contrastes (UI très clair)',
    ],
    tokens: {
      primary: '#1F4332',
      primarySoft: '#2D6A4F',
      primaryDeep: '#0E2818',
      accent: '#B8845A',
      accentSoft: '#E8D5BC',
      accentBright: '#C99B6F',
      bg: '#F5EFE6',
      bgSoft: '#EEE8DD',
      ink: '#2A2620',
      inkSoft: '#3D3830',
      muted: '#857F73',
      line: '#E2DCD0',
    },
  },
];

const formatStyle = (p: Palette) => `
  --p-primary: ${p.tokens.primary};
  --p-primary-soft: ${p.tokens.primarySoft};
  --p-primary-deep: ${p.tokens.primaryDeep};
  --p-accent: ${p.tokens.accent};
  --p-accent-soft: ${p.tokens.accentSoft};
  --p-accent-bright: ${p.tokens.accentBright};
  --p-bg: ${p.tokens.bg};
  --p-bg-soft: ${p.tokens.bgSoft};
  --p-ink: ${p.tokens.ink};
  --p-ink-soft: ${p.tokens.inkSoft};
  --p-muted: ${p.tokens.muted};
  --p-line: ${p.tokens.line};
`.replace(/\s+/g, ' ').trim();
---

<Base locale="fr">
  <section class="vp-intro">
    <div class="container">
      <p class="vp-eyebrow">Design review · Direction palette</p>
      <h1 class="vp-h1">Palette Scluba — 3 directions</h1>
      <p class="vp-lead">
        La palette actuelle (<em>Scluba Greenroom</em>) marche très bien — l'audit UI/UX la
        recommande à conserver. Mais avant de la graver dans le marbre, voici 2 alternatives
        sérieuses pour pressure-tester la décision dans des contextes réels (hero, carte récap, CTA).
      </p>
      <p class="vp-lead-sub">
        Chaque variante est rendue avec les mêmes blocs de page (logo, hero, carte, CTA) pour comparer
        à effort égal. Le choix se joue sur le ressenti, pas sur la théorie.
      </p>
    </div>
  </section>

  {palettes.map((p) => (
    <section class={`vp-showcase ${p.isCurrent ? 'is-current' : ''}`} id={p.id} style={formatStyle(p)}>
      <div class="container">
        <header class="vp-head">
          <div class="vp-head-meta">
            <span class="vp-tag">{p.isCurrent ? 'ACTUELLE' : 'ALTERNATIVE'}</span>
            <h2 class="vp-name">{p.name}</h2>
            <p class="vp-subtitle">{p.subtitle}</p>
          </div>
          <div class="vp-swatches" aria-label={`Palette ${p.name}`}>
            <div class="vp-swatch" style={`background: ${p.tokens.primary}`}>
              <span>primary</span><code>{p.tokens.primary}</code>
            </div>
            <div class="vp-swatch" style={`background: ${p.tokens.primaryDeep}`}>
              <span>deep</span><code>{p.tokens.primaryDeep}</code>
            </div>
            <div class="vp-swatch" style={`background: ${p.tokens.accent}; color: ${p.tokens.primary}`}>
              <span>accent</span><code>{p.tokens.accent}</code>
            </div>
            <div class="vp-swatch" style={`background: ${p.tokens.bg}; color: ${p.tokens.ink}; border: 1px solid ${p.tokens.line}`}>
              <span>bg</span><code>{p.tokens.bg}</code>
            </div>
          </div>
        </header>

        <p class="vp-description">{p.description}</p>
        <p class="vp-when">{p.when}</p>

        <ul class="vp-pros-cons">
          {p.pros.map((pro) => (
            <li class="vp-pro"><strong>+</strong> {pro}</li>
          ))}
          {p.cons.map((con) => (
            <li class="vp-con"><strong>−</strong> {con}</li>
          ))}
        </ul>

        <!-- ===== MOCKUP : Hero strip ===== -->
        <div class="mock-block">
          <span class="mock-label">Hero — première impression</span>
          <div class="mock-hero">
            <div class="mock-hero-text">
              <span class="mock-eyebrow">SaaS · Clubs de golf</span>
              <h3 class="mock-title">Scluba<span class="mock-dot">.</span></h3>
              <p class="mock-tagline">La scorecard digitale brandée pour votre club.</p>
              <p class="mock-sub">Vos joueurs jouent. Votre club rayonne.</p>
              <div class="mock-buttons">
                <button class="mock-btn mock-btn-accent">Voir une démo</button>
                <button class="mock-btn mock-btn-ghost">Comment ça marche</button>
              </div>
            </div>
            <div class="mock-hero-card">
              <div class="mock-card-photo">
                <svg viewBox="0 0 200 90" preserveAspectRatio="xMidYMid slice" width="100%" height="100%">
                  <defs>
                    <linearGradient id={`vp-sky-${p.id}`} x1="0" y1="0" x2="0" y2="1">
                      <stop offset="0%" stop-color={p.tokens.accent} stop-opacity="0.5"/>
                      <stop offset="100%" stop-color={p.tokens.primarySoft} stop-opacity="0.2"/>
                    </linearGradient>
                  </defs>
                  <rect width="200" height="90" fill={`url(#vp-sky-${p.id})`}/>
                  <ellipse cx="40" cy="55" rx="80" ry="14" fill={p.tokens.primarySoft} opacity="0.5"/>
                  <ellipse cx="160" cy="50" rx="90" ry="16" fill={p.tokens.primarySoft} opacity="0.4"/>
                  <path d={"M 0 70 Q 50 60, 100 68 T 200 66 L 200 90 L 0 90 Z"} fill={p.tokens.primary} opacity="0.85"/>
                  <line x1="80" y1="80" x2="80" y2="48" stroke={p.tokens.primary} stroke-width="1.4"/>
                  <path d="M 80 48 L 96 52 L 80 56 Z" fill={p.tokens.accent}/>
                  <circle cx="80" cy="80" r="1.4" fill="#FFFFFF"/>
                </svg>
              </div>
              <div class="mock-card-brand">
                <div class="mock-card-logo"></div>
                <div>
                  <small>Carte récap</small>
                  <strong>Golf du Soleil</strong>
                </div>
              </div>
              <div class="mock-card-divider">
                <span></span><em>SCORE · 18 TROUS</em><span></span>
              </div>
              <div class="mock-card-score">87</div>
              <div class="mock-card-score-meta">+15 · Par 72</div>
              <div class="mock-card-grid" aria-hidden="true">
                {Array.from({ length: 18 }, (_, i) => (
                  <span class={`mock-cell ${i % 5 === 0 ? 'is-birdie' : i % 3 === 0 ? 'is-bogey' : ''}`}>{(i % 4) + 3}</span>
                ))}
              </div>
              <button class="mock-share-cta">Partager</button>
            </div>
          </div>
        </div>

        <!-- ===== MOCKUP : Section header + plan card ===== -->
        <div class="mock-block">
          <span class="mock-label">Section interne — typo + carte tarif</span>
          <div class="mock-section">
            <div class="mock-section-header">
              <span class="mock-eyebrow">Tarifs</span>
              <h3 class="mock-section-title">Deux plans, une promesse.</h3>
              <p class="mock-section-lead">
                Le 49€ vous donne la carte récap brandée. Le 79€ ajoute l'app de tracking en
                temps réel. Sans engagement, résiliable au mois.
              </p>
            </div>
            <div class="mock-plan">
              <div class="mock-plan-badge">RECOMMANDÉ</div>
              <div class="mock-plan-launch">1ER MOIS OFFERT</div>
              <h4 class="mock-plan-name">Complet</h4>
              <p class="mock-plan-tagline">Tout l'Essentiel + l'app de tracking</p>
              <div class="mock-plan-price">
                <span class="mock-plan-num">79€</span>
                <span class="mock-plan-period">/mois</span>
              </div>
              <ul class="mock-plan-features">
                <li>✓ Web app + apps iOS et Android</li>
                <li>✓ Tracking GPS, distance, durée temps réel</li>
                <li>✓ Carte récap brandée à vos couleurs</li>
                <li>✓ Reporting détaillé d'usage au club</li>
              </ul>
              <button class="mock-btn mock-btn-primary mock-plan-cta">Voir une démo</button>
            </div>
          </div>
        </div>

        <!-- ===== MOCKUP : CTA dark ===== -->
        <div class="mock-block">
          <span class="mock-label">CTA finale — fond foncé brandé</span>
          <div class="mock-cta">
            <span class="mock-cta-eyebrow">DÉMO DE 10 MINUTES</span>
            <h3 class="mock-cta-title">Voyez à quoi ressemblerait votre carte avant toute décision.</h3>
            <p class="mock-cta-lead">
              Donnez-nous l'URL de votre golf, on génère la maquette en 24h. Aucune carte de crédit demandée.
            </p>
            <div class="mock-cta-form">
              <span class="mock-input">Votre nom</span>
              <span class="mock-input">Nom du club</span>
              <span class="mock-input mock-input-wide">Email professionnel</span>
              <button class="mock-btn mock-btn-accent mock-cta-submit">Demander la démo →</button>
            </div>
          </div>
        </div>

        <!-- ===== MOCKUP : Footer mini ===== -->
        <div class="mock-block">
          <span class="mock-label">Footer</span>
          <div class="mock-footer">
            <strong>Scluba<em>.</em></strong>
            <span>scluba.com · © 2026</span>
          </div>
        </div>
      </div>
    </section>
  ))}

  <section class="vp-decision">
    <div class="container">
      <h2>Ta décision</h2>
      <ol>
        <li>
          Scrolle les 3 sections, regarde celle qui te parle au premier coup d'œil
          (sans réfléchir « technique »).
        </li>
        <li>
          Réponds à Claude par <code>greenroom</code> (= ne rien changer),
          <code>oldcourse</code> ou <code>atelier</code>.
        </li>
        <li>
          Si <code>greenroom</code> : on ferme le sujet et on documente le thème dans
          <code>tokens.css</code> comme « Scluba Greenroom v1 » officiel.
        </li>
        <li>
          Si <code>oldcourse</code> ou <code>atelier</code> : 2ème PR d'intégration qui swap
          tokens.css + ajustements (contraste, états hover, dark mode).
        </li>
      </ol>
      <p class="vp-hint">
        💡 Si aucune ne te parle, dis-moi laquelle est « la moins pire » et ce qui cloche
        (trop foncé / trop clair / accent trop discret…) — je referai un round.
      </p>
    </div>
  </section>
</Base>

<style>
  /* ============== Page chrome ============== */
  .vp-intro {
    padding: var(--space-9) 0 var(--space-6);
    background: var(--bg);
    text-align: center;
  }
  .vp-eyebrow {
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: var(--space-3);
  }
  .vp-h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    margin-bottom: var(--space-4);
  }
  .vp-lead {
    font-size: var(--text-md);
    color: var(--ink);
    max-width: 65ch;
    margin: 0 auto var(--space-3);
    line-height: 1.55;
  }
  .vp-lead-sub {
    font-size: var(--text-sm);
    color: var(--muted);
    max-width: 60ch;
    margin: 0 auto;
  }

  /* ============== Showcase block ============== */
  .vp-showcase {
    padding: var(--space-9) 0;
    border-top: 1px solid var(--line);
  }
  .vp-showcase.is-current {
    background: linear-gradient(180deg, rgba(212, 165, 116, 0.04), transparent 200px);
  }

  .vp-head {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
    margin-bottom: var(--space-5);
    align-items: end;
  }
  @media (min-width: 900px) {
    .vp-head {
      grid-template-columns: 1.4fr 1fr;
      gap: var(--space-7);
    }
  }
  .vp-tag {
    display: inline-block;
    background: var(--p-primary);
    color: var(--p-accent);
    font-size: var(--text-xs);
    font-weight: 800;
    letter-spacing: 0.16em;
    padding: 4px 10px;
    border-radius: var(--radius-full);
    margin-bottom: var(--space-3);
  }
  .vp-showcase.is-current .vp-tag {
    background: var(--p-accent);
    color: var(--p-primary-deep);
  }
  .vp-name {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    line-height: 1.05;
    color: var(--p-primary);
    margin-bottom: var(--space-2);
  }
  .vp-subtitle {
    color: var(--p-muted);
    font-size: var(--text-md);
    font-style: italic;
  }
  .vp-swatches {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-2);
  }
  .vp-swatch {
    border-radius: var(--radius-md);
    padding: var(--space-3) var(--space-3) var(--space-2);
    color: #fff;
    min-height: 78px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    box-shadow: var(--shadow-sm);
    font-size: 11px;
  }
  .vp-swatch span {
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    opacity: 0.85;
  }
  .vp-swatch code {
    font-family: ui-monospace, SFMono-Regular, monospace;
    font-size: 10px;
    opacity: 0.95;
  }

  .vp-description {
    color: var(--p-ink);
    font-size: var(--text-md);
    max-width: 70ch;
    line-height: 1.6;
    margin-bottom: var(--space-2);
  }
  .vp-when {
    color: var(--p-primary-soft);
    font-size: var(--text-sm);
    font-style: italic;
    max-width: 70ch;
    margin-bottom: var(--space-5);
  }
  .vp-pros-cons {
    list-style: none;
    margin: 0 0 var(--space-7);
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 4px;
    max-width: 70ch;
  }
  .vp-pros-cons li {
    font-size: var(--text-sm);
    line-height: 1.5;
  }
  .vp-pros-cons strong {
    display: inline-block;
    width: 18px;
    text-align: center;
    margin-right: 4px;
  }
  .vp-pro { color: var(--p-primary-soft); }
  .vp-con { color: var(--p-muted); }

  /* ============== Mock blocks ============== */
  .mock-block {
    margin-bottom: var(--space-6);
  }
  .mock-label {
    display: block;
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--p-muted);
    margin-bottom: var(--space-3);
  }

  /* ----- Hero mock ----- */
  .mock-hero {
    background: var(--p-bg);
    border: 1px solid var(--p-line);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    align-items: center;
    box-shadow: var(--shadow-md);
  }
  @media (min-width: 768px) {
    .mock-hero {
      grid-template-columns: 1.2fr 1fr;
      padding: var(--space-7);
    }
  }
  .mock-eyebrow {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--p-accent);
    margin-bottom: var(--space-3);
  }
  .mock-title {
    font-family: var(--font-serif);
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 800;
    color: var(--p-primary);
    line-height: 1;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-3);
  }
  .mock-dot { color: var(--p-accent); }
  .mock-tagline {
    font-family: var(--font-serif);
    font-size: clamp(1.25rem, 2.5vw, 1.5rem);
    line-height: 1.2;
    color: var(--p-ink);
    margin-bottom: var(--space-3);
    letter-spacing: -0.01em;
  }
  .mock-sub {
    font-size: var(--text-sm);
    color: var(--p-muted);
    margin-bottom: var(--space-5);
    max-width: 32ch;
  }
  .mock-buttons {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }
  .mock-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 10px 20px;
    border-radius: var(--radius-full);
    font-weight: 600;
    font-size: var(--text-sm);
    cursor: pointer;
    border: none;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .mock-btn:hover { transform: translateY(-1px); box-shadow: var(--shadow-md); }
  .mock-btn-accent {
    background: var(--p-accent);
    color: var(--p-primary);
  }
  .mock-btn-primary {
    background: var(--p-primary);
    color: var(--p-bg);
  }
  .mock-btn-ghost {
    background: transparent;
    color: var(--p-primary);
    border: 1.5px solid var(--p-primary);
  }

  /* ----- Hero mock card ----- */
  .mock-hero-card {
    background: var(--p-bg-soft);
    border: 1px solid var(--p-line);
    border-radius: var(--radius-lg);
    padding: 0 0 var(--space-4);
    overflow: hidden;
    max-width: 280px;
    justify-self: center;
    box-shadow: var(--shadow-lg);
    font-variant-numeric: tabular-nums;
  }
  .mock-card-photo {
    position: relative;
    height: 90px;
    overflow: hidden;
  }
  .mock-card-brand {
    margin-top: -18px;
    text-align: center;
    padding: 0 var(--space-3);
    position: relative;
    z-index: 2;
  }
  .mock-card-logo {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: var(--p-bg);
    border: 1.5px solid var(--p-accent);
    margin: 0 auto;
    position: relative;
  }
  .mock-card-logo::before {
    content: "";
    position: absolute;
    inset: 6px;
    background: linear-gradient(135deg, var(--p-accent), var(--p-primary));
    border-radius: 50%;
    opacity: 0.7;
  }
  .mock-card-brand small {
    display: block;
    margin-top: 4px;
    font-size: 8px;
    color: var(--p-accent);
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-weight: 600;
  }
  .mock-card-brand strong {
    display: block;
    font-family: var(--font-serif);
    font-size: 13px;
    color: var(--p-primary);
    font-weight: 700;
    margin-top: 1px;
  }
  .mock-card-divider {
    display: flex;
    align-items: center;
    gap: 6px;
    margin: var(--space-3) var(--space-4) 0;
  }
  .mock-card-divider span {
    flex: 1;
    height: 1px;
    background: var(--p-accent);
    opacity: 0.5;
  }
  .mock-card-divider em {
    font-style: normal;
    font-size: 8px;
    color: var(--p-accent);
    letter-spacing: 0.16em;
    font-weight: 600;
  }
  .mock-card-score {
    text-align: center;
    font-family: var(--font-serif);
    font-size: 48px;
    font-weight: 800;
    color: var(--p-primary);
