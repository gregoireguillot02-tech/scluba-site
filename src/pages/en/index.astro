---
import Base from '../../layouts/Base.astro';
import Hero from '../../components/Hero.astro';
import ProblemNarrative from '../../components/ProblemNarrative.astro';
import ThreeSteps from '../../components/ThreeSteps.astro';
import PhoneMockup from '../../components/PhoneMockup.astro';
import ClubsShowcase from '../../components/ClubsShowcase.astro';
import HowItWorks from '../../components/HowItWorks.astro';
import Pricing from '../../components/Pricing.astro';
import FAQ from '../../components/FAQ.astro';
import CTAForm from '../../components/CTAForm.astro';
import { useT } from '../../i18n';
import { softwareApplicationJsonLd, faqJsonLd } from '../../lib/seo';

const locale = 'en' as const;
const t = useT(locale);
const jsonLd = [softwareApplicationJsonLd(locale), faqJsonLd(t.faq.items)];
---

<Base locale={locale} altPathname="/" jsonLd={jsonLd}>
  <Hero locale={locale} />
  <ProblemNarrative locale={locale} />
  <ThreeSteps locale={locale} />
  <PhoneMockup locale={locale} />
  <ClubsShowcase locale={locale} />
  <HowItWorks locale={locale} />
  <Pricing locale={locale} />
  <FAQ locale={locale} />
  <CTAForm locale={locale} />
</Base>
