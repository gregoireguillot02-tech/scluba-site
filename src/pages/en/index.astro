---
import Base from '../../layouts/Base.astro';
import Hero from '../../components/Hero.astro';
import Chapter01Constat from '../../components/chapters/Chapter01Constat.astro';
import Chapter02Promesse from '../../components/chapters/Chapter02Promesse.astro';
import Chapter03Rituel from '../../components/chapters/Chapter03Rituel.astro';
import Chapter04Partage from '../../components/chapters/Chapter04Partage.astro';
import Chapter05Offre from '../../components/chapters/Chapter05Offre.astro';
import QandA from '../../components/chapters/QandA.astro';
import CTAForm from '../../components/CTAForm.astro';

const locale = 'en' as const;
---

<Base locale={locale}>
  {/* "The Golfer's Journal" — editorial magazine narrative in 6 chapters.
      Preface (hero) → Chapters I→V → Q&A → CTA. */}
  <Hero locale={locale} />
  <Chapter01Constat locale={locale} />
  <Chapter02Promesse locale={locale} />
  <Chapter03Rituel locale={locale} />
  <Chapter04Partage locale={locale} />
  <Chapter05Offre locale={locale} />
  <QandA locale={locale} />
  <CTAForm locale={locale} />
</Base>
