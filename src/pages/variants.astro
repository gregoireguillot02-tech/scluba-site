---
import Base from '../layouts/Base.astro';

const wordmarks = [
  {
    id: 'w1-cormorant-period',
    title: 'W1 — Cormorant + point',
    subtitle: 'Plus minimal des trois',
    description: 'Cormorant Garamond SemiBold en bas-de-casse, point sable comme aujourd\'hui mais affiné par la nouvelle font. Continuité maximale avec le brand actuel, juste un upgrade typo : Cormorant a des terminaisons et un kerning bien plus refined que Georgia.',
    classMain: 'wm-cormorant',
    classCaps: false,
    markType: 'period',
  },
  {
    id: 'w2-cormorant-lozenge',
    title: 'W2 — Cormorant + losange (Recommandé)',
    subtitle: 'Le point devient un mark custom',
    description: 'Pareil que W1 mais le point est remplacé par un petit losange sable (carré tourné 45°). Subtil, géométrique, scandinave. Le losange devient la signature visuelle Klubba — utilisable seul comme mark sur les supports, comme le carré de Vuitton ou le rond Aesop.',
    classMain: 'wm-cormorant',
    classCaps: false,
    markType: 'lozenge',
  },
  {
    id: 'w3-marcellus-caps',
    title: 'W3 — Marcellus capitales (label Aesop)',
    subtitle: 'Universe apothicaire / hospitality',
    description: 'KLUBBA en capitales Marcellus avec letter-spacing élargi, losange sable comme séparateur et tagline "GOLF · CLUB · SCORE" en dessous. Style étiquette Aesop / Le Labo / wine bottle. Plus formel, plus B2B premium.',
    classMain: 'wm-marcellus',
    classCaps: true,
    markType: 'lozenge',
    tagline: 'GOLF · CLUB · SCORE',
  },
];

const oldRounds = {
  emblems: ['e1-course-view', 'e2-tee-ready'],
  minimal: ['v1-classic', 'v2-stroke', 'v3-floating', 'v4-trajectory', 'v5-pin'],
};
---

<Base locale="fr">
  <section class="intro">
    <div class="container">
      <p class="eyebrow">Logo Klubba · Round 3 · Wordmark custom (univers Aesop / Hospitality)</p>
      <h1>3 directions wordmark</h1>
      <p class="lead">
        Round 1 (5 picto plats) → trop minimal / icon-system. Round 2 (2 emblems gradient) → trop SaaS Virage,
        pas dans la DA Klubba. <strong>Round 3 ici</strong> : on quitte le picto pour un <em>wordmark custom</em>
        type Aesop / Le Labo / hospitality premium. Le mot <em>Klubba</em> EST le logo, peaufiné par une typo
        bespoke + un mark sand subtil. La DA actuelle (Cormorant Garamond, sable, tons feutrés) est respectée.
      </p>
    </div>
  </section>

  <section class="hero-show">
    <div class="container">
      {wordmarks.map((w) => (
        <article class="wm-card" id={w.id}>
          <div class="wm-stage">
            <div class={`wm-render ${w.classMain} wm-xl`}>
              {w.classCaps ? (
                <div class="wm-caps-stack">
                  <span class="wm-caps-row">
                    <span class="wm-caps">KLUBBA</span>
                    <span class="wm-mark wm-mark-lozenge wm-mark-xl"></span>
                  </span>
                  <span class="wm-tagline">{w.tagline}</span>
                </div>
              ) : (
                <span class="wm-row">
                  <span class="wm-text">Klubba</span>
                  {w.markType === 'lozenge' ? (
                    <span class="wm-mark wm-mark-lozenge wm-mark-xl"></span>
                  ) : (
                    <span class="wm-mark wm-mark-dot">.</span>
                  )}
                </span>
              )}
            </div>
          </div>
          <div class="wm-meta">
            <h2>{w.title}</h2>
            <p class="wm-sub">{w.subtitle}</p>
            <p class="wm-desc">{w.description}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="contexts">
    <div class="container">
      <h2 class="section-title">Mise en contexte des 3 wordmarks</h2>
      <p class="section-help">Chaque wordmark dans Nav (clair), Footer (foncé), et 3 tailles favicon (le K seul comme monogramme).</p>

      {wordmarks.map((w) => (
        <div class="ctx-block">
          <h3 class="ctx-title">{w.title}</h3>

          <div class="ctx-grid">
            <!-- Nav -->
            <div class="ctx ctx-nav">
              <span class="ctx-label">Nav (clair)</span>
              <div class="nav-mock">
                <div class={`wm-render ${w.classMain} wm-nav`}>
                  {w.classCaps ? (
                    <span class="wm-caps-row">
                      <span class="wm-caps">KLUBBA</span>
                      <span class="wm-mark wm-mark-lozenge wm-mark-sm"></span>
                    </span>
                  ) : (
                    <span class="wm-row">
                      <span class="wm-text">Klubba</span>
                      {w.markType === 'lozenge' ? (
                        <span class="wm-mark wm-mark-lozenge wm-mark-sm"></span>
                      ) : (
                        <span class="wm-mark wm-mark-dot">.</span>
                      )}
                    </span>
                  )}
                </div>
                <div class="nav-fake-links">
                  <span>Tarifs</span><span>Comment</span><span class="cta-fake">Démo</span>
                </div>
              </div>
            </div>

            <!-- Footer -->
            <div class="ctx ctx-footer">
              <span class="ctx-label">Footer (foncé)</span>
              <div class="footer-mock">
                <div class={`wm-render ${w.classMain} wm-footer wm-light`}>
                  {w.classCaps ? (
                    <span class="wm-caps-row">
                      <span class="wm-caps">KLUBBA</span>
                      <span class="wm-mark wm-mark-lozenge wm-mark-md"></span>
                    </span>
                  ) : (
                    <span class="wm-row">
                      <span class="wm-text">Klubba</span>
                      {w.markType === 'lozenge' ? (
                        <span class="wm-mark wm-mark-lozenge wm-mark-md"></span>
                      ) : (
                        <span class="wm-mark wm-mark-dot">.</span>
                      )}
                    </span>
                  )}
                </div>
                <span class="footer-tag">klubba.golf</span>
              </div>
            </div>

            <!-- Monogram K. as favicon -->
            <div class="ctx ctx-favicon">
              <span class="ctx-label">Monogramme K. — 64px</span>
              <div class="fav-mock fav-64">
                <div class={`wm-render ${w.classMain} fav-mono`}>
                  <span class="wm-text">K</span>
                  {w.markType === 'lozenge' ? (
                    <span class="wm-mark wm-mark-lozenge wm-mark-fav"></span>
                  ) : (
                    <span class="wm-mark wm-mark-dot">.</span>
                  )}
                </div>
              </div>
            </div>

            <div class="ctx ctx-favicon">
              <span class="ctx-label">32px</span>
              <div class="fav-mock fav-32">
                <div class={`wm-render ${w.classMain} fav-mono-32`}>
                  <span class="wm-text">K</span>
                  {w.markType === 'lozenge' ? (
                    <span class="wm-mark wm-mark-lozenge wm-mark-tiny"></span>
                  ) : (
                    <span class="wm-mark wm-mark-dot">.</span>
                  )}
                </div>
              </div>
            </div>

            <div class="ctx ctx-favicon">
              <span class="ctx-label">16px (réel onglet)</span>
              <div class="fav-mock fav-16">
                <div class={`wm-render ${w.classMain} fav-mono-16`}>
                  <span class="wm-text">K</span>
                </div>
              </div>
              <span class="ctx-help">↑ taille réelle (le losange disparaît à 16px, normal — on garde juste K)</span>
            </div>

            <!-- Large display -->
            <div class="ctx ctx-large">
              <span class="ctx-label">Large 240px (deck / hero)</span>
              <div class="large-mock">
                <div class={`wm-render ${w.classMain} wm-display`}>
                  {w.classCaps ? (
                    <div class="wm-caps-stack">
                      <span class="wm-caps-row">
                        <span class="wm-caps">KLUBBA</span>
                        <span class="wm-mark wm-mark-lozenge wm-mark-xl"></span>
                      </span>
                      <span class="wm-tagline">{w.tagline}</span>
                    </div>
                  ) : (
                    <span class="wm-row">
                      <span class="wm-text">Klubba</span>
                      {w.markType === 'lozenge' ? (
                        <span class="wm-mark wm-mark-lozenge wm-mark-xl"></span>
                      ) : (
                        <span class="wm-mark wm-mark-dot">.</span>
                      )}
                    </span>
                  )}
                </div>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="archive">
    <div class="container">
      <details class="archive-drop">
        <summary>Archive des rounds précédents (cliquer pour déplier)</summary>
        <div class="archive-section">
          <h4>Round 2 — 2 emblems Virage-style (rejetés : trop SaaS)</h4>
          <div class="archive-strip">
            {oldRounds.emblems.map((id) => (
              <div class="archive-cell">
                <img src={`/logos/emblems/${id}.svg`} alt={id} class="emb-32" />
                <span class="strip-id">{id.split('-')[0].toUpperCase()}</span>
              </div>
            ))}
          </div>
        </div>
        <div class="archive-section">
          <h4>Round 1 — 5 picto minimaux (rejetés : trop icon-system)</h4>
          <div class="archive-strip">
            {oldRounds.minimal.map((id) => (
              <div class="archive-cell">
                <img src={`/logos/variants/${id}.svg`} alt={id} class="emb-32" />
                <span class="strip-id">{id.split('-')[0].toUpperCase()}</span>
              </div>
            ))}
          </div>
        </div>
      </details>
    </div>
  </section>

  <section class="decision">
    <div class="container">
      <h2>Ta décision</h2>
      <ol>
        <li>Choisis : <code>w1</code> / <code>w2</code> / <code>w3</code></li>
        <li>Optionnel : ce que tu veux ajuster (font weight, taille du losange, kerning, autre tagline pour W3)</li>
        <li>Si rien ne va : <code>r4</code> + tes critiques précises (univers de marque, références visuelles à coller)</li>
      </ol>
      <p class="hint">💡 Une fois validé, j'intègre dans Nav + Footer + favicon (en remplaçant le rendu Georgia actuel par Cormorant + le mark choisi). Le wordmark devient ton vrai logo.</p>
    </div>
  </section>
</Base>

<style>
  .intro {
    padding: var(--space-9) 0 var(--space-6);
    text-align: center;
    background: var(--bg);
  }
  .eyebrow {
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: var(--space-3);
  }
  .intro h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    margin-bottom: var(--space-4);
  }
  .lead {
    font-size: var(--text-md);
    color: var(--ink);
    max-width: 70ch;
    margin: 0 auto;
    line-height: 1.6;
  }

  /* Wordmark renderings */
  .wm-render {
    color: var(--primary);
    display: inline-block;
  }
  .wm-light { color: var(--bg); }

  .wm-cormorant {
    font-family: var(--font-wordmark);
    font-weight: 600;
    letter-spacing: -0.015em;
    line-height: 1;
  }
  .wm-marcellus {
    font-family: var(--font-label);
    font-weight: 400;
    line-height: 1.1;
  }

  .wm-row {
    display: inline-flex;
    align-items: baseline;
    gap: 0.04em;
  }
  .wm-text { display: inline-block; }

  .wm-caps-stack {
    display: inline-flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.4em;
  }
  .wm-caps-row {
    display: inline-flex;
    align-items: center;
    gap: 0.45em;
  }
  .wm-caps {
    letter-spacing: 0.16em;
    font-weight: 400;
  }
  .wm-tagline {
    font-family: var(--font-sans);
    font-size: 0.32em;
    letter-spacing: 0.32em;
    color: var(--muted);
    font-weight: 500;
  }
  .wm-light .wm-tagline { color: var(--accent-soft); }

  /* Marks */
  .wm-mark { display: inline-block; flex-shrink: 0; }
  .wm-mark-dot {
    color: var(--accent);
    font-family: inherit;
    font-weight: inherit;
    line-height: 1;
  }
  .wm-mark-lozenge {
    background: var(--accent);
    transform: rotate(45deg);
    align-self: center;
  }
  .wm-mark-tiny { width: 0.18em; height: 0.18em; margin-left: 0.18em; }
  .wm-mark-sm { width: 0.22em; height: 0.22em; margin-left: 0.22em; }
  .wm-mark-md { width: 0.26em; height: 0.26em; margin-left: 0.24em; }
  .wm-mark-fav { width: 0.18em; height: 0.18em; margin-left: 0.14em; align-self: flex-end; margin-bottom: 0.1em; }
  .wm-mark-xl { width: 0.24em; height: 0.24em; margin-left: 0.22em; align-self: center; }

  /* Sizes */
  .wm-xl { font-size: clamp(3rem, 7vw, 5rem); }
  .wm-display { font-size: clamp(3rem, 7vw, 5rem); }
  .wm-nav { font-size: 1.5rem; }
  .wm-footer { font-size: 2rem; }

  .fav-mono { font-size: 56px; display: inline-flex; align-items: baseline; line-height: 1; }
  .fav-mono-32 { font-size: 28px; display: inline-flex; align-items: baseline; line-height: 1; }
  .fav-mono-16 { font-size: 14px; line-height: 1; display: inline-flex; align-items: baseline; }

  /* Hero showcase */
  .hero-show {
    padding: var(--space-7) 0;
    background: linear-gradient(180deg, var(--bg) 0%, var(--bg-soft) 100%);
  }
  .wm-card {
    background: #FFFFFF;
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    margin-bottom: var(--space-6);
    box-shadow: var(--shadow-sm);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-6);
    align-items: center;
  }
  @media (max-width: 720px) {
    .wm-card { grid-template-columns: 1fr; }
  }
  .wm-stage {
    background: linear-gradient(135deg, var(--bg-soft) 0%, var(--accent-soft) 100%);
    border-radius: var(--radius-md);
    padding: var(--space-7);
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 240px;
  }
  .wm-meta h2 {
    font-size: clamp(1.5rem, 3vw, 2rem);
    margin-bottom: var(--space-1);
  }
  .wm-sub {
    color: var(--accent);
    font-weight: 700;
    margin-bottom: var(--space-3);
    letter-spacing: 0.02em;
  }
  .wm-desc {
    color: var(--ink);
    line-height: 1.6;
  }

  /* Contexts grid */
  .contexts {
    padding: var(--space-7) 0 var(--space-9);
    background: var(--bg);
    border-top: 1px solid var(--line);
  }
  .section-title {
    font-size: clamp(1.5rem, 3vw, 2rem);
    margin-bottom: var(--space-2);
    text-align: center;
  }
  .section-help {
    color: var(--muted);
    font-size: var(--text-sm);
    text-align: center;
    margin-bottom: var(--space-7);
    max-width: 60ch;
    margin-left: auto;
    margin-right: auto;
  }
  .ctx-block {
    margin-bottom: var(--space-8);
    padding-bottom: var(--space-7);
    border-bottom: 1px solid var(--line);
  }
  .ctx-block:last-child { border-bottom: none; }
  .ctx-title {
    font-size: 1.4rem;
    margin-bottom: var(--space-5);
    color: var(--primary);
  }
  .ctx-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: var(--space-4);
  }
  .ctx {
    background: var(--bg-soft);
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .ctx-label {
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .ctx-help {
    font-size: 11px;
    color: var(--muted);
    margin-top: 4px;
  }

  /* Mocks */
  .nav-mock {
    background: #FFFFFF;
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    padding: 12px 16px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
  }
  .nav-fake-links {
    display: flex;
    gap: 12px;
    font-size: var(--text-xs);
    color: var(--muted);
    align-items: center;
  }
  .cta-fake {
    background: var(--primary);
    color: #FFFFFF;
    padding: 6px 12px;
    border-radius: var(--radius-full);
    font-weight: 700;
  }
  .footer-mock {
    background: var(--primary-deep);
    border-radius: var(--radius-md);
    padding: 18px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
  }
  .footer-tag {
    color: var(--accent-soft);
    font-size: var(--text-xs);
    letter-spacing: 0.1em;
  }

  /* Favicon mocks */
  .fav-mock {
    background: var(--bg-soft);
    border: 1px solid var(--line);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto;
  }
  .fav-64 { width: 80px; height: 80px; padding: 8px; }
  .fav-32 { width: 40px; height: 40px; padding: 4px; border-radius: 6px; }
  .fav-16 { width: 24px; height: 24px; padding: 2px; border-radius: 4px; }

  /* Large mock */
  .large-mock {
    background: linear-gradient(135deg, var(--bg-soft) 0%, var(--accent-soft) 100%);
    border-radius: var(--radius-md);
    padding: var(--space-5);
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 240px;
  }

  /* Archive */
  .archive {
    padding: var(--space-7) 0;
    background: var(--bg);
  }
  .archive-drop {
    background: var(--bg-soft);
    border: 1px dashed var(--line);
    border-radius: var(--radius-md);
    padding: var(--space-4) var(--space-5);
  }
  .archive-drop summary {
    cursor: pointer;
    color: var(--muted);
    font-weight: 700;
    font-size: var(--text-sm);
    letter-spacing: 0.04em;
  }
  .archive-section { margin-top: var(--space-5); }
  .archive-section h4 {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--muted);
    font-weight: 700;
    margin-bottom: var(--space-3);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .archive-strip {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(80px, 1fr));
    gap: var(--space-3);
  }
  .archive-cell {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    padding: var(--space-3);
    background: #FFFFFF;
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
    opacity: 0.65;
  }
  .archive-cell .emb-32 { width: 32px; height: 32px; }
  .strip-id {
    font-size: 10px;
    color: var(--muted);
    letter-spacing: 0.1em;
    font-weight: 700;
  }

  /* Decision */
  .decision {
    background: var(--primary-deep);
    color: #FFFFFF;
    padding: var(--space-9) 0;
  }
  .decision h2 {
    color: #FFFFFF;
    font-size: clamp(1.5rem, 3vw, 2rem);
    margin-bottom: var(--space-5);
  }
  .decision ol {
    color: var(--accent-soft);
    line-height: 1.7;
    padding-left: 1.4em;
  }
  .decision code {
    background: rgba(255, 255, 255, 0.1);
    padding: 2px 8px;
    border-radius: 4px;
    color: var(--accent);
    font-size: 0.95em;
  }
  .hint {
    margin-top: var(--space-5);
    color: var(--accent);
    font-size: var(--text-sm);
    font-style: italic;
  }
</style>
