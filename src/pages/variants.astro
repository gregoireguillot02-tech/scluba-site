---
import Base from '../layouts/Base.astro';

const emblems = [
  {
    id: 'e1-course-view',
    title: 'E1 — Course View',
    subtitle: 'Vue plongeante sur le green',
    description: 'Un emblème qui se lit comme une vue aérienne sur un green : les nuances de vert simulent la profondeur du gazon, le cup forme un point focal sombre, et le drapeau sand traverse la composition en diagonale. Distinctif sans verser dans le cliché golf.',
    designNotes: '4 gradients radiaux superposés (fond + green + cup + glow), highlight diagonal sur le pole, fanion avec gradient sand multi-stops. Composition asymétrique qui guide l\'œil de bas-droite (cup) vers haut-gauche (drapeau).',
  },
  {
    id: 'e2-tee-ready',
    title: 'E2 — Tee Ready',
    subtitle: 'Adaptation directe Virage : pill + balle + tee',
    description: 'Reprend littéralement la structure du logo Virage (toggle "on" en pill horizontale + knob blanc à droite), mais réinterprété en golf : pill = ligne de fairway, balle blanche = golf ball avec anneau intérieur, petit tee sand qui dépasse en bas. L\'instant juste avant le swing — état "ready".',
    designNotes: 'Gradient linear sur la pill (bell-curve éclairé au centre), highlight top + ombre bottom pour 3D, balle avec gradient sphère + rim shadow + anneau dimples. Le plus Virage-faithful structurellement.',
  },
];

const minimalVariants = [
  { id: 'v1-classic', title: 'V1 Classic' },
  { id: 'v2-stroke', title: 'V2 Stroke' },
  { id: 'v3-floating', title: 'V3 Floating' },
  { id: 'v4-trajectory', title: 'V4 Trajectory' },
  { id: 'v5-pin', title: 'V5 Pin' },
];
---

<Base locale="fr">
  <section class="intro">
    <div class="container">
      <p class="eyebrow">Logo Klubba · Round 2 · Style emblème (Virage-faithful)</p>
      <h1>2 emblems poussés à comparer</h1>
      <p class="lead">
        Round 1 (5 picto minimaux plats) écarté — registre "icon system Linear", pas le bon ton pour Klubba.
        Round 2 ici : <strong>emblems</strong> avec container plein, multi-gradients radiaux, layers superposés,
        comme le logo Virage. Choisis E1 ou E2, ou dis-moi ce qui cloche pour un round 3.
      </p>
    </div>
  </section>

  <section class="emblems-hero">
    <div class="container">
      <div class="hero-grid">
        {emblems.map((e) => (
          <article class="hero-card" id={e.id}>
            <div class="hero-emblem">
              <img src={`/logos/emblems/${e.id}.svg`} alt={e.title} />
            </div>
            <div class="hero-meta">
              <h2>{e.title}</h2>
              <p class="hero-sub">{e.subtitle}</p>
              <p class="hero-desc">{e.description}</p>
              <details class="hero-notes">
                <summary>Notes design</summary>
                <p>{e.designNotes}</p>
              </details>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="contexts">
    <div class="container">
      <h2 class="section-title">Mise en contexte (les 2 emblems)</h2>
      <p class="section-help">Chaque emblème dans 6 situations réelles. Le wordmark <em>Klubba.</em> est rendu en texte Georgia comme dans l'actuel Nav/Footer.</p>

      {emblems.map((e) => (
        <div class="ctx-block">
          <h3 class="ctx-title">{e.title}</h3>

          <div class="ctx-grid">
            <div class="ctx ctx-nav">
              <span class="ctx-label">Nav (clair)</span>
              <div class="nav-mock">
                <div class="brand-row">
                  <img src={`/logos/emblems/${e.id}.svg`} alt="" class="emb emb-nav" />
                  <span class="wordmark">Klubba<span class="dot">.</span></span>
                </div>
                <div class="nav-fake-links">
                  <span>Tarifs</span><span>Comment</span><span class="cta-fake">Démo</span>
                </div>
              </div>
            </div>

            <div class="ctx ctx-footer">
              <span class="ctx-label">Footer (foncé)</span>
              <div class="footer-mock">
                <div class="brand-row">
                  <img src={`/logos/emblems/${e.id}.svg`} alt="" class="emb emb-footer" />
                  <span class="wordmark wordmark-light">Klubba<span class="dot">.</span></span>
                </div>
                <span class="footer-tag">klubba.golf</span>
              </div>
            </div>

            <div class="ctx ctx-favicon">
              <span class="ctx-label">Favicon 64px</span>
              <div class="fav-mock fav-64">
                <img src={`/logos/emblems/${e.id}.svg`} alt="" />
              </div>
            </div>

            <div class="ctx ctx-favicon">
              <span class="ctx-label">Favicon 32px</span>
              <div class="fav-mock fav-32">
                <img src={`/logos/emblems/${e.id}.svg`} alt="" />
              </div>
            </div>

            <div class="ctx ctx-favicon">
              <span class="ctx-label">Favicon 16px (réel onglet)</span>
              <div class="fav-mock fav-16">
                <img src={`/logos/emblems/${e.id}.svg`} alt="" />
              </div>
              <span class="ctx-help">↑ taille réelle</span>
            </div>

            <div class="ctx ctx-large">
              <span class="ctx-label">Large 240px (deck / app icon)</span>
              <div class="large-mock">
                <img src={`/logos/emblems/${e.id}.svg`} alt="" class="emb emb-xl" />
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="compare-direct">
    <div class="container">
      <h2 class="section-title">Côte à côte</h2>
      <p class="section-help">Les 2 emblems alignés à 4 tailles réelles.</p>

      <div class="compare-row">
        <h3>16px (favicon réel)</h3>
        <div class="strip strip-light">
          {emblems.map((e) => (
            <div class="strip-cell">
              <img src={`/logos/emblems/${e.id}.svg`} alt="" class="emb-16" />
              <span class="strip-id">{e.id.split('-')[0].toUpperCase()}</span>
            </div>
          ))}
        </div>
      </div>

      <div class="compare-row">
        <h3>32px</h3>
        <div class="strip strip-light">
          {emblems.map((e) => (
            <div class="strip-cell">
              <img src={`/logos/emblems/${e.id}.svg`} alt="" class="emb-32" />
              <span class="strip-id">{e.id.split('-')[0].toUpperCase()}</span>
            </div>
          ))}
        </div>
      </div>

      <div class="compare-row">
        <h3>80px</h3>
        <div class="strip strip-light">
          {emblems.map((e) => (
            <div class="strip-cell">
              <img src={`/logos/emblems/${e.id}.svg`} alt="" class="emb-80" />
              <span class="strip-id">{e.id.split('-')[0].toUpperCase()}</span>
            </div>
          ))}
        </div>
      </div>

      <div class="compare-row">
        <h3>200px (decks / hero)</h3>
        <div class="strip strip-light">
          {emblems.map((e) => (
            <div class="strip-cell">
              <img src={`/logos/emblems/${e.id}.svg`} alt="" class="emb-200" />
              <span class="strip-id">{e.id.split('-')[0].toUpperCase()}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="archive">
    <div class="container">
      <details class="archive-drop">
        <summary>Round 1 — 5 picto minimaux (rejetés, gardés en référence)</summary>
        <p class="archive-help">Style "icon system Linear/Vercel". Ne sont pas dans le bon registre pour Klubba.</p>
        <div class="archive-strip">
          {minimalVariants.map((v) => (
            <div class="archive-cell">
              <img src={`/logos/variants/${v.id}.svg`} alt={v.title} class="emb-32" />
              <span class="strip-id">{v.title}</span>
            </div>
          ))}
        </div>
      </details>
    </div>
  </section>

  <section class="decision">
    <div class="container">
      <h2>Ta décision</h2>
      <ol>
        <li>Choisis : <code>e1</code> (Course View) ou <code>e2</code> (Tee Ready)</li>
        <li>Optionnel : ce que tu veux ajuster (proportions, intensité gradients, position du fanion, taille du cup, couleurs)</li>
        <li>Si aucun ne te plaît : dis-moi pourquoi (trop chargé, pas assez "golf", couleurs, etc.) et je fais un round 3</li>
      </ol>
      <p class="hint">💡 Inspecte aussi à 16px dans le tab du navigateur — c'est l'épreuve du feu pour un emblème. Si ça reste lisible là, ça passe partout.</p>
    </div>
  </section>
</Base>

<style>
  .intro {
    padding: var(--space-9) 0 var(--space-6);
    text-align: center;
    background: var(--bg);
  }
  .eyebrow {
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: var(--space-3);
  }
  .intro h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    margin-bottom: var(--space-4);
  }
  .lead {
    font-size: var(--text-md);
    color: var(--ink);
    max-width: 70ch;
    margin: 0 auto;
    line-height: 1.55;
  }

  /* Hero showcase */
  .emblems-hero {
    padding: var(--space-7) 0;
    background: linear-gradient(180deg, var(--bg) 0%, #FAF9F6 100%);
  }
  .hero-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(360px, 1fr));
    gap: var(--space-6);
  }
  .hero-card {
    background: #FFFFFF;
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    box-shadow: var(--shadow-sm);
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }
  .hero-emblem {
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #FAF9F6 0%, #F0EDE5 100%);
    border-radius: var(--radius-md);
    padding: var(--space-7);
    min-height: 260px;
  }
  .hero-emblem img {
    width: 200px;
    height: 200px;
    filter: drop-shadow(0 12px 32px rgba(15, 42, 30, 0.18));
  }
  .hero-meta h2 {
    font-size: clamp(1.5rem, 3vw, 2rem);
    margin-bottom: var(--space-1);
  }
  .hero-sub {
    color: var(--accent);
    font-weight: 700;
    margin-bottom: var(--space-3);
    letter-spacing: 0.02em;
  }
  .hero-desc {
    color: var(--ink);
    font-size: var(--text-base);
    line-height: 1.6;
    margin-bottom: var(--space-3);
  }
  .hero-notes summary {
    cursor: pointer;
    color: var(--muted);
    font-size: var(--text-sm);
    font-weight: 700;
    letter-spacing: 0.04em;
  }
  .hero-notes p {
    margin-top: var(--space-3);
    color: var(--muted);
    font-size: var(--text-sm);
    line-height: 1.55;
  }

  /* Contexts grid */
  .contexts {
    padding: var(--space-7) 0 var(--space-9);
    background: var(--bg);
    border-top: 1px solid var(--line);
  }
  .section-title {
    font-size: clamp(1.5rem, 3vw, 2rem);
    margin-bottom: var(--space-2);
    text-align: center;
  }
  .section-help {
    color: var(--muted);
    font-size: var(--text-sm);
    text-align: center;
    margin-bottom: var(--space-7);
    max-width: 60ch;
    margin-left: auto;
    margin-right: auto;
  }
  .ctx-block {
    margin-bottom: var(--space-8);
    padding-bottom: var(--space-7);
    border-bottom: 1px solid var(--line);
  }
  .ctx-block:last-child { border-bottom: none; }
  .ctx-title {
    font-size: 1.4rem;
    margin-bottom: var(--space-5);
    color: var(--primary);
  }
  .ctx-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: var(--space-4);
  }
  .ctx {
    background: #FAF9F6;
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .ctx-label {
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .ctx-help {
    font-size: 11px;
    color: var(--muted);
    margin-top: 4px;
  }

  /* Nav mock */
  .nav-mock {
    background: #FFFFFF;
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    padding: 12px 16px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
  }
  .brand-row {
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }
  .emb { display: block; flex-shrink: 0; }
  .emb-nav { width: 32px; height: 32px; }
  .emb-footer { width: 40px; height: 40px; }
  .emb-xl { width: 240px; height: 240px; filter: drop-shadow(0 18px 40px rgba(15, 42, 30, 0.22)); }

  .wordmark {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--primary);
    letter-spacing: -0.02em;
    line-height: 1;
  }
  .wordmark .dot { color: var(--accent); }
  .wordmark-light { color: #FFFFFF; font-size: 1.5rem; }

  .nav-fake-links {
    display: flex;
    gap: 12px;
    font-size: var(--text-xs);
    color: var(--muted);
    align-items: center;
  }
  .cta-fake {
    background: var(--primary);
    color: #FFFFFF;
    padding: 6px 12px;
    border-radius: var(--radius-full);
    font-weight: 700;
  }

  /* Footer mock */
  .footer-mock {
    background: var(--primary-deep);
    border-radius: var(--radius-md);
    padding: 18px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
  }
  .footer-tag {
    color: var(--accent-soft);
    font-size: var(--text-xs);
    letter-spacing: 0.1em;
  }

  /* Favicon mocks - emblem already has its own bg so no green wrapper needed */
  .fav-mock {
    background: #F0EDE5;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto;
    padding: 6px;
  }
  .fav-64 { width: 64px; height: 64px; padding: 4px; }
  .fav-64 img { width: 56px; height: 56px; }
  .fav-32 { width: 32px; height: 32px; padding: 2px; border-radius: 6px; }
  .fav-32 img { width: 28px; height: 28px; }
  .fav-16 { width: 16px; height: 16px; padding: 1px; border-radius: 3px; }
  .fav-16 img { width: 14px; height: 14px; }

  /* Large mock */
  .large-mock {
    background: linear-gradient(135deg, #FAF9F6 0%, #EBE7DC 100%);
    border-radius: var(--radius-md);
    padding: var(--space-5);
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 280px;
  }

  /* Compare strips */
  .compare-direct {
    background: #FAF9F6;
    padding: var(--space-7) 0;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }
  .compare-row {
    margin-bottom: var(--space-6);
  }
  .compare-row h3 {
    font-size: var(--text-sm);
    color: var(--muted);
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: var(--space-3);
    font-family: var(--font-sans);
  }
  .strip {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-4);
    background: #FFFFFF;
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    padding: var(--space-5);
    align-items: center;
    justify-items: center;
  }
  .strip-cell {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
  }
  .strip-id {
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 0.1em;
    font-weight: 700;
  }
  .emb-16 { width: 16px; height: 16px; }
  .emb-32 { width: 32px; height: 32px; }
  .emb-80 { width: 80px; height: 80px; }
  .emb-200 { width: 200px; height: 200px; filter: drop-shadow(0 12px 32px rgba(15, 42, 30, 0.18)); }

  /* Archive */
  .archive {
    padding: var(--space-7) 0;
    background: var(--bg);
  }
  .archive-drop {
    background: #FAF9F6;
    border: 1px dashed var(--line);
    border-radius: var(--radius-md);
    padding: var(--space-4) var(--space-5);
  }
  .archive-drop summary {
    cursor: pointer;
    color: var(--muted);
    font-weight: 700;
    font-size: var(--text-sm);
    letter-spacing: 0.04em;
  }
  .archive-help {
    color: var(--muted);
    font-size: var(--text-sm);
    margin-top: var(--space-3);
    margin-bottom: var(--space-4);
  }
  .archive-strip {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
    gap: var(--space-3);
  }
  .archive-cell {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    padding: var(--space-3);
    background: #FFFFFF;
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
    opacity: 0.7;
  }

  /* Decision */
  .decision {
    background: var(--primary-deep);
    color: #FFFFFF;
    padding: var(--space-9) 0;
  }
  .decision h2 {
    color: #FFFFFF;
    font-size: clamp(1.5rem, 3vw, 2rem);
    margin-bottom: var(--space-5);
  }
  .decision ol {
    color: var(--accent-soft);
    line-height: 1.7;
    padding-left: 1.4em;
  }
  .decision code {
    background: rgba(255, 255, 255, 0.1);
    padding: 2px 8px;
    border-radius: 4px;
    color: var(--accent);
    font-size: 0.95em;
  }
  .hint {
    margin-top: var(--space-5);
    color: var(--accent);
    font-size: var(--text-sm);
    font-style: italic;
  }

  @media (max-width: 720px) {
    .hero-grid { grid-template-columns: 1fr; }
    .nav-mock { flex-direction: column; align-items: flex-start; }
    .strip { grid-template-columns: 1fr 1fr; }
  }
</style>
