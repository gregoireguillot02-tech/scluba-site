---
export const prerender = false;

import '../../styles/tokens.css';
import '../../styles/global.css';
import { serviceClient } from '../../lib/supabase';
import type { Club } from '../../lib/clubs-types';
import { totalPar } from '../../lib/clubs-types';

const { slug } = Astro.params;
const sb = serviceClient();

const { data: club } = await sb
  .from('clubs')
  .select('*')
  .eq('slug', slug)
  .maybeSingle();

if (!club) {
  return new Response('Club introuvable', { status: 404 });
}

const c = club as Club;
const par = totalPar(c.course_data);
const heroColor = c.primary_color ?? '#1B4332';
---

<!doctype html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title>{c.name} — Démarrer une partie · Scluba</title>
  <meta name="description" content={`Scorecard digitale pour ${c.name}. Démarrez une partie en quelques secondes.`} />
  <meta name="robots" content="noindex, nofollow" />
  <meta name="theme-color" content={heroColor} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <style define:vars={{ heroColor }}>
    body {
      background: #FAF7EE;
      min-height: 100dvh;
      overflow-x: hidden;
    }
  </style>
</head>
<body>
  <main class="club-page">
    <section class="hero" style={`background: linear-gradient(180deg, ${heroColor} 0%, ${heroColor}dd 100%);`}>
      {c.photo_url && (
        <img class="hero-photo" src={c.photo_url} alt="" loading="eager" />
      )}
      <div class="hero-overlay" aria-hidden="true"></div>
      <div class="hero-content">
        {c.logo_url && <img class="hero-logo" src={c.logo_url} alt="" />}
        <p class="hero-eyebrow">Bienvenue au</p>
        <h1 class="hero-title">{c.name}</h1>
        {c.city && <p class="hero-city">{c.city}</p>}
      </div>
    </section>

    <section class="cta-block">
      <p class="cta-eyebrow">Scorecard digitale</p>
      <h2 class="cta-title">Démarrer une partie</h2>
      <p class="cta-lead">
        Saisis ton prénom et c'est parti. {c.course_data.holes.length} trous · Par {par}.
      </p>

      <form method="POST" action="/api/rounds" class="start-form">
        <input type="hidden" name="slug" value={c.slug} />
        <label class="start-label">
          Ton prénom
          <input
            class="start-input"
            type="text"
            name="display_name"
            placeholder="Ex. Antoine"
            maxlength="40"
            required
            autofocus
          />
        </label>
        <button type="submit" class="start-btn">
          C'est parti
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14"/>
            <path d="m12 5 7 7-7 7"/>
          </svg>
        </button>
      </form>

      <p class="cta-hint">Pas besoin de compte. Tu pourras partager ta carte à la fin.</p>
    </section>

    <footer class="club-footer">
      <span>FAIT À</span>
      <strong>Scluba<em>.</em></strong>
    </footer>
  </main>

  <style>
    .club-page {
      max-width: 480px;
      margin: 0 auto;
      min-height: 100dvh;
      display: flex;
      flex-direction: column;
      background: linear-gradient(180deg, #FAF7EE 0%, #F4F8F5 100%);
      box-shadow: 0 32px 80px rgba(27, 67, 50, 0.18);
    }

    .hero {
      position: relative;
      min-height: clamp(220px, 38vh, 320px);
      display: flex;
      align-items: flex-end;
      justify-content: center;
      padding: var(--space-7) var(--space-5);
      color: #FAF7EE;
      overflow: hidden;
    }
    .hero-photo {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center 60%;
      z-index: 0;
    }
    .hero-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(180deg, transparent 30%, rgba(0,0,0,0.45) 100%);
      z-index: 1;
    }
    .hero-content {
      position: relative;
      z-index: 2;
      text-align: center;
    }
    .hero-logo {
      display: block;
      margin: 0 auto var(--space-3);
      width: 72px;
      height: 72px;
      filter: drop-shadow(0 4px 16px rgba(0, 0, 0, 0.3));
    }
    .hero-eyebrow {
      font-size: var(--text-xs);
      letter-spacing: 0.18em;
      text-transform: uppercase;
      opacity: 0.85;
      margin: 0;
    }
    .hero-title {
      font-family: var(--font-serif);
      font-size: clamp(1.75rem, 6vw, 2.5rem);
      font-weight: 700;
      letter-spacing: -0.01em;
      margin: 4px 0 0;
      line-height: 1.1;
    }
    .hero-city {
      margin: var(--space-2) 0 0;
      font-size: var(--text-sm);
      opacity: 0.8;
    }

    .cta-block {
      flex: 1;
      padding: var(--space-7) var(--space-5);
      text-align: center;
    }
    .cta-eyebrow {
      font-size: var(--text-xs);
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--accent);
      margin: 0 0 var(--space-2);
    }
    .cta-title {
      font-family: var(--font-serif);
      font-size: clamp(1.5rem, 5vw, 2rem);
      color: var(--primary);
      margin: 0 0 var(--space-3);
      line-height: 1.15;
    }
    .cta-lead {
      color: var(--ink-soft);
      font-size: var(--text-sm);
      margin: 0 0 var(--space-6);
      line-height: 1.5;
    }

    .start-form {
      display: flex;
      flex-direction: column;
      gap: var(--space-4);
      max-width: 360px;
      margin: 0 auto;
    }
    .start-label {
      display: block;
      text-align: left;
      font-size: var(--text-xs);
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--accent);
    }
    .start-input {
      width: 100%;
      margin-top: 6px;
      padding: 14px 16px;
      border-radius: 12px;
      border: 1px solid var(--line);
      background: #fff;
      font-size: 16px;
      font-family: var(--font-sans);
      color: var(--ink);
    }
    .start-input:focus {
      outline: none;
      border-color: var(--primary-soft);
      box-shadow: 0 0 0 3px rgba(45, 106, 79, 0.15);
    }
    .start-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      padding: 16px 24px;
      border-radius: 12px;
      border: none;
      background: var(--heroColor);
      color: #FAF7EE;
      font-size: 16px;
      font-weight: 600;
      cursor: pointer;
      box-shadow: 0 8px 24px rgba(27, 67, 50, 0.18);
      transition: transform 0.1s, box-shadow 0.15s;
    }
    .start-btn:hover {
      box-shadow: 0 12px 32px rgba(27, 67, 50, 0.24);
    }
    .start-btn:active {
      transform: translateY(1px);
    }

    .cta-hint {
      margin-top: var(--space-5);
      color: var(--muted);
      font-size: 13px;
    }

    .club-footer {
      text-align: center;
      padding: var(--space-5) 0 var(--space-7);
      font-size: 11px;
      color: var(--muted);
      letter-spacing: 0.18em;
      text-transform: uppercase;
    }
    .club-footer strong {
      font-family: var(--font-serif);
      color: var(--primary);
      font-size: var(--text-md);
      font-weight: 700;
      margin-left: 6px;
    }
    .club-footer em {
      font-style: normal;
      color: var(--accent);
    }
  </style>
</body>
</html>
