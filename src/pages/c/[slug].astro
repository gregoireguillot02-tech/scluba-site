---
export const prerender = false;

import '../../styles/tokens.css';
import '../../styles/global.css';
import { serviceClient } from '../../lib/supabase';
import type { Club } from '../../lib/clubs-types';
import { totalPar } from '../../lib/clubs-types';

const { slug } = Astro.params;
const sb = serviceClient();

const { data: club } = await sb
  .from('clubs')
  .select('*')
  .eq('slug', slug)
  .maybeSingle();

if (!club) {
  return new Response('Club introuvable', { status: 404 });
}

const c = club as Club;
const par = totalPar(c.course_data);
const holeCount = c.course_data.holes.length;
const clubColor = c.primary_color ?? '#1B4332';
---

<!doctype html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title>{c.name} — Démarrer une partie · Scluba</title>
  <meta name="description" content={`Scorecard digitale pour ${c.name}. Démarrez une partie en quelques secondes.`} />
  <meta name="robots" content="noindex, nofollow" />
  <meta name="theme-color" content="#FAF7EE" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>
  <main class="club-page">
    <header class="masthead">
      {c.photo_url ? (
        <figure class="photo-card">
          <img src={c.photo_url} alt="" loading="eager" decoding="async" />
          <span class="photo-card-fade" aria-hidden="true"></span>
        </figure>
      ) : (
        <div class="photo-card photo-card-placeholder" aria-hidden="true"></div>
      )}

      {c.logo_url && (
        <div class="logo-frame">
          <img src={c.logo_url} alt="" />
        </div>
      )}

      {c.city && <p class="masthead-eyebrow">{c.city}</p>}

      <div class="title-rail" aria-hidden="true"></div>
      <h1 class="masthead-title">{c.name}</h1>
      <div class="title-rail" aria-hidden="true"></div>
    </header>

    <ul class="meta-strip" aria-label="Détails du parcours">
      <li>
        <span class="meta-l">Trous</span>
        <span class="meta-v">{holeCount}</span>
      </li>
      <li>
        <span class="meta-l">Par</span>
        <span class="meta-v">{par}</span>
      </li>
      <li>
        <span class="meta-l">Départ</span>
        <span class="meta-v">Libre</span>
      </li>
    </ul>

    <section class="cta-block" aria-labelledby="cta-title">
      <p class="cta-eyebrow">Scorecard digitale</p>
      <h2 id="cta-title" class="cta-title">Démarrer une partie</h2>

      <form method="POST" action="/api/rounds" class="start-form">
        <input type="hidden" name="slug" value={c.slug} />
        <label class="start-label">
          <span>Ton prénom</span>
          <input
            class="start-input"
            type="text"
            name="display_name"
            placeholder="Antoine"
            maxlength="40"
            required
            autocomplete="given-name"
            autofocus
          />
        </label>
        <button type="submit" class="start-btn">
          C'est parti
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
          </svg>
        </button>
      </form>

      <p class="cta-hint">Pas besoin de compte. Tu pourras partager ta carte à la fin.</p>
    </section>

    <footer class="colophon">
      <span class="colophon-rail" aria-hidden="true"></span>
      <span class="colophon-text">
        <span>carte by</span>
        <strong>SCLUBA</strong>
        <span class="colophon-dot" aria-hidden="true"></span>
      </span>
      <span class="colophon-rail" aria-hidden="true"></span>
    </footer>
  </main>

  <style define:vars={{ clubColor }}>
    body {
      background: #FAF7EE;
      min-height: 100dvh;
      overflow-x: hidden;
      margin: 0;
    }

    .club-page {
      max-width: 480px;
      margin: 0 auto;
      min-height: 100dvh;
      display: flex;
      flex-direction: column;
      padding: 0 var(--space-4);
      gap: 0;
    }

    /* === Masthead — photo card + logo overlap + title === */
    .masthead {
      text-align: center;
      padding-top: var(--space-5);
      padding-bottom: var(--space-5);
    }

    .photo-card {
      position: relative;
      margin: 0;
      aspect-ratio: 16 / 9;
      max-height: 240px;
      width: 100%;
      border-radius: 16px;
      overflow: hidden;
      background: #E8E0CB;
      box-shadow:
        0 1px 2px rgba(15, 42, 30, 0.06),
        0 12px 32px rgba(27, 67, 50, 0.10);
    }
    .photo-card img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center 55%;
      display: block;
    }
    .photo-card-fade {
      position: absolute;
      inset: auto 0 0 0;
      height: 40%;
      background: linear-gradient(180deg, transparent, rgba(15, 42, 30, 0.35));
      pointer-events: none;
    }
    .photo-card-placeholder {
      background: linear-gradient(135deg, #1B4332 0%, #2D6A4F 100%);
    }

    .logo-frame {
      position: relative;
      z-index: 2;
      margin: -36px auto 0;
      width: 76px;
      height: 76px;
      border-radius: 50%;
      background: #FAF7EE;
      border: 2px solid var(--accent);
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow:
        0 1px 2px rgba(15, 42, 30, 0.08),
        0 8px 20px rgba(27, 67, 50, 0.10);
      padding: 10px;
    }
    .logo-frame img {
      width: 100%;
      height: 100%;
      object-fit: contain;
      filter: none;
    }

    .masthead-eyebrow {
      margin: var(--space-4) 0 var(--space-3);
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--accent);
    }

    .title-rail {
      width: 64px;
      height: 1px;
      margin: 0 auto;
      background: var(--accent);
      opacity: 0.55;
    }

    .masthead-title {
      margin: var(--space-3) auto;
      font-family: var(--font-serif);
      font-weight: 700;
      font-size: clamp(1.6rem, 5.5vw, 2.1rem);
      line-height: 1.15;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      color: var(--clubColor);
      max-width: 22ch;
    }

    /* === Meta strip — 3 stats parcours === */
    .meta-strip {
      list-style: none;
      margin: 0 0 var(--space-6);
      padding: var(--space-3) var(--space-4);
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-3);
      background: rgba(212, 165, 116, 0.10);
      border-top: 1px solid rgba(212, 165, 116, 0.4);
      border-bottom: 1px solid rgba(212, 165, 116, 0.4);
    }
    .meta-strip li {
      display: flex;
      flex-direction: column;
      gap: 4px;
      text-align: center;
    }
    .meta-l {
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 0.2em;
      color: var(--accent);
      text-transform: uppercase;
    }
    .meta-v {
      font-family: var(--font-serif);
      font-size: var(--text-md);
      color: var(--clubColor);
      font-weight: 700;
      font-variant-numeric: tabular-nums;
    }

    /* === CTA block === */
    .cta-block {
      flex: 1;
      padding: 0 var(--space-2) var(--space-7);
      text-align: center;
    }
    .cta-eyebrow {
      margin: 0 0 var(--space-2);
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--accent);
    }
    .cta-title {
      margin: 0 0 var(--space-6);
      font-family: var(--font-serif);
      font-size: clamp(1.5rem, 5vw, 1.85rem);
      color: var(--clubColor);
      line-height: 1.15;
      letter-spacing: -0.005em;
    }

    .start-form {
      display: flex;
      flex-direction: column;
      gap: var(--space-4);
      max-width: 340px;
      margin: 0 auto;
    }
    .start-label {
      display: block;
      text-align: left;
    }
    .start-label > span {
      display: block;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 8px;
    }
    .start-input {
      width: 100%;
      padding: 14px 16px;
      border-radius: 12px;
      border: 1px solid var(--line);
      background: #fff;
      font-size: 16px;
      font-family: var(--font-sans);
      color: var(--ink);
    }
    .start-input::placeholder { color: var(--muted-soft); }
    .start-input:focus {
      outline: none;
      border-color: var(--primary-soft);
      box-shadow: 0 0 0 3px rgba(45, 106, 79, 0.15);
    }
    .start-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      min-height: 52px;
      padding: 14px 24px;
      border-radius: 12px;
      border: none;
      background: var(--clubColor);
      color: #FAF7EE;
      font-size: 16px;
      font-weight: 600;
      letter-spacing: 0.01em;
      cursor: pointer;
      box-shadow:
        0 1px 2px rgba(15, 42, 30, 0.08),
        0 8px 20px rgba(27, 67, 50, 0.18);
      transition: transform 0.12s ease-out, box-shadow 0.15s, filter 0.15s;
    }
    .start-btn:hover {
      filter: brightness(0.92);
      box-shadow:
        0 1px 2px rgba(15, 42, 30, 0.10),
        0 12px 32px rgba(27, 67, 50, 0.22);
    }
    .start-btn:active { transform: translateY(1px); }
    .start-btn:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 3px;
    }

    .cta-hint {
      margin: var(--space-5) 0 0;
      color: var(--muted);
      font-size: 13px;
    }

    /* === Colophon === */
    .colophon {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: var(--space-3);
      padding: var(--space-6) 0 var(--space-7);
      max-width: 320px;
      margin: 0 auto;
    }
    .colophon-rail {
      flex: 1;
      height: 1px;
      background: var(--accent);
      opacity: 0.45;
    }
    .colophon-text {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-family: var(--font-serif);
      font-size: 12px;
      letter-spacing: 0.04em;
      color: var(--muted);
      white-space: nowrap;
    }
    .colophon-text strong {
      font-family: var(--font-serif);
      font-weight: 700;
      color: var(--clubColor);
      letter-spacing: 0.08em;
    }
    .colophon-dot {
      width: 6px;
      height: 6px;
      background: var(--accent);
      border-radius: 1px;
    }

    /* Reduced motion support */
    @media (prefers-reduced-motion: reduce) {
      .start-btn { transition: none; }
    }
  </style>
</body>
</html>
