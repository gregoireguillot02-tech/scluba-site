---
export const prerender = false;

import OpsLayout from '../../../../layouts/OpsLayout.astro';
import { serviceClient } from '../../../../lib/supabase';
import { qrSvg, clubPageUrl, SCLUBA_GREEN } from '../../../../lib/qr';
import type { Club } from '../../../../lib/clubs-types';

const { id } = Astro.params;
const sb = serviceClient();

const { data: club } = await sb.from('clubs').select('*').eq('id', id).maybeSingle();
if (!club) {
  return Astro.redirect('/ops/clubs', 302);
}
const c = club as Club;

const origin = Astro.url.origin;
const pageUrl = clubPageUrl(c.slug, origin);

// Forest #1B4332 forcé pour cohérence avec la scorecard digitale.
const qrColor = SCLUBA_GREEN;
const cardQr = await qrSvg(pageUrl, { errorCorrectionLevel: 'H', dark: qrColor, margin: 1 });
const stickerQr = await qrSvg(pageUrl, { errorCorrectionLevel: 'M', dark: qrColor, margin: 1 });
const tees = Array.from({ length: 18 }, (_, i) => i + 1);
const cardSlots = [0];
---

<OpsLayout title={`Kit imprimable — ${c.name}`} active="clubs">
  <div class="ops-page-header no-print">
    <div>
      <a href={`/ops/clubs/${c.id}/edit`} class="back-link">← Édition club</a>
      <h1 class="ops-page-title">Kit imprimable</h1>
      <p class="ops-page-subtitle">{c.name} · slug <code>{c.slug}</code></p>
    </div>
    <div class="header-actions">
      <button id="downloadPdfBtn" type="button" class="ops-btn ops-btn-primary" data-slug={c.slug}>
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
          <polyline points="7 10 12 15 17 10"/>
          <line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
        <span class="btn-label">Télécharger PDF</span>
      </button>
    </div>
  </div>

  <div class="ops-card no-print intro-card">
    <h2>Comment ça marche</h2>
    <p>Clique sur <strong>"Télécharger PDF"</strong> en haut à droite. Le PDF est généré directement dans ton navigateur (pas de dialog d'impression) et téléchargé en quelques secondes. Tu n'as plus qu'à l'ouvrir dans Aperçu et imprimer depuis là.</p>
    <p>Le kit fait 3 pages A4 : carte QR centrée · 18 stickers · mémo équipe.</p>
    <p class="intro-hint">L'URL pointe vers <code>{pageUrl}</code>. Si tu changes le slug ensuite, regénère ce kit.</p>
  </div>

  <!-- ========================================================== -->
  <!-- SHEET 1 — 4 cartes QR A6 (template éditorial dark)         -->
  <!-- ========================================================== -->
  <section class="print-sheet cards-sheet">
    <div class="cards-grid">
      {cardSlots.map(() => (
        <article class="qr-card">
          <div class="qr-card-inner">

            <!-- HERO CLUB : logo + nom + tagline -->
            <header class="qr-card-club-hero">
              {c.logo_url && <img class="club-hero-logo" src={c.logo_url} alt="" />}
              <h2 class="club-hero-name">{c.name}</h2>
              <div class="qr-card-tagline">
                <span class="tagline-rule" aria-hidden="true"></span>
                <span class="tagline-text">Carte de score digitale</span>
                <span class="tagline-rule" aria-hidden="true"></span>
              </div>
            </header>

            <!-- QR avec corner brackets honey -->
            <div class="qr-card-qr-frame">
              <span class="bracket bracket-tl" aria-hidden="true"></span>
              <span class="bracket bracket-tr" aria-hidden="true"></span>
              <span class="bracket bracket-bl" aria-hidden="true"></span>
              <span class="bracket bracket-br" aria-hidden="true"></span>
              <div class="qr-card-qr" set:html={cardQr}></div>
            </div>

            <!-- STEPS : 3 icônes en cercle honey -->
            <ol class="qr-card-steps">
              <li>
                <span class="step-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="7" y="2" width="10" height="20" rx="2" />
                    <line x1="11" y1="18" x2="13" y2="18" />
                  </svg>
                </span>
                <span class="step-label">1. Scannez</span>
                <span class="step-desc">le QR avec votre téléphone</span>
              </li>
              <li>
                <span class="step-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="6" y1="3" x2="6" y2="21" />
                    <path d="M6 4l11 3-11 3" fill="currentColor" />
                    <circle cx="6" cy="21" r="0.8" fill="currentColor" stroke="none" />
                  </svg>
                </span>
                <span class="step-label">2. Jouez</span>
                <span class="step-desc">votre carte de score digitale</span>
              </li>
              <li>
                <span class="step-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="9" cy="9" r="3" />
                    <circle cx="16" cy="10" r="2.2" />
                    <path d="M3 19c0-3 3-5 6-5s6 2 6 5" />
                    <path d="M14 18c.5-2 2.5-3.5 4.5-3.5S22 16 22 18" />
                  </svg>
                </span>
                <span class="step-label">3. Partagez</span>
                <span class="step-desc">votre score, défiez vos amis</span>
              </li>
            </ol>

            <!-- FOOTER : "by Scluba" + balle (attribution discrète) -->
            <footer class="qr-card-footer">
              <span class="by-label">by</span>
              <span class="scluba-mark">
                <span class="scluba-wordmark">Scluba</span>
                <span class="scluba-ball" aria-hidden="true">
                  <svg viewBox="0 0 32 32">
                    <defs>
                      <radialGradient id="ball-gradient" cx="32%" cy="28%" r="78%">
                        <stop offset="0%" stop-color="#FFFFFF" />
                        <stop offset="55%" stop-color="#E8E8E8" />
                        <stop offset="100%" stop-color="#909090" />
                      </radialGradient>
                    </defs>
                    <circle cx="16" cy="16" r="13.8" fill="url(#ball-gradient)" />
                    <g fill="#000" opacity="0.13">
                      <circle cx="11" cy="10" r="0.8" /><circle cx="16" cy="10" r="0.8" /><circle cx="21" cy="10" r="0.8" />
                      <circle cx="11" cy="16" r="0.8" /><circle cx="16" cy="16" r="0.8" /><circle cx="21" cy="16" r="0.8" />
                      <circle cx="11" cy="22" r="0.8" /><circle cx="16" cy="22" r="0.8" /><circle cx="21" cy="22" r="0.8" />
                    </g>
                    <ellipse cx="11.5" cy="9" rx="3.6" ry="2.2" fill="#FFFFFF" opacity="0.6" />
                  </svg>
                </span>
              </span>
            </footer>

          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- ========================================================== -->
  <!-- SHEET 2 — Stickers QR (1 par tee)                           -->
  <!-- ========================================================== -->
  <section class="print-sheet stickers-sheet">
    <header class="stickers-head">
      <p class="stickers-eyebrow">Stickers QR · 1 par tee</p>
      <h2 class="stickers-title">{c.name}</h2>
      <p class="stickers-sub">Découper le long des pointillés et coller sur le piquet ou la borne du départ.</p>
    </header>
    <div class="stickers-grid">
      {tees.map((n) => (
        <div class="sticker">
          <div class="sticker-qr" set:html={stickerQr}></div>
          <div class="sticker-text">
            <span class="sticker-tee">Tee {n}</span>
            <span class="sticker-club">{c.name}</span>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ========================================================== -->
  <!-- SHEET 3 — Mémo équipe d'accueil                             -->
  <!-- ========================================================== -->
  <section class="print-sheet memo-sheet">
    <div class="memo-inner">
      <header class="memo-head">
        <p class="memo-eyebrow">Mémo · Équipe d'accueil</p>
        <h2 class="memo-title">Carte de score digitale Scluba</h2>
      </header>

      <aside class="memo-pilot-callout">
        <p class="pilot-label">Phase de test pilote</p>
        <p class="pilot-body">
          Nous testons cette solution avec votre club. <strong>Notez toutes les frustrations, retours, bugs et suggestions</strong> — des joueurs comme de l'équipe d'accueil. C'est ce qui nous permet d'améliorer Scluba avant le lancement officiel. Transmettez-les à <strong>team@scluba.com</strong> (un screenshot aide énormément).
        </p>
      </aside>

      <section class="memo-section">
        <h3>Quand un golfeur arrive au comptoir</h3>
        <ol>
          <li>Indiquez le QR à l'accueil.</li>
          <li>Précisez : "<em>Pas besoin de compte. Tapez votre prénom et jouez.</em>"</li>
          <li><strong>Partie à plusieurs (le plus simple)</strong> : une seule personne scanne le QR et saisit les prénoms de tous les joueurs. Depuis l'écran de la partie, le créateur affiche un QR partagé (ou un code à 6 chiffres) ; les autres le scannent ou le saisissent depuis leur écran d'accueil pour rejoindre. Une fois connectés, les invités peuvent <strong>suivre le classement en direct et récupérer leur propre carte à la fin</strong> (et modifier leur score si besoin).</li>
          <li><strong>Sinon</strong> : chacun peut faire sa propre partie de son côté et saisir lui-même ses scores.</li>
        </ol>
      </section>

      <section class="memo-section">
        <h3>Questions fréquentes</h3>
        <dl>
          <dt>« C'est gratuit pour moi ? »</dt>
          <dd>Oui, totalement. Le club paie l'abonnement, le golfeur ne paie rien.</dd>

          <dt>« Mes données sont stockées où ? »</dt>
          <dd>Sur des serveurs en Europe. Aucune donnée personnelle n'est demandée — juste un prénom.</dd>

          <dt>« Comment je récupère ma carte à la fin ? »</dt>
          <dd>Bouton "Partager" en fin de partie : SMS, email, WhatsApp, ou copier le lien.</dd>
        </dl>
      </section>

      <section class="memo-section">
        <h3>En cas de pépin</h3>
        <ul>
          <li><strong>Page fermée par mégarde</strong> : scannez le QR au début du trou suivant, cliquez sur "Reprendre la partie" et retapez votre prénom — la carte est récupérée à l'identique.</li>
          <li><strong>QR illisible</strong> : URL à taper manuellement = <code>{pageUrl.replace(/^https?:\/\//, '')}</code></li>
          <li><strong>Bug bloquant</strong> : prendre un screenshot + envoyer à <strong>team@scluba.com</strong>.</li>
        </ul>
      </section>

      <section class="memo-section">
        <h3>En cours de déploiement</h3>
        <ul>
          <li><strong>Timer de partie</strong> — chronomètre intégré pour suivre le rythme de jeu (utile au starter pour repérer les parties qui ralentissent).</li>
          <li><strong>Carnet de parcours</strong> — distances, plans des trous et conseils de jeu accessibles directement depuis le téléphone du joueur.</li>
          <li><strong>Avis sur le golf</strong> — en fin de partie, le joueur note son expérience (accueil, parcours, restauration). Retours agrégés transmis au club.</li>
          <li><strong>Infos terrain pour le jardinier</strong> — les joueurs peuvent signaler l'état des greens, fairways, bunkers, etc. Remontées directement à l'équipe d'entretien.</li>
        </ul>
      </section>

      <footer class="memo-footer">
        <span>SCLUBA</span>
        <span class="dot">·</span>
        <span>{pageUrl.replace(/^https?:\/\//, '')}</span>
        <span class="dot">·</span>
        <span>team@scluba.com</span>
      </footer>
    </div>
  </section>

  <!-- PDF généré client-side via html2canvas + jsPDF — chaque sheet captureé en place -->
  <script>
    import html2canvas from 'html2canvas';
    import { jsPDF } from 'jspdf';

    document.addEventListener('DOMContentLoaded', () => {
      const btn = document.getElementById('downloadPdfBtn') as HTMLButtonElement | null;
      if (!btn) return;
      const slug = btn.dataset.slug || 'kit';

      btn.addEventListener('click', async () => {
        const sheets = Array.from(document.querySelectorAll<HTMLElement>('.print-sheet'));
        if (!sheets.length) return;
        const label = (btn.querySelector('.btn-label') as HTMLElement | null) || btn;
        const original = label.textContent;
        label.textContent = 'Génération…';
        btn.disabled = true;

        try {
          const pdf = new jsPDF({ unit: 'cm', format: 'a4', orientation: 'portrait' });

          for (let i = 0; i < sheets.length; i++) {
            const sheet = sheets[i];
            const canvas = await html2canvas(sheet, {
              scale: 2,
              useCORS: true,
              allowTaint: true,
              backgroundColor: '#ffffff',
              logging: false,
            });
            const imgData = canvas.toDataURL('image/jpeg', 0.95);
            if (i > 0) pdf.addPage();
            // 21 × 29.7 cm = A4 exact, bord à bord
            pdf.addImage(imgData, 'JPEG', 0, 0, 21, 29.7);
          }

          pdf.save(`scluba-kit-${slug}.pdf`);
        } catch (err) {
          console.error('PDF generation failed:', err);
          alert('Erreur lors de la génération du PDF. Détails dans la console.');
        } finally {
          label.textContent = original;
          btn.disabled = false;
        }
      });
    });
  </script>
</OpsLayout>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@600;700&family=Bodoni+Moda:wght@700;800&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@500&display=swap');

  /* === Screen-only chrome (hidden on print) === */
  .intro-card { margin-bottom: 24px; }
  .intro-list { margin: 8px 0 0 24px; padding: 0; }
  .intro-list li { margin: 6px 0; }
  .intro-hint { margin-top: 12px; color: var(--muted); font-size: 13px; }
  .print-settings {
    margin: 10px 0 16px;
    padding: 12px 16px;
    background: rgba(212, 165, 116, 0.10);
    border-left: 3px solid #D4A574;
    border-radius: 4px;
    list-style: none;
  }
  .print-settings li {
    margin: 6px 0;
    font-size: 14px;
    line-height: 1.45;
  }
  .print-settings code {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    background: rgba(27, 67, 50, 0.08);
    padding: 1px 6px;
    border-radius: 3px;
    font-size: 13px;
    color: #1B4332;
  }
  .intro-hint code {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    background: var(--line-soft);
    padding: 1px 6px;
    border-radius: 4px;
    font-size: 12px;
  }
  .back-link { color: var(--muted); font-size: 13px; text-decoration: none; }
  .back-link:hover { color: var(--primary); }
  .header-actions { display: inline-flex; align-items: center; gap: 8px; flex-wrap: wrap; justify-content: flex-end; }

  /* === Sheets — design tokens === */
  .print-sheet {
    --forest:        #1B4332;
    --forest-deep:   #0A1F14;
    --honey:         #D4A574;
    --cream:         #F5E6CF;
    --muted:         #6B7280;
    --ink:           #1A1A1A;
    --line:          #E5E7EB;
    --grid-line:     rgba(27, 67, 50, 0.10);
    --grid-cell:     28px;
    --cut-line:      rgba(27, 67, 50, 0.30);

    color: #1A1A1A;
    background: #fff;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    margin: 24px auto;
    max-width: 21cm;
    border-radius: 8px;
    overflow: hidden;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
  }

  /* ==========================================================
     SHEET 1 — 4 cartes A6 éditoriales dark mode
     ========================================================== */
  .cards-sheet {
    aspect-ratio: 21 / 29.7;
    padding: 0;
    background: #fff;
  }
  .cards-grid {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .qr-card {
    position: relative;
    width: 10.5cm;
    height: 14.8cm;
    box-sizing: border-box;
    border: 1px dashed var(--cut-line);
    overflow: hidden;
    background:
      linear-gradient(180deg, rgba(10, 31, 20, 0.92) 0%, rgba(10, 31, 20, 0.85) 50%, rgba(10, 31, 20, 0.95) 100%),
      url('/photos/golf-du-soleil.jpg') center/cover no-repeat,
      var(--forest-deep);
    color: #FFFFFF;
  }
  .qr-card-inner {
    position: relative;
    height: 100%;
    padding: 0.85cm 0.7cm;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    align-items: center;
    text-align: center;
  }
  .qr-card-inner::before {
    content: '';
    position: absolute;
    inset: 0.25cm;
    border: 0.8px solid rgba(212, 165, 116, 0.45);
    pointer-events: none;
  }

  /* === HERO CLUB === */
  .qr-card-club-hero {
    margin-top: 0.1cm;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.18cm;
  }
  .club-hero-logo {
    width: 1.5cm;
    height: 1.5cm;
    object-fit: contain;
    filter:
      drop-shadow(0 6px 18px rgba(0, 0, 0, 0.45))
      drop-shadow(0 2px 4px rgba(0, 0, 0, 0.3));
  }
  .club-hero-name {
    margin: 0.1cm 0 0;
    font-family: 'Cormorant Garamond', 'Bodoni Moda', serif;
    font-weight: 700;
    font-size: 19pt;
    line-height: 1.0;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #FFFFFF;
    max-width: 8.8cm;
    text-shadow: 0 2px 6px rgba(0, 0, 0, 0.6);
  }

  /* === Tagline honey === */
  .qr-card-tagline {
    display: flex;
    align-items: center;
    gap: 0.22cm;
    color: var(--honey);
    font-family: 'Inter', sans-serif;
    font-weight: 500;
    font-size: 9pt;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    margin-top: 0.1cm;
  }
  .tagline-rule {
    width: 0.85cm;
    height: 0.5px;
    background: var(--honey);
    opacity: 0.7;
  }

  /* === QR avec corner brackets honey === */
  .qr-card-qr-frame {
    position: relative;
    margin: 0.55cm auto 0.5cm;
    width: 4.5cm;
    height: 4.5cm;
  }
  .qr-card-qr {
    width: 100%;
    height: 100%;
    padding: 0.2cm;
    background: #FFFFFF;
    border-radius: 4px;
    box-sizing: border-box;
    box-shadow:
      0 10px 30px rgba(0, 0, 0, 0.35),
      0 3px 8px rgba(0, 0, 0, 0.22);
  }
  .qr-card-qr :global(svg) {
    width: 100%;
    height: 100%;
    display: block;
  }
  .bracket {
    position: absolute;
    width: 0.5cm;
    height: 0.5cm;
    border: 1.2px solid var(--honey);
    pointer-events: none;
  }
  .bracket-tl { top: -0.15cm; left: -0.15cm; border-right: 0; border-bottom: 0; }
  .bracket-tr { top: -0.15cm; right: -0.15cm; border-left: 0; border-bottom: 0; }
  .bracket-bl { bottom: -0.15cm; left: -0.15cm; border-right: 0; border-top: 0; }
  .bracket-br { bottom: -0.15cm; right: -0.15cm; border-left: 0; border-top: 0; }

  /* === STEPS === */
  .qr-card-steps {
    list-style: none;
    margin: 0.4cm 0 0;
    padding: 0;
    width: 100%;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.2cm;
  }
  .qr-card-steps li {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.1cm;
    font-family: 'Inter', sans-serif;
  }
  .step-icon {
    width: 0.85cm;
    height: 0.85cm;
    border-radius: 50%;
    background: rgba(212, 165, 116, 0.15);
    border: 0.8px solid var(--honey);
    color: var(--honey);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .step-icon svg {
    width: 65%;
    height: 65%;
    display: block;
  }
  .step-label {
    font-size: 7pt;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: #FFFFFF;
    text-transform: uppercase;
  }
  .step-desc {
    font-size: 6pt;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.65);
    line-height: 1.25;
    max-width: 2.4cm;
  }

  /* === FOOTER : "by Scluba" === */
  .qr-card-footer {
    padding-top: 0.3cm;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.15cm;
    border-top: 0.5px solid rgba(255, 255, 255, 0.15);
  }
  .by-label {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-style: italic;
    font-size: 7pt;
    color: rgba(255, 255, 255, 0.55);
    letter-spacing: 0.03em;
  }
  .scluba-mark {
    display: inline-flex;
    align-items: baseline;
    gap: 0.03em;
  }
  .scluba-wordmark {
    font-family: 'Bodoni Moda', serif;
    font-weight: 800;
    font-size: 11pt;
    color: var(--cream);
    letter-spacing: -0.01em;
    line-height: 1;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.4);
  }
  .scluba-ball {
    width: 0.55em;
    height: 0.55em;
    align-self: center;
    display: inline-block;
    filter: drop-shadow(0 1px 2px rgba(0, 0, 0, 0.4));
  }
  .scluba-ball svg { width: 100%; height: 100%; display: block; }

  /* ==========================================================
     SHEET 2 — Stickers (dark editorial)
     ========================================================== */
  .stickers-sheet {
    padding: 1.4cm 1.2cm;
    background:
      linear-gradient(180deg, rgba(10, 31, 20, 0.94) 0%, rgba(10, 31, 20, 0.88) 50%, rgba(10, 31, 20, 0.96) 100%),
      url('/photos/golf-du-soleil.jpg') center/cover no-repeat,
      var(--forest-deep);
    color: #FFFFFF;
  }
  .stickers-head { text-align: center; margin-bottom: 0.9cm; }
  .stickers-eyebrow {
    margin: 0 0 0.25cm;
    display: inline-flex;
    align-items: center;
    gap: 0.22cm;
    color: var(--honey);
    font-family: 'Inter', sans-serif;
    font-weight: 500;
    font-size: 8pt;
    letter-spacing: 0.3em;
    text-transform: uppercase;
  }
