---
export const prerender = false;

import OpsLayout from '../../../../layouts/OpsLayout.astro';
import { serviceClient } from '../../../../lib/supabase';
import type { Club } from '../../../../lib/clubs-types';

const { id } = Astro.params;
const sb = serviceClient();

const { data: club } = await sb.from('clubs').select('*, prospect:prospects(id, club_name)').eq('id', id).maybeSingle();
if (!club) {
  return Astro.redirect('/ops/clubs', 302);
}
const c = club as Club & { prospect: { id: string; club_name: string } | null };

const url = new URL(Astro.request.url);
const justSaved = url.searchParams.get('ok') === '1';
const errMsg = url.searchParams.get('err');

const accent = c.primary_color ?? '#1B4332';
const ALLOWED_HOLE_COUNTS = [6, 9, 18] as const;
const currentHoleCount = c.course_data.holes.length;
const hasMultiLoop = Array.isArray(c.course_data.loops) && c.course_data.loops.length > 0;
// Selector starts on the club's actual hole count when it's one of the
// supported sizes; otherwise we default to 18 (the legacy behaviour).
const selectorHoleCount: number = (ALLOWED_HOLE_COUNTS as readonly number[]).includes(currentHoleCount)
  ? currentHoleCount
  : 18;
const totalPar = c.course_data.holes.reduce((s, h) => s + h.par, 0);
// Serialize holes for the client script so it can re-render when the selector
// changes without losing already-entered pars.
const holesJson = JSON.stringify(c.course_data.holes.map((h) => ({ number: h.number, par: h.par })));

// === Stats ===
const now = new Date();
const startOfDay = new Date(now);
startOfDay.setHours(0, 0, 0, 0);
const startOfWeek = new Date(now);
startOfWeek.setDate(startOfWeek.getDate() - 7);
const startOfMonth = new Date(now);
startOfMonth.setDate(startOfMonth.getDate() - 30);

const [{ data: rounds }, { data: roster }] = await Promise.all([
  sb.from('rounds').select('id, status, started_at, finished_at, created_at').eq('club_id', c.id).order('created_at', { ascending: false }),
  sb.from('round_players').select('display_name, user_id, joined_at, round_id').in('round_id',
    (await sb.from('rounds').select('id').eq('club_id', c.id)).data?.map((r) => r.id) ?? [],
  ),
]);

const allRounds = rounds ?? [];
const allPlayers = roster ?? [];

const stats = {
  totalRounds: allRounds.length,
  finishedRounds: allRounds.filter((r) => r.status === 'finished').length,
  activeRounds: allRounds.filter((r) => r.status === 'lobby' || r.status === 'playing').length,
  roundsToday: allRounds.filter((r) => new Date(r.created_at) >= startOfDay).length,
  roundsThisWeek: allRounds.filter((r) => new Date(r.created_at) >= startOfWeek).length,
  roundsThisMonth: allRounds.filter((r) => new Date(r.created_at) >= startOfMonth).length,
  totalPlayers: allPlayers.length,
  uniquePlayers: new Set(allPlayers.map((p) => p.display_name.toLowerCase().trim())).size,
  loggedInPlayers: allPlayers.filter((p) => p.user_id).length,
  lastRoundAt: allRounds[0]?.started_at ?? allRounds[0]?.created_at ?? null,
};

const avgPlayersPerRound = stats.totalRounds > 0
  ? (stats.totalPlayers / stats.totalRounds).toFixed(1)
  : '—';

function fmtRelative(iso: string | null): string {
  if (!iso) return '—';
  const d = new Date(iso);
  const diff = (Date.now() - d.getTime()) / 1000;
  if (diff < 60) return 'à l\'instant';
  if (diff < 3600) return `il y a ${Math.floor(diff / 60)} min`;
  if (diff < 86400) return `il y a ${Math.floor(diff / 3600)} h`;
  if (diff < 86400 * 7) return `il y a ${Math.floor(diff / 86400)} j`;
  return d.toLocaleDateString('fr-FR', { day: '2-digit', month: 'short' });
}
---

<OpsLayout title={c.name} active="clubs">
  <div class="ops-page-header">
    <div>
      <a href="/ops/clubs" class="back-link">← Tous les clubs</a>
      <h1 class="ops-page-title">{c.name}</h1>
      <p class="ops-page-subtitle">
        slug <code>{c.slug}</code>
        {c.prospect && (
          <>
            <span> · </span>
            <a href={`/ops/prospects/${c.prospect.id}`}>fiche prospect</a>
          </>
        )}
      </p>
    </div>
    <div class="header-actions">
      <a href={`/ops/clubs/${c.id}/qr`} class="ops-btn">QR</a>
      <a href={`/ops/clubs/${c.id}/print`} class="ops-btn">Kit imprimable</a>
      <a href={`/${c.slug}`} target="_blank" rel="noopener" class="ops-btn ops-btn-primary">
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
          <polyline points="15 3 21 3 21 9"/>
          <line x1="10" y1="14" x2="21" y2="3"/>
        </svg>
        Voir la page
      </a>
    </div>
  </div>

  {justSaved && <div class="ops-flash ops-flash-ok">✓ Modifications enregistrées.</div>}
  {errMsg && <div class="ops-flash ops-flash-err">{errMsg}</div>}

  <section class="stats-row" aria-labelledby="stats-title">
    <header class="stats-head">
      <h2 id="stats-title">Activité</h2>
      <span class="stats-last">Dernière partie : <strong>{fmtRelative(stats.lastRoundAt)}</strong></span>
    </header>
    <ul class="stats-grid">
      <li class="stats-card">
        <span class="stats-label">Aujourd'hui</span>
        <span class="stats-value">{stats.roundsToday}</span>
        <span class="stats-sub">parties</span>
      </li>
      <li class="stats-card">
        <span class="stats-label">7 derniers jours</span>
        <span class="stats-value">{stats.roundsThisWeek}</span>
        <span class="stats-sub">parties</span>
      </li>
      <li class="stats-card">
        <span class="stats-label">30 derniers jours</span>
        <span class="stats-value">{stats.roundsThisMonth}</span>
        <span class="stats-sub">parties</span>
      </li>
      <li class="stats-card">
        <span class="stats-label">En cours</span>
        <span class="stats-value">{stats.activeRounds}</span>
        <span class="stats-sub">{stats.activeRounds > 1 ? 'parties actives' : 'partie active'}</span>
      </li>
      <li class="stats-card">
        <span class="stats-label">Total parties</span>
        <span class="stats-value">{stats.totalRounds}</span>
        <span class="stats-sub">dont {stats.finishedRounds} terminée{stats.finishedRounds > 1 ? 's' : ''}</span>
      </li>
      <li class="stats-card">
        <span class="stats-label">Joueurs uniques</span>
        <span class="stats-value">{stats.uniquePlayers}</span>
        <span class="stats-sub">par prénom</span>
      </li>
      <li class="stats-card">
        <span class="stats-label">Joueurs total</span>
        <span class="stats-value">{stats.totalPlayers}</span>
        <span class="stats-sub">avec doublons</span>
      </li>
      <li class="stats-card">
        <span class="stats-label">Moyenne / partie</span>
        <span class="stats-value">{avgPlayersPerRound}</span>
        <span class="stats-sub">joueurs</span>
      </li>
    </ul>
  </section>

  <div class="edit-grid">
    <div>
      <!-- Identity & color -->
      <div class="ops-card">
        <h2>Identité du club</h2>
        <form method="POST" action={`/api/ops/clubs/${c.id}`} class="identity-form" id="identity-form">
          <input type="hidden" name="action" value="update" />

          <div class="form-grid">
            <label class="ops-label">Nom du club
              <input class="ops-input" name="name" value={c.name} required />
            </label>
            <label class="ops-label">Ville
              <input class="ops-input" name="city" value={c.city ?? ''} />
            </label>
            <label class="ops-label" style="grid-column:1/-1">Couleur primaire
              <div class="color-row">
                <input
                  type="color"
                  name="primary_color_picker"
                  value={c.primary_color ?? '#1B4332'}
                  data-color-picker
                  aria-label="Sélecteur visuel"
                />
                <input
                  class="ops-input color-hex"
                  name="primary_color"
                  value={c.primary_color ?? '#1B4332'}
                  pattern="^#[0-9A-Fa-f]{6}$"
                  required
                  data-color-hex
                />
                <span class="color-preview" style={`background:${accent}`}>Aa</span>
              </div>
              <span class="ops-hint">Cette couleur s'applique aux titres, scores, et boutons sur la page golfeur.</span>
            </label>
          </div>

          <h3 class="course-title">
            Parcours · <span data-total-par>Par {totalPar}</span>
          </h3>
          {hasMultiLoop ? (
            <>
              <p class="ops-hint multi-loop-hint" style="margin:0 0 8px">
                Club multi-boucles — édition des trous indisponible ici. Modifie via la base, l'édition ne touche que pars (loops/formats préservés).
              </p>
              <input type="hidden" name="hole_count" value={String(currentHoleCount)} />
              <div class="course-grid" style={`--row-cells:${Math.min(currentHoleCount, 9)}`}>
                {Array.from({ length: Math.ceil(currentHoleCount / 9) }).map((_, rowIdx) => {
                  const from = rowIdx * 9 + 1;
                  const to = Math.min(from + 8, currentHoleCount);
                  return (
                    <div class="course-row">
                      <span class="course-row-label">{from}-{to}</span>
                      {c.course_data.holes.slice(from - 1, to).map((h) => (
                        <label class="course-cell">
                          <span class="course-cell-num">{h.number}</span>
                          <input
                            class="course-cell-input"
                            type="number"
                            name={`par_${h.number}`}
                            value={h.par}
                            min="2"
                            max="6"
                            required
                          />
                        </label>
                      ))}
                    </div>
                  );
                })}
              </div>
            </>
          ) : (
            <>
              <div class="course-controls">
                <label class="course-count-label">
                  Nombre de trous
                  <select
                    class="ops-input course-count-select"
                    name="hole_count"
                    data-hole-count-select
                  >
                    {ALLOWED_HOLE_COUNTS.map((n) => (
                      <option value={n} selected={n === selectorHoleCount}>{n} trous</option>
                    ))}
                  </select>
                </label>
              </div>
              <p class="ops-hint" style="margin:8px 0">Pars entre 2 et 6 par trou.</p>
              <div
                class="course-grid"
                data-course-grid
                data-initial-holes={holesJson}
                data-initial-count={String(selectorHoleCount)}
              ></div>
            </>
          )}

          <div class="form-actions">
            <button type="submit" class="ops-btn ops-btn-primary">Enregistrer</button>
          </div>
        </form>

        <details class="danger-zone">
          <summary>Zone dangereuse</summary>
          <p class="ops-hint">Supprimer le club retire la page <code>/{c.slug}</code> et toutes les parties associées (cascading delete).</p>
          <form method="POST" action={`/api/ops/clubs/${c.id}`}>
            <input type="hidden" name="action" value="delete" />
            <button
              type="submit"
              class="ops-btn danger"
              onclick="return confirm('Supprimer ce club et TOUTES ses parties ? Cette action est irréversible.')"
            >Supprimer le club</button>
          </form>
        </details>
      </div>
    </div>

    <div>
      <!-- Logo upload -->
      <div class="ops-card">
        <h2>Logo</h2>
        <div class="upload-preview">
          {c.logo_url ? (
            <img class="logo-preview" src={c.logo_url} alt="Logo actuel" />
          ) : (
            <div class="logo-placeholder">Pas de logo</div>
          )}
        </div>
        <form
          method="POST"
          action={`/api/ops/clubs/${c.id}/upload?kind=logo`}
          enctype="multipart/form-data"
          class="upload-form"
        >
          <label class="ops-label">Remplacer le logo
            <input class="ops-input" type="file" name="file" accept=".svg,.png,.jpg,.jpeg,.webp" required />
          </label>
          <span class="ops-hint">SVG recommandé (vectoriel, propre à n'importe quelle taille). PNG/JPEG/WebP OK. Max 500 KB.</span>
          <button type="submit" class="ops-btn ops-btn-primary">Téléverser</button>
        </form>
      </div>

      <!-- Photo upload -->
      <div class="ops-card" style="margin-top:16px">
        <h2>Photo du parcours</h2>
        <div class="upload-preview">
          {c.photo_url ? (
            <img class="photo-preview" src={c.photo_url} alt="Photo actuelle" />
          ) : (
            <div class="photo-placeholder">Pas de photo</div>
          )}
        </div>
        <form
          method="POST"
          action={`/api/ops/clubs/${c.id}/upload?kind=photo`}
          enctype="multipart/form-data"
          class="upload-form"
        >
          <label class="ops-label">Remplacer la photo
            <input class="ops-input" type="file" name="file" accept=".jpg,.jpeg,.png,.webp" required />
          </label>
          <span class="ops-hint">JPEG ou WebP recommandé. Format paysage 16:9 idéal. Max 5 MB.</span>
          <button type="submit" class="ops-btn ops-btn-primary">Téléverser</button>
        </form>
      </div>

      <!-- Sponsors (4 slots optionnels) -->
      <div class="ops-card" style="margin-top:16px">
        <h2>Sponsors</h2>
        <p class="ops-hint" style="margin: 0 0 12px">
          Jusqu'à 4 logos partenaires affichés autour du score sur la carte recap. Les slots vides restent invisibles. Lien optionnel : si renseigné, le logo devient cliquable.
        </p>
        {[1, 2, 3, 4].map((n) => {
          const urlKey = `sponsor_${n}_url` as keyof Club;
          const linkKey = `sponsor_${n}_link` as keyof Club;
          const imgUrl = (c[urlKey] as string | null) ?? null;
          const linkUrl = (c[linkKey] as string | null) ?? '';
          return (
            <div class="sponsor-row">
              <div class="sponsor-row-head">
                <div class="sponsor-preview">
                  {imgUrl ? (
                    <img src={imgUrl} alt={`Sponsor ${n}`} />
                  ) : (
                    <span class="sponsor-placeholder">{n}</span>
                  )}
                </div>
                <div class="sponsor-meta">
                  <span class="sponsor-label">Sponsor {n}</span>
                  <label class="ops-label sponsor-link-label">
                    Lien (optionnel)
                    <input
                      class="ops-input"
                      type="url"
                      name={`sponsor_${n}_link`}
                      form="identity-form"
                      placeholder="https://exemple.com"
                      value={linkUrl}
                    />
                  </label>
                </div>
              </div>
              <div class="sponsor-actions">
                <form
                  method="POST"
                  action={`/api/ops/clubs/${c.id}/upload?kind=sponsor${n}`}
                  enctype="multipart/form-data"
                  class="sponsor-upload-form"
                >
                  <input
                    type="file"
                    name="file"
                    accept=".png,.jpg,.jpeg,.webp"
                    required
                  />
                  <button type="submit" class="ops-btn sponsor-btn">
                    {imgUrl ? 'Remplacer' : 'Téléverser'}
                  </button>
                </form>
                {imgUrl && (
                  <form method="POST" action={`/api/ops/clubs/${c.id}`} class="sponsor-delete-form">
                    <input type="hidden" name="action" value="delete-sponsor" />
                    <input type="hidden" name="index" value={String(n)} />
                    <button
                      type="submit"
                      class="ops-btn sponsor-btn sponsor-delete-btn"
                      onclick={`return confirm('Supprimer le sponsor ${n} ?')`}
                    >Supprimer</button>
                  </form>
                )}
              </div>
            </div>
          );
        })}
        <p class="ops-hint" style="margin-top: 8px">
          PNG/JPEG/WebP, max 500 KB. Format carré ou paysage léger conseillé.
        </p>
      </div>
    </div>
  </div>
</OpsLayout>

<script is:inline>
  // Sync color picker ↔ hex input.
  const picker = document.querySelector('[data-color-picker]');
  const hex = document.querySelector('[data-color-hex]');
  if (picker && hex) {
    picker.addEventListener('input', () => { hex.value = picker.value.toUpperCase(); });
    hex.addEventListener('input', () => {
      const v = hex.value.trim();
      if (/^#[0-9A-Fa-f]{6}$/.test(v)) picker.value = v;
    });
  }

  // === Live par total: works in both modes (multi-loop SSR grid and the
  // dynamic JS grid). Recomputes from whatever .course-cell-input is in DOM. ===
  (function setupTotalRecompute() {
    const totalLabel = document.querySelector('[data-total-par]');
    if (!totalLabel) return;
    function recompute() {
      let total = 0;
      document.querySelectorAll('.course-cell-input').forEach((el) => {
        const v = Number(el.value);
        if (Number.isFinite(v)) total += v;
      });
      totalLabel.textContent = 'Par ' + total;
    }
    document.addEventListener('input', (e) => {
      const t = e.target;
      if (t && t.classList && t.classList.contains('course-cell-input')) recompute();
    });
  })();

  // === Course grid: re-renders inputs when the hole-count selector changes,
  // preserving the pars the admin already typed. Only active for single-course
  // clubs — multi-loop clubs render their inputs SSR (see Astro template). ===
  (function setupCourseGrid() {
    const grid = document.querySelector('[data-course-grid]');
    const select = document.querySelector('[data-hole-count-select]');
    const totalLabel = document.querySelector('[data-total-par]');
    if (!grid || !select) return;

    // Initial pars come from the server-rendered course_data.holes.
    const initialHoles = JSON.parse(grid.dataset.initialHoles || '[]');
    // Map from hole number -> par. We update this on every input change so
    // switching count back and forth keeps the user's edits.
    const parsByNumber = new Map();
    for (const h of initialHoles) parsByNumber.set(h.number, h.par);

    function recomputeTotal() {
      let total = 0;
      grid.querySelectorAll('.course-cell-input').forEach((el) => {
        const v = Number(el.value);
        if (Number.isFinite(v)) total += v;
      });
      if (totalLabel) totalLabel.textContent = 'Par ' + total;
    }

    function buildRow(label, fromHole, toHole) {
      const row = document.createElement('div');
      row.className = 'course-row';
      const span = document.createElement('span');
      span.className = 'course-row-label';
      span.textContent = label;
      row.appendChild(span);
      for (let n = fromHole; n <= toHole; n++) {
        const cell = document.createElement('label');
        cell.className = 'course-cell';
        const num = document.createElement('span');
        num.className = 'course-cell-num';
        num.textContent = String(n);
        const input = document.createElement('input');
        input.className = 'course-cell-input';
        input.type = 'number';
        input.name = 'par_' + n;
        input.min = '2';
        input.max = '6';
        input.required = true;
        input.value = String(parsByNumber.get(n) ?? 4);
        input.addEventListener('input', () => {
          const v = Number(input.value);
          if (Number.isFinite(v)) parsByNumber.set(n, v);
          recomputeTotal();
        });
        cell.appendChild(num);
        cell.appendChild(input);
        row.appendChild(cell);
      }
      return row;
    }

    function render(count) {
      grid.innerHTML = '';
      grid.dataset.holeCount = String(count);
      // Layout: 6 → one row of 6 ("Parcours"). 9 → one row of 9 ("F9").
      // 18 → two rows F9/B9. Cells per row drive the CSS column count.
      if (count === 6) {
        grid.style.setProperty('--row-cells', '6');
        grid.appendChild(buildRow('1-6', 1, 6));
      } else if (count === 9) {
        grid.style.setProperty('--row-cells', '9');
        grid.appendChild(buildRow('F9', 1, 9));
      } else {
        grid.style.setProperty('--row-cells', '9');
        grid.appendChild(buildRow('F9', 1, 9));
        grid.appendChild(buildRow('B9', 10, 18));
      }
      recomputeTotal();
    }

    const initialCount = Number(grid.dataset.initialCount) || 18;
    render(initialCount);

    select.addEventListener('change', () => {
      const next = Number(select.value);
      if ([6, 9, 18].indexOf(next) === -1) return;
      render(next);
    });
  })();
</script>

<style>
  .back-link { color: var(--muted); font-size: 13px; text-decoration: none; }
  .back-link:hover { color: var(--primary); }
  .header-actions { display: inline-flex; align-items: center; gap: 8px; flex-wrap: wrap; justify-content: flex-end; }

  code {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    background: var(--line-soft);
    padding: 1px 6px;
    border-radius: 4px;
    font-size: 12px;
  }

  .edit-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 16px;
    align-items: start;
  }
  @media (max-width: 980px) {
    .edit-grid { grid-template-columns: 1fr; }
  }

  .stats-row {
    margin-bottom: 16px;
    padding: 16px;
    background: var(--bg);
    border: 1px solid var(--line);
    border-radius: 12px;
    box-shadow: 0 1px 2px rgba(15,42,30,0.04);
  }
  .stats-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 14px;
    flex-wrap: wrap;
  }
  .stats-head h2 {
    font-family: var(--font-serif);
    font-size: 17px;
    margin: 0;
    color: var(--primary);
  }
  .stats-last {
    font-size: 12px;
    color: var(--muted);
  }
  .stats-last strong { color: var(--ink); font-weight: 600; }

  .stats-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(8, 1fr);
    gap: 10px;
  }
  @media (max-width: 1280px) {
    .stats-grid { grid-template-columns: repeat(4, 1fr); }
  }
  @media (max-width: 700px) {
    .stats-grid { grid-template-columns: repeat(2, 1fr); }
  }
  .stats-card {
    background: var(--bg-soft);
    border: 1px solid var(--line);
    border-radius: 10px;
    padding: 12px 12px 10px;
    display: flex;
    flex-direction: column;
    gap: 2px;
    text-align: left;
    transition: border-color 0.15s;
  }
  .stats-card:hover { border-color: var(--accent); }

  .stats-label {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .stats-value {
    font-family: var(--font-serif);
    font-size: 26px;
    font-weight: 700;
    color: var(--primary);
    line-height: 1.1;
    font-variant-numeric: tabular-nums;
  }
  .stats-sub {
    font-size: 11px;
    color: var(--muted-soft);
    line-height: 1.3;
  }

  .form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px 14px;
  }
  @media (max-width: 600px) {
    .form-grid { grid-template-columns: 1fr; }
  }
  .form-actions { margin-top: 16px; display: flex; justify-content: flex-end; gap: 8px; }

  .ops-hint {
    display: block;
    margin-top: 4px;
    font-size: 12px;
    color: var(--muted);
  }

  .color-row {
    display: grid;
