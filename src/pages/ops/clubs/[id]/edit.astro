---
export const prerender = false;

import OpsLayout from '../../../../layouts/OpsLayout.astro';
import { serviceClient } from '../../../../lib/supabase';
import type { Club } from '../../../../lib/clubs-types';

const { id } = Astro.params;
const sb = serviceClient();

const { data: club } = await sb.from('clubs').select('*, prospect:prospects(id, club_name)').eq('id', id).maybeSingle();
if (!club) {
  return Astro.redirect('/ops/clubs', 302);
}
const c = club as Club & { prospect: { id: string; club_name: string } | null };

// Accès portail club : allowlist d'emails (table club_members).
const { data: clubMembers } = await sb
  .from('club_members')
  .select('id, email, role')
  .eq('club_id', c.id)
  .order('created_at', { ascending: true });

const url = new URL(Astro.request.url);
const portalUrl = `${url.origin}/club`;
const justSaved = url.searchParams.get('ok') === '1';
const errMsg = url.searchParams.get('err');

const accent = c.primary_color ?? '#1B4332';
const ALLOWED_HOLE_COUNTS = [6, 9, 18] as const;
const currentHoleCount = c.course_data.holes.length;
const hasMultiLoop = Array.isArray(c.course_data.loops) && c.course_data.loops.length > 0;
// Selector starts on the club's actual hole count when it's one of the
// supported sizes; otherwise we default to 18 (the legacy behaviour).
const selectorHoleCount: number = (ALLOWED_HOLE_COUNTS as readonly number[]).includes(currentHoleCount)
  ? currentHoleCount
  : 18;
const totalPar = c.course_data.holes.reduce((s, h) => s + h.par, 0);
// Serialize holes for the client script so it can re-render when the selector
// changes without losing already-entered pars.
const holesJson = JSON.stringify(c.course_data.holes.map((h) => ({ number: h.number, par: h.par })));

// Mode initial de l'éditeur de parcours : 'multi' si le club a déjà des
// boucles, sinon 'single'. Le toggle laisse basculer (mode simple = boucles
// effacées au save). Boucles + formats existants sérialisés pour l'éditeur
// multi-boucles côté client.
const initialCourseMode = hasMultiLoop ? 'multi' : 'single';
const loopsJson = JSON.stringify(c.course_data.loops ?? []);
const formatsJson = JSON.stringify(c.course_data.formats ?? []);

// === Stats ===
const now = new Date();
const startOfDay = new Date(now);
startOfDay.setHours(0, 0, 0, 0);
const startOfWeek = new Date(now);
startOfWeek.setDate(startOfWeek.getDate() - 7);
const startOfMonth = new Date(now);
startOfMonth.setDate(startOfMonth.getDate() - 30);

const [{ data: rounds }, { data: roster }] = await Promise.all([
  sb.from('rounds').select('id, status, started_at, finished_at, created_at').eq('club_id', c.id).order('created_at', { ascending: false }),
  sb.from('round_players').select('display_name, user_id, joined_at, round_id').in('round_id',
    (await sb.from('rounds').select('id').eq('club_id', c.id)).data?.map((r) => r.id) ?? [],
  ),
]);

const allRounds = rounds ?? [];
const allPlayers = roster ?? [];

const stats = {
  totalRounds: allRounds.length,
  finishedRounds: allRounds.filter((r) => r.status === 'finished').length,
  activeRounds: allRounds.filter((r) => r.status === 'lobby' || r.status === 'playing').length,
  roundsToday: allRounds.filter((r) => new Date(r.created_at) >= startOfDay).length,
  roundsThisWeek: allRounds.filter((r) => new Date(r.created_at) >= startOfWeek).length,
  roundsThisMonth: allRounds.filter((r) => new Date(r.created_at) >= startOfMonth).length,
  totalPlayers: allPlayers.length,
  uniquePlayers: new Set(allPlayers.map((p) => p.display_name.toLowerCase().trim())).size,
  loggedInPlayers: allPlayers.filter((p) => p.user_id).length,
  lastRoundAt: allRounds[0]?.started_at ?? allRounds[0]?.created_at ?? null,
};

const avgPlayersPerRound = stats.totalRounds > 0
  ? (stats.totalPlayers / stats.totalRounds).toFixed(1)
  : '—';

function fmtRelative(iso: string | null): string {
  if (!iso) return '—';
  const d = new Date(iso);
  const diff = (Date.now() - d.getTime()) / 1000;
  if (diff < 60) return 'à l\'instant';
  if (diff < 3600) return `il y a ${Math.floor(diff / 60)} min`;
  if (diff < 86400) return `il y a ${Math.floor(diff / 3600)} h`;
  if (diff < 86400 * 7) return `il y a ${Math.floor(diff / 86400)} j`;
  return d.toLocaleDateString('fr-FR', { day: '2-digit', month: 'short' });
}
---

<OpsLayout title={c.name} active="clubs">
  <div class="ops-page-header">
    <div>
      <a href="/ops/clubs" class="back-link">← Tous les clubs</a>
      <h1 class="ops-page-title">{c.name}</h1>
      <p class="ops-page-subtitle">
        slug <code>{c.slug}</code>
        {c.prospect && (
          <>
            <span> · </span>
            <a href={`/ops/prospects/${c.prospect.id}`}>fiche prospect</a>
          </>
        )}
      </p>
    </div>
    <div class="header-actions">
      <a href={`/ops/clubs/${c.id}/qr`} class="ops-btn">QR</a>
      <a href={`/ops/clubs/${c.id}/print`} class="ops-btn">Kit imprimable</a>
      <a href={`/${c.slug}`} target="_blank" rel="noopener" class="ops-btn ops-btn-primary">
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
          <polyline points="15 3 21 3 21 9"/>
          <line x1="10" y1="14" x2="21" y2="3"/>
        </svg>
        Voir la page
      </a>
    </div>
  </div>

  {justSaved && <div class="ops-flash ops-flash-ok">✓ Modifications enregistrées.</div>}
  {errMsg && <div class="ops-flash ops-flash-err">{errMsg}</div>}

  <section class="stats-row" aria-labelledby="stats-title">
    <header class="stats-head">
      <h2 id="stats-title">Activité</h2>
      <span class="stats-last">Dernière partie : <strong>{fmtRelative(stats.lastRoundAt)}</strong></span>
    </header>
    <ul class="stats-grid">
      <li class="stats-card">
        <span class="stats-label">Aujourd'hui</span>
        <span class="stats-value">{stats.roundsToday}</span>
        <span class="stats-sub">parties</span>
      </li>
      <li class="stats-card">
        <span class="stats-label">7 derniers jours</span>
        <span class="stats-value">{stats.roundsThisWeek}</span>
        <span class="stats-sub">parties</span>
      </li>
      <li class="stats-card">
        <span class="stats-label">30 derniers jours</span>
        <span class="stats-value">{stats.roundsThisMonth}</span>
        <span class="stats-sub">parties</span>
      </li>
      <li class="stats-card">
        <span class="stats-label">En cours</span>
        <span class="stats-value">{stats.activeRounds}</span>
        <span class="stats-sub">{stats.activeRounds > 1 ? 'parties actives' : 'partie active'}</span>
      </li>
      <li class="stats-card">
        <span class="stats-label">Total parties</span>
        <span class="stats-value">{stats.totalRounds}</span>
        <span class="stats-sub">dont {stats.finishedRounds} terminée{stats.finishedRounds > 1 ? 's' : ''}</span>
      </li>
      <li class="stats-card">
        <span class="stats-label">Joueurs uniques</span>
        <span class="stats-value">{stats.uniquePlayers}</span>
        <span class="stats-sub">par prénom</span>
      </li>
      <li class="stats-card">
        <span class="stats-label">Joueurs total</span>
        <span class="stats-value">{stats.totalPlayers}</span>
        <span class="stats-sub">avec doublons</span>
      </li>
      <li class="stats-card">
        <span class="stats-label">Moyenne / partie</span>
        <span class="stats-value">{avgPlayersPerRound}</span>
        <span class="stats-sub">joueurs</span>
      </li>
    </ul>
  </section>

  <div class="edit-grid">
    <div>
      <!-- Identity & color -->
      <div class="ops-card">
        <h2>Identité du club</h2>
        <form method="POST" action={`/api/ops/clubs/${c.id}`} class="identity-form" id="identity-form">
          <input type="hidden" name="action" value="update" />

          <div class="form-grid">
            <label class="ops-label">Nom du club
              <input class="ops-input" name="name" value={c.name} required />
            </label>
            <label class="ops-label">Ville
              <input class="ops-input" name="city" value={c.city ?? ''} />
            </label>
            <label class="ops-label" style="grid-column:1/-1">Couleur primaire
              <div class="color-row">
                <input
                  type="color"
                  name="primary_color_picker"
                  value={c.primary_color ?? '#1B4332'}
                  data-color-picker
                  aria-label="Sélecteur visuel"
                />
                <input
                  class="ops-input color-hex"
                  name="primary_color"
                  value={c.primary_color ?? '#1B4332'}
                  pattern="^#[0-9A-Fa-f]{6}$"
                  required
                  data-color-hex
                />
                <span class="color-preview" style={`background:${accent}`}>Aa</span>
              </div>
              <span class="ops-hint">Cette couleur s'applique aux titres, scores, et boutons sur la page golfeur.</span>
            </label>
          </div>

          <h3 class="course-title">
            Parcours · <span data-total-par>Par {totalPar}</span>
          </h3>

          <div class="mode-toggle" role="radiogroup" aria-label="Type de parcours">
            <label class="mode-seg">
              <input type="radio" name="course_mode" value="single" checked={initialCourseMode === 'single'} data-mode-radio />
              <span>Un seul parcours</span>
            </label>
            <label class="mode-seg">
              <input type="radio" name="course_mode" value="multi" checked={initialCourseMode === 'multi'} data-mode-radio />
              <span>Plusieurs boucles</span>
            </label>
          </div>

          {/* Mode simple : sélecteur 6/9/18 + grille de pars dynamique (inchangé). */}
          <div data-editor="single" hidden={initialCourseMode !== 'single'}>
            <div class="course-controls">
              <label class="course-count-label">
                Nombre de trous
                <select
                  class="ops-input course-count-select"
                  name="hole_count"
                  data-hole-count-select
                >
                  {ALLOWED_HOLE_COUNTS.map((n) => (
                    <option value={n} selected={n === selectorHoleCount}>{n} trous</option>
                  ))}
                </select>
              </label>
            </div>
            <p class="ops-hint" style="margin:8px 0">Pars entre 2 et 6 par trou.</p>
            <div
              class="course-grid"
              data-course-grid
              data-initial-holes={holesJson}
              data-initial-count={String(selectorHoleCount)}
            ></div>
          </div>

          {/* Mode multi-boucles : éditeur dynamique (voir script plus bas). */}
          <div
            data-editor="multi"
            hidden={initialCourseMode !== 'multi'}
            data-loops-editor
            data-initial-loops={loopsJson}
            data-initial-formats={formatsJson}
          >
            <p class="ops-hint" style="margin:0 0 10px">
              Chaque boucle est un « neuf » nommé (La Plaine, Le Vallon…). Coche ensuite les formats à proposer aux golfeurs au départ.
            </p>
            <div class="loops-list" data-loops-list></div>
            <button type="button" class="ops-btn loops-add-btn" data-add-loop>+ Ajouter une boucle</button>

            <h4 class="loops-formats-title">Formats proposés aux golfeurs</h4>
            <p class="ops-hint" style="margin:0 0 8px">
              Le golfeur en choisit un au départ. Décoche ceux que tu ne proposes pas, renomme librement.
            </p>
            <div class="formats-list" data-formats-list></div>

            <p class="loops-error" data-loops-error hidden></p>
            <input type="hidden" name="course_loops_json" data-loops-json />
          </div>

          <div class="form-actions">
            <button type="submit" class="ops-btn ops-btn-primary">Enregistrer</button>
          </div>
        </form>

        <details class="danger-zone">
          <summary>Zone dangereuse</summary>
          <p class="ops-hint">Supprimer le club retire la page <code>/{c.slug}</code> et toutes les parties associées (cascading delete).</p>
          <form method="POST" action={`/api/ops/clubs/${c.id}`}>
            <input type="hidden" name="action" value="delete" />
            <button
              type="submit"
              class="ops-btn danger"
              onclick="return confirm('Supprimer ce club et TOUTES ses parties ? Cette action est irréversible.')"
            >Supprimer le club</button>
          </form>
        </details>
      </div>
    </div>

    <div>
      <!-- Logo upload -->
      <div class="ops-card">
        <h2>Logo</h2>
        <div class="upload-preview">
          {c.logo_url ? (
            <img class="logo-preview" src={c.logo_url} alt="Logo actuel" />
          ) : (
            <div class="logo-placeholder">Pas de logo</div>
          )}
        </div>
        <form
          method="POST"
          action={`/api/ops/clubs/${c.id}/upload?kind=logo`}
          enctype="multipart/form-data"
          class="upload-form"
          data-logo-form
          data-club-id={c.id}
        >
          <label class="ops-label">Remplacer le logo
            <input class="ops-input" type="file" name="file" accept=".svg,.png,.jpg,.jpeg,.webp" required />
          </label>
          <span class="ops-hint">SVG recommandé (vectoriel, propre à n'importe quelle taille). PNG/JPEG/WebP OK. Max 500 KB.</span>
          <button type="submit" class="ops-btn ops-btn-primary">Téléverser</button>
        </form>
      </div>

      <!-- Photo upload -->
      <div class="ops-card" style="margin-top:16px">
        <h2>Photo du parcours</h2>
        <div class="upload-preview">
          {c.photo_url ? (
            <img class="photo-preview" src={c.photo_url} alt="Photo actuelle" />
          ) : (
            <div class="photo-placeholder">Pas de photo</div>
          )}
        </div>
        <form
          method="POST"
          action={`/api/ops/clubs/${c.id}/upload?kind=photo`}
          enctype="multipart/form-data"
          class="upload-form"
        >
          <label class="ops-label">Remplacer la photo
            <input class="ops-input" type="file" name="file" accept=".jpg,.jpeg,.png,.webp" required />
          </label>
          <span class="ops-hint">JPEG ou WebP recommandé. Format paysage 16:9 idéal. Max 5 MB.</span>
          <button type="submit" class="ops-btn ops-btn-primary">Téléverser</button>
        </form>
      </div>

      <!-- Carnet de parcours -->
      <div class="ops-card" style="margin-top:16px">
        <h2>Carnet de parcours</h2>
        <p class="ops-hint" style="margin: 0 0 12px">
          Dépose le carnet du club (PDF ou images) et assigne un visuel à chaque trou. Les golfeurs verront un bouton « Voir le trou » sur la scorecard.
        </p>
        <a class="ops-btn ops-btn-primary" href={`/ops/clubs/${c.id}/carnet`}>Gérer le carnet de parcours →</a>
      </div>

      <!-- Sponsors (4 slots optionnels) -->
      <div class="ops-card" style="margin-top:16px">
        <h2>Sponsors</h2>
        <p class="ops-hint" style="margin: 0 0 12px">
          Jusqu'à 4 logos partenaires affichés autour du score sur la carte recap. Les slots vides restent invisibles. Lien optionnel : si renseigné, le logo devient cliquable.
        </p>
        {[1, 2, 3, 4].map((n) => {
          const urlKey = `sponsor_${n}_url` as keyof Club;
          const linkKey = `sponsor_${n}_link` as keyof Club;
          const imgUrl = (c[urlKey] as string | null) ?? null;
          const linkUrl = (c[linkKey] as string | null) ?? '';
          return (
            <div class="sponsor-row">
              <div class="sponsor-row-head">
                <div class="sponsor-preview">
                  {imgUrl ? (
                    <img src={imgUrl} alt={`Sponsor ${n}`} />
                  ) : (
                    <span class="sponsor-placeholder">{n}</span>
                  )}
                </div>
                <div class="sponsor-meta">
                  <span class="sponsor-label">Sponsor {n}</span>
                  <label class="ops-label sponsor-link-label">
                    Lien (optionnel)
                    <input
                      class="ops-input"
                      type="url"
                      name={`sponsor_${n}_link`}
                      form="identity-form"
                      placeholder="https://exemple.com"
                      value={linkUrl}
                    />
                  </label>
                </div>
              </div>
              <div class="sponsor-actions">
                <form
                  method="POST"
                  action={`/api/ops/clubs/${c.id}/upload?kind=sponsor${n}`}
                  enctype="multipart/form-data"
                  class="sponsor-upload-form"
                >
                  <input
                    type="file"
                    name="file"
                    accept=".png,.jpg,.jpeg,.webp"
                    required
                  />
                  <button type="submit" class="ops-btn sponsor-btn">
                    {imgUrl ? 'Remplacer' : 'Téléverser'}
                  </button>
                </form>
                {imgUrl && (
                  <form method="POST" action={`/api/ops/clubs/${c.id}`} class="sponsor-delete-form">
                    <input type="hidden" name="action" value="delete-sponsor" />
                    <input type="hidden" name="index" value={String(n)} />
                    <button
                      type="submit"
                      class="ops-btn sponsor-btn sponsor-delete-btn"
                      onclick={`return confirm('Supprimer le sponsor ${n} ?')`}
                    >Supprimer</button>
                  </form>
                )}
              </div>
            </div>
          );
        })}
        <p class="ops-hint" style="margin-top: 8px">
          PNG/JPEG/WebP, max 500 KB. Format carré ou paysage léger conseillé.
        </p>
      </div>

      <!-- Accès portail club -->
      <div class="ops-card" style="margin-top:16px">
        <h2>Accès portail club</h2>
        <p class="ops-hint" style="margin: 0 0 12px">
          Le club se connecte sur <code>{portalUrl}</code> avec un <b>email autorisé</b> (liste plus bas) <b>et le mot de passe</b> du club. C'est l'email qui décide du tableau de bord : « Jardinier » ne voit que les signalements.
        </p>

        <div class="portal-code-block">
          <span class="portal-code-title">Mot de passe du club</span>
          <div class="portal-code-row">
            <code class="portal-code-value" id="portal-code-value" data-empty={c.portal_code ? 'false' : 'true'}>{c.portal_code ?? 'Non défini'}</code>
            <button
              type="button"
              class="ops-btn portal-copy-btn"
              id="portal-copy-btn"
              data-code={c.portal_code ?? ''}
              style={c.portal_code ? '' : 'display:none'}
            >Copier</button>
            <button type="button" class="ops-btn ops-btn-primary portal-gen-btn" id="portal-gen-btn" data-club-id={c.id}>
              {c.portal_code ? 'Régénérer' : 'Générer'}
            </button>
          </div>
          <span class="ops-hint">À communiquer au club. « Régénérer » remplace le code — l'ancien ne permettra plus de se connecter.</span>
          <output id="portal-code-msg" class="member-msg"></output>
        </div>

        <hr class="portal-sep" />

        <span class="portal-code-title">Emails autorisés</span>
        <ul class="member-list">
          {(clubMembers ?? []).map((m) => (
            <li class="member-row">
              <span class="member-email">{m.email}</span>
              <span class="member-role">{m.role === 'admin' ? 'Admin' : 'Jardinier'}</span>
              <button type="button" class="ops-btn member-remove" data-remove-id={m.id}>Retirer</button>
            </li>
          ))}
          {(clubMembers ?? []).length === 0 && <li class="member-empty">Aucun accès pour l'instant.</li>}
        </ul>

        <div class="member-add">
          <input class="ops-input" type="email" id="member-email" placeholder="email@club.com" />
          <select class="ops-input" id="member-role">
            <option value="admin">Admin</option>
            <option value="greenkeeper">Jardinier</option>
          </select>
          <button type="button" class="ops-btn ops-btn-primary" id="member-add-btn" data-club-id={c.id}>Ajouter</button>
        </div>
        <output id="member-msg" class="member-msg"></output>
      </div>
    </div>
  </div>
</OpsLayout>

<script is:inline>
  // Sync color picker ↔ hex input.
  const picker = document.querySelector('[data-color-picker]');
  const hex = document.querySelector('[data-color-hex]');
  if (picker && hex) {
    picker.addEventListener('input', () => { hex.value = picker.value.toUpperCase(); });
    hex.addEventListener('input', () => {
      const v = hex.value.trim();
      if (/^#[0-9A-Fa-f]{6}$/.test(v)) picker.value = v;
    });
  }

  // === Live par total: works in both modes (multi-loop SSR grid and the
  // dynamic JS grid). Recomputes from whatever .course-cell-input is in DOM. ===
  (function setupTotalRecompute() {
    const totalLabel = document.querySelector('[data-total-par]');
    if (!totalLabel) return;
    function recompute() {
      let total = 0;
      document.querySelectorAll('.course-cell-input').forEach((el) => {
        const v = Number(el.value);
        if (Number.isFinite(v)) total += v;
      });
      totalLabel.textContent = 'Par ' + total;
    }
    document.addEventListener('input', (e) => {
      const t = e.target;
      if (t && t.classList && t.classList.contains('course-cell-input')) recompute();
    });
  })();

  // === Course grid: re-renders inputs when the hole-count selector changes,
  // preserving the pars the admin already typed. Only active for single-course
  // clubs — multi-loop clubs render their inputs SSR (see Astro template). ===
  (function setupCourseGrid() {
    const grid = document.querySelector('[data-course-grid]');
    const select = document.querySelector('[data-hole-count-select]');
    const totalLabel = document.querySelector('[data-total-par]');
    if (!grid || !select) return;

    // Initial pars come from the server-rendered course_data.holes.
    const initialHoles = JSON.parse(grid.dataset.initialHoles || '[]');
    // Map from hole number -> par. We update this on every input change so
    // switching count back and forth keeps the user's edits.
    const parsByNumber = new Map();
    for (const h of initialHoles) parsByNumber.set(h.number, h.par);

    function recomputeTotal() {
      let total = 0;
      grid.querySelectorAll('.course-cell-input').forEach((el) => {
        const v = Number(el.value);
        if (Number.isFinite(v)) total += v;
      });
      if (totalLabel) totalLabel.textContent = 'Par ' + total;
    }

    function buildRow(label, fromHole, toHole) {
      const row = document.createElement('div');
      row.className = 'course-row';
      const span = document.createElement('span');
      span.className = 'course-row-label';
      span.textContent = label;
      row.appendChild(span);
      for (let n = fromHole; n <= toHole; n++) {
        const cell = document.createElement('label');
        cell.className = 'course-cell';
        const num = document.createElement('span');
        num.className = 'course-cell-num';
        num.textContent = String(n);
        const input = document.createElement('input');
        input.className = 'course-cell-input';
        input.type = 'number';
        input.name = 'par_' + n;
        input.min = '2';
        input.max = '6';
        input.required = true;
        input.value = String(parsByNumber.get(n) ?? 4);
        input.addEventListener('input', () => {
          const v = Number(input.value);
          if (Number.isFinite(v)) parsByNumber.set(n, v);
          recomputeTotal();
        });
        cell.appendChild(num);
        cell.appendChild(input);
        row.appendChild(cell);
      }
      return row;
    }

    function render(count) {
      grid.innerHTML = '';
      grid.dataset.holeCount = String(count);
      // Layout: 6 → one row of 6 ("Parcours"). 9 → one row of 9 ("F9").
      // 18 → two rows F9/B9. Cells per row drive the CSS column count.
      if (count === 6) {
        grid.style.setProperty('--row-cells', '6');
        grid.appendChild(buildRow('1-6', 1, 6));
      } else if (count === 9) {
        grid.style.setProperty('--row-cells', '9');
        grid.appendChild(buildRow('F9', 1, 9));
      } else {
        grid.style.setProperty('--row-cells', '9');
        grid.appendChild(buildRow('F9', 1, 9));
        grid.appendChild(buildRow('B9', 10, 18));
      }
      recomputeTotal();
    }

    const initialCount = Number(grid.dataset.initialCount) || 18;
    render(initialCount);

    select.addEventListener('change', () => {
      const next = Number(select.value);
      if ([6, 9, 18].indexOf(next) === -1) return;
      render(next);
    });
  })();
</script>

<script is:inline>
  // Gestion de l'allowlist d'emails du portail club (ajout / retrait).
  (function setupClubMembers() {
    const addBtn = document.getElementById('member-add-btn');
    if (!addBtn) return;
    const emailInput = document.getElementById('member-email');
    const roleSel = document.getElementById('member-role');
    const msg = document.getElementById('member-msg');

    addBtn.addEventListener('click', async () => {
      const email = emailInput.value.trim();
      if (!email) { msg.textContent = 'Entrez un email.'; return; }
      addBtn.disabled = true;
      msg.textContent = 'Ajout…';
      try {
        const res = await fetch('/api/ops/club-members', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ club_id: addBtn.getAttribute('data-club-id'), email, role: roleSel.value }),
        });
        if (res.ok) { location.reload(); }
        else { msg.textContent = 'Erreur : ' + (await res.text()); addBtn.disabled = false; }
      } catch (e) {
        msg.textContent = 'Erreur réseau, réessayez.'; addBtn.disabled = false;
      }
    });

    document.querySelectorAll('.member-remove').forEach((btn) => {
      btn.addEventListener('click', async () => {
        if (!confirm('Retirer cet accès au portail ?')) return;
        btn.disabled = true;
        try {
          const res = await fetch('/api/ops/club-members', {
            method: 'DELETE',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id: btn.getAttribute('data-remove-id') }),
          });
          if (res.ok) { location.reload(); }
          else { alert('Erreur, réessayez.'); btn.disabled = false; }
        } catch (e) { alert('Erreur réseau, réessayez.'); btn.disabled = false; }
      });
    });
  })();

  // Mot de passe du Portail Club : générer / régénérer + copier.
  (function setupPortalCode() {
    const genBtn = document.getElementById('portal-gen-btn');
    if (!genBtn) return;
    const valueEl = document.getElementById('portal-code-value');
    const copyBtn = document.getElementById('portal-copy-btn');
    const msg = document.getElementById('portal-code-msg');

    genBtn.addEventListener('click', async () => {
      const already = valueEl.dataset.empty === 'false';
      if (already && !confirm("Régénérer le mot de passe ? L'ancien ne marchera plus.")) return;
      genBtn.disabled = true;
      msg.textContent = 'Génération…';
      try {
        const res = await fetch('/api/ops/club-code', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ club_id: genBtn.getAttribute('data-club-id') }),
        });
        if (res.ok) {
          const data = await res.json();
          valueEl.textContent = data.code;
          valueEl.dataset.empty = 'false';
          genBtn.textContent = 'Régénérer';
          if (copyBtn) { copyBtn.style.display = ''; copyBtn.setAttribute('data-code', data.code); }
          msg.textContent = 'Nouveau mot de passe généré — pensez à le communiquer au club.';
        } else {
          msg.textContent = 'Erreur : ' + (await res.text());
        }
      } catch (e) {
        msg.textContent = 'Erreur réseau, réessayez.';
      } finally {
        genBtn.disabled = false;
      }
    });

    if (copyBtn) {
      copyBtn.addEventListener('click', async () => {
        const code = copyBtn.getAttribute('data-code') || valueEl.textContent;
        try {
          await navigator.clipboard.writeText(code);
          msg.textContent = 'Copié !';
        } catch (e) {
          msg.textContent = 'Copie impossible — sélectionnez le code à la main.';
        }
      });
    }
  })();
</script>

<script>
  // À l'upload du logo : on génère EN PLUS une icône carrée 512² (logo centré
  // sur fond couleur club) pour l'écran d'accueil iOS/Android, stockée en
  // icon_url. Enhancement raster only ; sans JS le form POST classique upload
  // le logo seul (dégradation gracieuse).
  import { computeIconLayout } from '../../../../lib/club-icon';

  const form = document.querySelector('[data-logo-form]') as HTMLFormElement | null;
  if (form) {
    const fileInput = form.querySelector('input[type="file"]') as HTMLInputElement;
    const clubId = form.dataset.clubId!;

    form.addEventListener('submit', async (e) => {
      const file = fileInput.files?.[0];
      // SVG/autre → on laisse le POST normal (le serveur valide/refuse).
      if (!file || !/^image\/(png|jpeg|webp)$/.test(file.type)) return;
      e.preventDefault();
      const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      const original = btn.textContent;
      btn.disabled = true;
      btn.textContent = 'Traitement…';
      try {
        // 1) Upload du logo original.
        const logoFd = new FormData();
        logoFd.append('file', file);
        const logoRes = await fetch(`/api/ops/clubs/${clubId}/upload?kind=logo`, { method: 'POST', body: logoFd });
        if (!logoRes.ok) throw new Error('logo');
        // 2) Génération du carré 512² + upload comme icône écran d'accueil.
        const blob = await generateSquareIcon(file);
        const iconFd = new FormData();
        iconFd.append('file', blob, 'icon.png');
        const iconRes = await fetch(`/api/ops/clubs/${clubId}/upload?kind=icon`, { method: 'POST', body: iconFd });
        if (!iconRes.ok) throw new Error('icon');
        window.location.href = `/ops/clubs/${clubId}/edit?ok=1`;
      } catch {
        btn.disabled = false;
        btn.textContent = original;
        window.location.href = `/ops/clubs/${clubId}/edit?err=${encodeURIComponent('Upload logo/icône échoué')}`;
      }
    });
  }

  async function generateSquareIcon(file: File): Promise<Blob> {
    const bitmap = await createImageBitmap(file);
    const SIZE = 512;
    const PADDING = 0.1;
    const { drawW, drawH, dx, dy } = computeIconLayout(bitmap.width, bitmap.height, SIZE, PADDING);
    const canvas = document.createElement('canvas');
    canvas.width = SIZE;
    canvas.height = SIZE;
    const ctx = canvas.getContext('2d')!;
    // Fond blanc : se fond avec les logos sur fond blanc (cas courant), neutre
    // pour les logos transparents. Évite la bordure de couleur autour du logo.
    ctx.fillStyle = '#FFFFFF';
    ctx.fillRect(0, 0, SIZE, SIZE);
    ctx.drawImage(bitmap, dx, dy, drawW, drawH);
    return await new Promise<Blob>((resolve, reject) =>
      canvas.toBlob((b) => (b ? resolve(b) : reject(new Error('toBlob failed'))), 'image/png'),
    );
  }
</script>

<script>
  // Toggle « Un seul parcours / Plusieurs boucles » + éditeur multi-boucles.
  // Le mode multi sérialise tout son modèle (boucles + formats cochés) dans le
  // champ caché course_loops_json ; l'API le re-valide et recalcule le plat.
  import { suggestFormats, loopIdsKey, resolvePrimaryFlatHoles } from '../../../../lib/course-formats';

  type EditorHole = { par: number };
  type EditorLoop = { id: string; name: string; holes: EditorHole[] };

  const totalLabel = document.querySelector('[data-total-par]');
  const modeRadios = Array.from(document.querySelectorAll('[data-mode-radio]')) as HTMLInputElement[];
  const singleEditor = document.querySelector('[data-editor="single"]') as HTMLElement | null;
  const multiEditor = document.querySelector('[data-editor="multi"]') as HTMLElement | null;

  // Présent uniquement sur la page d'édition club (sinon on ne fait rien).
  if (modeRadios.length && multiEditor) {
    const loopsListEl = multiEditor.querySelector('[data-loops-list]') as HTMLElement;
    const formatsListEl = multiEditor.querySelector('[data-formats-list]') as HTMLElement;
    const jsonInput = multiEditor.querySelector('[data-loops-json]') as HTMLInputElement;
    const errorEl = multiEditor.querySelector('[data-loops-error]') as HTMLElement;
    const addBtn = multiEditor.querySelector('[data-add-loop]') as HTMLButtonElement;
    const form = document.getElementById('identity-form') as HTMLFormElement | null;

    let loops: EditorLoop[] = [];
    let initialFormats: { id: string; label: string; loop_ids: string[] }[] = [];
    // Choix utilisateur par format (clé = ensemble de boucles) : coché + libellé.
    const userFmt = new Map<string, { enabled: boolean; label: string }>();
    let seq = 0;

    const currentMode = (): string => modeRadios.find((r) => r.checked)?.value ?? 'single';

    function uniqueLoopId(): string {
      const taken = new Set(loops.map((l) => l.id));
      let id: string;
      do { id = 'loop-' + (++seq); } while (taken.has(id));
      return id;
    }
    const nineHoles = (): EditorHole[] => Array.from({ length: 9 }, () => ({ par: 4 }));

    // Formats actuellement cochés (ce qui sera persisté).
    function enabledFormats() {
      const out: { id: string; label: string; loop_ids: string[] }[] = [];
      for (const s of suggestFormats(loops, initialFormats)) {
        const o = userFmt.get(loopIdsKey(s.loop_ids));
        const enabled = o ? o.enabled : s.enabled;
        if (!enabled) continue;
        out.push({ id: s.id, label: o && o.label ? o.label : s.label, loop_ids: s.loop_ids });
      }
      return out;
    }

    function serialize() {
      const formats = enabledFormats();
      jsonInput.value = JSON.stringify({
        loops: loops.map((l) => ({ id: l.id, name: l.name, holes: l.holes.map((h) => ({ par: h.par })) })),
        formats,
      });
      if (currentMode() === 'multi' && totalLabel) {
        const modelLoops = loops.map((l) => ({
          id: l.id,
          name: l.name,
          holes: l.holes.map((h, i) => ({ number: i + 1, par: h.par })),
        }));
        const flat = resolvePrimaryFlatHoles(modelLoops, formats);
        totalLabel.textContent = 'Par ' + flat.reduce((s, h) => s + h.par, 0);
      }
    }

    function renderLoops() {
      loopsListEl.innerHTML = '';
      loops.forEach((loop, idx) => {
        const card = document.createElement('div');
        card.className = 'loop-card';

        const head = document.createElement('div');
        head.className = 'loop-head';

        const nameInput = document.createElement('input');
        nameInput.className = 'ops-input loop-name';
        nameInput.placeholder = 'Nom de la boucle (ex. La Plaine)';
        nameInput.value = loop.name;
        nameInput.maxLength = 120;
        nameInput.addEventListener('input', () => {
          loop.name = nameInput.value;
          renderFormats();
          serialize();
        });

        const holesSel = document.createElement('select');
        holesSel.className = 'ops-input loop-holes-select';
        for (const n of [6, 9]) {
          const opt = document.createElement('option');
          opt.value = String(n);
          opt.textContent = n + ' trous';
          if (loop.holes.length === n) opt.selected = true;
          holesSel.appendChild(opt);
        }
        holesSel.addEventListener('change', () => {
          const n = Number(holesSel.value);
          const cur = loop.holes;
          loop.holes = Array.from({ length: n }, (_, i) => cur[i] ?? { par: 4 });
          renderLoops();
          renderFormats();
          serialize();
        });

        const removeBtn = document.createElement('button');
        removeBtn.type = 'button';
        removeBtn.className = 'ops-btn loop-remove';
        removeBtn.textContent = 'Retirer';
        removeBtn.disabled = loops.length <= 1;
        removeBtn.addEventListener('click', () => {
          if (loops.length <= 1) return;
          loops.splice(idx, 1);
          renderLoops();
          renderFormats();
          serialize();
        });

        head.appendChild(nameInput);
        head.appendChild(holesSel);
        head.appendChild(removeBtn);
        card.appendChild(head);

        const grid = document.createElement('div');
        grid.className = 'loop-grid';
        grid.style.setProperty('--row-cells', String(loop.holes.length));
        loop.holes.forEach((hole, hi) => {
          const cell = document.createElement('label');
          cell.className = 'loop-cell';
          const num = document.createElement('span');
          num.className = 'loop-cell-num';
          num.textContent = String(hi + 1);
          const input = document.createElement('input');
          input.className = 'loop-par-input';
          input.type = 'number';
          input.min = '2';
          input.max = '6';
          input.value = String(hole.par);
          input.addEventListener('input', () => {
            const v = Number(input.value);
            hole.par = Number.isFinite(v) ? v : NaN;
            serialize();
          });
          cell.appendChild(num);
          cell.appendChild(input);
          grid.appendChild(cell);
        });
        card.appendChild(grid);
        loopsListEl.appendChild(card);
      });
    }

    function renderFormats() {
      formatsListEl.innerHTML = '';
      const nameById = new Map(loops.map((l) => [l.id, l.name.trim() || '(sans nom)']));
      const suggestions = suggestFormats(loops, initialFormats);
      if (suggestions.length === 0) {
        const empty = document.createElement('p');
        empty.className = 'ops-hint';
        empty.textContent = 'Ajoute des boucles pour voir les formats.';
        formatsListEl.appendChild(empty);
        return;
      }
      for (const s of suggestions) {
        const key = loopIdsKey(s.loop_ids);
        const o = userFmt.get(key);
        const enabled = o ? o.enabled : s.enabled;
        const label = o && o.label ? o.label : s.label;

        const row = document.createElement('div');
        row.className = 'format-row';
        if (!enabled) row.classList.add('is-off');

        const cb = document.createElement('input');
        cb.type = 'checkbox';
        cb.className = 'format-enable';
        cb.checked = enabled;

        const labelInput = document.createElement('input');
        labelInput.className = 'ops-input format-label';
        labelInput.value = label;
        labelInput.maxLength = 120;

        const desc = document.createElement('span');
        desc.className = 'format-desc';
        desc.textContent = s.loop_ids.map((id) => nameById.get(id) ?? id).join(' + ');

        const sync = () => {
          userFmt.set(key, { enabled: cb.checked, label: labelInput.value });
          row.classList.toggle('is-off', !cb.checked);
          serialize();
        };
        cb.addEventListener('change', sync);
        labelInput.addEventListener('input', sync);

        row.appendChild(cb);
        row.appendChild(labelInput);
        row.appendChild(desc);
        formatsListEl.appendChild(row);
      }
    }

    function renderAll() {
      renderLoops();
      renderFormats();
      serialize();
    }

    addBtn.addEventListener('click', () => {
      loops.push({ id: uniqueLoopId(), name: '', holes: nineHoles() });
      renderLoops();
      renderFormats();
      serialize();
    });

    // --- Toggle de mode : montre/masque + (dés)active les champs de chaque
    //     éditeur pour qu'un `required` hors écran ne bloque pas l'envoi. ---
    function setEditorEnabled(editor: HTMLElement | null, on: boolean) {
      if (!editor) return;
      editor.hidden = !on;
      editor.querySelectorAll('input, select, button, textarea').forEach((el) => {
        const node = el as HTMLInputElement;
        if (node.type === 'hidden') return;
        node.disabled = !on;
      });
    }
    function singleTotal(): number {
      let total = 0;
      singleEditor?.querySelectorAll('.course-cell-input').forEach((el) => {
        const v = Number((el as HTMLInputElement).value);
        if (Number.isFinite(v)) total += v;
      });
      return total;
    }
    function applyMode(mode: string) {
      setEditorEnabled(singleEditor, mode === 'single');
      setEditorEnabled(multiEditor, mode === 'multi');
      if (mode === 'multi') renderAll();
      else if (totalLabel) totalLabel.textContent = 'Par ' + singleTotal();
    }
    modeRadios.forEach((r) => r.addEventListener('change', () => applyMode(currentMode())));

    // --- Validation au submit (mode multi seulement). ---
    form?.addEventListener('submit', (e) => {
      if (currentMode() !== 'multi') return;
      serialize();
      let err = '';
      if (loops.some((l) => !l.name.trim())) err = 'Chaque boucle doit avoir un nom.';
      else if (loops.some((l) => l.holes.some((h) => !Number.isInteger(h.par) || h.par < 2 || h.par > 6)))
        err = 'Tous les pars doivent être des entiers entre 2 et 6.';
      else if (enabledFormats().length === 0) err = 'Coche au moins un format à proposer aux golfeurs.';
      if (err) {
        e.preventDefault();
        errorEl.textContent = err;
        errorEl.hidden = false;
        errorEl.scrollIntoView({ block: 'center', behavior: 'smooth' });
      } else {
        errorEl.hidden = true;
      }
    });

    // --- Init du modèle depuis les données SSR. ---
    const rawLoops = JSON.parse(multiEditor.dataset.initialLoops || '[]');
    initialFormats = JSON.parse(multiEditor.dataset.initialFormats || '[]');
    loops = rawLoops.map((l: any) => ({
      id: String(l.id || ''),
      name: String(l.name || ''),
      holes: Array.isArray(l.holes) && l.holes.length
        ? l.holes.map((h: any) => ({ par: Number(h.par) || 4 }))
        : nineHoles(),
    }));
    for (const l of loops) {
      const m = /^loop-(\d+)$/.exec(l.id);
      if (m) seq = Math.max(seq, Number(m[1]));
    }
    if (loops.length === 0) loops = [{ id: uniqueLoopId(), name: '', holes: nineHoles() }];
    for (const f of initialFormats) userFmt.set(loopIdsKey(f.loop_ids), { enabled: true, label: f.label });

    applyMode(currentMode());
  }
</script>

