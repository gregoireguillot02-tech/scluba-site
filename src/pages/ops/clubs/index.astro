---
export const prerender = false;

import OpsLayout from '../../../layouts/OpsLayout.astro';
import { serviceClient } from '../../../lib/supabase';
import { escapeLikePattern } from '../../../lib/safe-redirect';
import type { Club } from '../../../lib/clubs-types';

const sb = serviceClient();
const url = new URL(Astro.request.url);
const q = (url.searchParams.get('q') ?? '').trim();

// Only accept Supabase Storage public URLs in the background-image slot so a
// poisoned photo_url can't smuggle CSS expressions (`)` / `;` / quotes).
function safePhotoUrl(raw: string | null | undefined): string | null {
  if (!raw) return null;
  try {
    const u = new URL(raw);
    if (u.protocol !== 'https:') return null;
    if (!/\.supabase\.co$/i.test(u.hostname)) return null;
    if (/["'()\\\s]/.test(raw)) return null;
    return u.toString();
  } catch {
    return null;
  }
}

function safeHexAccent(raw: string | null | undefined, fallback: string): string {
  if (!raw) return fallback;
  return /^#[0-9A-Fa-f]{6}$/.test(raw) ? raw : fallback;
}

let query = sb.from('clubs').select('*, prospect:prospects(id, club_name)').order('created_at', { ascending: false });
if (q) {
  const escaped = escapeLikePattern(q).replace(/[,()]/g, ' ');
  query = query.or(`name.ilike.%${escaped}%,city.ilike.%${escaped}%,slug.ilike.%${escaped}%`);
}
const { data: clubs } = await query;

const allClubs = (clubs ?? []) as (Club & { prospect: { id: string; club_name: string } | null })[];

// Build round counts per club so we can show activity at a glance.
const clubIds = allClubs.map((c) => c.id);
const { data: roundsRaw } = clubIds.length
  ? await sb.from('rounds').select('club_id, status').in('club_id', clubIds)
  : { data: [] as { club_id: string; status: string }[] };
const rounds = (roundsRaw ?? []) as { club_id: string; status: string }[];

const roundCounts: Record<string, { total: number; active: number; finished: number }> = {};
for (const r of rounds) {
  if (!roundCounts[r.club_id]) roundCounts[r.club_id] = { total: 0, active: 0, finished: 0 };
  roundCounts[r.club_id].total++;
  if (r.status === 'finished') roundCounts[r.club_id].finished++;
  else roundCounts[r.club_id].active++;
}

function fmtDate(iso: string): string {
  return new Date(iso).toLocaleDateString('fr-FR', { day: '2-digit', month: 'short', year: 'numeric' });
}
---

<OpsLayout title="Clubs" active="clubs">
  <div class="ops-page-header">
    <div>
      <h1 class="ops-page-title">Clubs</h1>
      <p class="ops-page-subtitle">{allClubs.length} club{allClubs.length > 1 ? 's' : ''} avec page active</p>
    </div>
    <div class="header-actions">
      <a href="/ops/clubs/import" class="ops-btn ops-btn-primary">+ Importer depuis URL</a>
      <form method="GET" class="search-form">
        <input
          class="ops-input"
          type="search"
          name="q"
          value={q}
          placeholder="Chercher par nom, ville, slug…"
        />
        <button type="submit" class="ops-btn">Filtrer</button>
      </form>
    </div>
  </div>

  {allClubs.length === 0 ? (
    <div class="ops-card">
      <p class="ops-empty">
        {q ? `Aucun club ne correspond à "${q}".` : "Aucun club encore. Génère une page depuis une fiche prospect."}
      </p>
    </div>
  ) : (
    <ul class="club-grid">
      {allClubs.map((c) => {
        const counts = roundCounts[c.id] ?? { total: 0, active: 0, finished: 0 };
        const accent = safeHexAccent(c.primary_color, '#1B4332');
        const photo = safePhotoUrl(c.photo_url);
        const logo = safePhotoUrl(c.logo_url);
        return (
          <li class="club-tile">
            <div
              class:list={["club-tile-photo", { "has-photo": !!photo }]}
              style={photo
                ? { "--club-photo": `url("${photo}")` }
                : { background: accent }}
            >
              {logo && <img class="club-tile-logo" src={logo} alt="" />}
            </div>
            <div class="club-tile-body">
              <h2 class="club-tile-name" style={{ color: accent }}>{c.name}</h2>
              <p class="club-tile-meta">
                {c.city && <span>{c.city}</span>}
                {c.city && <span class="dot" aria-hidden="true">·</span>}
                <code>{c.slug}</code>
              </p>
              {c.prospect && (
                <p class="club-tile-prospect">
                  <a href={`/ops/prospects/${c.prospect.id}`}>Fiche prospect</a>
                </p>
              )}
              <p class="club-tile-stats">
                <span><strong>{counts.total}</strong> partie{counts.total > 1 ? 's' : ''}</span>
                {counts.active > 0 && <span class="active-badge">{counts.active} en cours</span>}
              </p>
              <p class="club-tile-date">Créé {fmtDate(c.created_at)}</p>

              <div class="club-tile-actions">
                <a href={`/ops/clubs/${c.id}/edit`} class="ops-btn ops-btn-primary">Modifier</a>
                <a href={`/ops/clubs/${c.id}/print`} class="ops-btn">Kit</a>
                <a href={`/ops/clubs/${c.id}/qr`} class="ops-btn">QR</a>
                <a href={`/${c.slug}`} target="_blank" rel="noopener" class="ops-btn ops-btn-ghost">Page</a>
              </div>
            </div>
          </li>
        );
      })}
    </ul>
  )}
</OpsLayout>

<style>
  .header-actions {
    display: flex;
    gap: 10px;
    align-items: center;
    flex-wrap: wrap;
  }
  .search-form {
    display: flex;
    gap: 8px;
    align-items: center;
  }
  .search-form .ops-input { width: 240px; }
  @media (max-width: 700px) {
    .header-actions { width: 100%; }
    .search-form { width: 100%; flex-wrap: wrap; }
    .search-form .ops-input { flex: 1; min-width: 200px; }
  }

  .club-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 16px;
  }

  .club-tile {
    background: var(--bg);
    border: 1px solid var(--line);
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 1px 2px rgba(15,42,30,0.04);
    transition: box-shadow 0.15s, transform 0.1s;
  }
  .club-tile:hover {
    box-shadow: 0 1px 2px rgba(15,42,30,0.08), 0 8px 20px rgba(27,67,50,0.08);
  }

  .club-tile-photo {
    height: 120px;
    position: relative;
    background-color: var(--primary);
    display: flex;
    align-items: flex-end;
    padding: 12px;
  }
  .club-tile-photo.has-photo {
    background-image: var(--club-photo);
    background-size: cover;
    background-position: center 55%;
  }
  .club-tile-logo {
    width: 44px;
    height: 44px;
    object-fit: contain;
    background: rgba(250, 247, 238, 0.94);
    border-radius: 50%;
    padding: 4px;
    box-shadow: 0 1px 2px rgba(0,0,0,0.16);
  }

  .club-tile-body {
    padding: 14px 16px 16px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .club-tile-name {
    font-family: var(--font-serif);
    font-size: 17px;
    font-weight: 700;
    margin: 0;
    letter-spacing: 0.02em;
  }
  .club-tile-meta {
    margin: 0;
    font-size: 13px;
    color: var(--muted);
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
  }
  .club-tile-meta code {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    background: var(--line-soft);
    padding: 1px 6px;
    border-radius: 4px;
    font-size: 11px;
  }
  .club-tile-meta .dot { color: var(--accent); }

  .club-tile-prospect {
    margin: 0;
    font-size: 12px;
  }
  .club-tile-prospect a {
    color: var(--primary-soft);
    text-decoration: none;
    border-bottom: 1px dashed var(--primary-soft);
  }
  .club-tile-prospect a:hover { color: var(--primary); }

  .club-tile-stats {
    margin: 4px 0 0;
    font-size: 13px;
    color: var(--ink-soft);
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .active-badge {
    background: rgba(212, 165, 116, 0.18);
    color: #92400E;
    padding: 2px 8px;
    border-radius: 999px;
    font-size: 11px;
    font-weight: 600;
  }
  .club-tile-date {
    margin: 0;
    font-size: 12px;
    color: var(--muted-soft);
  }

  .club-tile-actions {
    display: flex;
    gap: 6px;
    margin-top: 12px;
    flex-wrap: wrap;
  }
  .club-tile-actions .ops-btn {
    flex: 1;
    justify-content: center;
    padding: 7px 12px;
    font-size: 13px;
    min-width: 60px;
  }
</style>
