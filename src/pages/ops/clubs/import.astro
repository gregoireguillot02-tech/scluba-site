---
export const prerender = false;

import OpsLayout from '../../../layouts/OpsLayout.astro';
---

<OpsLayout title="Importer un club" active="clubs">
  <div class="ops-page-header">
    <div>
      <a href="/ops/clubs" class="back-link">← Tous les clubs</a>
      <h1 class="ops-page-title">Importer un club depuis son site</h1>
      <p class="ops-page-subtitle">
        Colle l'URL du site officiel du club. Scluba récupère logo, photo, couleur, nom, parcours et pars. Tu corriges si besoin avant de sauver.
      </p>
    </div>
  </div>

  <section class="ops-card import-launcher">
    <form id="import-form" class="launcher-form">
      <label for="url" class="ops-label">URL du site (https://…)</label>
      <div class="launcher-row">
        <input class="ops-input" type="url" id="url" name="url" placeholder="https://www.golf-lyon-tassin.fr" required />
        <button type="submit" class="ops-btn ops-btn-primary" id="import-btn">Importer</button>
      </div>
      <p class="hint">Comptez ~10s : on lit la page d'accueil + les pages parcours, on télécharge le logo, et Claude structure les infos.</p>
    </form>
  </section>

  <section id="status" class="status" hidden>
    <div class="status-spinner" aria-hidden="true"></div>
    <span id="status-text">Analyse en cours…</span>
  </section>

  <section id="error" class="ops-flash ops-flash-err" hidden></section>

  <section id="preview" class="preview-wrap" hidden>
    <header class="preview-head">
      <h2>Aperçu</h2>
      <p class="hint">Vérifie chaque champ. Les warnings ci-dessous demandent ton attention.</p>
    </header>

    <ul id="warnings" class="warnings" hidden></ul>
    <p id="llm-notes" class="llm-notes" hidden></p>

    <form id="save-form" class="preview-form">
      <div class="preview-grid">
        <div>
          <label class="ops-label" for="name">Nom du club</label>
          <input class="ops-input" type="text" id="name" name="name" required maxlength="120" />
        </div>

        <div>
          <label class="ops-label" for="city">Ville</label>
          <input class="ops-input" type="text" id="city" name="city" maxlength="120" />
        </div>

        <div>
          <label class="ops-label" for="primary_color">Couleur primaire</label>
          <div class="color-row">
            <input class="color-picker" type="color" id="primary_color_picker" title="Clique pour ouvrir le sélecteur de couleur" aria-label="Sélecteur de couleur" />
            <input class="ops-input color-hex" type="text" id="primary_color" name="primary_color" pattern="#[0-9A-Fa-f]{6}" maxlength="7" />
          </div>
          <p class="hint color-hint">Clique le carré pour ouvrir le sélecteur de couleur.</p>
        </div>
      </div>

      <div class="assets-row">
        <div class="asset-card">
          <span class="ops-label">Logo</span>
          <div class="asset-frame" id="logo-frame">
            <img id="logo-img" alt="logo détecté" />
            <p id="logo-missing" class="asset-missing" hidden>Pas de logo détecté</p>
          </div>
          <p class="hint" id="logo-source"></p>
          <p class="hint asset-status" id="logo-status" hidden></p>
          <div class="asset-actions">
            <input type="file" id="logo-file" accept="image/png,image/jpeg,image/webp" hidden />
            <button type="button" class="ops-btn ops-btn-ghost asset-btn" id="logo-replace">Remplacer par un fichier</button>
            <button type="button" class="ops-btn ops-btn-ghost asset-btn" id="logo-clear" hidden>Effacer</button>
          </div>
          <p class="hint asset-error" id="logo-error" hidden></p>
        </div>
        <div class="asset-card">
          <span class="ops-label">Photo</span>
          <div class="asset-frame asset-frame-wide" id="photo-frame">
            <img id="photo-img" alt="photo détectée" />
            <p id="photo-missing" class="asset-missing" hidden>Pas de photo détectée</p>
          </div>
          <p class="hint" id="photo-source"></p>
          <p class="hint asset-status" id="photo-status" hidden></p>
          <div class="asset-actions">
            <input type="file" id="photo-file" accept="image/png,image/jpeg,image/webp" hidden />
            <button type="button" class="ops-btn ops-btn-ghost asset-btn" id="photo-replace">Remplacer par un fichier</button>
            <button type="button" class="ops-btn ops-btn-ghost asset-btn" id="photo-clear" hidden>Effacer</button>
          </div>
          <p class="hint asset-error" id="photo-error" hidden></p>
        </div>
      </div>

      <div id="loops" class="loops"></div>

      <div class="save-actions">
        <button type="submit" id="save-btn" class="ops-btn ops-btn-primary">Créer le club</button>
        <a href="/ops/clubs" class="ops-btn ops-btn-ghost">Annuler</a>
      </div>
    </form>
  </section>
</OpsLayout>

<script>
type Hole = { number: number; par: number };
type Loop = { id: string; name: string; holes: Hole[] };
type CourseData = { holes: Hole[]; loops?: Loop[]; formats?: { id: string; label: string; loop_ids: string[] }[] };
type ImportResult = {
  source_url: string;
  name: string;
  city: string | null;
  primary_color: string;
  logo_url: string | null;
  photo_url: string | null;
  course_data: CourseData;
  warnings: string[];
  llm_notes: string | null;
};

const $ = <T extends HTMLElement>(id: string) => document.getElementById(id) as T;

type AssetKind = 'logo' | 'photo';

let current: ImportResult | null = null;

const localFiles: Record<AssetKind, File | null> = { logo: null, photo: null };
const cleared: Record<AssetKind, boolean> = { logo: false, photo: false };
const blobUrls: Record<AssetKind, string | null> = { logo: null, photo: null };

const ASSET_LIMITS: Record<AssetKind, { maxBytes: number; label: string }> = {
  logo: { maxBytes: 500 * 1024, label: '500 Ko' },
  photo: { maxBytes: 5 * 1024 * 1024, label: '5 Mo' },
};
const ALLOWED_MIME = new Set(['image/png', 'image/jpeg', 'image/webp']);

function showError(msg: string) {
  const el = $<HTMLElement>('error');
  el.textContent = msg;
  el.hidden = false;
}
function clearError() { $<HTMLElement>('error').hidden = true; }

function setStatus(text: string | null) {
  const wrap = $<HTMLElement>('status');
  if (!text) { wrap.hidden = true; return; }
  $<HTMLElement>('status-text').textContent = text;
  wrap.hidden = false;
}

function renderLoops(course: CourseData) {
  const root = $<HTMLElement>('loops');
  root.innerHTML = '';
  const loops = course.loops ?? [{ id: 'main', name: 'Parcours', holes: course.holes }];
  loops.forEach((loop, loopIdx) => {
    const section = document.createElement('section');
    section.className = 'loop-card';
    const header = document.createElement('header');
    header.className = 'loop-head';
    const nameInput = document.createElement('input');
    nameInput.type = 'text';
    nameInput.className = 'ops-input loop-name';
    nameInput.value = loop.name;
    nameInput.dataset.loopIdx = String(loopIdx);
    nameInput.maxLength = 80;
    const meta = document.createElement('span');
    meta.className = 'loop-meta';
    meta.textContent = `${loop.holes.length} trou${loop.holes.length > 1 ? 's' : ''} · par total ${loop.holes.reduce((s, h) => s + h.par, 0)}`;
    header.appendChild(nameInput);
    header.appendChild(meta);
    section.appendChild(header);

    const grid = document.createElement('div');
    grid.className = 'hole-grid';
    loop.holes.forEach((h, holeIdx) => {
      const cell = document.createElement('label');
      cell.className = 'hole-cell';
      const num = document.createElement('span');
      num.className = 'hole-num';
      num.textContent = String(h.number);
      const input = document.createElement('input');
      input.type = 'number';
      input.min = '3';
      input.max = '6';
      input.value = String(h.par);
      input.className = 'hole-par';
      input.dataset.loopIdx = String(loopIdx);
      input.dataset.holeIdx = String(holeIdx);
      input.required = true;
      input.addEventListener('input', () => {
        const v = Number(input.value);
        if (Number.isFinite(v)) {
          loop.holes[holeIdx].par = v;
          meta.textContent = `${loop.holes.length} trou${loop.holes.length > 1 ? 's' : ''} · par total ${loop.holes.reduce((s, h) => s + h.par, 0)}`;
        }
      });
      cell.appendChild(num);
      cell.appendChild(input);
      grid.appendChild(cell);
    });
    section.appendChild(grid);
    root.appendChild(section);

    nameInput.addEventListener('input', () => {
      loop.name = nameInput.value;
    });
  });
}

function revokeBlobUrl(kind: AssetKind) {
  if (blobUrls[kind]) {
    URL.revokeObjectURL(blobUrls[kind]!);
    blobUrls[kind] = null;
  }
}

function resetAssetState() {
  for (const kind of ['logo', 'photo'] as const) {
    revokeBlobUrl(kind);
    localFiles[kind] = null;
    cleared[kind] = false;
    const fileInput = document.getElementById(`${kind}-file`) as HTMLInputElement | null;
    if (fileInput) fileInput.value = '';
    const errEl = document.getElementById(`${kind}-error`) as HTMLElement | null;
    if (errEl) { errEl.textContent = ''; errEl.hidden = true; }
  }
}

function applyAssetState(kind: AssetKind) {
  if (!current) return;
  const img = document.getElementById(`${kind}-img`) as HTMLImageElement;
  const missing = document.getElementById(`${kind}-missing`) as HTMLElement;
  const sourceEl = document.getElementById(`${kind}-source`) as HTMLElement;
  const statusEl = document.getElementById(`${kind}-status`) as HTMLElement;
  const clearBtn = document.getElementById(`${kind}-clear`) as HTMLButtonElement;
  const replaceBtn = document.getElementById(`${kind}-replace`) as HTMLButtonElement;

  const sourceUrl = kind === 'logo' ? current.logo_url : current.photo_url;
  const file = localFiles[kind];
  const isCleared = cleared[kind];

  if (file) {
    revokeBlobUrl(kind);
    const blobUrl = URL.createObjectURL(file);
    blobUrls[kind] = blobUrl;
    img.src = blobUrl;
    img.hidden = false;
    missing.hidden = true;
    sourceEl.hidden = true;
    sourceEl.textContent = '';
    statusEl.textContent = `Fichier local : ${file.name} (${Math.round(file.size / 1024)} Ko)`;
    statusEl.hidden = false;
    clearBtn.hidden = false;
    replaceBtn.textContent = 'Choisir un autre fichier';
  } else if (isCleared) {
    revokeBlobUrl(kind);
    img.removeAttribute('src');
    img.hidden = true;
    missing.hidden = false;
    sourceEl.hidden = true;
    sourceEl.textContent = '';
    statusEl.textContent = 'Sera vide — uploade depuis la page édition.';
    statusEl.hidden = false;
    clearBtn.hidden = true;
    replaceBtn.textContent = 'Remplacer par un fichier';
  } else if (sourceUrl) {
    revokeBlobUrl(kind);
    img.src = sourceUrl;
    img.hidden = false;
    missing.hidden = true;
    sourceEl.textContent = `Source : ${sourceUrl}`;
    sourceEl.hidden = false;
    statusEl.hidden = true;
    statusEl.textContent = '';
    clearBtn.hidden = false;
    replaceBtn.textContent = 'Remplacer par un fichier';
  } else {
    revokeBlobUrl(kind);
    img.removeAttribute('src');
    img.hidden = true;
    missing.hidden = false;
    sourceEl.hidden = true;
    sourceEl.textContent = '';
    statusEl.hidden = true;
    statusEl.textContent = '';
    clearBtn.hidden = true;
    replaceBtn.textContent = 'Choisir un fichier';
  }
}

function showAssetError(kind: AssetKind, msg: string) {
  const errEl = document.getElementById(`${kind}-error`) as HTMLElement;
  errEl.textContent = msg;
  errEl.hidden = false;
}

function clearAssetError(kind: AssetKind) {
  const errEl = document.getElementById(`${kind}-error`) as HTMLElement;
  errEl.textContent = '';
  errEl.hidden = true;
}

function handleFileChosen(kind: AssetKind, file: File) {
  clearAssetError(kind);
  if (!ALLOWED_MIME.has(file.type)) {
    showAssetError(kind, `Format non supporté (${file.type || 'inconnu'}). Utilise PNG, JPEG ou WebP.`);
    return;
  }
  const { maxBytes, label } = ASSET_LIMITS[kind];
  if (file.size > maxBytes) {
    showAssetError(kind, `Fichier trop lourd (${Math.round(file.size / 1024)} Ko). Max ${label}.`);
    return;
  }
  localFiles[kind] = file;
  cleared[kind] = false;
  applyAssetState(kind);
}

function renderPreview(r: ImportResult) {
  current = r;
  resetAssetState();
  $<HTMLInputElement>('name').value = r.name;
  $<HTMLInputElement>('city').value = r.city ?? '';
  $<HTMLInputElement>('primary_color').value = r.primary_color;
  // Safari throws "The string did not match the expected pattern" when
  // <input type="color">.value is set to a hex with uppercase letters,
  // even though the HTML spec says to sanitize silently. Force lowercase.
  $<HTMLInputElement>('primary_color_picker').value = r.primary_color.toLowerCase();

  applyAssetState('logo');
  applyAssetState('photo');

  const warnList = $<HTMLElement>('warnings');
  warnList.innerHTML = '';
  if (r.warnings.length) {
    for (const w of r.warnings) {
      const li = document.createElement('li');
      li.textContent = w;
      warnList.appendChild(li);
    }
    warnList.hidden = false;
  } else {
    warnList.hidden = true;
  }

  const notes = $<HTMLElement>('llm-notes');
  if (r.llm_notes) {
    notes.textContent = `Note de l'IA : ${r.llm_notes}`;
    notes.hidden = false;
  } else {
    notes.hidden = true;
  }

  renderLoops(r.course_data);

  $<HTMLElement>('preview').hidden = false;
}

$<HTMLFormElement>('import-form').addEventListener('submit', async (e) => {
  e.preventDefault();
  clearError();
  $<HTMLElement>('preview').hidden = true;
  const url = $<HTMLInputElement>('url').value.trim();
  if (!url) return;
  const btn = $<HTMLButtonElement>('import-btn');
  btn.disabled = true;
  setStatus('Analyse en cours… (peut prendre 10-20s)');
  try {
    const res = await fetch('/api/ops/clubs/import', {
      method: 'POST',
      headers: { 'content-type': 'application/json' },
      body: JSON.stringify({ url }),
    });
    const json = await res.json();
    if (!res.ok || !json.ok) throw new Error(json.error ?? `HTTP ${res.status}`);
    renderPreview(json.data as ImportResult);
  } catch (err) {
    showError(err instanceof Error ? err.message : 'Erreur inconnue');
  } finally {
    setStatus(null);
    btn.disabled = false;
  }
});

$<HTMLInputElement>('primary_color_picker').addEventListener('input', (e) => {
  const v = (e.target as HTMLInputElement).value.toUpperCase();
  $<HTMLInputElement>('primary_color').value = v;
});
$<HTMLInputElement>('primary_color').addEventListener('input', (e) => {
  const v = (e.target as HTMLInputElement).value;
  if (/^#[0-9A-Fa-f]{6}$/.test(v)) {
    $<HTMLInputElement>('primary_color_picker').value = v.toLowerCase();
  }
});

for (const kind of ['logo', 'photo'] as const) {
  const fileInput = $<HTMLInputElement>(`${kind}-file`);
  const replaceBtn = $<HTMLButtonElement>(`${kind}-replace`);
  const clearBtn = $<HTMLButtonElement>(`${kind}-clear`);

  replaceBtn.addEventListener('click', () => {
    fileInput.click();
  });
  fileInput.addEventListener('change', () => {
    const file = fileInput.files?.[0];
    if (!file) return;
    handleFileChosen(kind, file);
    // Reset value so picking the same file twice re-fires change.
    fileInput.value = '';
  });
  clearBtn.addEventListener('click', () => {
    localFiles[kind] = null;
    cleared[kind] = true;
    clearAssetError(kind);
    applyAssetState(kind);
  });
}

$<HTMLFormElement>('save-form').addEventListener('submit', async (e) => {
  e.preventDefault();
  if (!current) return;
  clearError();

  const courseData = current.course_data;
  // Reflatten holes 1..N from current loops state (loops are mutated in place by inputs).
  const loops = courseData.loops;
  if (loops) {
    let n = 1;
    courseData.holes = [];
    for (const loop of loops) {
      for (const h of loop.holes) {
        courseData.holes.push({ number: n, par: h.par });
        h.number = n;
        n++;
      }
    }
  }

  // If the admin chose a local file or cleared the asset, don't send the
  // scraped URL — we'll either upload the local file after club creation, or
  // leave the asset empty for the edit page to fix.
  const logoOverride = localFiles.logo !== null || cleared.logo;
  const photoOverride = localFiles.photo !== null || cleared.photo;

  const payload = {
    name: $<HTMLInputElement>('name').value.trim(),
    city: $<HTMLInputElement>('city').value.trim() || null,
    primary_color: $<HTMLInputElement>('primary_color').value.toUpperCase(),
    source_logo_url: logoOverride ? null : current.logo_url,
    source_photo_url: photoOverride ? null : current.photo_url,
    course_data: courseData,
  };

  const btn = $<HTMLButtonElement>('save-btn');
  btn.disabled = true;
  setStatus('Création du club et upload des assets…');
  try {
    const res = await fetch('/api/ops/clubs/from-import', {
      method: 'POST',
      headers: { 'content-type': 'application/json' },
      body: JSON.stringify(payload),
    });
    const json = await res.json();
    if (!res.ok || !json.ok) throw new Error(json.error ?? `HTTP ${res.status}`);

    const clubId = json.club_id as string;
    const uploadWarnings: string[] = [];

    for (const kind of ['logo', 'photo'] as const) {
      const file = localFiles[kind];
      if (!file) continue;
      setStatus(`Upload ${kind}…`);
      const fd = new FormData();
      fd.append('file', file);
      try {
        const r = await fetch(`/api/ops/clubs/${clubId}/upload?kind=${kind}`, {
          method: 'POST',
          body: fd,
        });
        if (!r.ok) {
          uploadWarnings.push(`Upload ${kind} a échoué (HTTP ${r.status}) — finalise depuis la page édition.`);
        }
      } catch {
        uploadWarnings.push(`Upload ${kind} a échoué (réseau) — finalise depuis la page édition.`);
      }
    }

    const redirectUrl = json.redirect ?? `/ops/clubs/${clubId}/edit?ok=1`;
    if (uploadWarnings.length) {
      showError(uploadWarnings.join(' · '));
      // Give the user a moment to read before redirecting.
      setTimeout(() => { window.location.href = redirectUrl; }, 2500);
    } else {
      window.location.href = redirectUrl;
    }
  } catch (err) {
    showError(err instanceof Error ? err.message : 'Erreur inconnue');
    btn.disabled = false;
  } finally {
    setStatus(null);
  }
});
</script>

<style>
  .back-link {
    display: inline-block;
    font-size: 13px;
    color: var(--muted);
    text-decoration: none;
    margin-bottom: 6px;
  }
  .back-link:hover { color: var(--ink); }

  .import-launcher { padding: 18px 20px; }
  .launcher-form { display: flex; flex-direction: column; gap: 8px; }
  .launcher-row {
    display: flex;
    gap: 10px;
    align-items: stretch;
    flex-wrap: wrap;
  }
  .launcher-row .ops-input { flex: 1; min-width: 280px; }
  .ops-label { display: block; font-size: 12px; color: var(--muted); font-weight: 600; text-transform: uppercase; letter-spacing: 0.04em; margin-bottom: 4px; }
  .hint { font-size: 12px; color: var(--muted); margin: 4px 0 0; }

  .status {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 16px;
    background: rgba(212, 165, 116, 0.10);
    border: 1px solid rgba(212, 165, 116, 0.4);
    border-radius: 8px;
    margin-top: 18px;
    font-size: 14px;
  }
  .status-spinner {
    width: 16px;
    height: 16px;
    border: 2px solid rgba(27, 67, 50, 0.2);
    border-top-color: var(--primary, #1B4332);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  .preview-wrap { margin-top: 24px; }
  .preview-head { margin-bottom: 14px; }
  .preview-head h2 {
    font-family: var(--font-serif);
    font-size: 22px;
    margin: 0 0 4px;
  }

  .warnings {
    list-style: none;
    margin: 0 0 12px;
    padding: 12px 14px;
    background: #FEF3C7;
    border: 1px solid #FBBF24;
    border-radius: 8px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    font-size: 13px;
    color: #78350F;
  }
  .warnings li::before { content: '⚠ '; font-weight: 700; }

  .llm-notes {
    margin: 0 0 12px;
    padding: 10px 14px;
    background: rgba(27, 67, 50, 0.06);
    border-left: 3px solid var(--primary, #1B4332);
    border-radius: 6px;
    font-size: 13px;
    color: var(--ink);
  }

  .preview-form { display: flex; flex-direction: column; gap: 20px; }

  .preview-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 14px;
  }
  .color-row { display: flex; gap: 8px; align-items: stretch; }
  .color-picker {
    width: 64px;
    height: 42px;
    border: 2px solid var(--line, #ddd);
    border-radius: 6px;
    padding: 0;
    cursor: pointer;
    transition: border-color 0.15s ease, transform 0.15s ease;
  }
  .color-picker:hover {
    border-color: var(--ink, #1B4332);
    transform: scale(1.03);
  }
  .color-picker:focus-visible {
    outline: 2px solid var(--primary, #1B4332);
    outline-offset: 2px;
  }
  .color-hex { flex: 1; font-family: ui-monospace, SFMono-Regular, Menlo, monospace; }
  .color-hint { font-style: italic; }

  .assets-row {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 16px;
  }
  @media (max-width: 700px) {
    .assets-row { grid-template-columns: 1fr; }
  }
  .asset-card { display: flex; flex-direction: column; gap: 6px; }
  .asset-frame {
    border: 1px dashed var(--line, #ccc);
    border-radius: 8px;
    background: rgba(0,0,0,0.02);
    min-height: 120px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding: 12px;
  }
  .asset-frame img { max-width: 100%; max-height: 180px; object-fit: contain; }
  .asset-frame-wide { min-height: 220px; }
  .asset-frame-wide img { max-height: 320px; }
  .asset-missing { color: var(--muted); font-size: 13px; margin: 0; }
  .asset-actions { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 4px; }
  .asset-btn { font-size: 13px; padding: 6px 12px; }
  .asset-status { color: var(--ink); font-weight: 500; }
  .asset-error { color: #B91C1C; font-weight: 500; }

  .loops { display: flex; flex-direction: column; gap: 14px; }
  .loop-card {
    border: 1px solid var(--line, #ddd);
    border-radius: 10px;
    padding: 14px;
    background: var(--bg, #fff);
  }
  .loop-head {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 12px;
    flex-wrap: wrap;
  }
  .loop-name { flex: 1; min-width: 180px; font-weight: 600; }
  .loop-meta { font-size: 12px; color: var(--muted); }

  .hole-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(54px, 1fr));
    gap: 6px;
  }
  .hole-cell {
