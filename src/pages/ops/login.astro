---
export const prerender = false;

import '../../styles/tokens.css';
import { isAllowedEmail } from '../../lib/supabase';

const url = Astro.url;
const next = url.searchParams.get('next') || '/ops';
const sent = url.searchParams.get('sent') === '1';
const errMsg = url.searchParams.get('err');

let formError: string | null = null;
let formSent = sent;

if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const email = String(formData.get('email') ?? '').trim().toLowerCase();
    const nextField = String(formData.get('next') ?? '/ops');

    if (!email) {
      formError = 'Email requis.';
    } else if (!isAllowedEmail(email)) {
      formError = "Cet email n'est pas autorisé. Contacte Grégoire ou Paul.";
    } else {
      const supabase = Astro.locals.supabase;
      const origin = url.origin;
      const redirectTo = `${origin}/ops/auth/callback?next=${encodeURIComponent(nextField)}`;
      const { error } = await supabase.auth.signInWithOtp({
        email,
        options: { emailRedirectTo: redirectTo },
      });
      if (error) {
        formError = `Erreur: ${error.message}`;
      } else {
        return Astro.redirect(`/ops/login?sent=1&next=${encodeURIComponent(nextField)}`, 302);
      }
    }
  } catch (e) {
    formError = `Erreur: ${(e as Error).message}`;
  }
}
---

<!doctype html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex,nofollow" />
  <title>Connexion — Scluba Ops</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>
  <main class="login-page">
    <div class="login-card">
      <div class="login-brand">
        <span class="login-mark">K</span>
        <span class="login-name">Scluba Ops</span>
      </div>
      <h1 class="login-title">Connexion</h1>
      <p class="login-lead">Espace de pilotage interne. Lien magique envoyé par email.</p>

      {formSent && !formError && (
        <div class="login-flash ok">
          ✓ Lien envoyé. Ouvre l'email et clique pour te connecter.
        </div>
      )}
      {formError && <div class="login-flash err">{formError}</div>}
      {errMsg && <div class="login-flash err">{errMsg}</div>}

      <form method="POST" class="login-form">
        <label class="login-label">
          Email
          <input
            type="email"
            name="email"
            required
            autofocus
            placeholder="toi@email.com"
            class="login-input"
          />
        </label>
        <input type="hidden" name="next" value={next} />
        <button type="submit" class="login-btn">Recevoir le lien magique</button>
      </form>

      <p class="login-foot">
        <a href="/" class="login-back">← Retour au site</a>
      </p>
    </div>
  </main>
</body>
</html>

<style>
  body {
    margin: 0;
    background: linear-gradient(135deg, #0F2A1E 0%, #1B4332 100%);
    min-height: 100vh;
    color: #1A1A1A;
    font-family: var(--font-sans);
  }
  .login-page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
  }
  .login-card {
    background: #fff;
    border-radius: 20px;
    padding: 40px 36px;
    width: 100%;
    max-width: 420px;
    box-shadow: 0 32px 80px rgba(0,0,0,0.32);
  }
  .login-brand {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 28px;
  }
  .login-mark {
    width: 32px;
    height: 32px;
    border-radius: 8px;
    background: #D4A574;
    color: #0F2A1E;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-serif);
    font-size: 18px;
  }
  .login-name {
    font-weight: 600;
    color: #1B4332;
  }
  .login-title {
    font-family: var(--font-serif);
    font-size: 28px;
    margin: 0 0 8px;
    color: #1B4332;
  }
  .login-lead {
    color: #6B7280;
    font-size: 14px;
    margin: 0 0 24px;
    line-height: 1.5;
  }
  .login-form { display: flex; flex-direction: column; gap: 16px; }
  .login-label {
    display: block;
    font-size: 13px;
    font-weight: 500;
    color: #2D2D2D;
  }
  .login-input {
    margin-top: 6px;
    width: 100%;
    padding: 12px 14px;
    border-radius: 8px;
    border: 1px solid #E5E7EB;
    font-size: 15px;
    font-family: inherit;
  }
  .login-input:focus {
    outline: none;
    border-color: #2D6A4F;
    box-shadow: 0 0 0 3px rgba(45,106,79,0.15);
  }
  .login-btn {
    margin-top: 4px;
    padding: 12px 18px;
    border-radius: 8px;
    border: none;
    background: #1B4332;
    color: #fff;
    font-size: 15px;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.15s;
  }
  .login-btn:hover { background: #0F2A1E; }
  .login-flash {
    padding: 12px 14px;
    border-radius: 8px;
    font-size: 14px;
    margin-bottom: 16px;
  }
  .login-flash.ok {
    background: #ECFDF5;
    border: 1px solid #A7F3D0;
    color: #065F46;
  }
  .login-flash.err {
    background: #FEF2F2;
    border: 1px solid #FECACA;
    color: #991B1B;
  }
  .login-foot { margin-top: 24px; text-align: center; }
  .login-back {
    color: #6B7280;
    font-size: 13px;
    text-decoration: none;
  }
  .login-back:hover { color: #1B4332; }
</style>
