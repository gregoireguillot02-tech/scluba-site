---
export const prerender = false;

import OpsLayout from '../../layouts/OpsLayout.astro';
import { serviceClient } from '../../lib/supabase';
import {
  STATUS_LABELS,
  STATUS_COLORS,
  OWNER_LABELS,
  OWNERS,
  type ProspectStatus,
  type Task,
} from '../../lib/ops-types';

const sb = serviceClient();

type TaskWithClub = Task & { prospects: { club_name: string } | null };
type ActionProspect = {
  id: string;
  club_name: string;
  contact_name: string | null;
  contact_role: string | null;
  phone: string | null;
  email: string | null;
  status: ProspectStatus;
};
type ActionRow = {
  id: string;
  due_on: string;
  note: string | null;
  prospect: ActionProspect | ActionProspect[] | null;
};

const [{ data: actionsRaw }, { data: tasksRaw }] = await Promise.all([
  sb
    .from('prospect_actions')
    .select('id, due_on, note, prospect:prospects(id, club_name, contact_name, contact_role, phone, email, status)')
    .eq('done', false)
    .order('due_on', { ascending: true }),
  sb
    .from('tasks')
    .select('*, prospects(club_name)')
    .neq('status', 'done')
    .not('due_date', 'is', null)
    .order('due_date', { ascending: true }),
]);

const actionRows = (actionsRaw ?? []) as ActionRow[];
const tasks: TaskWithClub[] = (tasksRaw ?? []) as TaskWithClub[];

// "Aujourd'hui" en heure de Paris (le serveur tourne en UTC sur Cloudflare).
// Colonnes 'YYYY-MM-DD' → comparaison de chaînes ISO = ordre chronologique.
const TZ = 'Europe/Paris';
function isoDay(d: Date): string {
  return new Intl.DateTimeFormat('en-CA', {
    timeZone: TZ,
    year: 'numeric',
    month: '2-digit',
    day: '2-digit',
  }).format(d);
}
const todayStr = isoDay(new Date());
const weekEndStr = isoDay(new Date(Date.now() + 7 * 86400000));

type Item =
  | { kind: 'action'; day: string; id: string; note: string | null; p: ActionProspect }
  | { kind: 'task'; day: string; t: TaskWithClub };

const items: Item[] = [];
for (const a of actionRows) {
  const p = Array.isArray(a.prospect) ? a.prospect[0] : a.prospect;
  if (!a.due_on || !p) continue;
  items.push({ kind: 'action', day: a.due_on.slice(0, 10), id: a.id, note: a.note, p });
}
for (const t of tasks) {
  if (t.due_date) items.push({ kind: 'task', day: t.due_date.slice(0, 10), t });
}
items.sort((a, b) => a.day.localeCompare(b.day));

const buckets: Record<string, Item[]> = {
  overdue: items.filter((i) => i.day < todayStr),
  today: items.filter((i) => i.day === todayStr),
  week: items.filter((i) => i.day > todayStr && i.day <= weekEndStr),
  later: items.filter((i) => i.day > weekEndStr),
};

const bucketDefs: { key: keyof typeof buckets; label: string; cls: string }[] = [
  { key: 'overdue', label: 'En retard', cls: 'b-overdue' },
  { key: 'today', label: "Aujourd'hui", cls: 'b-today' },
  { key: 'week', label: 'Cette semaine', cls: 'b-week' },
  { key: 'later', label: 'Plus tard', cls: 'b-later' },
];

const overdueCount = buckets.overdue.length;
const todayCount = buckets.today.length;

function fmtDay(day: string): string {
  const d = new Date(`${day}T12:00:00`);
  return d.toLocaleDateString('fr-FR', { day: '2-digit', month: 'short' });
}
---

<OpsLayout title="Todo commerciale" active="home">
  <div class="ops-page-header">
    <div>
      <h1 class="ops-page-title">Todo commerciale</h1>
      <p class="ops-page-subtitle">
        {items.length === 0
          ? 'Relances et tâches du moment'
          : `${overdueCount} en retard · ${todayCount} aujourd'hui`}
      </p>
    </div>
    <a href="/ops/stats" class="ops-btn ops-btn-ghost">Voir les stats →</a>
  </div>

  {items.length === 0 ? (
    <div class="ops-card">
      <div class="ops-empty">
        Rien de programmé pour l'instant.<br />
        Ajoute une <strong>prochaine action</strong> sur un prospect (fiche → « Prochaines actions »)
        ou crée une tâche ci-dessous.
      </div>
    </div>
  ) : (
    <div class="buckets">
      {bucketDefs.map(({ key, label, cls }) => {
        const list = buckets[key];
        if (list.length === 0) return null;
        return (
          <section class={`bucket ${cls}`}>
            <header class="bucket-head">
              <span class="bucket-pip" aria-hidden="true"></span>
              <h2 class="bucket-title">{label}</h2>
              <span class="bucket-count">{list.length}</span>
            </header>
            <div class="bucket-body">
              {list.map((item) =>
                item.kind === 'action' ? (
                  <div class="ai-item">
                    <div class="ai-main">
                      <div class="ai-row1">
                        <a href={`/ops/prospects/${item.p.id}`} class="ai-title">{item.p.club_name}</a>
                        <span
                          class="ops-tag"
                          style={`background:${STATUS_COLORS[item.p.status]}22; color:${STATUS_COLORS[item.p.status]}`}
                        >{STATUS_LABELS[item.p.status]}</span>
                        <span class="ai-day">{fmtDay(item.day)}</span>
                      </div>
                      {item.note && <div class="ai-note">{item.note}</div>}
                      <div class="ai-contacts">
                        {item.p.contact_name && <span class="ai-contact">{item.p.contact_name}{item.p.contact_role ? ` · ${item.p.contact_role}` : ''}</span>}
                        {item.p.phone && (
                          <a href={`tel:${item.p.phone}`} class="ai-contact ai-link">
                            <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                            {item.p.phone}
                          </a>
                        )}
                        {item.p.email && (
                          <a href={`mailto:${item.p.email}`} class="ai-contact ai-link">
                            <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-10 6L2 7"/></svg>
                            {item.p.email}
                          </a>
                        )}
                      </div>
                    </div>
                    <form method="POST" action="/api/ops/prospect-actions" class="ai-actions">
                      <input type="hidden" name="action" value="complete" />
                      <input type="hidden" name="id" value={item.id} />
                      <button type="submit" class="ops-btn ops-btn-primary ai-done">Fait</button>
                    </form>
                  </div>
                ) : (
                  <div class="ai-item ai-task">
                    <div class="ai-main">
                      <div class="ai-row1">
                        <span class="ai-title ai-title-task">{item.t.title}</span>
                        <span class="ops-tag">{OWNER_LABELS[item.t.assignee]}</span>
                        <span class="ai-day">{fmtDay(item.day)}</span>
                      </div>
                      {item.t.prospects?.club_name && (
                        <a href={`/ops/prospects/${item.t.prospect_id}`} class="ai-note ai-task-club">→ {item.t.prospects.club_name}</a>
                      )}
                    </div>
                    <form method="POST" action="/api/ops/tasks" class="ai-actions">
                      <input type="hidden" name="action" value="set_status" />
                      <input type="hidden" name="id" value={item.t.id} />
                      <input type="hidden" name="status" value="done" />
                      <button type="submit" class="ops-btn ai-done">Fait</button>
                    </form>
                  </div>
                )
              )}
            </div>
          </section>
        );
      })}
    </div>
  )}

  <div class="ops-card quick-card">
    <form method="POST" action="/api/ops/tasks" class="quick-task">
      <input type="hidden" name="action" value="create" />
      <input class="ops-input" name="title" placeholder="Ajouter une tâche…" required />
      <select class="ops-select" name="assignee">
        {OWNERS.map((o) => <option value={o} selected={o === 'shared'}>{OWNER_LABELS[o]}</option>)}
      </select>
      <input class="ops-input" type="date" name="due_date" />
      <button type="submit" class="ops-btn ops-btn-primary">Ajouter</button>
    </form>
    <a href="/ops/todo" class="ops-btn ops-btn-ghost">Toute la todo →</a>
  </div>
</OpsLayout>

<style>
  .buckets {
    display: flex;
    flex-direction: column;
    gap: 20px;
    margin-bottom: 24px;
  }

  .bucket-head {
    display: flex;
    align-items: center;
    gap: 9px;
    margin-bottom: 10px;
  }
  .bucket-pip {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--muted);
  }
  .bucket-title {
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--ink-soft);
    margin: 0;
  }
  .bucket-count {
    font-variant-numeric: tabular-nums;
    color: var(--muted);
    font-size: 12px;
    font-weight: 600;
    background: var(--line-soft);
    padding: 2px 9px;
    border-radius: 999px;
  }
  .b-overdue .bucket-pip { background: #DC2626; }
  .b-overdue .bucket-title { color: #B91C1C; }
  .b-today .bucket-pip { background: var(--primary); }
  .b-today .bucket-title { color: var(--primary); }
  .b-week .bucket-pip { background: var(--accent); }
  .b-later .bucket-pip { background: var(--muted-soft); }

  .bucket-body {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ai-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    background: var(--bg);
    border: 1px solid var(--line);
    border-radius: 10px;
    padding: 12px 14px;
    box-shadow: 0 1px 2px rgba(15,42,30,0.04);
  }
  .b-overdue .ai-item { border-color: #FECACA; }

  .ai-main { min-width: 0; flex: 1; }
  .ai-row1 {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }
  .ai-title {
    font-weight: 600;
    color: var(--primary);
    font-size: 15px;
    text-decoration: none;
  }
  .ai-title:hover { text-decoration: underline; }
  .ai-title-task { color: var(--ink); }
  .ai-day {
    margin-left: auto;
    font-size: 12px;
    color: var(--muted);
    font-variant-numeric: tabular-nums;
  }
  .b-overdue .ai-day { color: #DC2626; font-weight: 600; }

  .ai-note {
    margin-top: 4px;
    font-size: 14px;
    color: var(--ink-soft);
    line-height: 1.4;
  }
  .ai-task-club {
    display: inline-block;
    color: var(--primary-soft);
    text-decoration: none;
  }
  .ai-task-club:hover { text-decoration: underline; }

  .ai-contacts {
    margin-top: 6px;
    display: flex;
    align-items: center;
    gap: 14px;
    flex-wrap: wrap;
  }
  .ai-contact {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 13px;
    color: var(--muted);
  }
  .ai-link { color: var(--primary-soft); text-decoration: none; }
  .ai-link:hover { text-decoration: underline; }

  .ai-actions {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
  }
  .ai-done { padding: 8px 16px; }

  @media (max-width: 700px) {
    .ai-item { flex-direction: column; align-items: stretch; }
    .ai-actions { justify-content: flex-end; }
    .ai-day { margin-left: 0; }
  }

  .quick-card {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }
  .quick-task {
    display: grid;
    grid-template-columns: 1fr 150px 150px auto;
    gap: 8px;
    flex: 1;
    min-width: 280px;
  }
  @media (max-width: 700px) {
    .quick-task { grid-template-columns: 1fr; }
  }
</style>
