---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import Chapter01Constat from '../components/chapters/Chapter01Constat.astro';
import ThreeSteps from '../components/ThreeSteps.astro';
import PhoneShowcase from '../components/PhoneShowcase.astro';
import ClubsShowcase from '../components/ClubsShowcase.astro';
import HowItWorks from '../components/HowItWorks.astro';
import Pricing from '../components/Pricing.astro';
import FAQ from '../components/FAQ.astro';
import CTAForm from '../components/CTAForm.astro';

const locale = 'fr' as const;
---

<Base locale={locale}>
  {/* PR #2 — Hero éditorial + Chapitre I (Le Constat) refondus.
      Les sections en-dessous restent en mode hybride pour cette PR ;
      Chapters II-V arrivent en PR #3, ProblemNarrative est désormais
      remplacé par Chapter01Constat. */}
  <Hero locale={locale} />
  <Chapter01Constat locale={locale} />
  <ThreeSteps locale={locale} />
  <PhoneShowcase locale={locale} />
  <ClubsShowcase locale={locale} />
  <HowItWorks locale={locale} />
  <Pricing locale={locale} />
  <FAQ locale={locale} />
  <CTAForm locale={locale} />
</Base>
