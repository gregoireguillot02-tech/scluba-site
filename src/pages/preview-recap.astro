---
/**
 * /preview-recap — preview du redesign /recap avec données mock (sans DB).
 *
 * Affichage statique read-only : pas de save commentaire, pas de share
 * réel. Permet de valider visuellement la DA quadrillage + cartes glass
 * sur /recap sans avoir à terminer une vraie partie.
 *
 * URL publique : https://scluba.com/preview-recap
 * noindex pour ne pas polluer le SEO.
 */
export const prerender = false;

import PlayerLayout from '../layouts/PlayerLayout.astro';
import Masthead from '../components/player/Masthead.astro';
import Colophon from '../components/player/Colophon.astro';
import Scorecard from '../components/player/Scorecard.astro';
import Leaderboard from '../components/player/Leaderboard.astro';

// Mock — round terminé fictif Caen-la-Mer, 3 joueurs, 18/18 trous joués
const club = {
  name: 'Golf de Caen-La-Mer',
  primary_color: '#1A4490',
  logo_url: null as string | null,
  photo_url: null as string | null,
};

const holes = [
  { number: 1,  par: 4 }, { number: 2,  par: 3 }, { number: 3,  par: 5 },
  { number: 4,  par: 4 }, { number: 5,  par: 4 }, { number: 6,  par: 4 },
  { number: 7,  par: 3 }, { number: 8,  par: 5 }, { number: 9,  par: 4 },
  { number: 10, par: 4 }, { number: 11, par: 3 }, { number: 12, par: 5 },
  { number: 13, par: 4 }, { number: 14, par: 4 }, { number: 15, par: 5 },
  { number: 16, par: 3 }, { number: 17, par: 4 }, { number: 18, par: 4 },
];
const par = holes.reduce((s, h) => s + h.par, 0); // 71
const holesCount = holes.length;

const roundSections = [
  { loop_id: 'plaine', loop_name: 'La Plaine', holes: holes.slice(0, 9) },
  { loop_id: 'vallon', loop_name: 'Le Vallon', holes: holes.slice(9, 18) },
];

// Scores fictifs cohérents : Gregoire 79 (+8), Martin 82 (+11) avec 1 pickup, Jean 76 (+5) = leader
const meScores: Record<number, { strokes: number | null; picked_up: boolean }> = {
  1: { strokes: 4, picked_up: false }, 2:  { strokes: 4, picked_up: false }, 3:  { strokes: 6, picked_up: false },
  4: { strokes: 5, picked_up: false }, 5:  { strokes: 4, picked_up: false }, 6:  { strokes: 5, picked_up: false },
  7: { strokes: 3, picked_up: false }, 8:  { strokes: 5, picked_up: false }, 9:  { strokes: 4, picked_up: false },
  10:{ strokes: 4, picked_up: false }, 11: { strokes: 4, picked_up: false }, 12: { strokes: 6, picked_up: false },
  13:{ strokes: 4, picked_up: false }, 14: { strokes: 5, picked_up: false }, 15: { strokes: 5, picked_up: false },
  16:{ strokes: 3, picked_up: false }, 17: { strokes: 4, picked_up: false }, 18: { strokes: 4, picked_up: false },
};
const meTotal = { strokes: 79, played: 18, pickedUp: 0, playedPar: 71, diff: 8 };

const me = { id: 'p1', display_name: 'Grégoire' };

const leaderboardPlayers = [
  { player_id: 'p3', display_name: 'Jean',     strokes: 76, diff: 5,  played: 18, finished: true, is_me: false },
  { player_id: 'p1', display_name: 'Grégoire', strokes: 79, diff: 8,  played: 18, finished: true, is_me: true  },
  { player_id: 'p2', display_name: 'Martin',   strokes: 82, diff: 11, played: 17, finished: true, is_me: false },
];

const weather = { emoji: '🌤️', temp_c: 18 };
const startedAt = '2026-05-21T09:30:00Z';
const shortCode = 'PREVIEW';
const formatLabel = 'La Plaine + Le Vallon';

function fmtDate(iso: string): string {
  return new Date(iso).toLocaleDateString('fr-FR', { weekday: 'short', day: '2-digit', month: 'short', year: 'numeric' });
}

const clubColor = club.primary_color;
---

<PlayerLayout
  title={`${club.name} — Preview /recap · Scluba`}
  themeColor="#FFFFFF"
  clubColor={clubColor}
  gridBackdrop={true}
>
  <main class="card">
    <p class="demo-banner">PREVIEW · données fictives · redesign /recap quadrillage + cartes glass</p>

    <Masthead
      photoUrl={club.photo_url}
      logoUrl={club.logo_url}
      eyebrow="Carte récapitulative"
      title={club.name}
      size="large"
    />

    <ul class="meta-strip" aria-label="Détails de la partie">
      <li>
        <span class="meta-l">Date</span>
        <span class="meta-v">{fmtDate(startedAt)}</span>
      </li>
      <li>
        <span class="meta-l">Réf.</span>
        <span class="meta-v">{shortCode}</span>
      </li>
      <li>
        <span class="meta-l">Météo</span>
        <span class="meta-v meta-v-weather">
          <span class="meta-weather-emoji" aria-hidden="true">{weather.emoji}</span>
          <span>{weather.temp_c}°C</span>
        </span>
      </li>
    </ul>

    <section class="score-block" aria-labelledby="score-title">
      <p id="score-title" class="sr-only">
        Score final {meTotal.strokes}, +{meTotal.diff} par rapport au par {par}.
      </p>
      <p class="score-eyebrow">Score · {formatLabel}</p>
      <div class="score-value" data-card-score data-target={String(meTotal.strokes)}>{meTotal.strokes}</div>
      <p class="score-meta">
        <span class="score-diff over">+{meTotal.diff}</span>
        <span class="score-sep" aria-hidden="true">·</span>
        <span>Par {par}</span>
        <span class="score-sep" aria-hidden="true">·</span>
        <span>{meTotal.played}/{holesCount} trous</span>
      </p>
    </section>

    <section class="grid-block" aria-label="Score par trou">
      <Scorecard sections={roundSections} mode="final" scoreMap={meScores} />
      <ul class="grid-legend" aria-hidden="true">
        <li><span class="legend-swatch legend-birdie"></span>Birdie</li>
        <li><span class="legend-swatch legend-par"></span>Par</li>
        <li><span class="legend-swatch legend-bogey"></span>Bogey</li>
      </ul>
    </section>

    <Leaderboard players={leaderboardPlayers} eyebrow="Multijoueur" title="Classement" />

    <section class="comment-block">
      <p class="comment-eyebrow">Ton commentaire</p>
      <form class="comment-form" onsubmit="event.preventDefault()">
        <textarea
          class="comment-input"
          maxlength="200"
          rows="2"
          placeholder="Soleil, terrain gras, partie de fou…"
        >Beau temps, fairways secs, un birdie au 13 — bonne partie.</textarea>
        <div class="comment-actions">
          <span class="comment-count">63/200</span>
          <button type="submit" class="comment-btn" disabled>Enregistrer</button>
        </div>
      </form>
    </section>

    <section class="player-row">
      <div>
        <span class="meta-l">Joueur</span>
        <span class="player-name">{me.display_name}</span>
      </div>
      <button type="button" class="share-btn" disabled>
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/>
          <polyline points="16 6 12 2 8 6"/>
          <line x1="12" y1="2" x2="12" y2="15"/>
        </svg>
        Partager
      </button>
    </section>

    <Colophon />

    <p class="proto-note">PREVIEW PUBLIC · scluba.com/preview-recap</p>
  </main>

  <style>
    .sr-only {
      position: absolute;
      width: 1px; height: 1px;
      padding: 0; margin: -1px; overflow: hidden;
      clip: rect(0,0,0,0); white-space: nowrap; border: 0;
    }

    .card {
      max-width: 480px;
      margin: 0 auto;
      min-height: 100dvh;
      display: flex;
      flex-direction: column;
      padding: 0 var(--space-4);
      background: transparent;
      touch-action: manipulation;
    }

    .demo-banner {
      margin: var(--space-3) 0;
      padding: 8px 16px;
      background: rgba(255, 255, 255, 0.62);
      -webkit-backdrop-filter: blur(8px) saturate(115%);
              backdrop-filter: blur(8px) saturate(115%);
      color: var(--accent, #10D277);
      font-size: 10.5px;
      letter-spacing: 0.1em;
      text-align: center;
      border: 1px solid rgba(15, 42, 30, 0.06);
      border-radius: 12px;
      box-shadow: var(--play-card-shadow);
    }

    /* === Meta strip glass === */
    .meta-strip {
      list-style: none;
      margin: 0 0 var(--space-6);
      padding: var(--space-3) var(--space-4);
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-3);
      background: var(--play-card-bg);
      -webkit-backdrop-filter: var(--play-card-blur);
              backdrop-filter: var(--play-card-blur);
      border: 1px solid rgba(15, 42, 30, 0.06);
      border-top: 1px solid color-mix(in srgb, var(--accent) 45%, transparent);
      border-bottom: 1px solid color-mix(in srgb, var(--accent) 45%, transparent);
      border-radius: 14px;
      box-shadow: var(--play-card-shadow);
    }
    @supports not (backdrop-filter: blur(1px)) {
      .meta-strip { background: rgba(255, 255, 255, 0.92); }
    }
    .meta-strip li {
      display: flex; flex-direction: column; gap: 4px; text-align: center;
    }
    .meta-l {
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 0.2em;
      color: var(--accent);
      text-transform: uppercase;
    }
    .meta-v {
      font-family: var(--font-serif);
      font-size: var(--text-sm);
      color: var(--clubColor);
      font-weight: 700;
      font-variant-numeric: tabular-nums;
    }
    .meta-v-weather {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 4px;
    }
    .meta-weather-emoji {
      font-size: 14px;
      line-height: 1;
    }

    /* === Score block glass === */
    .score-block {
      text-align: center;
      padding: var(--space-7) var(--space-5) var(--space-6);
      margin-bottom: var(--space-5);
      background: var(--play-card-bg);
      -webkit-backdrop-filter: var(--play-card-blur);
              backdrop-filter: var(--play-card-blur);
      border: 1px solid rgba(15, 42, 30, 0.06);
      border-radius: 18px;
      box-shadow: var(--play-card-shadow);
    }
    @supports not (backdrop-filter: blur(1px)) {
      .score-block { background: rgba(255, 255, 255, 0.92); }
    }
    .score-eyebrow {
      margin: 0 0 var(--space-4);
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--accent);
    }
    .score-value {
      font-family: var(--font-serif);
      font-size: clamp(5rem, 22vw, 7rem);
      font-weight: 800;
      color: var(--clubColor);
      line-height: 1;
      letter-spacing: -0.03em;
      font-variant-numeric: tabular-nums;
    }
    .score-meta {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      margin-top: var(--space-3);
      font-size: var(--text-sm);
      color: var(--muted);
      letter-spacing: 0.04em;
    }
    .score-diff { font-weight: 700; font-variant-numeric: tabular-nums; }
    .score-diff.over { color: #C0392B; }
    .score-sep { color: var(--accent); font-weight: 700; }

    /* === Grid block glass === */
    .grid-block {
      padding: var(--space-5) var(--space-4) var(--space-4);
      display: flex;
      flex-direction: column;
      gap: var(--space-3);
      margin-bottom: var(--space-5);
      background: var(--play-card-bg);
      -webkit-backdrop-filter: var(--play-card-blur);
              backdrop-filter: var(--play-card-blur);
      border: 1px solid rgba(15, 42, 30, 0.06);
      border-top: 1px solid rgba(212, 165, 116, 0.4);
      border-bottom: 1px solid rgba(212, 165, 116, 0.4);
      border-radius: 16px;
      box-shadow: var(--play-card-shadow);
    }
    @supports not (backdrop-filter: blur(1px)) {
      .grid-block { background: rgba(255, 255, 255, 0.92); }
    }
    .grid-legend {
      list-style: none;
      margin: var(--space-3) 0 0;
      padding: 0;
      display: flex;
      gap: var(--space-4);
      justify-content: center;
      font-size: 11px;
      color: var(--muted);
      letter-spacing: 0.04em;
    }
    .grid-legend li { display: inline-flex; align-items: center; gap: 6px; }
    .legend-swatch {
      width: 14px; height: 14px;
      border-radius: var(--radius-sm);
      border: 1px solid var(--line);
    }
    .legend-swatch.legend-birdie {
      color: #C0392B; background: var(--accent-soft); border-color: var(--accent);
    }
    .legend-swatch.legend-par { background: var(--bg); }
    .legend-swatch.legend-bogey { background: var(--bg); }

    /* === Comment block glass === */
    .comment-block {
      padding: var(--space-5) var(--space-4);
      margin-bottom: var(--space-4);
      display: flex;
      flex-direction: column;
      gap: var(--space-3);
      background: var(--play-card-bg);
      -webkit-backdrop-filter: var(--play-card-blur);
              backdrop-filter: var(--play-card-blur);
      border: 1px solid rgba(15, 42, 30, 0.06);
      border-radius: 16px;
      box-shadow: var(--play-card-shadow);
    }
    @supports not (backdrop-filter: blur(1px)) {
      .comment-block { background: rgba(255, 255, 255, 0.92); }
    }
    .comment-eyebrow {
      margin: 0;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--accent);
    }
    .comment-input {
      width: 100%;
      box-sizing: border-box;
      padding: 12px 14px;
      border-radius: 12px;
      border: 1px solid var(--line);
      background: #fff;
      font: inherit;
      font-size: 14px;
      color: var(--ink);
      resize: vertical;
      min-height: 60px;
    }
    .comment-actions {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: var(--space-3);
    }
    .comment-count { font-size: 11px; color: var(--muted); font-variant-numeric: tabular-nums; }
    .comment-btn {
      padding: 8px 18px;
      border-radius: 10px;
      border: 1px solid var(--clubColor);
      background: transparent;
      color: var(--clubColor);
      font-size: 13px;
      font-weight: 600;
      cursor: not-allowed;
      opacity: 0.6;
    }

    /* === Player row + share === */
    .player-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: var(--space-3);
      padding: var(--space-4) 0;
      margin-top: var(--space-4);
      border-top: 1px dashed color-mix(in srgb, var(--accent) 45%, transparent);
      border-bottom: 1px dashed color-mix(in srgb, var(--accent) 45%, transparent);
    }
    .player-row > div { display: flex; flex-direction: column; gap: 4px; }
    .player-name {
      font-family: var(--font-serif);
      font-size: var(--text-md);
      color: var(--clubColor);
      font-weight: 700;
    }
    .share-btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      min-height: 44px;
      padding: 10px 18px;
      border-radius: 12px;
      border: none;
      background: var(--clubColor);
      color: var(--bg);
      font-size: var(--text-sm);
      font-weight: 600;
      cursor: not-allowed;
      opacity: 0.7;
      box-shadow: 0 1px 2px rgba(15, 42, 30, 0.08), 0 4px 12px rgba(27, 67, 50, 0.10);
    }

    .proto-note {
      text-align: center;
      font-family: var(--font-mono);
      font-size: 9px;
      letter-spacing: 0.3em;
      color: var(--muted);
      opacity: 0.4;
      margin: 40px 0 20px;
    }
  </style>
</PlayerLayout>
