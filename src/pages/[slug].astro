---
export const prerender = false;

import '../styles/tokens.css';
import '../styles/global.css';
import { serviceClient } from '../lib/supabase';
import type { Club } from '../lib/clubs-types';
import { totalPar } from '../lib/clubs-types';
import Honeypot from '../components/Honeypot.astro';
import { escapeLikePattern } from '../lib/safe-redirect';
import { displayNameSchema } from '../lib/validation/schemas';

const { slug } = Astro.params;
const sb = serviceClient();

const { data: club } = await sb
  .from('clubs')
  .select('*')
  .eq('slug', slug)
  .maybeSingle();

if (!club) {
  return Astro.rewrite('/404');
}

const c = club as Club;
const par = totalPar(c.course_data);
const holeCount = c.course_data.holes.length;
const clubColor = c.primary_color ?? '#1B4332';

// Formats are optional — a club without `formats[]` falls back to the legacy
// 18-hole flat course, and we just don't render the selector.
const courseFormats = c.course_data.formats ?? [];
const hasFormats = courseFormats.length > 0;

// Recovery flow: read query params set by /api/clubs/[slug]/find-round.
const url = new URL(Astro.request.url);
const recoverErr = url.searchParams.get('recover_err');
const recoverMode = url.searchParams.get('recover');
// Validate `name` with the same schema the form uses, otherwise a raw `%`
// or `_` in the query string would widen the .ilike() match below to "all
// players" and leak short_codes + display_names for every active round in
// this club.
const recoverNameRaw = url.searchParams.get('name') ?? '';
const recoverNameParsed = displayNameSchema.safeParse(recoverNameRaw);
const recoverName = recoverNameParsed.success ? recoverNameParsed.data : '';

// Ambiguous case — multiple active rounds match the name. Fetch them so the
// page can render a disambiguation list (start time + code + player count).
type AmbiguousMatch = {
  round_id: string;
  short_code: string;
  status: 'lobby' | 'playing';
  started_at: string | null;
  created_at: string;
  display_name: string;
  player_count: number;
};
let ambiguousMatches: AmbiguousMatch[] = [];

if (recoverMode === 'ambiguous' && recoverName) {
  const { data: activeRounds } = await sb
    .from('rounds')
    .select('id, short_code, status, started_at, created_at')
    .eq('club_id', c.id)
    .in('status', ['lobby', 'playing']);
  const rounds = activeRounds ?? [];
  if (rounds.length > 0) {
    const roundIds = rounds.map((r) => r.id);
    const [{ data: players }, { data: roster }] = await Promise.all([
      sb.from('round_players').select('round_id, display_name').in('round_id', roundIds).ilike('display_name', escapeLikePattern(recoverName)),
      sb.from('round_players').select('round_id').in('round_id', roundIds),
    ]);
    const counts: Record<string, number> = {};
    for (const r of roster ?? []) counts[r.round_id] = (counts[r.round_id] ?? 0) + 1;

    const seenRound = new Set<string>();
    for (const p of players ?? []) {
      if (seenRound.has(p.round_id)) continue;
      seenRound.add(p.round_id);
      const r = rounds.find((x) => x.id === p.round_id);
      if (!r) continue;
      ambiguousMatches.push({
        round_id: r.id,
        short_code: r.short_code,
        status: r.status as 'lobby' | 'playing',
        started_at: r.started_at,
        created_at: r.created_at,
        display_name: p.display_name,
        player_count: counts[r.round_id] ?? 1,
      });
    }
    ambiguousMatches.sort((a, b) => (b.started_at ?? b.created_at).localeCompare(a.started_at ?? a.created_at));
  }
}

function fmtTime(iso: string | null): string {
  if (!iso) return '—';
  return new Date(iso).toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' });
}
---

<!doctype html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title>{c.name} — Démarrer une partie · Scluba</title>
  <meta name="description" content={`Scorecard digitale pour ${c.name}. Démarrez une partie en quelques secondes.`} />
  <meta name="robots" content="noindex, nofollow" />
  <meta name="theme-color" content="#FAF7EE" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>
  <main class="club-page">
    <header class="masthead">
      {c.photo_url ? (
        <figure class="photo-card">
          <img src={c.photo_url} alt="" loading="eager" decoding="async" />
          <span class="photo-card-fade" aria-hidden="true"></span>
        </figure>
      ) : (
        <div class="photo-card photo-card-placeholder" aria-hidden="true"></div>
      )}

      {c.logo_url && (
        <div class="logo-frame">
          <img src={c.logo_url} alt="" />
        </div>
      )}

      {c.city && <p class="masthead-eyebrow">{c.city}</p>}

      <div class="title-rail" aria-hidden="true"></div>
      <h1 class="masthead-title">{c.name}</h1>
      <div class="title-rail" aria-hidden="true"></div>
    </header>

    <ul class="meta-strip" aria-label="Détails du parcours">
      <li>
        <span class="meta-l">Trous</span>
        <span class="meta-v">{holeCount}</span>
      </li>
      <li>
        <span class="meta-l">Par</span>
        <span class="meta-v">{par}</span>
      </li>
      <li>
        <span class="meta-l">Départ</span>
        <span class="meta-v">Libre</span>
      </li>
    </ul>

    <section class="cta-block" aria-labelledby="cta-title">
      <p class="cta-eyebrow">Scorecard digitale</p>
      <h2 id="cta-title" class="cta-title">Démarrer une partie</h2>

      <div class="mode-tabs" role="tablist" aria-label="Type de partie">
        <button type="button" class="mode-tab is-active" role="tab" aria-selected="true" data-mode-tab="solo" data-mode-target="solo">
          <span>En solo</span>
        </button>
        <button type="button" class="mode-tab" role="tab" aria-selected="false" data-mode-tab="group" data-mode-target="group">
          <span>À plusieurs</span>
        </button>
      </div>

      <form method="POST" action="/api/rounds" class="start-form" data-mode-panel="solo">
        <input type="hidden" name="slug" value={c.slug} />
        <Honeypot />
        <label class="start-label">
          <span>Ton prénom</span>
          <input
            class="start-input"
            type="text"
            name="display_name"
            placeholder="Antoine"
            maxlength="40"
            required
            autocomplete="given-name"
            autofocus
          />
        </label>
        {hasFormats && (
          <fieldset class="format-fieldset">
            <legend>Quel parcours&nbsp;?</legend>
            <div class="format-list">
              {courseFormats.map((fmt) => (
                <label class="format-radio">
                  <input type="radio" name="format_id" value={fmt.id} required />
                  <span>{fmt.label}</span>
                </label>
              ))}
            </div>
          </fieldset>
        )}
        <label class="start-label">
          <span>Heure de départ</span>
          <input
            class="start-input"
            type="time"
            name="start_time"
            data-start-time
          />
        </label>
        <button type="submit" class="start-btn">
          Créer la partie
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
          </svg>
        </button>
      </form>

      <form method="POST" action="/api/rounds" class="start-form" data-mode-panel="group" hidden data-group-form>
        <input type="hidden" name="slug" value={c.slug} />
        <Honeypot />
        <label class="start-label">
          <span>Ton prénom</span>
          <input
            class="start-input"
            type="text"
            name="display_name"
            placeholder="Antoine"
            maxlength="40"
            required
            autocomplete="given-name"
          />
        </label>
        {hasFormats && (
          <fieldset class="format-fieldset">
            <legend>Quel parcours&nbsp;?</legend>
            <div class="format-list">
              {courseFormats.map((fmt) => (
                <label class="format-radio">
                  <input type="radio" name="format_id" value={fmt.id} required />
                  <span>{fmt.label}</span>
                </label>
              ))}
            </div>
          </fieldset>
        )}
        <fieldset class="party-fieldset">
          <legend>Avec qui tu joues&nbsp;?</legend>
          <p class="party-hint">Tape les prénoms des autres joueurs. Chacun scannera ensuite le QR pour rejoindre.</p>
          <div class="party-list" data-party-list>
            <label class="party-row">
              <span class="party-row-label">Joueur 2</span>
              <input
                class="start-input party-input"
                type="text"
                name="additional_players"
                placeholder="Marc"
                maxlength="40"
                autocomplete="off"
                required
              />
            </label>
          </div>
          <button type="button" class="party-add-btn" data-party-add>
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M12 5v14"/><path d="M5 12h14"/>
            </svg>
            <span>Ajouter un joueur</span>
          </button>
        </fieldset>
        <label class="start-label">
          <span>Heure de départ</span>
          <input
            class="start-input"
            type="time"
            name="start_time"
            data-start-time
          />
        </label>
        <button type="submit" class="start-btn">
          Créer la partie
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
          </svg>
        </button>
      </form>

      <p class="cta-hint">Pas besoin de compte. Tu pourras partager ta carte à la fin.</p>

      {recoverErr === 'not_found' && (
        <div class="recover-flash recover-flash-warn">
          Pas de partie en cours au nom de <strong>{recoverName}</strong>. Demande à un copain le code, ou démarre une nouvelle partie.
        </div>
      )}

      {recoverMode === 'ambiguous' && ambiguousMatches.length > 1 && (
        <section class="recover-picker" aria-labelledby="recover-picker-title">
          <p id="recover-picker-title" class="recover-picker-title">
            Plusieurs parties trouvées au nom de <strong>{recoverName}</strong>. Choisis la tienne&nbsp;:
          </p>
          <ul class="recover-picker-list">
            {ambiguousMatches.map((m) => (
              <li>
                <form method="POST" action={`/api/clubs/${c.slug}/find-round`}>
                  <input type="hidden" name="display_name" value={m.display_name} />
                  <input type="hidden" name="short_code" value={m.short_code} />
                  <button type="submit" class="recover-picker-btn">
                    <span class="picker-time">{fmtTime(m.started_at ?? m.created_at)}</span>
                    <span class="picker-meta">
                      <code>{m.short_code}</code>
                      <span> · {m.player_count} joueur{m.player_count > 1 ? 's' : ''}</span>
                      {m.status === 'lobby' && <span class="picker-status">en lobby</span>}
                    </span>
                  </button>
                </form>
              </li>
            ))}
          </ul>
        </section>
      )}

      <details class="join-block recover-block" open={recoverErr === 'not_found' || recoverMode === 'ambiguous'}>
        <summary class="join-summary">
          <span>Reprendre ma partie</span>
          <svg class="join-chevron" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="6 9 12 15 18 9"/>
          </svg>
        </summary>
        <form method="POST" action={`/api/clubs/${c.slug}/find-round`} class="join-form">
          <Honeypot />
          <label class="start-label">
            <span>Ton prénom</span>
            <input
              class="start-input"
              type="text"
              name="display_name"
              placeholder="Antoine"
              maxlength="40"
              required
              autocomplete="given-name"
              value={recoverName}
            />
          </label>
          <button type="submit" class="join-btn">
            Retrouver ma partie
          </button>
        </form>
        <p class="recover-hint">
          Ton tel s'est éteint en cours de partie ? Tape ton prénom et on te ramène sur ta carte. Pas besoin du code.
        </p>
      </details>

      <details class="join-block">
        <summary class="join-summary">
          <span>Rejoindre une partie en cours</span>
          <svg class="join-chevron" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="6 9 12 15 18 9"/>
          </svg>
        </summary>
        <form
          method="POST"
          action="/api/rounds/__CODE__/join"
          class="join-form"
          data-join-form
          novalidate
        >
          <Honeypot />
          <label class="start-label">
            <span>Code de la partie</span>
            <input
              class="start-input join-code-input"
              type="text"
              name="short_code"
              placeholder="BIRD42"
              maxlength="6"
              required
              autocomplete="off"
              autocapitalize="characters"
              spellcheck="false"
              data-join-code
            />
          </label>
          <label class="start-label">
            <span>Ton prénom</span>
            <input
              class="start-input"
              type="text"
              name="display_name"
              placeholder="Antoine"
              maxlength="40"
              required
              autocomplete="given-name"
            />
          </label>
          <button type="submit" class="join-btn">
            Rejoindre
          </button>
        </form>
      </details>
    </section>

    <script>
      // Rewrite the join form action with the typed code on submit so we can
      // POST to /api/rounds/<CODE>/join (a path param, not a form field).
      const form = document.querySelector<HTMLFormElement>('[data-join-form]');
      const codeInput = document.querySelector<HTMLInputElement>('[data-join-code]');
      if (form && codeInput) {
        codeInput.addEventListener('input', () => {
          codeInput.value = codeInput.value.toUpperCase();
        });
        form.addEventListener('submit', (e) => {
          const code = codeInput.value.trim().toUpperCase();
          if (!code) {
            e.preventDefault();
            codeInput.focus();
            return;
          }
          form.action = `/api/rounds/${encodeURIComponent(code)}/join`;
        });
      }

      // Mode tabs: Solo vs Groupe. Show/hide the matching form and mark the
      // hidden form's inputs as disabled so they don't submit by mistake.
      const tabs = document.querySelectorAll<HTMLButtonElement>('[data-mode-tab]');
      const panels = document.querySelectorAll<HTMLElement>('[data-mode-panel]');
      function setMode(mode: string) {
        for (const t of tabs) {
          const on = t.dataset.modeTab === mode;
          t.classList.toggle('is-active', on);
          t.setAttribute('aria-selected', String(on));
        }
        for (const p of panels) {
          const on = p.dataset.modePanel === mode;
          p.hidden = !on;
          // Disable inputs in the hidden panel so HTML5 'required' on the
          // off-screen form doesn't block submission of the visible one.
          p.querySelectorAll<HTMLInputElement>('input, button').forEach((el) => {
            if (el.type === 'hidden') return;
            el.disabled = !on;
          });
        }
      }
      for (const t of tabs) {
        t.addEventListener('click', () => setMode(t.dataset.modeTab!));
      }
      // Initialise: ensure off-panel inputs are disabled from the start.
      setMode('solo');

      // "Ajouter un joueur" — append another input to the party list, cap at
      // 7 extras (matches the server schema additionalPlayersSchema.max(7)).
      const partyList = document.querySelector<HTMLElement>('[data-party-list]');
      const partyAddBtn = document.querySelector<HTMLButtonElement>('[data-party-add]');
      const MAX_EXTRAS = 7;
      function renumberPartyRows() {
        if (!partyList) return;
        const rows = partyList.querySelectorAll<HTMLElement>('.party-row');
        rows.forEach((row, i) => {
          const label = row.querySelector<HTMLElement>('.party-row-label');
          if (label) label.textContent = `Joueur ${i + 2}`;
        });
      }
      if (partyList && partyAddBtn) {
        partyAddBtn.addEventListener('click', () => {
          const current = partyList.querySelectorAll('.party-row').length;
          if (current >= MAX_EXTRAS) return;
          const row = document.createElement('label');
          row.className = 'party-row';
          row.innerHTML = `
            <span class="party-row-label"></span>
            <span class="party-row-fields">
              <input
                class="start-input party-input"
                type="text"
                name="additional_players"
                placeholder="Prénom"
                maxlength="40"
                autocomplete="off"
                required
              />
              <button type="button" class="party-remove-btn" aria-label="Retirer ce joueur">
                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M18 6 6 18"/><path d="m6 6 12 12"/>
                </svg>
              </button>
            </span>
          `;
          partyList.appendChild(row);
          renumberPartyRows();
          row.querySelector<HTMLInputElement>('input')?.focus();
          if (partyList.querySelectorAll('.party-row').length >= MAX_EXTRAS) {
            partyAddBtn.disabled = true;
          }
        });
        partyList.addEventListener('click', (e) => {
          const target = e.target as HTMLElement;
          const btn = target.closest<HTMLButtonElement>('.party-remove-btn');
          if (!btn) return;
          const row = btn.closest('.party-row');
          if (!row) return;
          // Always keep at least one extra-player row in group mode.
          if (partyList.querySelectorAll('.party-row').length <= 1) return;
          row.remove();
          renumberPartyRows();
          partyAddBtn.disabled = false;
        });
      }

      // Heure de départ : prefill avec l'heure courante, et à la soumission
      // convertir le HH:MM (tz locale du navigateur) en ISO UTC pour le serveur.
      const startTimeInputs = document.querySelectorAll<HTMLInputElement>('[data-start-time]');
      for (const input of startTimeInputs) {
        const now = new Date();
        const hh = String(now.getHours()).padStart(2, '0');
        const mm = String(now.getMinutes()).padStart(2, '0');
        input.value = `${hh}:${mm}`;
        const parentForm = input.closest('form');
        parentForm?.addEventListener('submit', () => {
          if (!input.value) return;
          const [h, m] = input.value.split(':').map(Number);
          if (Number.isNaN(h) || Number.isNaN(m)) return;
          const d = new Date();
          d.setHours(h, m, 0, 0);
          const hidden = document.createElement('input');
          hidden.type = 'hidden';
          hidden.name = 'started_at';
          hidden.value = d.toISOString();
          parentForm.appendChild(hidden);
        });
      }
    </script>

    <footer class="colophon">
      <span class="colophon-rail" aria-hidden="true"></span>
      <span class="colophon-text">
        <span>carte by</span>
        <strong>SCLUBA</strong>
        <span class="colophon-dot" aria-hidden="true"></span>
      </span>
      <span class="colophon-rail" aria-hidden="true"></span>
    </footer>

    <p class="privacy-note">
      Données stockées en Europe. Aucune donnée perso requise — juste un prénom.
      <a href="/legal/confidentialite/">En savoir plus</a>
    </p>
  </main>

  <style define:vars={{ clubColor }}>
    body {
      background: #FAF7EE;
      min-height: 100dvh;
      overflow-x: hidden;
      margin: 0;
    }

    .club-page {
      max-width: 480px;
      margin: 0 auto;
      min-height: 100dvh;
      display: flex;
      flex-direction: column;
      padding: 0 var(--space-4);
      gap: 0;
    }

    /* === Masthead — photo card + logo overlap + title === */
    .masthead {
      text-align: center;
      padding-top: var(--space-5);
      padding-bottom: var(--space-5);
    }

    .photo-card {
      position: relative;
      margin: 0;
      aspect-ratio: 16 / 9;
      max-height: 240px;
      width: 100%;
      border-radius: 16px;
      overflow: hidden;
      background: #E8E0CB;
      box-shadow:
        0 1px 2px rgba(15, 42, 30, 0.06),
        0 12px 32px rgba(27, 67, 50, 0.10);
    }
    .photo-card img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center 55%;
      display: block;
    }
    .photo-card-fade {
      position: absolute;
      inset: auto 0 0 0;
      height: 40%;
      background: linear-gradient(180deg, transparent, rgba(15, 42, 30, 0.35));
      pointer-events: none;
    }
    .photo-card-placeholder {
      background: linear-gradient(135deg, #1B4332 0%, #2D6A4F 100%);
    }

    .logo-frame {
      position: relative;
      z-index: 2;
      margin: -36px auto 0;
      width: 76px;
      height: 76px;
      border-radius: 50%;
      background: #FAF7EE;
      border: 2px solid var(--accent);
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow:
        0 1px 2px rgba(15, 42, 30, 0.08),
        0 8px 20px rgba(27, 67, 50, 0.10);
      padding: 10px;
    }
    .logo-frame img {
      width: 100%;
      height: 100%;
      object-fit: contain;
      filter: none;
    }

    .masthead-eyebrow {
      margin: var(--space-4) 0 var(--space-3);
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--accent);
    }

    .title-rail {
      width: 64px;
      height: 1px;
      margin: 0 auto;
      background: var(--accent);
      opacity: 0.55;
    }

    .masthead-title {
      margin: var(--space-3) auto;
      font-family: var(--font-serif);
      font-weight: 700;
      font-size: clamp(1.6rem, 5.5vw, 2.1rem);
      line-height: 1.15;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      color: var(--clubColor);
      max-width: 22ch;
    }

    /* === Meta strip — 3 stats parcours === */
    .meta-strip {
      list-style: none;
      margin: 0 0 var(--space-6);
      padding: var(--space-3) var(--space-4);
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-3);
      background: rgba(212, 165, 116, 0.10);
      border-top: 1px solid rgba(212, 165, 116, 0.4);
      border-bottom: 1px solid rgba(212, 165, 116, 0.4);
    }
    .meta-strip li {
      display: flex;
      flex-direction: column;
      gap: 4px;
      text-align: center;
    }
    .meta-l {
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 0.2em;
      color: var(--accent);
      text-transform: uppercase;
    }
    .meta-v {
      font-family: var(--font-serif);
      font-size: var(--text-md);
      color: var(--clubColor);
      font-weight: 700;
      font-variant-numeric: tabular-nums;
    }

    /* === CTA block === */
    .cta-block {
      flex: 1;
      padding: 0 var(--space-2) var(--space-7);
      text-align: center;
    }
    .cta-eyebrow {
      margin: 0 0 var(--space-2);
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--accent);
    }
    .cta-title {
      margin: 0 0 var(--space-6);
      font-family: var(--font-serif);
      font-size: clamp(1.5rem, 5vw, 1.85rem);
      color: var(--clubColor);
      line-height: 1.15;
      letter-spacing: -0.005em;
    }

    /* === Mode tabs: solo vs group === */
    .mode-tabs {
      display: inline-flex;
      gap: 4px;
      padding: 4px;
      margin: 0 auto var(--space-5);
      background: var(--line-soft);
      border-radius: 999px;
    }
    .mode-tab {
      appearance: none;
      border: none;
      background: transparent;
      padding: 8px 18px;
      border-radius: 999px;
      font-size: 13px;
      font-weight: 600;
      letter-spacing: 0.02em;
      color: var(--muted);
      cursor: pointer;
      transition: background 0.15s, color 0.15s, box-shadow 0.15s;
    }
    .mode-tab.is-active {
      background: #fff;
      color: var(--clubColor);
      box-shadow: 0 1px 2px rgba(15, 42, 30, 0.10);
    }
    .mode-tab:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 2px;
    }

    /* === Group party fieldset === */
    .party-fieldset,
    .format-fieldset {
      border: none;
      padding: 0;
      margin: 0;
      text-align: left;
    }
    .party-fieldset legend,
    .format-fieldset legend {
      display: block;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 8px;
    }

    /* === Format selector (multi-loop clubs) === */
    .format-list {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }
    .format-radio {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 12px 14px;
      border: 1px solid var(--line);
      border-radius: 12px;
      background: #fff;
      cursor: pointer;
      transition: border-color 0.15s, background 0.15s;
    }
    .format-radio:hover { border-color: var(--accent); background: var(--bg-soft); }
    .format-radio input {
      flex-shrink: 0;
      accent-color: var(--clubColor);
      cursor: pointer;
    }
    .format-radio span {
      font-size: 14px;
      font-weight: 500;
      color: var(--ink);
    }
    .format-radio:has(input:checked) {
      border-color: var(--clubColor);
      background: rgba(212, 165, 116, 0.08);
    }
    .format-radio:has(input:checked) span {
      font-weight: 600;
      color: var(--clubColor);
    }
    .party-hint {
      margin: 0 0 var(--space-3);
      font-size: 12px;
      color: var(--muted);
      line-height: 1.5;
    }
    .party-list {
      display: flex;
      flex-direction: column;
      gap: var(--space-3);
    }
    .party-row {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }
    .party-row-label {
      font-size: 11px;
      font-weight: 600;
      color: var(--muted);
      letter-spacing: 0.06em;
    }
    .party-row-fields {
      display: flex;
      gap: 6px;
      align-items: stretch;
    }
    .party-row-fields .party-input { flex: 1; }
    .party-remove-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 44px;
      flex-shrink: 0;
      border-radius: 12px;
      border: 1px solid var(--line);
      background: #fff;
      color: var(--muted);
      cursor: pointer;
      transition: border-color 0.15s, color 0.15s, background 0.15s;
    }
    .party-remove-btn:hover {
      border-color: #DC2626;
      color: #DC2626;
      background: #FEF2F2;
    }
    .party-add-btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      align-self: flex-start;
      margin-top: var(--space-3);
      padding: 8px 14px;
      border-radius: 10px;
      border: 1px dashed var(--accent);
      background: transparent;
      color: var(--clubColor);
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      transition: background 0.15s;
    }
    .party-add-btn:hover { background: rgba(212, 165, 116, 0.10); }
    .party-add-btn:disabled {
      opacity: 0.4;
      cursor: not-allowed;
    }

    .start-form {
      display: flex;
      flex-direction: column;
      gap: var(--space-4);
      max-width: 340px;
      margin: 0 auto;
    }
    /* Astro renders both panels server-side; the `hidden` attribute must beat
       `display: flex` so the inactive form is invisible before JS runs. */
    .start-form[hidden] { display: none; }
    .start-label {
      display: block;
      text-align: left;
    }
    .start-label > span {
      display: block;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 8px;
    }
    .start-input {
      width: 100%;
      padding: 14px 16px;
      border-radius: 12px;
      border: 1px solid var(--line);
      background: #fff;
      font-size: 16px;
      font-family: var(--font-sans);
      color: var(--ink);
    }
    .start-input::placeholder { color: var(--muted-soft); }
    .start-input:focus {
      outline: none;
      border-color: var(--primary-soft);
      box-shadow: 0 0 0 3px rgba(45, 106, 79, 0.15);
    }
    .start-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      min-height: 52px;
      padding: 14px 24px;
      border-radius: 12px;
      border: none;
      background: var(--clubColor);
      color: #FAF7EE;
      font-size: 16px;
      font-weight: 600;
      letter-spacing: 0.01em;
      cursor: pointer;
      box-shadow:
        0 1px 2px rgba(15, 42, 30, 0.08),
        0 8px 20px rgba(27, 67, 50, 0.18);
      transition: transform 0.12s ease-out, box-shadow 0.15s, filter 0.15s;
    }
    .start-btn:hover {
      filter: brightness(0.92);
      box-shadow:
        0 1px 2px rgba(15, 42, 30, 0.10),
        0 12px 32px rgba(27, 67, 50, 0.22);
    }
    .start-btn:active { transform: translateY(1px); }
    .start-btn:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 3px;
    }

    .cta-hint {
      margin: var(--space-5) 0 0;
      color: var(--muted);
      font-size: 13px;
    }

    /* === Join existing round (collapsible) === */
    .join-block {
      max-width: 340px;
      margin: var(--space-6) auto 0;
      text-align: left;
    }
    .join-summary {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      padding: 12px 16px;
      border-radius: 10px;
      background: transparent;
      cursor: pointer;
      list-style: none;
      font-size: 13px;
      font-weight: 600;
      letter-spacing: 0.04em;
      color: var(--clubColor);
      transition: background 0.15s;
    }
    .join-summary::-webkit-details-marker { display: none; }
    .join-summary:hover { background: rgba(212, 165, 116, 0.10); }
    .join-block[open] .join-chevron { transform: rotate(180deg); }
    .join-chevron { transition: transform 0.2s ease-out; }

    .join-form {
      margin-top: var(--space-4);
      display: flex;
      flex-direction: column;
      gap: var(--space-3);
    }
    .join-code-input {
      font-family: var(--font-serif);
      font-size: 22px;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-align: center;
      text-transform: uppercase;
    }
    .join-btn {
      min-height: 48px;
      padding: 12px 18px;
      border-radius: 12px;
      border: 1px solid var(--clubColor);
      background: transparent;
      color: var(--clubColor);
      font-size: 15px;
      font-weight: 600;
      cursor: pointer;
      transition: background 0.15s, color 0.15s;
    }
    .join-btn:hover {
      background: var(--clubColor);
      color: #FAF7EE;
    }
    .join-btn:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 3px;
    }

    .auth-hint {
      margin: var(--space-5) 0 0;
      text-align: center;
      font-size: 12px;
      color: var(--muted);
    }
    .auth-hint a {
      color: var(--clubColor);
      text-decoration: underline;
      text-underline-offset: 2px;
    }

    /* === Recovery flow === */
    .recover-flash {
      max-width: 340px;
      margin: var(--space-5) auto 0;
      padding: 12px 14px;
      border-radius: 10px;
      font-size: 13px;
      line-height: 1.4;
      text-align: left;
    }
    .recover-flash-warn {
      background: #FEF3C7;
      border: 1px solid #FCD34D;
      color: #78350F;
    }

    .recover-picker {
      max-width: 340px;
      margin: var(--space-5) auto 0;
      padding: var(--space-3) var(--space-4);
      background: rgba(212, 165, 116, 0.10);
      border: 1px solid rgba(212, 165, 116, 0.4);
      border-radius: 12px;
    }
    .recover-picker-title {
      margin: 0 0 var(--space-3);
      font-size: 13px;
      color: var(--ink-soft);
      line-height: 1.4;
      text-align: left;
    }
    .recover-picker-list {
      list-style: none;
      margin: 0;
      padding: 0;
      display: flex;
      flex-direction: column;
      gap: 6px;
    }
    .recover-picker-list form { margin: 0; }
    .recover-picker-btn {
      width: 100%;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      padding: 10px 14px;
      border-radius: 10px;
      border: 1px solid var(--line);
      background: #fff;
      cursor: pointer;
      transition: border-color 0.15s, background 0.15s;
      text-align: left;
    }
    .recover-picker-btn:hover {
      border-color: var(--clubColor);
      background: var(--bg-soft);
    }
    .picker-time {
      font-family: var(--font-serif);
      font-size: 15px;
      font-weight: 700;
      color: var(--clubColor);
      font-variant-numeric: tabular-nums;
      flex-shrink: 0;
    }
    .picker-meta {
      font-size: 12px;
      color: var(--muted);
      display: inline-flex;
      align-items: center;
      gap: 4px;
      flex-wrap: wrap;
    }
    .picker-meta code {
      font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
      background: var(--line-soft);
      padding: 1px 5px;
      border-radius: 3px;
      font-size: 11px;
      letter-spacing: 0.06em;
      color: var(--ink);
    }
    .picker-status {
      background: rgba(212, 165, 116, 0.18);
      color: #92400E;
      padding: 1px 6px;
      border-radius: 999px;
      font-size: 10px;
      font-weight: 600;
    }

    .recover-hint {
      margin: var(--space-3) 0 0;
      font-size: 12px;
      color: var(--muted);
      line-height: 1.5;
      text-align: left;
    }

    /* === Colophon === */
    .colophon {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: var(--space-3);
      padding: var(--space-6) 0 var(--space-7);
      max-width: 320px;
      margin: 0 auto;
    }
    .colophon-rail {
      flex: 1;
      height: 1px;
      background: var(--accent);
      opacity: 0.45;
    }
    .colophon-text {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-family: var(--font-serif);
      font-size: 12px;
      letter-spacing: 0.04em;
      color: var(--muted);
      white-space: nowrap;
    }
    .colophon-text strong {
      font-family: var(--font-serif);
      font-weight: 700;
      color: var(--clubColor);
      letter-spacing: 0.08em;
    }
    .colophon-dot {
      width: 6px;
      height: 6px;
      background: var(--accent);
      border-radius: 1px;
    }

    .privacy-note {
      max-width: 360px;
      margin: 0 auto var(--space-5);
      text-align: center;
      font-size: 11px;
      line-height: 1.5;
      color: var(--muted);
    }
    .privacy-note a {
      color: var(--muted);
      text-decoration: underline;
      text-underline-offset: 2px;
    }
    .privacy-note a:hover { color: var(--clubColor); }

    /* Reduced motion support */
    @media (prefers-reduced-motion: reduce) {
      .start-btn { transition: none; }
    }
  </style>
</body>
</html>
